---
interface Props {
  title: string;
  description?: string;
  activeTab?: 'skills' | 'tools' | 'agents' | 'movers' | 'submit' | 'api';
  jsonLd?: object | object[];
  keywords?: string;
  canonicalUrl?: string;
}

const {
  title,
  description = 'Your AI picks tools from months-old training data. AgentRank scores 25,000+ MCP servers and agent tools daily — so every recommendation is current.',
  activeTab = 'skills',
  jsonLd,
  keywords,
  canonicalUrl,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl || 'https://agentrank-ai.com'} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
    <link rel="alternate" type="application/atom+xml" title="AgentRank Rankings" href="/feed.xml" />
    {keywords && <meta name="keywords" content={keywords} />}
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {jsonLd && (Array.isArray(jsonLd)
      ? jsonLd.map((item) => <script type="application/ld+json" set:html={JSON.stringify(item).replace(/<\//g, '<\\/')} />)
      : <script type="application/ld+json" set:html={JSON.stringify(jsonLd).replace(/<\//g, '<\\/')} />
    )}
    <style>
      :root {
        --bg: #0a0a0a;
        --bg-surface: #141414;
        --bg-hover: #1a1a1a;
        --text: #e5e5e5;
        --text-muted: #a1a1aa;
        --accent: #22c55e;
        --border: #27272a;
        --max-width: 1200px;
      }

      @media (prefers-color-scheme: light) {
        :root {
          --bg: #fafafa;
          --bg-surface: #ffffff;
          --bg-hover: #f5f5f5;
          --text: #18181b;
          --text-muted: #71717a;
          --accent: #16a34a;
          --border: #e4e4e7;
        }
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, 'DejaVu Sans Mono', monospace;
        background: var(--bg);
        color: var(--text);
        line-height: 1.5;
        font-size: 14px;
      }

      .container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 1rem;
      }

      header {
        border-bottom: 1px solid var(--border);
        padding: 1.5rem 0;
        margin-bottom: 1.5rem;
      }

      .header-top {
        display: flex;
        align-items: baseline;
        gap: 1.5rem;
        flex-wrap: wrap;
      }

      header h1 {
        font-size: 1.25rem;
        font-weight: 700;
        flex-shrink: 0;
      }

      header h1 a {
        color: var(--accent);
        text-decoration: none;
      }

      nav.tabs {
        display: flex;
        gap: 0.25rem;
        flex-wrap: wrap;
      }

      nav.tabs a {
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.85rem;
        padding: 0.2rem 0.6rem;
        border-bottom: 2px solid transparent;
        transition: color 0.15s, border-color 0.15s;
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
      }

      nav.tabs a:hover {
        color: var(--text);
        text-decoration: none;
      }

      nav.tabs a.active {
        color: var(--accent);
        font-weight: 700;
        border-bottom-color: var(--accent);
      }

      .badge-beta {
        font-size: 0.6rem;
        text-transform: lowercase;
        border: 1px solid var(--accent);
        color: var(--accent);
        border-radius: 3px;
        padding: 0.05rem 0.3rem;
        line-height: 1.3;
        font-weight: 400;
        vertical-align: middle;
      }

      header .tagline {
        color: var(--text-muted);
        font-size: 0.8rem;
        width: 100%;
        margin-top: 0.35rem;
      }

      footer {
        border-top: 1px solid var(--border);
        padding: 1.5rem 0;
        margin-top: 2rem;
        color: var(--text-muted);
        font-size: 0.75rem;
        text-align: center;
      }

      footer a {
        color: var(--text-muted);
        text-decoration: underline;
      }

      a {
        color: var(--accent);
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      main {
        min-height: 60vh;
      }

      @media (max-width: 480px) {
        .header-top {
          gap: 0.75rem;
        }

        nav.tabs {
          gap: 0.1rem;
        }

        nav.tabs a {
          font-size: 0.8rem;
          padding: 0.2rem 0.4rem;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <div class="header-top">
          <h1><a href="/">AgentRank</a></h1>
          <nav class="tabs">
            <a href="/" class={activeTab === 'skills' ? 'active' : ''}>Skills</a>
            <a href="/tools/" class={activeTab === 'tools' ? 'active' : ''}>Tools</a>
            <a href="/movers/" class={activeTab === 'movers' ? 'active' : ''}>Movers</a>
            <a href="/agents/" class={activeTab === 'agents' ? 'active' : ''}>Agents <span class="badge-beta">beta</span></a>
            <a href="/submit/" class={activeTab === 'submit' ? 'active' : ''}>Submit</a>
            <a href="/api-docs/" class={activeTab === 'api' ? 'active' : ''}>API</a>
          </nav>
        </div>
        <span class="tagline">The reputation layer for AI skills, tools & agents</span>
      </div>
    </header>
    <main>
      <div class="container">
        <slot />
      </div>
    </main>
    <footer>
      <div class="container">
        Scored by real signals, updated daily &middot; <a href="https://github.com/superlowburn/agentrank" target="_blank" rel="noopener noreferrer">Open source on GitHub</a> &middot; <a href="/feed.xml">RSS</a> &middot; Built by <a href="https://x.com/comforteagle" target="_blank" rel="noopener noreferrer">@comforteagle</a>
      </div>
    </footer>
    <!-- Cloudflare Web Analytics -->
    <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "9e9faec619504d9ba50fba0ee6cd4916"}'></script>
  </body>
</html>

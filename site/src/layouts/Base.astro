---
interface Props {
  title: string;
  description?: string;
  activeTab?: 'skills' | 'tools' | 'agents' | 'movers' | 'trends' | 'submit' | 'api' | 'blog' | 'pricing' | 'changelog' | 'news' | 'integrations';
  jsonLd?: object | object[];
  keywords?: string;
  canonicalUrl?: string;
  ogImage?: string;
}

const {
  title,
  description = 'AgentRank indexes 25,000+ MCP servers and agent tools, scored daily from real signals. Install once and your AI automatically finds the right tool.',
  activeTab = 'skills',
  jsonLd,
  keywords,
  canonicalUrl,
  ogImage,
} = Astro.props;

const ogImageUrl = ogImage
  ? `https://agentrank-ai.com${ogImage}`
  : 'https://agentrank-ai.com/og-image.png';
const ogImageWidth = ogImage ? '1200' : '1500';
const ogImageHeight = ogImage ? '630' : '500';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl || 'https://agentrank-ai.com'} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="AgentRank" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content={ogImageWidth} />
    <meta property="og:image:height" content={ogImageHeight} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@AgentRank_ai" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <title>{title}</title>
    <link rel="preconnect" href="https://static.cloudflareinsights.com" />
    <link rel="dns-prefetch" href="https://static.cloudflareinsights.com" />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <link rel="alternate" type="application/atom+xml" title="AgentRank Rankings" href="/feed.xml" />
    <link rel="alternate" type="application/rss+xml" title="AgentRank Blog" href="/blog/rss.xml" />
    {keywords && <meta name="keywords" content={keywords} />}
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {jsonLd && (Array.isArray(jsonLd)
      ? jsonLd.map((item) => <script type="application/ld+json" set:html={JSON.stringify(item).replace(/<\//g, '<\\/')} />)
      : <script type="application/ld+json" set:html={JSON.stringify(jsonLd).replace(/<\//g, '<\\/')} />
    )}
    <style>
      :root {
        --bg: #0a0a0a;
        --bg-surface: #141414;
        --bg-hover: #1a1a1a;
        --text: #e5e5e5;
        --text-muted: #a1a1aa;
        --accent: #22c55e;
        --border: #27272a;
        --max-width: 1200px;
      }

      @media (prefers-color-scheme: light) {
        :root {
          --bg: #fafafa;
          --bg-surface: #ffffff;
          --bg-hover: #f5f5f5;
          --text: #18181b;
          --text-muted: #71717a;
          --accent: #16a34a;
          --border: #e4e4e7;
        }
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, 'DejaVu Sans Mono', monospace;
        background: var(--bg);
        color: var(--text);
        line-height: 1.5;
        font-size: 14px;
      }

      .container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 1rem;
      }

      header {
        border-bottom: 1px solid var(--border);
        padding: 1.5rem 0;
        margin-bottom: 1.5rem;
      }

      .header-top {
        display: flex;
        align-items: baseline;
        gap: 1.5rem;
        flex-wrap: wrap;
      }

      header h1 {
        font-size: 1.25rem;
        font-weight: 700;
        flex-shrink: 0;
      }

      header h1 a {
        color: var(--accent);
        text-decoration: none;
      }

      nav.tabs {
        display: flex;
        gap: 0.25rem;
        flex-wrap: wrap;
      }

      nav.tabs a {
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.85rem;
        padding: 0.2rem 0.6rem;
        border-bottom: 2px solid transparent;
        transition: color 0.15s, border-color 0.15s;
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
      }

      nav.tabs a:hover {
        color: var(--text);
        text-decoration: none;
      }

      nav.tabs a.active {
        color: var(--accent);
        font-weight: 700;
        border-bottom-color: var(--accent);
      }

      .badge-beta {
        font-size: 0.6rem;
        text-transform: lowercase;
        border: 1px solid var(--accent);
        color: var(--accent);
        border-radius: 3px;
        padding: 0.05rem 0.3rem;
        line-height: 1.3;
        font-weight: 400;
        vertical-align: middle;
      }

      header .tagline {
        color: var(--text);
        font-size: 0.82rem;
        width: 100%;
        margin-top: 0.4rem;
        opacity: 0.7;
      }

      footer {
        border-top: 1px solid var(--border);
        padding: 1.5rem 0;
        margin-top: 2rem;
        color: var(--text-muted);
        font-size: 0.75rem;
        text-align: center;
      }

      footer a {
        color: var(--text-muted);
        text-decoration: underline;
      }

      .footer-subscribe {
        margin-bottom: 0.85rem;
      }

      .footer-subscribe-form {
        display: inline-flex;
        gap: 0.4rem;
        align-items: center;
        flex-wrap: wrap;
        justify-content: center;
      }

      .footer-subscribe-form input[type="email"] {
        background: var(--bg);
        border: 1px solid var(--border);
        color: var(--text);
        padding: 0.35rem 0.65rem;
        border-radius: 4px;
        font-family: inherit;
        font-size: 0.75rem;
        width: 200px;
      }

      .footer-subscribe-form input[type="email"]:focus {
        outline: 1px solid var(--accent);
        border-color: var(--accent);
      }

      .footer-subscribe-form button {
        background: var(--accent);
        color: #000;
        border: none;
        border-radius: 4px;
        padding: 0.35rem 0.75rem;
        font-family: inherit;
        font-size: 0.75rem;
        font-weight: 600;
        cursor: pointer;
        white-space: nowrap;
        transition: opacity 0.15s;
      }

      .footer-subscribe-form button:hover { opacity: 0.85; }
      .footer-subscribe-form button:disabled { opacity: 0.5; cursor: not-allowed; }

      .footer-hp {
        position: absolute;
        left: -9999px;
        opacity: 0;
        height: 0;
        width: 0;
        pointer-events: none;
      }

      .footer-subscribe-msg {
        font-size: 0.72rem;
        min-height: 1em;
        display: block;
        margin-top: 0.25rem;
      }

      .footer-subscribe-msg.success { color: var(--accent); }
      .footer-subscribe-msg.error { color: #ef4444; }

      a {
        color: var(--accent);
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      main {
        min-height: 60vh;
      }

      @media (max-width: 480px) {
        .header-top {
          gap: 0.75rem;
        }

        nav.tabs {
          gap: 0.1rem;
        }

        nav.tabs a {
          font-size: 0.8rem;
          padding: 0.2rem 0.4rem;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <div class="header-top">
          <h1><a href="/">AgentRank</a></h1>
          <nav class="tabs">
            <a href="/" class={activeTab === 'skills' ? 'active' : ''}>Skills</a>
            <a href="/tools/" class={activeTab === 'tools' ? 'active' : ''}>Tools</a>
            <a href="/movers/" class={activeTab === 'movers' ? 'active' : ''}>Movers</a>
            <a href="/trends/" class={activeTab === 'trends' ? 'active' : ''}>Trends</a>
            <a href="/agents/" class={activeTab === 'agents' ? 'active' : ''}>Agents <span class="badge-beta">beta</span></a>
            <a href="/submit/" class={activeTab === 'submit' ? 'active' : ''}>Submit</a>
            <a href="/docs/" class={activeTab === 'api' ? 'active' : ''}>API</a>
            <a href="/integrations/" class={activeTab === 'integrations' ? 'active' : ''}>Integrations</a>
            <a href="/pricing/" class={activeTab === 'pricing' ? 'active' : ''}>Pricing</a>
            <a href="/news/" class={activeTab === 'news' ? 'active' : ''}>News</a>
            <a href="/blog/" class={activeTab === 'blog' ? 'active' : ''}>Blog</a>
            <a href="/changelog/" class={activeTab === 'changelog' ? 'active' : ''}>Changelog</a>
          </nav>
        </div>
        <span class="tagline">Google PageRank for AI agents. 25,000+ tools indexed.</span>
      </div>
    </header>
    <main>
      <div class="container">
        <slot />
      </div>
    </main>
    <footer>
      <div class="container">
        <div class="footer-subscribe">
          <form class="footer-subscribe-form" id="footer-subscribe-form" novalidate>
            <input
              type="email"
              id="footer-subscribe-email"
              name="email"
              placeholder="you@example.com"
              autocomplete="email"
              required
            />
            <button type="submit" id="footer-subscribe-btn">Get digest</button>
            <input type="text" name="_hp" class="footer-hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
          </form>
          <span class="footer-subscribe-msg" id="footer-subscribe-msg" aria-live="polite"></span>
        </div>
        Scored by real signals, updated daily &middot; <a href="/methodology/">Methodology</a> &middot; <a href="/faq/">FAQ</a> &middot; <a href="/changelog/">Changelog</a> &middot; <a href="https://github.com/superlowburn/agentrank" target="_blank" rel="noopener noreferrer">Open source on GitHub</a> &middot; <a href="/feed.xml">RSS</a> &middot; Built by <a href="https://x.com/comforteagle" target="_blank" rel="noopener noreferrer">@comforteagle</a>
      </div>
    </footer>
    <script>
      const footerForm = document.getElementById('footer-subscribe-form') as HTMLFormElement | null;
      const footerEmail = document.getElementById('footer-subscribe-email') as HTMLInputElement | null;
      const footerBtn = document.getElementById('footer-subscribe-btn') as HTMLButtonElement | null;
      const footerMsg = document.getElementById('footer-subscribe-msg') as HTMLSpanElement | null;

      footerForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const hp = (footerForm.querySelector<HTMLInputElement>('.footer-hp')?.value ?? '');
        if (hp) return;
        const email = footerEmail!.value.trim();
        if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
          footerMsg!.textContent = 'Please enter a valid email address.';
          footerMsg!.className = 'footer-subscribe-msg error';
          return;
        }
        footerBtn!.disabled = true;
        footerMsg!.textContent = '';
        footerMsg!.className = 'footer-subscribe-msg';
        try {
          const res = await fetch('/api/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, source: 'footer', _hp: '' }),
          });
          const data = await res.json();
          if (data.success) {
            footerMsg!.textContent = data.already ? "You're already subscribed." : "You're in.";
            footerMsg!.className = 'footer-subscribe-msg success';
            footerEmail!.value = '';
          } else {
            footerMsg!.textContent = data.error || 'Something went wrong.';
            footerMsg!.className = 'footer-subscribe-msg error';
            footerBtn!.disabled = false;
          }
        } catch {
          footerMsg!.textContent = 'Network error. Please try again.';
          footerMsg!.className = 'footer-subscribe-msg error';
          footerBtn!.disabled = false;
        }
      });
    </script>
    <!-- Scroll-triggered sticky subscribe bar (blog pages only) -->
    <div id="sticky-bar" style="display:none">
      <form id="sticky-bar-form" novalidate>
        <span class="sticky-bar-label">Get the weekly AgentRank digest</span>
        <input type="email" id="sticky-bar-email" name="email" placeholder="your@email.com" autocomplete="email" required />
        <input type="text" name="_hp" class="sticky-hp" tabindex="-1" autocomplete="off" />
        <button type="submit" id="sticky-bar-btn">Subscribe</button>
        <span id="sticky-bar-msg" aria-live="polite"></span>
      </form>
      <button class="sticky-bar-close" id="sticky-bar-close" aria-label="Dismiss">&times;</button>
    </div>
    <style>
      #sticky-bar {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        background: var(--bg-surface);
        border-top: 1px solid var(--accent);
        padding: 0.6rem 1rem;
        z-index: 100;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.82rem;
        flex-wrap: wrap;
      }
      #sticky-bar form {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex: 1;
        flex-wrap: wrap;
      }
      .sticky-bar-label { color: var(--text-muted); white-space: nowrap; }
      #sticky-bar-email {
        background: var(--bg);
        border: 1px solid var(--border);
        color: var(--text);
        padding: 0.3rem 0.6rem;
        border-radius: 4px;
        font-family: inherit;
        font-size: 0.8rem;
        width: 180px;
      }
      #sticky-bar-email:focus { outline: 1px solid var(--accent); border-color: var(--accent); }
      #sticky-bar form button[type="submit"] {
        background: var(--accent);
        color: #000;
        border: none;
        border-radius: 4px;
        padding: 0.3rem 0.75rem;
        font-family: inherit;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        white-space: nowrap;
        transition: opacity 0.15s;
      }
      #sticky-bar form button[type="submit"]:hover { opacity: 0.85; }
      #sticky-bar form button[type="submit"]:disabled { opacity: 0.5; cursor: not-allowed; }
      #sticky-bar-msg { font-size: 0.75rem; }
      #sticky-bar-msg.success { color: var(--accent); }
      #sticky-bar-msg.error { color: #ef4444; }
      .sticky-bar-close {
        background: none;
        border: none;
        color: var(--text-muted);
        font-size: 1.1rem;
        cursor: pointer;
        padding: 0 0.25rem;
        line-height: 1;
        margin-left: auto;
      }
      .sticky-bar-close:hover { color: var(--text); }
      .sticky-hp {
        position: absolute;
        left: -9999px;
        opacity: 0;
        height: 0;
        width: 0;
        pointer-events: none;
      }
    </style>
    <script>
      (function () {
        if (!window.location.pathname.startsWith('/blog/') || window.location.pathname === '/blog/') return;
        const bar = document.getElementById('sticky-bar');
        const closeBtn = document.getElementById('sticky-bar-close');
        const form = document.getElementById('sticky-bar-form') as HTMLFormElement | null;
        const emailInput = document.getElementById('sticky-bar-email') as HTMLInputElement | null;
        const submitBtn = document.getElementById('sticky-bar-btn') as HTMLButtonElement | null;
        const msg = document.getElementById('sticky-bar-msg') as HTMLSpanElement | null;
        if (!bar) return;

        const DISMISSED_KEY = 'ar_sticky_dismissed';
        if (sessionStorage.getItem(DISMISSED_KEY)) return;

        let shown = false;
        const showBar = () => {
          if (shown) return;
          shown = true;
          bar.style.display = 'flex';
        };
        const hideBar = () => {
          bar.style.display = 'none';
        };

        window.addEventListener('scroll', () => {
          const scrolled = window.scrollY + window.innerHeight;
          const total = document.body.scrollHeight;
          if (scrolled / total >= 0.7) showBar();
        }, { passive: true });

        closeBtn?.addEventListener('click', () => {
          hideBar();
          sessionStorage.setItem(DISMISSED_KEY, '1');
        });

        form?.addEventListener('submit', async (e) => {
          e.preventDefault();
          const hp = (form.querySelector<HTMLInputElement>('.sticky-hp')?.value ?? '');
          if (hp) return;
          const email = emailInput!.value.trim();
          if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
            msg!.textContent = 'Enter a valid email.';
            msg!.className = 'error';
            return;
          }
          submitBtn!.disabled = true;
          msg!.textContent = '';
          msg!.className = '';
          try {
            const res = await fetch('/api/subscribe', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ email, source: 'sticky-blog', _hp: '' }),
            });
            const data = await res.json();
            if (data.success) {
              msg!.textContent = data.already ? "Already subscribed." : "You're in.";
              msg!.className = 'success';
              emailInput!.value = '';
              setTimeout(() => { hideBar(); sessionStorage.setItem(DISMISSED_KEY, '1'); }, 2000);
            } else {
              msg!.textContent = data.error || 'Something went wrong.';
              msg!.className = 'error';
              submitBtn!.disabled = false;
            }
          } catch {
            msg!.textContent = 'Network error.';
            msg!.className = 'error';
            submitBtn!.disabled = false;
          }
        });
      })();
    </script>
    <!-- Cloudflare Web Analytics -->
    <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "9e9faec619504d9ba50fba0ee6cd4916"}'></script>
  </body>
</html>

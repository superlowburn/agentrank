---
import Layout from '../layouts/Base.astro';
export const prerender = true;
---

<Layout
  title="Free MCP Server Health Checker — AgentRank"
  description="Paste any GitHub URL to instantly see its AgentRank health score. Stars, freshness, issue health, contributors, and more — all in one diagnostic view."
  keywords="MCP server health check, MCP server quality, MCP server score, GitHub MCP tool checker, is my MCP server good"
  canonicalUrl="https://agentrank-ai.com/check/"
>
  <div class="check-page">

    <div class="hero">
      <div class="hero-label">FREE TOOL</div>
      <h1>MCP Server Health Check</h1>
      <p class="hero-sub">Paste a GitHub URL — get an instant diagnostic on any MCP server in our index.</p>
    </div>

    <div class="checker-shell">
      <div class="input-row">
        <span class="prompt">&gt;</span>
        <input
          type="url"
          id="url-input"
          class="url-input"
          placeholder="https://github.com/owner/repo"
          autocomplete="off"
          spellcheck="false"
        />
        <button id="check-btn" class="check-btn">CHECK</button>
      </div>
      <p class="rate-hint">10 checks / hour per IP &nbsp;·&nbsp; no login required</p>
    </div>

    <div id="scan-state" class="scan-state" style="display:none;">
      <div class="scan-bar"></div>
      <span class="scan-label">scanning...</span>
    </div>

    <div id="result-area" style="display:none;"></div>

  </div>
</Layout>

<script>
  const input = document.getElementById('url-input') as HTMLInputElement;
  const btn = document.getElementById('check-btn') as HTMLButtonElement;
  const scanState = document.getElementById('scan-state')!;
  const resultArea = document.getElementById('result-area')!;

  // Auto-run if ?url= in query string
  const params = new URLSearchParams(window.location.search);
  const preload = params.get('url');
  if (preload) {
    input.value = preload;
    runCheck(preload);
  }

  btn.addEventListener('click', () => {
    const val = input.value.trim();
    if (val) runCheck(val);
  });

  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      const val = input.value.trim();
      if (val) runCheck(val);
    }
  });

  async function runCheck(url: string) {
    // Update browser URL without reload
    const newUrl = new URL(window.location.href);
    newUrl.searchParams.set('url', url);
    history.replaceState({}, '', newUrl.toString());

    btn.disabled = true;
    btn.textContent = '...';
    scanState.style.display = 'flex';
    resultArea.style.display = 'none';
    resultArea.innerHTML = '';

    try {
      const res = await fetch(`/api/v1/check?url=${encodeURIComponent(url)}`);
      const data = await res.json();

      scanState.style.display = 'none';

      if (res.status === 429) {
        showError('Rate limit reached. You can run 10 checks per hour.');
        return;
      }

      if (res.status === 400) {
        showError(data.error || 'Invalid URL. Expected: https://github.com/owner/repo');
        return;
      }

      if (!data.found) {
        showNotFound(data.repo || url);
        return;
      }

      showResult(data);
    } catch {
      scanState.style.display = 'none';
      showError('Network error. Please try again.');
    } finally {
      btn.disabled = false;
      btn.textContent = 'CHECK';
    }
  }

  function showError(msg: string) {
    resultArea.innerHTML = `<div class="result-error">${esc(msg)}</div>`;
    resultArea.style.display = 'block';
  }

  function showNotFound(repo: string) {
    const submitUrl = `/submit/?github_url=${encodeURIComponent(`https://github.com/${repo}`)}`;
    resultArea.innerHTML = `
      <div class="not-found-card">
        <div class="nf-icon">—</div>
        <div class="nf-body">
          <div class="nf-title">Not in our index</div>
          <div class="nf-repo">${esc(repo)}</div>
          <p class="nf-desc">This tool isn't indexed yet. Submit it and we'll score it in the next nightly run.</p>
          <a href="${esc(submitUrl)}" class="submit-cta">Submit this tool &rarr;</a>
        </div>
      </div>
    `;
    resultArea.style.display = 'block';
  }

  function showResult(d: any) {
    const scoreColor = d.score >= 70 ? '#22c55e' : d.score >= 40 ? '#f59e0b' : '#ef4444';
    const grade = d.score >= 80 ? 'A' : d.score >= 65 ? 'B' : d.score >= 50 ? 'C' : d.score >= 30 ? 'D' : 'F';
    const gradeLabel = d.score >= 80 ? 'Excellent' : d.score >= 65 ? 'Good' : d.score >= 50 ? 'Fair' : d.score >= 30 ? 'Needs Work' : 'Critical';
    const slug = d.name.replace('/', '--');
    const detailUrl = `/tool/${slug}/`;

    const signals = [
      { key: 'stars',             label: 'Stars',         desc: formatStars(d.stars) + ' stars' },
      { key: 'freshness',         label: 'Freshness',     desc: d.isArchived ? 'Archived' : d.lastCommitAt ? 'Last commit ' + relTime(d.lastCommitAt) : 'No commit data' },
      { key: 'issueHealth',       label: 'Issue Health',  desc: (() => { const t = d.openIssues + d.closedIssues; return t === 0 ? 'No issues tracked' : `${d.closedIssues}/${t} resolved`; })() },
      { key: 'contributors',      label: 'Contributors',  desc: d.contributors + ' contributor' + (d.contributors !== 1 ? 's' : '') },
      { key: 'dependents',        label: 'Dependents',    desc: d.dependents + ' dependent repo' + (d.dependents !== 1 ? 's' : '') },
      { key: 'descriptionQuality',label: 'Docs Quality',  desc: !d.description ? 'No description' : d.description.length < 50 ? 'Brief' : d.description.length < 150 ? 'Moderate' : 'Good' },
      { key: 'licenseHealth',     label: 'License',       desc: d.license || 'No license' },
    ];

    const barsHtml = signals.map((s, i) => {
      const val = d.signals[s.key] as number;
      const weight = Math.round((d.weights[s.key] || 0) * 100);
      const pct = Math.round(val * 100);
      const barColor = val >= 0.7 ? '#22c55e' : val >= 0.4 ? '#f59e0b' : '#ef4444';
      return `
        <div class="signal-row" style="--delay:${i * 60}ms">
          <div class="signal-head">
            <span class="signal-label">${esc(s.label)}</span>
            <span class="signal-meta">${esc(s.desc)}</span>
          </div>
          <div class="signal-bar-wrap">
            <div class="signal-bar" style="--w:${pct}%; --c:${barColor};"></div>
          </div>
          <div class="signal-stats">
            <span class="signal-pct">${pct}%</span>
            <span class="signal-weight">×${weight}%</span>
          </div>
        </div>
      `;
    }).join('');

    const tweetText = `Checked ${d.name} on AgentRank — scored ${d.score}/100 (rank #${d.rank.toLocaleString()}).\n\nCheck your MCP server:`;
    const tweetUrl = `https://agentrank-ai.com/check/?url=${encodeURIComponent(d.githubUrl)}`;
    const shareHref = `https://twitter.com/intent/tweet?text=${encodeURIComponent(tweetText)}&url=${encodeURIComponent(tweetUrl)}`;

    resultArea.innerHTML = `
      <div class="result-card">
        <div class="result-header">
          <div class="score-block" style="--sc:${scoreColor}">
            <div class="score-number">${d.score}</div>
            <div class="score-label">${esc(grade)} · ${esc(gradeLabel)}</div>
          </div>
          <div class="result-meta">
            <div class="result-name">${esc(d.name)}</div>
            ${d.description ? `<div class="result-desc">${esc(d.description)}</div>` : ''}
            <div class="result-badges">
              <span class="badge">Rank #${d.rank.toLocaleString()}</span>
              ${d.language ? `<span class="badge">${esc(d.language)}</span>` : ''}
              ${d.license ? `<span class="badge">${esc(d.license)}</span>` : ''}
              ${d.isArchived ? `<span class="badge badge-warn">Archived</span>` : ''}
            </div>
            <div class="result-actions">
              <a href="${esc(detailUrl)}" class="action-link">Full listing &rarr;</a>
              <a href="${esc(d.githubUrl)}" target="_blank" rel="noopener" class="action-link">GitHub &rarr;</a>
              <a href="${esc(shareHref)}" target="_blank" rel="noopener" class="share-btn">Share on X</a>
            </div>
          </div>
        </div>
        <div class="signals-section">
          <div class="signals-title">Signal Breakdown</div>
          <div class="signals-list">
            ${barsHtml}
          </div>
        </div>
        <div class="result-footer">
          <span>Scores update nightly.</span>
          <a href="/methodology/">How scoring works</a>
        </div>
      </div>
    `;
    resultArea.style.display = 'block';

    // Trigger bar animations after render
    requestAnimationFrame(() => {
      resultArea.querySelectorAll('.signal-row').forEach((row) => {
        (row as HTMLElement).classList.add('revealed');
      });
    });
  }

  function esc(s: string): string {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  function formatStars(n: number): string {
    if (n >= 1000) return (n / 1000).toFixed(1).replace(/\.0$/, '') + 'k';
    return String(n);
  }

  function relTime(iso: string): string {
    const diff = Date.now() - new Date(iso).getTime();
    const days = Math.floor(diff / 86_400_000);
    if (days < 1) return 'today';
    if (days === 1) return '1d ago';
    if (days < 30) return `${days}d ago`;
    const mo = Math.floor(days / 30);
    if (mo < 12) return `${mo}mo ago`;
    return `${Math.floor(mo / 12)}y ago`;
  }
</script>

<style>
  .check-page {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1rem 4rem;
  }

  /* ── Hero ─────────────────────────────────────────────── */
  .hero {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .hero-label {
    display: inline-block;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 0.15rem 0.55rem;
    border-radius: 2px;
    margin-bottom: 1rem;
    opacity: 0.8;
  }

  .hero h1 {
    font-size: clamp(1.4rem, 4vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.6rem;
    color: var(--text);
  }

  .hero-sub {
    color: var(--text-muted);
    font-size: 0.9rem;
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* ── Checker input ────────────────────────────────────── */
  .checker-shell {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem 1.25rem 1rem;
    margin-bottom: 1.5rem;
  }

  .input-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .prompt {
    color: var(--accent);
    font-size: 1.1rem;
    font-weight: 700;
    flex-shrink: 0;
    user-select: none;
  }

  .url-input {
    flex: 1;
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    font-family: inherit;
    font-size: 0.9rem;
    padding: 0.35rem 0;
    outline: none;
    transition: border-color 0.15s;
    min-width: 0;
  }

  .url-input:focus {
    border-bottom-color: var(--accent);
  }

  .url-input::placeholder {
    color: var(--text-muted);
    opacity: 0.5;
  }

  .check-btn {
    background: var(--accent);
    color: #000;
    border: none;
    border-radius: 4px;
    padding: 0.4rem 1rem;
    font-family: inherit;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    cursor: pointer;
    flex-shrink: 0;
    transition: opacity 0.15s;
  }

  .check-btn:hover { opacity: 0.85; }
  .check-btn:disabled { opacity: 0.4; cursor: not-allowed; }

  .rate-hint {
    font-size: 0.72rem;
    color: var(--text-muted);
    margin-top: 0.65rem;
    opacity: 0.7;
  }

  /* ── Scan animation ───────────────────────────────────── */
  .scan-state {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem 0;
    justify-content: center;
  }

  .scan-bar {
    width: 200px;
    height: 2px;
    background: var(--border);
    border-radius: 1px;
    overflow: hidden;
    position: relative;
  }

  .scan-bar::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--accent);
    animation: scan 1.2s ease-in-out infinite;
    transform-origin: left;
  }

  @keyframes scan {
    0%   { transform: scaleX(0) translateX(0); transform-origin: left; }
    50%  { transform: scaleX(1) translateX(0); transform-origin: left; }
    50.001% { transform-origin: right; }
    100% { transform: scaleX(0); transform-origin: right; }
  }

  .scan-label {
    font-size: 0.78rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  /* ── Error / not found ────────────────────────────────── */
  .result-error {
    padding: 1rem 1.25rem;
    background: rgba(239, 68, 68, 0.08);
    border: 1px solid rgba(239, 68, 68, 0.3);
    border-radius: 6px;
    font-size: 0.85rem;
    color: #f87171;
  }

  .not-found-card {
    display: flex;
    gap: 1.25rem;
    padding: 1.5rem;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    align-items: flex-start;
  }

  .nf-icon {
    font-size: 1.5rem;
    color: var(--text-muted);
    opacity: 0.4;
    flex-shrink: 0;
    padding-top: 0.1rem;
    width: 2rem;
    text-align: center;
  }

  .nf-title {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.2rem;
  }

  .nf-repo {
    font-size: 0.8rem;
    color: var(--accent);
    margin-bottom: 0.6rem;
  }

  .nf-desc {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
    line-height: 1.5;
  }

  .submit-cta {
    display: inline-block;
    padding: 0.45rem 1rem;
    background: var(--accent);
    color: #000;
    border-radius: 4px;
    font-size: 0.82rem;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .submit-cta:hover { opacity: 0.85; }

  /* ── Result card ──────────────────────────────────────── */
  .result-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }

  .result-header {
    display: flex;
    gap: 1.5rem;
    padding: 1.5rem;
    border-bottom: 1px solid var(--border);
    align-items: flex-start;
  }

  /* Score block */
  .score-block {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 90px;
    height: 90px;
    border: 2px solid var(--sc, #22c55e);
    border-radius: 6px;
    background: color-mix(in srgb, var(--sc, #22c55e) 8%, transparent);
  }

  .score-number {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1;
    color: var(--sc, #22c55e);
  }

  .score-label {
    font-size: 0.58rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--sc, #22c55e);
    opacity: 0.8;
    margin-top: 0.3rem;
    text-align: center;
  }

  /* Meta side */
  .result-meta {
    flex: 1;
    min-width: 0;
  }

  .result-name {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.35rem;
    word-break: break-word;
  }

  .result-desc {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 0.6rem;
    line-height: 1.5;
  }

  .result-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.85rem;
  }

  .badge {
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    background: var(--bg-hover);
    border: 1px solid var(--border);
    border-radius: 3px;
    color: var(--text-muted);
  }

  .badge-warn {
    border-color: #f59e0b;
    color: #f59e0b;
    background: rgba(245, 158, 11, 0.08);
  }

  .result-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .action-link {
    font-size: 0.78rem;
    color: var(--accent);
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .action-link:hover { opacity: 0.75; }

  .share-btn {
    font-size: 0.75rem;
    padding: 0.3rem 0.75rem;
    background: #000;
    color: #fff;
    border: 1px solid #333;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 500;
    transition: opacity 0.15s;
  }

  .share-btn:hover { opacity: 0.8; }

  /* ── Signals ──────────────────────────────────────────── */
  .signals-section {
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .signals-title {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .signals-list {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .signal-row {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    gap: 0.2rem 0.75rem;
    align-items: center;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.3s ease var(--delay, 0ms), transform 0.3s ease var(--delay, 0ms);
  }

  .signal-row.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .signal-head {
    grid-column: 1;
    grid-row: 1;
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
  }

  .signal-label {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text);
  }

  .signal-meta {
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  .signal-stats {
    grid-column: 2;
    grid-row: 1;
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
    text-align: right;
    white-space: nowrap;
  }

  .signal-pct {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text);
  }

  .signal-weight {
    font-size: 0.65rem;
    color: var(--text-muted);
  }

  .signal-bar-wrap {
    grid-column: 1 / -1;
    grid-row: 2;
    height: 4px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .signal-bar {
    height: 100%;
    width: 0;
    background: var(--c, #22c55e);
    border-radius: 2px;
    transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1) var(--delay, 0ms);
  }

  .signal-row.revealed .signal-bar {
    width: var(--w, 0%);
  }

  /* ── Footer ───────────────────────────────────────────── */
  .result-footer {
    padding: 0.75rem 1.5rem;
    display: flex;
    gap: 1.5rem;
    font-size: 0.72rem;
    color: var(--text-muted);
  }

  .result-footer a {
    color: var(--text-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* ── Mobile ───────────────────────────────────────────── */
  @media (max-width: 500px) {
    .result-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .score-block {
      width: 100%;
      height: auto;
      flex-direction: row;
      padding: 0.75rem 1rem;
      gap: 0.75rem;
    }

    .score-number { font-size: 1.6rem; }

    .signals-section { padding: 1rem; }
    .result-header { padding: 1rem; }
  }
</style>

    { href: '/blog/motherduck-mcp-vs-redis-mcp/', title: 'MotherDuck MCP vs Redis MCP: Analytical vs In-Memory' },
    { href: '/blog/how-to-choose-an-mcp-server/', title: 'How to Choose an MCP Server in 2026' },
  ],
  deployment: [
    { href: '/blog/best-mcp-servers-devops/', title: 'Best MCP Servers for DevOps & Infrastructure' },
    { href: '/blog/kubernetes-mcp-server-vs-mcp-server-kubernetes/', title: 'Kubernetes MCP Server Comparison' },
    { href: '/blog/how-to-choose-an-mcp-server/', title: 'How to Choose an MCP Server in 2026' },
  ],
  'ai-models': [
    { href: '/blog/best-mcp-servers-ai-ml/', title: 'Best MCP Servers for AI & Machine Learning' },
    { href: '/blog/how-to-choose-an-mcp-server/', title: 'How to Choose an MCP Server in 2026' },
    { href: '/blog/mcp-server-landscape-q1-2026/', title: 'The MCP Server Landscape: Q1 2026' },
  ],
  communication: [
    { href: '/blog/best-mcp-servers-communication/', title: 'Best MCP Servers for Communication in 2026' },
    { href: '/blog/best-mcp-servers-productivity/', title: 'Best MCP Servers for Productivity' },
    { href: '/blog/google-workspace-mcp-vs-microsoft-365-mcp/', title: 'Google Workspace MCP vs Microsoft 365 MCP' },
  ],
  'mcp-server': [
    { href: '/blog/how-to-choose-an-mcp-server/', title: 'How to Choose an MCP Server in 2026' },
    { href: '/blog/mcp-server-comparison-top-10/', title: 'MCP Server Comparison: Top 10 Head-to-Head' },
    { href: '/blog/mcp-server-framework-comparison/', title: 'MCP Server Framework Comparison: SDK vs FastMCP vs MCP-Go' },
    { href: '/blog/state-of-mcp-2026/', title: 'State of MCP 2026' },
  ],
  'browser-automation': [
    { href: '/blog/best-mcp-servers-web-browser/', title: 'Best MCP Servers for Web Scraping & Browser Automation' },
    { href: '/blog/playwright-mcp-vs-puppeteer-mcp/', title: 'Playwright MCP vs Puppeteer MCP: Which Browser Automation Tool?' },
    { href: '/blog/how-to-choose-an-mcp-server/', title: 'How to Choose an MCP Server in 2026' },
  ],
  search: [
    { href: '/blog/best-mcp-servers-web-scraping-research/', title: 'Best MCP Servers for Web Scraping & Research' },
    { href: '/blog/exa-mcp-vs-firecrawl-mcp/', title: 'Exa MCP vs Firecrawl MCP: Search vs Scraping' },
    { href: '/blog/tavily-mcp-vs-brave-search-mcp/', title: 'Tavily MCP vs Brave Search MCP' },
  ],
  filesystem: [
    { href: '/blog/best-mcp-servers-file-management/', title: 'Best MCP Servers for File Management in 2026' },
    { href: '/blog/desktop-commander-mcp-vs-official-filesystem/', title: 'Desktop Commander MCP vs Official Filesystem MCP' },
    { href: '/blog/how-to-choose-an-mcp-server/', title: 'How to Choose an MCP Server in 2026' },
  ],
  'code-generation': [
    { href: '/blog/best-mcp-servers-code-generation/', title: 'Best MCP Servers for Code Generation in 2026' },
    { href: '/blog/github-mcp-vs-git-mcp/', title: 'GitHub MCP Server vs git-mcp: Which GitHub Integration?' },
    { href: '/blog/how-to-choose-an-mcp-server/', title: 'How to Choose an MCP Server in 2026' },
  ],
  'api-integration': [
    { href: '/blog/best-mcp-servers-api-integration/', title: 'Best MCP Servers for API Integration in 2026' },
    { href: '/blog/mcp-server-vs-rest-api/', title: 'MCP Server vs REST API: When to Use Each' },
    { href: '/blog/how-to-choose-an-mcp-server/', title: 'How to Choose an MCP Server in 2026' },
  ],
  'data-processing': [
    { href: '/blog/best-mcp-servers-data-science/', title: 'Best MCP Servers for Data Science in 2026' },
    { href: '/blog/how-to-choose-an-mcp-server/', title: 'How to Choose an MCP Server in 2026' },
  ],
  monitoring: [
    { href: '/blog/mcp-server-security-best-practices/', title: 'MCP Server Security Best Practices' },
    { href: '/blog/how-to-choose-an-mcp-server/', title: 'How to Choose an MCP Server in 2026' },
  ],
  'agent-framework': [
    { href: '/blog/state-of-mcp-2026/', title: 'State of MCP 2026' },
    { href: '/blog/mcp-server-landscape-q1-2026/', title: 'The MCP Server Landscape: Q1 2026' },
    { href: '/blog/how-to-choose-an-mcp-server/', title: 'How to Choose an MCP Server in 2026' },
  ],
};

// Language-based virtual categories
const LANGUAGE_CATEGORIES: Record<string, string> = {
  python: 'Python',
  typescript: 'TypeScript',
  javascript: 'JavaScript',
  go: 'Go',
  rust: 'Rust',
};

const ALL_CATEGORY_LABELS: Record<string, string> = {
  ...CATEGORIES,
  ...Object.fromEntries(Object.entries(LANGUAGE_CATEGORIES).map(([k, v]) => [k, `${v} Tools`])),
};

export function getStaticPaths() {
  const LANG_SLUGS = ['python', 'typescript', 'javascript', 'go', 'rust'];

  const allTools = getAllTools();
  const allSkills = getAllSkills();

  // Domain/type category slugs from classified data
  const toolCats = new Set(allTools.map((t) => t.category).filter(Boolean));
  const skillCats = new Set(allSkills.map((s) => s.category).filter(Boolean));
  const domainSlugs = new Set([...toolCats, ...skillCats]);

  // Language slugs — only include languages with enough tools to be useful
  const langCounts: Record<string, number> = {};
  for (const t of allTools) {
    if (t.language) {
      const lang = t.language.toLowerCase();
      langCounts[lang] = (langCounts[lang] || 0) + 1;
    }
  }
  const languageSlugs = LANG_SLUGS.filter((lang) => (langCounts[lang] || 0) >= 5);

  const allSlugs = new Set([...domainSlugs, ...languageSlugs]);

  return [...allSlugs].map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const isLanguageSlug = slug! in LANGUAGE_CATEGORIES;
const label = ALL_CATEGORY_LABELS[slug!] || slug!;
const content = !isLanguageSlug ? CATEGORY_CONTENT[slug!] : undefined;

const allTools = isLanguageSlug
  ? getAllTools().filter((t) => t.language?.toLowerCase() === slug)
  : getAllTools().filter((t) => t.category === slug);

const allSkills = isLanguageSlug
  ? [] // skills don't have language field
  : getAllSkills().filter((s) => s.category === slug);

const pageUrl = `https://agentrank-ai.com/category/${slug}/`;
const totalCount = allTools.length + allSkills.length;

// Average score across tools + skills in this category
const scoredTools = allTools.filter((t) => typeof t.score === 'number');
const scoredSkills = allSkills.filter((s) => typeof s.score === 'number');
const avgScore = (scoredTools.length + scoredSkills.length) > 0
  ? (scoredTools.reduce((sum, t) => sum + t.score, 0) + scoredSkills.reduce((sum, s) => sum + s.score, 0))
    / (scoredTools.length + scoredSkills.length)
  : null;

// Related categories: resolve labels for display
const relatedCategoryEntries = (content?.relatedCategories || [])
  .map((cat) => ({ slug: cat, label: ALL_CATEGORY_LABELS[cat] || cat }))
  .filter((c) => c.label);

// Meta title/description: use content override if available, otherwise generate
const metaTitle = content?.metaTitle
  ?? `Best ${label} MCP Servers & Agent Tools — AgentRank`;
const metaDescription = content?.metaDescription
  ?? `Top ${label} MCP servers, agent tools, and AI skills ranked by stars, freshness, and real usage signals. ${totalCount} ${label} tools and skills indexed.`;
const metaKeywords = content?.keywords
  ?? `${label} MCP servers, best ${label} agent tools, ${label} AI skills, top ${label} tools`;

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'AgentRank',
      item: 'https://agentrank-ai.com/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Categories',
      item: 'https://agentrank-ai.com/category/',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: content?.heading ?? label,
      item: pageUrl,
    },
  ],
};

const categoryItemListJsonLd = totalCount > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: content?.heading ?? `Top ${label} MCP Servers & Agent Tools`,
  description: content?.metaDescription,
  itemListOrder: 'https://schema.org/ItemListOrderDescending',
  numberOfItems: Math.min(totalCount, 10),
  itemListElement: [
    ...allTools.slice(0, 5).map((t, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: t.full_name,
      url: `https://agentrank-ai.com/tool/${toSlug(t.full_name)}/`,
    })),
    ...allSkills.slice(0, 5).map((s, i) => ({
      '@type': 'ListItem',
      position: allTools.length + i + 1,
      name: s.name || s.slug,
      url: `https://agentrank-ai.com/skill/${toSkillSlug(s.slug)}/`,
    })),
  ].slice(0, 10),
} : undefined;

const jsonLd = categoryItemListJsonLd
  ? [breadcrumbJsonLd, categoryItemListJsonLd]
  : breadcrumbJsonLd;
---

<Base
  title={metaTitle}
  description={metaDescription}
  keywords={metaKeywords}
  canonicalUrl={pageUrl}
  jsonLd={jsonLd}
>
  <div class="breadcrumb">
    <a href="/">AgentRank</a> / <a href="/category/">Categories</a> / <span>{content?.heading ?? label}</span>
  </div>

  <h2 class="category-heading">{content?.heading ?? label}</h2>
  <p class="category-sub">
    {allTools.length} tool{allTools.length !== 1 ? 's' : ''}
    {allSkills.length > 0 && <> &middot; {allSkills.length} skill{allSkills.length !== 1 ? 's' : ''}</>}
    {avgScore !== null && <> &middot; avg score <span class="avg-score">{avgScore.toFixed(1)}</span></>}
  </p>

  {content?.intro && content.intro.length > 0 && (
    <section class="intro-section">
      {content.intro.map((para) => (
        <p class="intro-para">{para}</p>
      ))}
    </section>
  )}

  {allTools.length > 0 && (
    <section>
      {allSkills.length > 0 && <h3 class="section-heading">Tools</h3>}
      <div id="category-sponsored" data-category={slug}></div>
      <div class="table-wrap">
        <table id="tools-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Name</th>
              <th>Score</th>
              <th>Stars</th>
              <th>Last Commit</th>
              <th>Language</th>
            </tr>
          </thead>
          <tbody>
            {allTools.map((tool, i) => (
              <tr data-full-name={tool.full_name}>
                <td class="rank">{i + 1}</td>
                <td class="name">
                  <a href={`/tool/${toSlug(tool.full_name)}/`}>{tool.full_name}</a>
                  {tool.is_archived && <span class="badge archived">archived</span>}
                </td>
                <td class="score">
                  <span class="score-bar" style={`--w: ${tool.score}%; --c: ${scoreColor(tool.score)}`}>
                    {tool.score.toFixed(1)}
                  </span>
                </td>
                <td class="muted">{formatStars(tool.stars)}</td>
                <td class="muted">{relativeTime(tool.last_commit_at)}</td>
                <td class="muted">{tool.language || '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  )}

  {allSkills.length > 0 && (
    <section>
      <h3 class="section-heading">Skills</h3>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>#</th>
              <th>Name</th>
              <th>Score</th>
              <th>Installs</th>
              <th>Source</th>
            </tr>
          </thead>
          <tbody>
            {allSkills.map((skill, i) => (
              <tr>
                <td class="rank">{i + 1}</td>
                <td class="name">
                  <a href={`/skill/${toSkillSlug(skill.slug)}/`}>{skill.name || skill.slug}</a>
                </td>
                <td class="score">
                  <span class="score-bar" style={`--w: ${skill.score}%; --c: ${scoreColor(skill.score)}`}>
                    {skill.score.toFixed(1)}
                  </span>
                </td>
                <td class="muted">{formatInstalls(skill.installs)}</td>
                <td class="muted">{sourceLabel(skill.source)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  )}

  {relatedCategoryEntries.length > 0 && (
    <section class="related-section">
      <h3 class="section-heading">Related Categories</h3>
      <div class="related-grid">
        {relatedCategoryEntries.map((cat) => (
          <a href={`/category/${cat.slug}/`} class="related-card">
            <span class="related-label">{cat.label}</span>
            <span class="related-arrow">→</span>
          </a>
        ))}
      </div>
    </section>
  )}

  {CATEGORY_BLOG_LINKS[slug!] && (
    <section class="blog-links-section">
      <h3 class="section-heading">Related Reading</h3>
      <div class="blog-links-list">
        {CATEGORY_BLOG_LINKS[slug!].map((post) => (
          <a href={post.href} class="blog-link-item">{post.title}</a>
        ))}
        <a href="/methodology/" class="blog-link-item">How AgentRank Scores Work</a>
      </div>
    </section>
  )}

  <BlogSubscribeCTA source={`category-${slug}`} />
</Base>

<style>
  .breadcrumb {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .breadcrumb a {
    color: var(--text-muted);
  }

  .breadcrumb a:hover {
    color: var(--accent);
  }

  .category-heading {
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }

  .category-sub {
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-bottom: 1.5rem;
  }

  .avg-score {
    font-weight: 600;
    color: var(--accent);
  }

  .intro-section {
    margin-bottom: 2.5rem;
    max-width: 72ch;
  }

  .intro-para {
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--text);
    margin-bottom: 1rem;
  }

  .intro-para:last-child {
    margin-bottom: 0;
  }

  section {
    margin-bottom: 3rem;
  }

  .section-heading {
    font-size: 0.9rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.5rem;
  }

  .table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
  }

  th {
    background: var(--bg-surface);
    border-bottom: 2px solid var(--border);
    padding: 0.5rem 0.75rem;
    text-align: left;
    font-weight: 600;
    white-space: nowrap;
    color: var(--text-muted);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  td {
    padding: 0.4rem 0.75rem;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }

  tr:hover td {
    background: var(--bg-hover);
  }

  .rank {
    color: var(--text-muted);
    width: 3rem;
  }

  .name a {
    color: var(--text);
    font-weight: 500;
  }

  .name a:hover {
    color: var(--accent);
  }

  .badge {
    font-size: 0.65rem;
    padding: 0.1rem 0.35rem;
    border-radius: 3px;
    margin-left: 0.5rem;
    vertical-align: middle;
    background: #78350f;
    color: #fbbf24;
  }

  .score-bar {
    display: inline-block;
    padding: 0.1rem 0.5rem;
    border-radius: 3px;
    background: linear-gradient(90deg, var(--c) var(--w), transparent var(--w));
    background-color: var(--bg-surface);
    min-width: 4rem;
    font-weight: 600;
  }

  .muted {
    color: var(--text-muted);
  }

  .related-section {
    margin-top: 1rem;
  }

  .related-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .related-card {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.75rem;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    font-size: 0.82rem;
    color: var(--text);
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }

  .related-card:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .related-arrow {
    color: var(--text-muted);
    font-size: 0.75rem;
  }

  .related-card:hover .related-arrow {
    color: var(--accent);
  }

  @media (prefers-color-scheme: light) {
    .badge {
      background: #fef3c7;
      color: #92400e;
    }
  }

  @media (max-width: 480px) {
    .related-grid {
      flex-direction: column;
    }
  }

  .blog-links-section {
    margin-bottom: 3rem;
  }

  .blog-links-list {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .blog-link-item {
    font-size: 0.85rem;
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
  }

  .blog-link-item:hover {
    text-decoration: underline;
  }

  /* Category sponsored placement */
  .cat-sponsor-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background: color-mix(in srgb, var(--accent) 4%, var(--bg-surface));
    border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--border));
    border-left: 3px solid var(--accent);
    border-radius: 5px;
    padding: 0.85rem 1rem;
    margin-bottom: 0.75rem;
    text-decoration: none;
    flex-wrap: wrap;
    gap: 0.5rem;
    transition: background 0.15s;
  }

  .cat-sponsor-card:hover {
    background: color-mix(in srgb, var(--accent) 8%, var(--bg-surface));
    text-decoration: none;
  }

  .cat-sponsor-body {
    flex: 1;
    min-width: 0;
  }

  .cat-sponsor-name-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .cat-sponsor-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
  }

  .cat-sponsor-badge {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.1rem 0.35rem;
    border-radius: 3px;
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);
  }

  .cat-sponsor-desc {
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.4;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }

  .cat-sponsor-cta {
    align-self: center;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--accent);
    white-space: nowrap;
  }

  /* Sponsored row highlight */
  tr.sponsored-row td {
    background: color-mix(in srgb, var(--accent) 4%, transparent) !important;
  }

  tr.sponsored-row:hover td {
    background: color-mix(in srgb, var(--accent) 8%, transparent) !important;
  }

  .sponsored-pill {
    display: inline-block;
    font-size: 0.58rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.08rem 0.3rem;
    border-radius: 3px;
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);
    margin-left: 0.35rem;
    vertical-align: middle;
  }
</style>

<script>
  const container = document.getElementById('category-sponsored') as HTMLElement | null;
  if (container) {
    const category = container.dataset.category || '';
    (async () => {
      try {
        const res = await fetch('/api/sponsored');
        if (!res.ok) return;
        const { sponsored } = await res.json();
        if (!sponsored || sponsored.length === 0) return;

        const sponsoredSet = new Set<string>(sponsored.map((t: any) => t.full_name));

        // Highlight sponsored rows in the tools table
        document.querySelectorAll<HTMLElement>('#tools-table tbody tr[data-full-name]').forEach((row) => {
          if (sponsoredSet.has(row.dataset.fullName || '')) {
            row.classList.add('sponsored-row');
            const nameCell = row.querySelector('.name');
            if (nameCell && !nameCell.querySelector('.sponsored-pill')) {
              const pill = document.createElement('span');
              pill.className = 'sponsored-pill';
              pill.textContent = 'Sponsored';
              nameCell.appendChild(pill);
            }
          }
        });

        // Find sponsored tool matching this category
        const match = sponsored.find((t: any) => t.category === category);
        if (!match) return;

        const slug = match.full_name.replace('/', '--');
        const desc = (match.sponsor_description || match.description || '').slice(0, 120);
        const ctaHtml = match.sponsor_cta_text
          ? `<span class="cat-sponsor-cta">${match.sponsor_cta_text} &rarr;</span>`
          : `<span class="cat-sponsor-cta">View &rarr;</span>`;

        container.innerHTML = `<a class="cat-sponsor-card" href="/api/sponsored/click?tool=${encodeURIComponent(match.full_name)}&type=detail&page=category">
          <div class="cat-sponsor-body">
            <div class="cat-sponsor-name-row">
              <span class="cat-sponsor-name">${match.full_name.split('/')[1] || match.full_name}</span>
              <span class="cat-sponsor-badge">Sponsored</span>
            </div>
            ${desc ? `<p class="cat-sponsor-desc">${desc}</p>` : ''}
          </div>
          ${ctaHtml}
        </a>`;
      } catch {
        // Non-fatal
      }
    })();
  }

---
export const prerender = true;

import Base from '../../layouts/Base.astro';
import BlogSubscribeCTA from '../../components/BlogSubscribeCTA.astro';
import { getAllTools } from '../../data/ranked';
import { getAllSkills } from '../../data/ranked-skills';
import { toSlug, formatStars, relativeTime, scoreColor } from '../../data/tools';
import { toSkillSlug, formatInstalls, sourceLabel } from '../../data/skills';
import { CATEGORIES, CATEGORY_CONTENT } from '../../data/content-gen';

const CATEGORY_BLOG_LINKS: Record<string, { href: string; title: string }[]> = {
  database: [

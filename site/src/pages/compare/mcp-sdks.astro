<script>
  // ── Filter logic ──────────────────────────────────────────────────────────
  let activeLang = 'all';
  let activeType = 'all';
  let activeSortCol = 'score';
  let sortDir = -1; // -1 = desc

  function applyFilters() {
    const tbody = document.getElementById('sdk-tbody');
    const noResults = document.getElementById('no-results');
    if (!tbody || !noResults) return;
    const rows = Array.from(tbody.querySelectorAll('tr'));
    let visible = 0;
    for (const row of rows) {
      const lang = row.dataset.lang || '';
      const type = row.dataset.type || '';
      const show =
        (activeLang === 'all' || lang === activeLang) &&
        (activeType === 'all' || type === activeType);
      (row as HTMLElement).style.display = show ? '' : 'none';
      if (show) visible++;
    }
    noResults.classList.toggle('hidden', visible > 0);
  }

  function applySort() {
    const tbody = document.getElementById('sdk-tbody');
    if (!tbody) return;
    const rows = Array.from(tbody.querySelectorAll('tr')) as HTMLTableRowElement[];
    rows.sort((a, b) => {
      let va: string | number = '';
      let vb: string | number = '';
      if (activeSortCol === 'score') { va = parseFloat(a.dataset.score || '0'); vb = parseFloat(b.dataset.score || '0'); }
      else if (activeSortCol === 'stars') { va = parseInt(a.dataset.stars || '0'); vb = parseInt(b.dataset.stars || '0'); }
      else if (activeSortCol === 'contributors') { va = parseInt(a.dataset.contributors || '0'); vb = parseInt(b.dataset.contributors || '0'); }
      else if (activeSortCol === 'dependents') { va = parseInt(a.dataset.dependents || '0'); vb = parseInt(b.dataset.dependents || '0'); }
      else if (activeSortCol === 'commit') { va = a.dataset.commit || ''; vb = b.dataset.commit || ''; }
      else if (activeSortCol === 'name') { va = (a.querySelector('.sdk-name')?.textContent || '').toLowerCase(); vb = (b.querySelector('.sdk-name')?.textContent || '').toLowerCase(); }
      if (va < vb) return sortDir;
      if (va > vb) return -sortDir;
      return 0;
    });
    for (const row of rows) tbody.appendChild(row);
  }

  // Language filter pills
  document.getElementById('lang-filters')?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-filter="lang"]') as HTMLElement;
    if (!btn) return;
    activeLang = btn.dataset.value || 'all';
    document.querySelectorAll('[data-filter="lang"]').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    applyFilters();
  });

  // Type filter pills
  document.getElementById('type-filters')?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-filter="type"]') as HTMLElement;
    if (!btn) return;
    activeType = btn.dataset.value || 'all';
    document.querySelectorAll('[data-filter="type"]').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    applyFilters();
  });

  // Sort columns
  document.getElementById('sdk-table')?.addEventListener('click', (e) => {
    const th = (e.target as HTMLElement).closest('th.sortable') as HTMLElement;
    if (!th) return;
    const col = th.dataset.sort || '';
    if (activeSortCol === col) {
      sortDir = -sortDir;
    } else {
      activeSortCol = col;
      sortDir = -1;
    }
    document.querySelectorAll('th.sortable').forEach(h => {
      h.classList.remove('active-sort');
      const icon = h.querySelector('.sort-icon');
      if (icon) icon.textContent = '↕';
    });
    th.classList.add('active-sort');
    const icon = th.querySelector('.sort-icon');
    if (icon) icon.textContent = sortDir === -1 ? '↓' : '↑';
    applySort();
  });

  // ── Code snippet tabs ──────────────────────────────────────────────────────
  document.getElementById('snippet-tabs')?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.snip-tab') as HTMLElement;
    if (!btn) return;
    const lang = btn.dataset.lang;
    document.querySelectorAll('.snip-tab').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.querySelectorAll('.snip-panel').forEach(p => {
      p.classList.toggle('active', (p as HTMLElement).dataset.lang === lang);
    });
  });

  // Variant tabs within a panel
  document.getElementById('snippet-panels')?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.var-tab') as HTMLElement;
    if (!btn) return;
    const panel = btn.closest('.snip-panel');
    if (!panel) return;
    const vi = btn.dataset.variant;
    panel.querySelectorAll('.var-tab').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    panel.querySelectorAll('.snip-code').forEach(c => {
      c.classList.toggle('active', (c as HTMLElement).dataset.variant === vi);
    });
  });
</script>


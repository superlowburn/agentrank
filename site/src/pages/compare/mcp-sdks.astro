const codeSnippets: Record<string, { label: string; lang: string; code: string }[]> = {
  Python: [
    {
      label: 'fastmcp (recommended)',
      lang: 'python',
      code: `from fastmcp import FastMCP

mcp = FastMCP("My Server")

@mcp.tool()
def add(a: int, b: int) -> int:
    """Add two numbers."""
    return a + b

if __name__ == "__main__":
    mcp.run()`,
    },
    {
      label: 'official python-sdk',
      lang: 'python',
      code: `from mcp.server.fastmcp import FastMCP

mcp = FastMCP("My Server")

@mcp.tool()
async def add(a: int, b: int) -> int:
    """Add two numbers."""
    return a + b`,
    },
  ],
  TypeScript: [
    {
      label: 'fastmcp (recommended)',
      lang: 'typescript',
      code: `import { FastMCP } from "fastmcp";

const mcp = new FastMCP({ name: "My Server" });

mcp.addTool({
  name: "add",
  description: "Add two numbers",
  parameters: z.object({ a: z.number(), b: z.number() }),
  execute: async ({ a, b }) => String(a + b),
});

mcp.start({ transportType: "stdio" });`,
    },
    {
      label: 'official typescript-sdk',
      lang: 'typescript',
      code: `import { McpServer } from "@modelcontextprotocol/sdk/server/mcp.js";
import { StdioServerTransport } from "@modelcontextprotocol/sdk/server/stdio.js";
import { z } from "zod";

const server = new McpServer({ name: "My Server", version: "1.0.0" });

server.tool("add", { a: z.number(), b: z.number() },
  async ({ a, b }) => ({ content: [{ type: "text", text: String(a + b) }] })
);

const transport = new StdioServerTransport();
await server.connect(transport);`,
    },
  ],
  Go: [
    {
      label: 'mcp-go (recommended)',
      lang: 'go',
      code: `package main

import (
    "github.com/mark3labs/mcp-go/mcp"
    "github.com/mark3labs/mcp-go/server"
)

func main() {
    s := server.NewMCPServer("My Server", "1.0.0")

    tool := mcp.NewTool("add",
        mcp.WithDescription("Add two numbers"),
        mcp.WithNumber("a", mcp.Required()),
        mcp.WithNumber("b", mcp.Required()),
    )
    s.AddTool(tool, func(args mcp.CallToolRequest) (*mcp.CallToolResult, error) {
        a := args.Params.Arguments["a"].(float64)
        b := args.Params.Arguments["b"].(float64)
        return mcp.NewToolResultText(fmt.Sprintf("%v", a+b)), nil
    })
    server.ServeStdio(s)
}`,
    },
    {
      label: 'official go-sdk',
      lang: 'go',
      code: `package main

import (
    "github.com/modelcontextprotocol/go-sdk/mcp"
)

func main() {
    s := mcp.NewServer("My Server", "1.0.0", nil)
    mcp.AddTool(s, &mcp.Tool{
        Name:        "add",
        Description: "Add two numbers",
    }, func(ctx context.Context, ss *mcp.ServerSession,
        params *mcp.CallToolParamsFor[AddParams]) (*mcp.CallToolResult, error) {
        result := params.Arguments.A + params.Arguments.B
        return mcp.NewToolResultText(fmt.Sprint(result)), nil
    })
    mcp.RunStdioServer(s)
}`,
    },
  ],
  Rust: [
    {
      label: 'rust-mcp-sdk',
      lang: 'rust',
      code: `use rust_mcp_sdk::prelude::*;

#[mcp_tool(description = "Add two numbers")]
async fn add(a: f64, b: f64) -> McpResult<f64> {
    Ok(a + b)
}

#[tokio::main]
async fn main() {
    McpServer::builder()
        .name("My Server")
        .version("1.0.0")
        .tool(add)
        .build()
        .run_stdio()
        .await
        .unwrap();
}`,
    },
  ],
  Java: [
    {
      label: 'official java-sdk (Spring AI)',
      lang: 'java',
      code: `@SpringBootApplication
public class MyMcpServer {
    public static void main(String[] args) {
        SpringApplication.run(MyMcpServer.class, args);
    }

    @Bean
    public McpServerFeatures.SyncToolSpecification addTool() {
        return new McpServerFeatures.SyncToolSpecification(
            new Tool("add", "Add two numbers",
                schema(Map.of("a", "number", "b", "number"))),
            (exchange, args) -> {
                double result = (Double)args.get("a") + (Double)args.get("b");
                return new CallToolResult(result);
            }
        );
    }
}`,
    },
  ],
  Kotlin: [
    {
      label: 'official kotlin-sdk (JetBrains)',
      lang: 'kotlin',
      code: `import io.modelcontextprotocol.kotlin.sdk.*

fun main() {
    val server = Server(
        Implementation(name = "My Server", version = "1.0.0")
    )

    server.addTool(
        name = "add",
        description = "Add two numbers",
        inputSchema = Tool.Input(properties = buildJsonObject {
            put("a", buildJsonObject { put("type", "number") })
            put("b", buildJsonObject { put("type", "number") })
        })
    ) { request ->
        val a = request.arguments["a"]!!.jsonPrimitive.double
        val b = request.arguments["b"]!!.jsonPrimitive.double
        CallToolResult(content = listOf(TextContent("\${a + b}")))
    }

    server.connect(StdioServerTransport())
}`,
    },
  ],
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Table',
  name: 'MCP SDK Comparison 2026',
  description,
  url: canonicalUrl,
  about: {
    '@type': 'SoftwareApplication',
    name: 'Model Context Protocol',
    applicationCategory: 'DeveloperTool',
  },
};

const publishDate = '2026-03-18';
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: publishDate,
  dateModified: publishDate,
  author: { '@type': 'Organization', name: 'AgentRank', url: SITE },
  publisher: { '@type': 'Organization', name: 'AgentRank', url: SITE },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
  keywords,
};

const languages = ['Python', 'TypeScript', 'Go', 'Rust', 'Java', 'Kotlin', 'C#', 'Swift'];
---

<Base
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  keywords={keywords}
  jsonLd={[jsonLd, articleJsonLd]}
>
  <!-- Breadcrumb -->
  <nav class="breadcrumb">
    <a href="/">Home</a>
    <span>/</span>
    <a href="/compare/">Compare</a>
    <span>/</span>
    <span>MCP SDK Comparison</span>
  </nav>

  <div class="sdk-page">
    <div class="page-header">
      <h1 class="page-title">MCP SDK Comparison</h1>
      <p class="page-sub">
        Every major MCP SDK across 8 languages, ranked by real signals from the AgentRank index.
        Updated daily. Compare official and community implementations side by side.
      </p>
      <div class="header-meta">
        <span class="meta-item">{sdks.length} SDKs indexed</span>
        <span class="meta-sep">·</span>
        <span class="meta-item">8 languages</span>
        <span class="meta-sep">·</span>
        <span class="meta-item">Updated 2026-03-18</span>
      </div>
    </div>

    <!-- Filters -->
    <div class="filter-bar">
      <div class="filter-group">
        <span class="filter-label">Language</span>
        <div class="filter-pills" id="lang-filters">
          <button class="pill active" data-filter="lang" data-value="all">All</button>
          {languages.map(lang => (
            <button
              class="pill"
              data-filter="lang"
              data-value={lang}
              style={`--lang-color: ${LANG_COLORS[lang] || '#888'}`}
            >
              <span class="lang-dot"></span>
              {lang}
            </button>
          ))}
        </div>
      </div>
      <div class="filter-group">
        <span class="filter-label">Type</span>
        <div class="filter-pills" id="type-filters">
          <button class="pill active" data-filter="type" data-value="all">All</button>
          <button class="pill" data-filter="type" data-value="official">Official</button>
          <button class="pill" data-filter="type" data-value="community">Community</button>
        </div>
      </div>
    </div>

    <!-- Comparison Table -->
    <div class="table-wrap">
      <table class="sdk-table" id="sdk-table">
        <thead>
          <tr>
            <th class="col-name sortable" data-sort="name">SDK <span class="sort-icon">↕</span></th>
            <th class="col-lang">Language</th>
            <th class="col-type">Type</th>
            <th class="col-score sortable active-sort" data-sort="score">Score <span class="sort-icon">↓</span></th>
            <th class="col-stars sortable" data-sort="stars">Stars <span class="sort-icon">↕</span></th>
            <th class="col-contrib sortable" data-sort="contributors">Contrib <span class="sort-icon">↕</span></th>
            <th class="col-deps sortable" data-sort="dependents">Deps <span class="sort-icon">↕</span></th>
            <th class="col-commit sortable" data-sort="commit">Last Commit <span class="sort-icon">↕</span></th>
            <th class="col-maturity">Maturity</th>
            <th class="col-install">Install</th>
          </tr>
        </thead>
        <tbody id="sdk-tbody">
          {sdks.sort((x, y) => y.score - x.score).map(sdk => {
            const langColor = LANG_COLORS[sdk.language] || '#888';
            const issueHealth = sdk.open_issues + sdk.closed_issues > 0
              ? (sdk.closed_issues / (sdk.open_issues + sdk.closed_issues) * 100).toFixed(0)
              : '50';
            return (
              <tr
                data-lang={sdk.language}
                data-type={sdk.type}
                data-score={sdk.score}
                data-stars={sdk.stars}
                data-contributors={sdk.contributors}
                data-dependents={sdk.dependents}
                data-commit={sdk.last_commit_at}
              >
                <td class="col-name">
                  <div class="sdk-name-cell">
                    <a class="sdk-name" href={`/tool/${sdk.slug}/`}>{sdk.name}</a>
                    <span class="sdk-repo">{sdk.full_name}</span>
                  </div>
                </td>
                <td class="col-lang">
                  <span class="lang-badge" style={`--lc: ${langColor}`}>
                    <span class="lang-dot-inline"></span>
                    {sdk.language}
                  </span>
                </td>
                <td class="col-type">
                  <span class={`type-badge type-${sdk.type}`}>{sdk.type}</span>
                </td>
                <td class="col-score">
                  <div class="score-cell">
                    <span class="score-val">{sdk.score.toFixed(1)}</span>
                    <div class="score-bar">
                      <div class="score-fill" style={`width:${sdk.score}%`}></div>
                    </div>
                  </div>
                </td>
                <td class="col-stars">
                  <span class="num">{sdk.stars >= 1000 ? (sdk.stars / 1000).toFixed(sdk.stars >= 10000 ? 0 : 1) + 'k' : sdk.stars}</span>
                </td>
                <td class="col-contrib">
                  <span class="num">{sdk.contributors}</span>
                </td>
                <td class="col-deps">
                  <span class={`num ${sdk.dependents > 0 ? 'dep-pos' : 'dep-zero'}`}>
                    {sdk.dependents > 0 ? sdk.dependents.toLocaleString('en-US') : '—'}
                  </span>
                </td>
                <td class="col-commit">
                  <span class="commit-date">{sdk.last_commit_at}</span>
                </td>
                <td class="col-maturity">
                  <span class={`maturity-badge mat-${sdk.maturity}`}>{sdk.maturity}</span>
                </td>
                <td class="col-install">
                  <code class="install-cmd">{sdk.install}</code>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>

    <p class="no-results hidden" id="no-results">No SDKs match the selected filters.</p>

    <!-- Code Snippets -->
    <div class="snippets-section">
      <h2 class="section-title">Quickstart Code Examples</h2>
      <p class="section-sub">Build your first MCP tool in each language. All examples create a simple "add" tool that sums two numbers.</p>

      <div class="snippet-lang-tabs" id="snippet-tabs">
        {Object.keys(codeSnippets).map((lang, i) => (
          <button
            class={`snip-tab ${i === 0 ? 'active' : ''}`}
            data-lang={lang}
            style={`--lc: ${LANG_COLORS[lang] || '#888'}`}
          >
            <span class="snip-dot"></span>
            {lang}
          </button>
        ))}
      </div>

      <div class="snippet-panels" id="snippet-panels">
        {Object.entries(codeSnippets).map(([lang, variants], i) => (
          <div class={`snip-panel ${i === 0 ? 'active' : ''}`} data-lang={lang}>
            {variants.length > 1 && (
              <div class="snip-variant-tabs">
                {variants.map((v, vi) => (
                  <button class={`var-tab ${vi === 0 ? 'active' : ''}`} data-variant={vi}>
                    {v.label}
                  </button>
                ))}
              </div>
            )}
            {variants.map((v, vi) => (
              <div class={`snip-code ${vi === 0 ? 'active' : ''}`} data-variant={vi}>
                <div class="code-header">
                  <span class="code-lang">{v.lang}</span>
                  <span class="code-label">{v.label}</span>
                </div>
                <pre class="code-block"><code>{v.code}</code></pre>
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>

    <!-- How to Choose -->
    <div class="choose-section">
      <h2 class="section-title">How to Choose</h2>
      <div class="choose-grid">
        <div class="choose-card">
          <div class="choose-header">
            <span class="choose-lang" style={`color: ${LANG_COLORS.Python}`}>Python</span>
            <span class="choose-rec">Recommended: fastmcp</span>
          </div>
          <p>Best for data science workflows, AI/ML pipelines, and rapid prototyping. FastMCP's decorator pattern is the fastest path from idea to working server. Use the official SDK when you need strict spec compliance.</p>
        </div>
        <div class="choose-card">
          <div class="choose-header">
            <span class="choose-lang" style={`color: ${LANG_COLORS.TypeScript}`}>TypeScript</span>
            <span class="choose-rec">Recommended: fastmcp or official</span>
          </div>
          <p>Best for Node.js backends and full-stack teams. The official SDK has more stars and full spec coverage. fastmcp (TS) offers faster DX with less boilerplate for simple use cases.</p>
        </div>
        <div class="choose-card">
          <div class="choose-header">
            <span class="choose-lang" style={`color: ${LANG_COLORS.Go}`}>Go</span>
            <span class="choose-rec">Recommended: mcp-go</span>
          </div>
          <p>Best for high-performance servers, CLI tools, and infrastructure. mcp-go is #5 overall on AgentRank and battle-tested with 2,938 dependents. The official go-sdk is newer but maintained with Google.</p>
        </div>
        <div class="choose-card">
          <div class="choose-header">

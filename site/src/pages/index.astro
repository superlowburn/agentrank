</style>

<script>
  const tbody = document.getElementById('tbody')!;
  const rows = Array.from(tbody.querySelectorAll('tr'));
  const searchInput = document.getElementById('search') as HTMLInputElement;
  const categoryFilter = document.getElementById('category-filter') as HTMLSelectElement;
  const visibleCount = document.getElementById('visible-count')!;

  let currentSort = { col: '', dir: 'asc' };

  function applyFilters() {
    const q = searchInput.value.toLowerCase();
    const cat = categoryFilter.value;
    let count = 0;
    rows.forEach((row) => {
      const name = row.querySelector('.name')!.textContent!.toLowerCase();
      const source = row.querySelector('.source')!.textContent!.toLowerCase();
      const platforms = row.querySelector('.platforms')!.textContent!.toLowerCase();
      const rowCat = (row as HTMLElement).dataset.category || '';
      const matchesSearch = !q || name.includes(q) || source.includes(q) || platforms.includes(q);
      const matchesCat = !cat || rowCat === cat;
      const visible = matchesSearch && matchesCat;
      row.classList.toggle('hidden-row', !visible);
      if (visible) count++;
    });
    visibleCount.textContent = String(count);
  }

  searchInput.addEventListener('input', applyFilters);
  categoryFilter.addEventListener('change', applyFilters);

  document.querySelectorAll('th.sortable').forEach((th) => {
    th.addEventListener('click', () => {
      const col = (th as HTMLElement).dataset.col!;
      const type = (th as HTMLElement).dataset.type!;
      const dir = currentSort.col === col && currentSort.dir === 'asc' ? 'desc' : 'asc';
      currentSort = { col, dir };

      document.querySelectorAll('th.sortable').forEach((h) => {
        h.classList.remove('sorted-asc', 'sorted-desc');
      });
      th.classList.add(dir === 'asc' ? 'sorted-asc' : 'sorted-desc');

      const getCellValue = (row: Element): string => {
        switch (col) {
          case 'rank': return row.querySelector('.rank')!.textContent!;
          case 'name': return row.querySelector('.name')!.textContent!;
          case 'score': return row.querySelector('.score-bar')!.textContent!;
          case 'installs': return row.querySelector('.installs')!.textContent!;
          case 'platforms': return row.querySelector('.platforms')!.textContent!;
          case 'source': return row.querySelector('.source')!.textContent!;
          default: return '';
        }
      };

      const parseNum = (s: string): number => {
        s = s.trim();
        if (s.endsWith('M')) return parseFloat(s) * 1000000;
        if (s.endsWith('k')) return parseFloat(s) * 1000;
        return parseFloat(s.replace(/,/g, '')) || 0;
      };

      rows.sort((a, b) => {
        const aVal = getCellValue(a);
        const bVal = getCellValue(b);
        let cmp: number;
        if (type === 'num') {
          cmp = parseNum(aVal) - parseNum(bVal);
        } else {
          cmp = aVal.localeCompare(bVal);
        }
        return dir === 'asc' ? cmp : -cmp;
      });

      rows.forEach((row) => tbody.appendChild(row));
    });
  });

  const subscribeForm = document.getElementById('subscribe-form') as HTMLFormElement;
  const subscribeEmail = document.getElementById('subscribe-email') as HTMLInputElement;
  const subscribeBtn = document.getElementById('subscribe-btn') as HTMLButtonElement;
  const subscribeMsg = document.getElementById('subscribe-msg') as HTMLSpanElement;

  subscribeForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const hp = (subscribeForm.querySelector<HTMLInputElement>('.hp-field')?.value ?? '');
    if (hp) return; // honeypot triggered — silently abort
    const email = subscribeEmail.value.trim();
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      subscribeMsg.textContent = 'Please enter a valid email address.';
      subscribeMsg.className = 'subscribe-msg error';
      return;
    }
    subscribeBtn.disabled = true;
    subscribeMsg.textContent = '';
    subscribeMsg.className = 'subscribe-msg';
    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, source: 'homepage', _hp: '' }),
      });
      const data = await res.json();
      if (data.success) {
        subscribeMsg.textContent = data.already ? "You're already subscribed." : "You're in. Updates coming your way.";
        subscribeMsg.className = 'subscribe-msg success';
        subscribeEmail.value = '';
      } else {
        subscribeMsg.textContent = data.error || 'Something went wrong.';
        subscribeMsg.className = 'subscribe-msg error';
        subscribeBtn.disabled = false;
      }
    } catch {
      subscribeMsg.textContent = 'Network error. Please try again.';
      subscribeMsg.className = 'subscribe-msg error';
      subscribeBtn.disabled = false;
    }
  });

  document.querySelectorAll('.install-cmd').forEach((el) => {
    el.addEventListener('click', () => {
      navigator.clipboard.writeText(el.textContent!.trim());
      el.classList.add('copied');
      const hint = el.nextElementSibling as HTMLElement | null;
      const origHint = hint?.textContent;
      if (hint) hint.textContent = 'copied!';
      setTimeout(() => {
        el.classList.remove('copied');
        if (hint && origHint) hint.textContent = origHint;
      }, 1500);
    });
  });

  // Live stats — update social-proof counts from /api/v1/stats
  (async () => {
    try {
      const res = await fetch('/api/v1/stats');
      if (!res.ok) return;
      const data = await res.json();
      const skillsEl = document.getElementById('stat-skills');
      const toolsEl = document.getElementById('stat-tools');
      const updatedEl = document.getElementById('stat-updated');
      if (skillsEl && data.totalSkills) {
        skillsEl.textContent = data.totalSkills.toLocaleString('en-US');
      }
      if (toolsEl && data.totalTools) {
        toolsEl.textContent = data.totalTools.toLocaleString('en-US') + '+';
      }
      if (updatedEl && data.generatedAt) {
        const mins = Math.round((Date.now() - new Date(data.generatedAt).getTime()) / 60000);
        if (mins < 60) {
          updatedEl.textContent = `updated ${mins}m ago`;
        } else {
          const hrs = Math.floor(mins / 60);
          updatedEl.textContent = `updated ${hrs}h ago`;
        }
      }
    } catch {
      // Non-fatal — static values remain
    }
  })();

  // Animated stat counters — fetch live stats and count up
  (async () => {
    function animateCount(el: HTMLElement, target: number, duration: number = 1200) {
      const start = performance.now();
      const startVal = 0;
      const step = (now: number) => {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        // ease-out cubic
        const eased = 1 - Math.pow(1 - progress, 3);
        const current = Math.round(startVal + (target - startVal) * eased);
        el.textContent = current.toLocaleString('en-US');
        if (progress < 1) requestAnimationFrame(step);
        else el.textContent = target.toLocaleString('en-US');
      };
      requestAnimationFrame(step);
    }

    try {
      const res = await fetch('/api/v1/stats');
      if (!res.ok) return;
      const data = await res.json();
      const toolsEl = document.getElementById('stat-tools') as HTMLElement | null;
      const skillsEl = document.getElementById('stat-skills') as HTMLElement | null;
      if (toolsEl && data.totalTools) animateCount(toolsEl, data.totalTools);
      if (skillsEl && data.totalSkills) animateCount(skillsEl, data.totalSkills);
    } catch {
      // Non-fatal — static build-time values remain
    }
  })();

  // Hero inline search — debounced live search with dropdown
  ((() => {
    const input = document.getElementById('hero-search') as HTMLInputElement | null;
    const results = document.getElementById('hero-search-results') as HTMLElement | null;
    if (!input || !results) return;

    let debounceTimer: ReturnType<typeof setTimeout> | null = null;
    let currentQuery = '';
    let activeIndex = -1;
    let items: HTMLElement[] = [];

    function setActive(idx: number) {
      items.forEach((el, i) => el.classList.toggle('hsr-active', i === idx));
      activeIndex = idx;
    }

    function closeResults() {
      results.hidden = true;
      results.innerHTML = '';
      activeIndex = -1;
      items = [];
    }

    async function doSearch(q: string) {
      if (!q.trim()) { closeResults(); return; }
      results.hidden = false;
      results.innerHTML = '<div class="hsr-loading">searching…</div>';
      try {
        const res = await fetch(`/api/v1/search?q=${encodeURIComponent(q)}&limit=6`);
        if (!res.ok) throw new Error('search failed');
        const data = await res.json();
        if (q !== currentQuery) return; // stale
        if (!data.results || data.results.length === 0) {
          results.innerHTML = `<div class="hsr-empty">No results for "${q}"</div>`;
          items = [];
          return;
        }
        const html = data.results.slice(0, 5).map((r: any) => {
          const typeClass = `hsr-type-${r.type}`;
          const score = r.score != null ? `${r.score.toFixed(1)}` : '';
          const name = r.name || r.id;
          // Path-only URLs for same-origin nav
          const href = r.url ? new URL(r.url).pathname : '#';
          return `<a class="hsr-item" href="${href}" role="option" data-url="${href}">
            <span class="hsr-type ${typeClass}">${r.type}</span>
            <span class="hsr-name">${name}</span>
            ${score ? `<span class="hsr-score">${score}</span>` : ''}
          </a>`;
        }).join('');
        const total = data.meta?.total ?? data.results.length;
        const footer = total > 5
          ? `<div class="hsr-footer"><a href="/?q=${encodeURIComponent(q)}" style="color:var(--accent);text-decoration:none">View all ${total} results &rarr;</a></div>`
          : '';
        results.innerHTML = html + footer;
        items = Array.from(results.querySelectorAll('.hsr-item'));
        activeIndex = -1;
      } catch {
        if (q === currentQuery) results.innerHTML = '<div class="hsr-empty">Search unavailable</div>';
      }
    }

    input.addEventListener('input', () => {
      currentQuery = input.value;
      if (debounceTimer) clearTimeout(debounceTimer);
      if (!currentQuery.trim()) { closeResults(); return; }
      debounceTimer = setTimeout(() => doSearch(currentQuery), 220);
    });

    input.addEventListener('keydown', (e: KeyboardEvent) => {
      if (results.hidden) return;
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        setActive(Math.min(activeIndex + 1, items.length - 1));
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        setActive(Math.max(activeIndex - 1, 0));
      } else if (e.key === 'Enter') {
        if (activeIndex >= 0 && items[activeIndex]) {
          e.preventDefault();
          (items[activeIndex] as HTMLAnchorElement).click();
        } else if (currentQuery.trim()) {
          window.location.href = `/?q=${encodeURIComponent(currentQuery.trim())}`;
        }
      } else if (e.key === 'Escape') {
        closeResults();
        input.blur();
      }
    });

    document.addEventListener('click', (e) => {
      if (!input.contains(e.target as Node) && !results.contains(e.target as Node)) {
        closeResults();
      }
    });

    input.addEventListener('focus', () => {
      if (currentQuery.trim()) doSearch(currentQuery);
    });
  })());

  // Featured sponsors — load from API and inject above leaderboard
  (async () => {
    const container = document.getElementById('featured-sponsors');
    if (!container) return;
    try {
      const res = await fetch('/api/sponsored');
      if (!res.ok) return;
      const { sponsored } = await res.json();
      if (!sponsored || sponsored.length === 0) return;

      const top = sponsored.slice(0, 3);
      const cards = top.map((t) => {
        const slug = t.full_name.replace('/', '--');
        const desc = (t.sponsor_description || t.description || '').slice(0, 120);
        const cat = t.category ? `<span class="sponsor-card-category">${t.category}</span>` : '';
        const cta = t.sponsor_cta_text && t.sponsor_cta_url
          ? `<a class="sponsor-cta-btn" href="/api/sponsored/click?tool=${encodeURIComponent(t.full_name)}&type=cta&page=homepage" target="_blank" rel="noopener noreferrer">${t.sponsor_cta_text} &rarr;</a>`
          : '';
        return `<a class="sponsor-card" href="/api/sponsored/click?tool=${encodeURIComponent(t.full_name)}&type=detail&page=homepage">
          <div class="sponsor-card-top">
            <span class="sponsor-card-name">${t.full_name.split('/')[1] || t.full_name}</span>
            <span class="sponsor-badge">Sponsored</span>
          </div>
          ${desc ? `<p class="sponsor-card-desc">${desc}</p>` : ''}
          <div class="sponsor-card-meta">
            <span class="sponsor-card-score">Score: ${(t.score || 0).toFixed(1)}</span>
            ${cat}
          </div>
          ${cta}
        </a>`;
      }).join('');

      container.innerHTML = `<div class="featured-sponsors">
        <div class="featured-sponsors-header">
          <span class="featured-sponsors-label">Featured Tools</span>
          <a class="featured-sponsors-cta" href="/pricing/#sponsored">Get featured &rarr;</a>
        </div>
        <div class="featured-sponsors-grid">${cards}</div>
      </div>`;
    } catch {
      // Non-fatal — just don't show the section
    }
  })();

  // News widget — load latest items from API
  (async () => {
    const container = document.getElementById('news-widget-items');
    if (!container) return;
    try {
      const res = await fetch('/api/v1/news?limit=5');
      if (!res.ok) throw new Error('fetch failed');
      const { items } = await res.json();
      if (!items || items.length === 0) {
        document.getElementById('news-widget')?.remove();
        return;
      }
      function relTime(iso) {
        const diff = Date.now() - new Date(iso).getTime();
        const mins = Math.floor(diff / 60000);
        if (mins < 60) return `${mins}m ago`;
        const hrs = Math.floor(mins / 60);
        if (hrs < 24) return `${hrs}h ago`;
        const days = Math.floor(hrs / 24);
        return days === 1 ? 'yesterday' : `${days}d ago`;
      }
      const catColors = { launch: '#22c55e', update: '#3b82f6', community: '#a855f7', trending: '#f59e0b', analysis: '#ef4444' };
      container.innerHTML = items.map((item) => `
        <div class="nwi">
          <span class="nwi-cat" style="color:${catColors[item.category] || 'var(--text-muted)'}">${item.category}</span>
          <a class="nwi-title" href="${item.source_url}" target="_blank" rel="noopener noreferrer">${item.title}</a>
          <span class="nwi-time">${relTime(item.published_at)}</span>
        </div>
      `).join('');
    } catch {
      document.getElementById('news-widget')?.remove();
    }
  })();
</script>

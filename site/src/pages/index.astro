---
export const prerender = true;

import Base from '../layouts/Base.astro';
import { getTopSkills, getAllSkills } from '../data/ranked-skills';
import { toSkillSlug, formatInstalls, platformBadges, scoreColor, sourceLabel } from '../data/skills';
import { getAllTools } from '../data/ranked';
import { CATEGORIES } from '../data/content-gen';
import { getToolOfTheDay } from '../data/tool-of-the-day';
import { scoreColor as toolScoreColor, formatStars } from '../data/tools';

const TOP_N = 500;
const allSkills = getAllSkills();
const skills = getTopSkills(TOP_N);
const totalCount = allSkills.length;
const totalToolCount = getAllTools().length;
const totd = getToolOfTheDay();
const totdShortName = totd.tool.full_name.split('/')[1] || totd.tool.full_name;

const usedCategories = [...new Set(skills.map((s) => s.category).filter(Boolean))].sort() as string[];

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'AgentRank',
  url: 'https://agentrank-ai.com',
  description: 'Google PageRank for AI agents. Indexes 25,000+ MCP servers and agent tools, scored daily from real signals.',
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: 'https://agentrank-ai.com/api/search?q={search_term_string}',
    },
    'query-input': 'required name=search_term_string',
  },
};

const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Top AI Skills',
  itemListOrder: 'https://schema.org/ItemListOrderDescending',
  numberOfItems: Math.min(skills.length, 10),
  itemListElement: skills.slice(0, 10).map((skill, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: skill.name || skill.slug,
    url: `https://agentrank-ai.com/skill/${toSkillSlug(skill.slug)}/`,
  })),
};
---

<Base
  title="AgentRank — Google PageRank for AI agents"
  description={`Discover and rank ${totalCount.toLocaleString('en-US')}+ AI skills, MCP servers, and agent tools. Scored daily from real signals. Install once and your AI automatically finds the best tool.`}
  keywords="AI skills, MCP servers, agent tools, Claude skills, AI agent tools, best AI skills, skills.sh, Glama MCP, model context protocol skills"
  activeTab="skills"
  canonicalUrl="https://agentrank-ai.com/"
  jsonLd={[websiteJsonLd, itemListJsonLd]}
  ogImage="/og/home.png"
>
  <div class="install-banner">
    <div class="hero-headline">
      <h2>Find the best MCP servers and AI agent tools</h2>
      <p class="hero-sub">Ranked by real signals, updated daily. The index your AI uses to find the right tool automatically.</p>
    </div>

    <div class="hero-stats">
      <div class="hero-stat">
        <span class="hero-stat-num" id="stat-tools">{totalToolCount.toLocaleString('en-US')}</span>
        <span class="hero-stat-label">tools</span>
      </div>
      <span class="hero-stat-sep" aria-hidden="true">·</span>
      <div class="hero-stat">
        <span class="hero-stat-num" id="stat-skills">{totalCount.toLocaleString('en-US')}</span>
        <span class="hero-stat-label">skills</span>
      </div>
      <span class="hero-stat-sep" aria-hidden="true">·</span>
      <div class="hero-stat">
        <span class="hero-stat-num">daily</span>
        <span class="hero-stat-label">updates</span>
      </div>
      <span class="hero-stat-sep" aria-hidden="true">·</span>
      <a href="/reports/" class="hero-stat hero-stat-link">
        <span class="hero-stat-num">weekly</span>
        <span class="hero-stat-label">reports</span>
      </a>
    </div>

    <div class="hero-search-wrap">
      <div class="hero-search-inner">
        <span class="hero-search-icon" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </span>
        <input
          type="text"
          id="hero-search"
          class="hero-search-input"
          placeholder="Search tools and skills..."
          autocomplete="off"
          spellcheck="false"
          aria-label="Search tools and skills"
          aria-autocomplete="list"
          aria-controls="hero-search-results"
        />
        <span class="hero-search-hint" id="hero-search-hint" aria-hidden="true">↵ to browse all</span>
      </div>
      <div class="hero-search-results" id="hero-search-results" role="listbox" aria-label="Search suggestions"></div>
    </div>

    <div class="install-pitch">
      <strong class="install-headline">Install once — your AI picks the right tool automatically.</strong>
      <span class="install-sub">No prompting, no config.</span>
    </div>
    <div class="install-options">
      <div class="install-option">
        <span class="install-label">
          <svg class="platform-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><polyline points="8 12 11 15 16 9"/></svg>
          Claude Code
        </span>
        <div class="install-cmd-wrap">
          <code class="install-cmd">claude mcp add agentrank -- npx -y agentrank-mcp-server</code>
          <span class="copy-hint" aria-hidden="true">copy</span>
        </div>
      </div>
      <div class="install-option">
        <span class="install-label">
          <svg class="platform-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
          Cursor / Windsurf
        </span>
        <div class="install-cmd-wrap">
          <code class="install-cmd">{'{"command":"npx","args":["-y","agentrank-mcp-server"]}'}</code>
          <span class="copy-hint" aria-hidden="true">copy</span>
        </div>
      </div>
      <div class="install-option">
        <span class="install-label">
          <svg class="platform-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>
          VS Code
        </span>
        <div class="install-cmd-wrap">
          <code class="install-cmd">{'{"servers":{"agentrank":{"command":"npx","args":["-y","agentrank-mcp-server"]}}}'}</code>
          <span class="copy-hint" aria-hidden="true">copy</span>
        </div>
      </div>
    </div>
  </div>

  <div class="subscribe-banner">
    <div class="subscribe-headline">
      <strong>Get the weekly digest</strong>
      <span class="subscribe-tagline">Top movers, new tools, ecosystem shifts — every Wednesday.</span>
    </div>
    <form id="subscribe-form" class="subscribe-form" novalidate>
      <div class="subscribe-input-row">
        <input
          type="email"
          id="subscribe-email"
          name="email"
          placeholder="you@example.com"
          autocomplete="email"
          required
        />
        <button type="submit" id="subscribe-btn">Subscribe</button>
      </div>
      <input type="text" name="_hp" class="hp-field" tabindex="-1" autocomplete="off" aria-hidden="true" />
      <span id="subscribe-msg" class="subscribe-msg" aria-live="polite"></span>
    </form>
    <div class="maintainer-row">
      <span class="maintainer-row-text">Maintainer? <a href="/submit/" class="maintainer-row-link">Claim your listing</a> to add context, get a verified badge, and track your rank.</span>
      <span class="api-row-sep" aria-hidden="true">·</span>
      <span class="api-row-text">Builder? <a href="/pricing/#api" class="api-row-link">Get API access</a> to the full ranked index.</span>
    </div>
  </div>

  <div class="health-check-cta">
    <div class="health-check-cta-text">
      <strong>Is your MCP server healthy?</strong>
      <span>Paste a GitHub URL for an instant score — stars, freshness, issue health, contributors. No login required.</span>
    </div>
    <a href="/check/" class="health-check-cta-btn">Try the free health checker &rarr;</a>
  </div>

  <div class="news-widget" id="news-widget">
    <div class="news-widget-header">
      <span class="news-widget-title">Latest from the ecosystem</span>
      <a href="/news/" class="news-widget-more">all news &rarr;</a>
    </div>
    <div class="news-widget-items" id="news-widget-items">
      <div class="news-widget-loading">loading…</div>
    </div>
  </div>

  <div class="totd-widget">
    <div class="totd-widget-label">Tool of the Day</div>
    <div class="totd-widget-body">
      <div class="totd-widget-info">
        <a href={`/tool/${totd.slug}/`} class="totd-widget-name">{totdShortName}</a>
        <span class="totd-widget-repo">{totd.tool.full_name}</span>
        {totd.tool.description && (
          <p class="totd-widget-desc">{totd.tool.description.slice(0, 140)}{totd.tool.description.length > 140 ? '…' : ''}</p>
        )}
      </div>
      <div class="totd-widget-aside">
        <span class="totd-widget-score" style={`color: ${toolScoreColor(totd.tool.score)}`}>{totd.tool.score?.toFixed(1)}</span>
        <span class="totd-widget-score-label">score</span>
        <div class="totd-widget-meta">
          <span>#{totd.tool.rank}</span>
          {totd.tool.stars > 0 && <span>· {formatStars(totd.tool.stars)} ★</span>}
        </div>
        <a href={`/tool/${totd.slug}/`} class="totd-widget-cta">View profile &rarr;</a>
        <a href="/tool-of-the-day" class="totd-widget-share">share link</a>
      </div>
    </div>
  </div>

  <div class="controls">
    <input type="text" id="search" placeholder="Search skills..." autocomplete="off" />
    <select id="category-filter" aria-label="Filter by category">
      <option value="">All categories</option>
      {usedCategories.map((cat) => (
        <option value={cat}>{CATEGORIES[cat] || cat}</option>
      ))}
    </select>
    <span class="count"><span id="visible-count">{skills.length}</span> of {totalCount.toLocaleString('en-US')} skills</span>
  </div>

  <div class="category-nav">
    {usedCategories.map((cat) => (
      <a href={`/category/${cat}/`} class="cat-chip">{CATEGORIES[cat] || cat}</a>
    ))}
  </div>

  <div id="featured-sponsors"></div>

  <div class="table-wrap">
    <table id="leaderboard">
      <thead>
        <tr>
          <th class="sortable" data-col="rank" data-type="num">#</th>
          <th class="sortable" data-col="name" data-type="str">Name</th>
          <th class="sortable" data-col="score" data-type="num">Score</th>
          <th class="sortable" data-col="installs" data-type="num">Installs</th>
          <th class="sortable" data-col="platforms" data-type="str">Platforms</th>
          <th class="sortable" data-col="source" data-type="str">Source</th>
        </tr>
      </thead>
      <tbody id="tbody">
        {skills.map((skill) => (
          <tr data-category={skill.category || ''}>
            <td class="rank">{skill.rank}</td>
            <td class="name">
              <a href={`/skill/${toSkillSlug(skill.slug)}/`}>{skill.name || skill.slug}</a>
            </td>
            <td class="score">
              <span class="score-bar" style={`--w: ${skill.score}%; --c: ${scoreColor(skill.score)}`}>
                {skill.score.toFixed(1)}
              </span>
            </td>
            <td class="installs">{formatInstalls(skill.installs)}</td>
            <td class="platforms">
              {platformBadges(skill.platforms).map((p) => (
                <span class="platform-badge">{p}</span>
              ))}
            </td>
            <td class="source">{sourceLabel(skill.source)}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</Base>

<style>
  .totd-widget {
    border: 1px solid var(--accent);
    border-radius: 6px;
    background: var(--bg-surface);
    padding: 1rem 1.25rem;
    margin-bottom: 1.5rem;
    position: relative;
    overflow: hidden;
  }

  .totd-widget::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), transparent);
  }

  .totd-widget-label {
    font-size: 0.68rem;
    color: var(--accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .totd-widget-body {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .totd-widget-info {
    flex: 1;
    min-width: 0;
  }

  .totd-widget-name {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
    display: block;
    margin-bottom: 0.15rem;
  }

  .totd-widget-name:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .totd-widget-repo {
    font-size: 0.75rem;
    color: var(--text-muted);
    display: block;
    margin-bottom: 0.5rem;
  }

  .totd-widget-desc {
    font-size: 0.82rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin: 0;
  }

  .totd-widget-aside {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.2rem;
    flex-shrink: 0;
  }

  .totd-widget-score {
    font-size: 2rem;
    font-weight: 800;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .totd-widget-score-label {
    font-size: 0.7rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .totd-widget-meta {
    font-size: 0.75rem;
    color: var(--text-muted);
    display: flex;
    gap: 0.3rem;
    margin-top: 0.25rem;
  }

  .totd-widget-cta {
    display: inline-block;
    margin-top: 0.5rem;
    padding: 0.3rem 0.7rem;
    background: var(--accent);
    color: #000;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 3px;
    text-decoration: none;
    transition: opacity 0.15s;
    white-space: nowrap;
  }

  .totd-widget-cta:hover {
    opacity: 0.85;
    text-decoration: none;
  }

  .totd-widget-share {
    font-size: 0.7rem;
    color: var(--text-muted);
    text-decoration: none;
    text-align: right;
  }

  .totd-widget-share:hover {
    color: var(--accent);
    text-decoration: none;
  }

  @media (max-width: 500px) {
    .totd-widget-body {
      flex-direction: column;
    }
    .totd-widget-aside {
      flex-direction: row;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .totd-widget-score {
      font-size: 1.5rem;
    }
  }

  .category-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .cat-chip {
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    border-radius: 3px;
    border: 1px solid var(--border);
    color: var(--text-muted);
    background: var(--bg-surface);
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s;
  }

  .cat-chip:hover {
    color: var(--accent);
    border-color: var(--accent);
    text-decoration: none;
  }

  .subscribe-banner {
    background: var(--bg-surface);
    border: 1px solid var(--accent);
    border-radius: 6px;
    padding: 1rem 1.25rem;
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .subscribe-headline {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .subscribe-headline strong {
    font-size: 0.92rem;
    color: var(--text);
  }

  .subscribe-tagline {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .subscribe-form {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    width: 100%;
  }

  .subscribe-input-row {
    display: flex;
    gap: 0.5rem;
    flex: 1;
    min-width: 0;
  }

  .maintainer-row {
    border-top: 1px solid var(--border);
    padding-top: 0.5rem;
    margin-top: 0.1rem;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .maintainer-row-text {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .maintainer-row-link {
    color: var(--accent);
    font-weight: 600;
    text-decoration: none;
  }

  .maintainer-row-link:hover {
    text-decoration: underline;
  }

  .api-row-sep {
    font-size: 0.78rem;
    color: var(--border);
  }

  .api-row-text {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .api-row-link {
    color: var(--accent);
    font-weight: 600;
    text-decoration: none;
  }

  .api-row-link:hover {
    text-decoration: underline;
  }

  #subscribe-email {
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 0.4rem 0.75rem;
    border-radius: 4px;
    font-family: inherit;
    font-size: 0.85rem;
    flex: 1;
    min-width: 0;
  }

  #subscribe-email:focus {
    outline: 1px solid var(--accent);
    border-color: var(--accent);
  }

  #subscribe-btn {
    background: var(--accent);
    color: #000;
    border: none;
    border-radius: 4px;
    padding: 0.4rem 0.9rem;
    font-family: inherit;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.15s;
  }

  #subscribe-btn:hover {
    opacity: 0.85;
  }

  #subscribe-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .subscribe-msg {
    font-size: 0.78rem;
    min-height: 1em;
    width: 100%;
  }

  .subscribe-msg.success {
    color: var(--accent);
  }

  .subscribe-msg.error {
    color: #ef4444;
  }

  .hp-field {
    position: absolute;
    left: -9999px;
    opacity: 0;
    height: 0;
    width: 0;
    pointer-events: none;
  }

  @media (max-width: 600px) {
    .subscribe-form {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .subscribe-input-row {
      width: 100%;
    }
  }

  .hero-headline {
    margin-bottom: 0.85rem;
  }

  .hero-headline h2 {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.3rem;
    line-height: 1.3;
  }

  .hero-sub {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin: 0;
  }

  /* Animated stats row */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .hero-stat {
    display: flex;
    align-items: baseline;
    gap: 0.3rem;
  }

  .hero-stat-num {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.01em;
    font-variant-numeric: tabular-nums;
  }

  .hero-stat-label {
    font-size: 0.68rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hero-stat-sep {
    color: var(--border);
    font-size: 0.75rem;
    flex-shrink: 0;
  }

  a.hero-stat-link {
    text-decoration: none;
    cursor: pointer;
  }

  a.hero-stat-link:hover .hero-stat-num {
    text-decoration: underline;
  }

  /* Hero inline search */
  .hero-search-wrap {
    position: relative;
    margin-bottom: 1rem;
  }

  .hero-search-inner {
    position: relative;
    display: flex;
    align-items: center;
  }

  .hero-search-icon {
    position: absolute;
    left: 0.75rem;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    pointer-events: none;
    flex-shrink: 0;
  }

  .hero-search-input {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 5px;
    padding: 0.55rem 6rem 0.55rem 2.2rem;
    font-family: inherit;
    font-size: 0.875rem;
    color: var(--text);
    transition: border-color 0.15s, box-shadow 0.15s;
    min-width: 0;
  }

  .hero-search-input::placeholder {
    color: var(--text-muted);
  }

  .hero-search-input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 15%, transparent);
  }

  .hero-search-hint {
    position: absolute;
    right: 0.75rem;
    font-size: 0.65rem;
    color: var(--text-muted);
    pointer-events: none;
    white-space: nowrap;
    opacity: 0.7;
    letter-spacing: 0.02em;
  }

  .hero-search-results {
    position: absolute;
    top: calc(100% + 2px);
    left: 0;
    right: 0;
    background: var(--bg-surface);
    border: 1px solid var(--accent);
    border-radius: 5px;
    z-index: 50;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0,0,0,0.4);
  }

  .hero-search-results[hidden] {
    display: none;
  }

  .hsr-item {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    cursor: pointer;
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    transition: background 0.1s;
  }

  .hsr-item:last-child {
    border-bottom: none;
  }

  .hsr-item:hover,
  .hsr-item.hsr-active {
    background: var(--bg-hover);
  }

  .hsr-type {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.1rem 0.3rem;
    border-radius: 3px;
    flex-shrink: 0;
  }

  .hsr-type-tool {

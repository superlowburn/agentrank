---
export const prerender = true;

import Base from '../layouts/Base.astro';
import { getTopSkills, getAllSkills } from '../data/ranked-skills';
import { toSkillSlug, formatInstalls, platformBadges, scoreColor, sourceLabel } from '../data/skills';
import { CATEGORIES } from '../data/content-gen';

const TOP_N = 500;
const allSkills = getAllSkills();
const skills = getTopSkills(TOP_N);
const totalCount = allSkills.length;

const usedCategories = [...new Set(skills.map((s) => s.category).filter(Boolean))].sort() as string[];

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'AgentRank',
  url: 'https://agentrank-ai.com',
  description: 'Google PageRank for AI agents. Indexes 25,000+ MCP servers and agent tools, scored daily from real signals.',
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: 'https://agentrank-ai.com/api/search?q={search_term_string}',
    },
    'query-input': 'required name=search_term_string',
  },
};

const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Top AI Skills',
  itemListOrder: 'https://schema.org/ItemListOrderDescending',
  numberOfItems: Math.min(skills.length, 10),
  itemListElement: skills.slice(0, 10).map((skill, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: skill.name || skill.slug,
    url: `https://agentrank-ai.com/skill/${toSkillSlug(skill.slug)}/`,
  })),
};
---

<Base
  title="AgentRank — Google PageRank for AI agents"
  description={`Discover and rank ${totalCount.toLocaleString('en-US')}+ AI skills, MCP servers, and agent tools. Scored daily from real signals. Install once and your AI automatically finds the best tool.`}
  keywords="AI skills, MCP servers, agent tools, Claude skills, AI agent tools, best AI skills, skills.sh, Glama MCP, model context protocol skills"
  activeTab="skills"
  canonicalUrl="https://agentrank-ai.com/"
  jsonLd={[websiteJsonLd, itemListJsonLd]}
  ogImage="/og/home.png"
>
  <div class="install-banner">
    <div class="hero-headline">
      <h2>Find the best MCP servers and AI agent tools</h2>
      <p class="hero-sub">Ranked by real signals, updated daily. The index your AI uses to find the right tool automatically.</p>
    </div>
    <div class="social-proof">
      <span class="sp-stat">{totalCount.toLocaleString('en-US')} skills ranked</span>
      <span class="sp-sep">·</span>
      <span class="sp-stat">25,000+ tools indexed</span>
      <span class="sp-sep">·</span>
      <span class="sp-stat">updated daily</span>
      <span class="sp-sep">·</span>
      <a class="sp-stat sp-link" href="https://github.com/superlowburn/agentrank" target="_blank" rel="noopener noreferrer">open source</a>
    </div>
    <div class="install-pitch">
      <strong class="install-headline">Install once — your AI picks the right tool automatically.</strong>
      <span class="install-sub">No prompting, no config.</span>
    </div>
    <div class="install-options">
      <div class="install-option">
        <span class="install-label">Claude Code</span>
        <div class="install-cmd-wrap">
          <code class="install-cmd">claude mcp add agentrank -- npx -y agentrank-mcp-server</code>
          <span class="copy-hint" aria-hidden="true">copy</span>
        </div>
      </div>
      <div class="install-option">
        <span class="install-label">Claude Desktop / Cursor / Windsurf</span>
        <div class="install-cmd-wrap">
          <code class="install-cmd">{'{"command":"npx","args":["-y","agentrank-mcp-server"]}'}</code>
          <span class="copy-hint" aria-hidden="true">copy</span>
        </div>
      </div>
    </div>
  </div>

  <div class="subscribe-banner">
    <form id="subscribe-form" class="subscribe-form" novalidate>
      <span class="subscribe-label">Get the weekly AgentRank digest — top movers, new tools, ecosystem insights.</span>
      <div class="subscribe-input-row">
        <input
          type="email"
          id="subscribe-email"
          name="email"
          placeholder="you@example.com"
          autocomplete="email"
          required
        />
        <button type="submit" id="subscribe-btn">Subscribe</button>
      </div>
      <input type="text" name="_hp" class="hp-field" tabindex="-1" autocomplete="off" aria-hidden="true" />
      <span id="subscribe-msg" class="subscribe-msg" aria-live="polite"></span>
    </form>
  </div>

  <div class="controls">
    <input type="text" id="search" placeholder="Search skills..." autocomplete="off" />
    <select id="category-filter" aria-label="Filter by category">
      <option value="">All categories</option>
      {usedCategories.map((cat) => (
        <option value={cat}>{CATEGORIES[cat] || cat}</option>
      ))}
    </select>
    <span class="count"><span id="visible-count">{skills.length}</span> of {totalCount.toLocaleString('en-US')} skills</span>
  </div>

  <div class="category-nav">
    {usedCategories.map((cat) => (
      <a href={`/category/${cat}/`} class="cat-chip">{CATEGORIES[cat] || cat}</a>
    ))}
  </div>

  <div class="table-wrap">
    <table id="leaderboard">
      <thead>
        <tr>
          <th class="sortable" data-col="rank" data-type="num">#</th>
          <th class="sortable" data-col="name" data-type="str">Name</th>
          <th class="sortable" data-col="score" data-type="num">Score</th>
          <th class="sortable" data-col="installs" data-type="num">Installs</th>
          <th class="sortable" data-col="platforms" data-type="str">Platforms</th>
          <th class="sortable" data-col="source" data-type="str">Source</th>
        </tr>
      </thead>
      <tbody id="tbody">
        {skills.map((skill) => (
          <tr data-category={skill.category || ''}>
            <td class="rank">{skill.rank}</td>
            <td class="name">
              <a href={`/skill/${toSkillSlug(skill.slug)}/`}>{skill.name || skill.slug}</a>
            </td>
            <td class="score">
              <span class="score-bar" style={`--w: ${skill.score}%; --c: ${scoreColor(skill.score)}`}>
                {skill.score.toFixed(1)}
              </span>
            </td>
            <td class="installs">{formatInstalls(skill.installs)}</td>
            <td class="platforms">
              {platformBadges(skill.platforms).map((p) => (
                <span class="platform-badge">{p}</span>
              ))}
            </td>
            <td class="source">{sourceLabel(skill.source)}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</Base>

<style>
  .category-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .cat-chip {
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    border-radius: 3px;
    border: 1px solid var(--border);
    color: var(--text-muted);
    background: var(--bg-surface);
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s;
  }

  .cat-chip:hover {
    color: var(--accent);
    border-color: var(--accent);
    text-decoration: none;
  }

  .subscribe-banner {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.85rem 1.25rem;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
  }

  .subscribe-form {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    width: 100%;
  }

  .subscribe-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .subscribe-input-row {
    display: flex;
    gap: 0.5rem;
    flex: 1;
    min-width: 0;
  }

  #subscribe-email {
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 0.4rem 0.75rem;
    border-radius: 4px;
    font-family: inherit;
    font-size: 0.85rem;
    flex: 1;
    min-width: 0;
  }

  #subscribe-email:focus {
    outline: 1px solid var(--accent);
    border-color: var(--accent);
  }

  #subscribe-btn {
    background: var(--accent);
    color: #000;
    border: none;
    border-radius: 4px;
    padding: 0.4rem 0.9rem;
    font-family: inherit;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.15s;
  }

  #subscribe-btn:hover {
    opacity: 0.85;
  }

  #subscribe-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .subscribe-msg {
    font-size: 0.78rem;
    min-height: 1em;
    width: 100%;
  }

  .subscribe-msg.success {
    color: var(--accent);
  }

  .subscribe-msg.error {
    color: #ef4444;
  }

  .hp-field {
    position: absolute;
    left: -9999px;
    opacity: 0;
    height: 0;
    width: 0;
    pointer-events: none;
  }

  @media (max-width: 600px) {
    .subscribe-form {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .subscribe-input-row {
      width: 100%;
    }
  }

  .hero-headline {
    margin-bottom: 0.85rem;
  }

  .hero-headline h2 {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.3rem;
    line-height: 1.3;
  }

  .hero-sub {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin: 0;
  }

  .install-banner {
    background: var(--bg-surface);
    border: 1px solid var(--accent);
    border-radius: 6px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1.5rem;
  }

  .social-proof {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .sp-stat {
    font-size: 0.72rem;
    color: var(--accent);
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .sp-sep {
    color: var(--border);
    font-size: 0.72rem;
  }

  .sp-link {
    text-decoration: none;
  }

  .sp-link:hover {
    text-decoration: underline;
  }

  .install-headline {
    font-size: 1rem;
  }

  .install-sub {
    color: var(--text-muted);
    font-size: 0.8rem;
    margin-left: 0.5rem;
  }

  .install-options {
    display: flex;
    gap: 1.5rem;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }

  .install-option {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
    flex: 1;
  }

  .install-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    font-weight: 600;
  }

  .install-cmd-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .install-cmd {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.4rem 2.5rem 0.4rem 0.6rem;
    font-size: 0.78rem;
    color: var(--accent);
    cursor: pointer;
    overflow-x: auto;
    white-space: nowrap;
    transition: border-color 0.15s;
    flex: 1;
    min-width: 0;
  }

  .install-cmd:hover {
    border-color: var(--accent);
  }

  .install-cmd:hover + .copy-hint {
    opacity: 1;
  }

  .install-cmd.copied + .copy-hint {
    opacity: 1;
    color: var(--accent);
  }

  .copy-hint {
    position: absolute;
    right: 0.5rem;
    font-size: 0.65rem;
    color: var(--text-muted);
    pointer-events: none;
    opacity: 0;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: opacity 0.15s, color 0.15s;
    user-select: none;
  }

  @media (max-width: 640px) {
    .install-sub {
      display: block;
      margin-left: 0;
      margin-top: 0.25rem;
    }

    .install-options {
      flex-direction: column;
      gap: 0.75rem;
    }

    .social-proof {
      gap: 0.4rem;
    }
  }

  .controls {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  #search {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 0.5rem 0.75rem;
    border-radius: 4px;
    font-family: inherit;
    font-size: 0.85rem;
    width: 260px;
    min-width: 0;
    flex-shrink: 1;
  }

  #search:focus {
    outline: 1px solid var(--accent);
    border-color: var(--accent);
  }

  #category-filter {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 0.5rem 0.75rem;
    border-radius: 4px;
    font-family: inherit;
    font-size: 0.85rem;
    cursor: pointer;
    min-width: 0;
    flex-shrink: 1;
  }

  #category-filter:focus {
    outline: 1px solid var(--accent);
    border-color: var(--accent);
  }

  .count {
    color: var(--text-muted);
    font-size: 0.8rem;
    white-space: nowrap;
    margin-left: auto;
  }

  @media (max-width: 600px) {
    .controls {
      flex-direction: column;
      align-items: stretch;
      gap: 0.5rem;
    }

    #search {
      width: 100%;
    }

    #category-filter {
      width: 100%;
    }

    .count {
      margin-left: 0;
      text-align: right;
    }
  }

  .table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
  }

  thead {
    position: sticky;
    top: 0;
    z-index: 1;
  }

  th {
    background: var(--bg-surface);
    border-bottom: 2px solid var(--border);
    padding: 0.5rem 0.75rem;
    text-align: left;
    font-weight: 600;
    white-space: nowrap;
    user-select: none;
    color: var(--text-muted);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  th.sortable {
    cursor: pointer;
  }

  th.sortable:hover {
    color: var(--text);
  }

  th.sorted-asc::after {
    content: ' \2191';
  }

  th.sorted-desc::after {
    content: ' \2193';
  }

  td {
    padding: 0.4rem 0.75rem;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }

  tr:hover td {
    background: var(--bg-hover);
  }

  .rank {
    color: var(--text-muted);
    width: 3rem;
  }

  .name a {
    color: var(--text);
    font-weight: 500;
  }

  .name a:hover {
    color: var(--accent);
  }

  .score-bar {
    display: inline-block;
    padding: 0.1rem 0.5rem;
    border-radius: 3px;
    background: linear-gradient(90deg, var(--c) var(--w), transparent var(--w));
    background-color: var(--bg-surface);
    min-width: 4rem;
    font-weight: 600;
  }

  .installs {
    color: var(--text-muted);
  }

  .platforms {
    display: flex;
    gap: 0.25rem;
    flex-wrap: nowrap;
  }

  .platform-badge {
    display: inline-block;
    font-size: 0.65rem;
    padding: 0.1rem 0.35rem;
    border-radius: 3px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    color: var(--text-muted);
    white-space: nowrap;
  }

  .source {
    color: var(--text-muted);
  }

  .hidden-row {
    display: none;
  }

  @media (prefers-color-scheme: light) {
    .platform-badge {
      background: #f4f4f5;
      border-color: #e4e4e7;
      color: #52525b;
    }
  }
</style>

<script>
  const tbody = document.getElementById('tbody')!;
  const rows = Array.from(tbody.querySelectorAll('tr'));
  const searchInput = document.getElementById('search') as HTMLInputElement;
  const categoryFilter = document.getElementById('category-filter') as HTMLSelectElement;
  const visibleCount = document.getElementById('visible-count')!;

  let currentSort = { col: '', dir: 'asc' };

  function applyFilters() {
    const q = searchInput.value.toLowerCase();
    const cat = categoryFilter.value;
    let count = 0;
    rows.forEach((row) => {
      const name = row.querySelector('.name')!.textContent!.toLowerCase();
      const source = row.querySelector('.source')!.textContent!.toLowerCase();
      const platforms = row.querySelector('.platforms')!.textContent!.toLowerCase();
      const rowCat = (row as HTMLElement).dataset.category || '';
      const matchesSearch = !q || name.includes(q) || source.includes(q) || platforms.includes(q);
      const matchesCat = !cat || rowCat === cat;
      const visible = matchesSearch && matchesCat;
      row.classList.toggle('hidden-row', !visible);
      if (visible) count++;
    });
    visibleCount.textContent = String(count);
  }

  searchInput.addEventListener('input', applyFilters);
  categoryFilter.addEventListener('change', applyFilters);

  document.querySelectorAll('th.sortable').forEach((th) => {
    th.addEventListener('click', () => {
      const col = (th as HTMLElement).dataset.col!;
      const type = (th as HTMLElement).dataset.type!;
      const dir = currentSort.col === col && currentSort.dir === 'asc' ? 'desc' : 'asc';
      currentSort = { col, dir };

      document.querySelectorAll('th.sortable').forEach((h) => {
        h.classList.remove('sorted-asc', 'sorted-desc');
      });
      th.classList.add(dir === 'asc' ? 'sorted-asc' : 'sorted-desc');

      const getCellValue = (row: Element): string => {
        switch (col) {
          case 'rank': return row.querySelector('.rank')!.textContent!;
          case 'name': return row.querySelector('.name')!.textContent!;
          case 'score': return row.querySelector('.score-bar')!.textContent!;
          case 'installs': return row.querySelector('.installs')!.textContent!;
          case 'platforms': return row.querySelector('.platforms')!.textContent!;
          case 'source': return row.querySelector('.source')!.textContent!;
          default: return '';
        }
      };

      const parseNum = (s: string): number => {
        s = s.trim();
        if (s.endsWith('M')) return parseFloat(s) * 1000000;
        if (s.endsWith('k')) return parseFloat(s) * 1000;
        return parseFloat(s.replace(/,/g, '')) || 0;
      };

      rows.sort((a, b) => {
        const aVal = getCellValue(a);
        const bVal = getCellValue(b);
        let cmp: number;
        if (type === 'num') {
          cmp = parseNum(aVal) - parseNum(bVal);
        } else {
          cmp = aVal.localeCompare(bVal);
        }
        return dir === 'asc' ? cmp : -cmp;
      });

      rows.forEach((row) => tbody.appendChild(row));
    });
  });

  const subscribeForm = document.getElementById('subscribe-form') as HTMLFormElement;
  const subscribeEmail = document.getElementById('subscribe-email') as HTMLInputElement;
  const subscribeBtn = document.getElementById('subscribe-btn') as HTMLButtonElement;
  const subscribeMsg = document.getElementById('subscribe-msg') as HTMLSpanElement;

  subscribeForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const hp = (subscribeForm.querySelector<HTMLInputElement>('.hp-field')?.value ?? '');
    if (hp) return; // honeypot triggered — silently abort
    const email = subscribeEmail.value.trim();
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      subscribeMsg.textContent = 'Please enter a valid email address.';
      subscribeMsg.className = 'subscribe-msg error';
      return;
    }
    subscribeBtn.disabled = true;
    subscribeMsg.textContent = '';
    subscribeMsg.className = 'subscribe-msg';
    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, source: 'homepage', _hp: '' }),
      });
      const data = await res.json();
      if (data.success) {
        subscribeMsg.textContent = data.already ? "You're already subscribed." : "You're in. Updates coming your way.";
        subscribeMsg.className = 'subscribe-msg success';
        subscribeEmail.value = '';
      } else {
        subscribeMsg.textContent = data.error || 'Something went wrong.';
        subscribeMsg.className = 'subscribe-msg error';
        subscribeBtn.disabled = false;
      }
    } catch {
      subscribeMsg.textContent = 'Network error. Please try again.';
      subscribeMsg.className = 'subscribe-msg error';
      subscribeBtn.disabled = false;
    }
  });

  document.querySelectorAll('.install-cmd').forEach((el) => {
    el.addEventListener('click', () => {
      navigator.clipboard.writeText(el.textContent!.trim());
      el.classList.add('copied');
      const hint = el.nextElementSibling as HTMLElement | null;
      const origHint = hint?.textContent;
      if (hint) hint.textContent = 'copied!';
      setTimeout(() => {
        el.classList.remove('copied');
        if (hint && origHint) hint.textContent = origHint;
      }, 1500);
    });
  });
</script>

---
export const prerender = false;

import Base from '../layouts/Base.astro';
import { toSkillSlug } from '../data/skills';
import { toSlug } from '../data/tools';

const { env } = Astro.locals.runtime;

const today = new Date().toISOString().slice(0, 10);
const d7 = new Date(today + 'T00:00:00Z');
d7.setUTCDate(d7.getUTCDate() - 7);
const prevDateCutoff = d7.toISOString().slice(0, 10);

interface MoverRow {
  identifier: string;
  name: string | null;
  current_rank: number;
  current_score: number;
  prev_rank: number;
  prev_score: number;
}

interface NewEntryRow {
  identifier: string;
  name: string | null;
  rank: number;
  score: number;
}

// Find the most recent snapshot date in rank_history
let todaySnapshotDate: string | null = null;
let comparisonDate: string | null = null;
let hasData = false;

try {
  const latestRow = await env.DB.prepare(
    `SELECT MAX(snapshot_date) as d FROM rank_history`
  ).first<{ d: string | null }>();

  todaySnapshotDate = latestRow?.d ?? null;

  if (todaySnapshotDate) {
    const prevRow = await env.DB.prepare(
      `SELECT MAX(snapshot_date) as d FROM rank_history WHERE snapshot_date <= ?`
    ).bind(prevDateCutoff).first<{ d: string | null }>();

    comparisonDate = prevRow?.d ?? null;
    hasData = !!comparisonDate;
  }
} catch {
  // rank_history not yet populated
}

const daysSpan = hasData && todaySnapshotDate && comparisonDate
  ? Math.round((new Date(todaySnapshotDate).getTime() - new Date(comparisonDate).getTime()) / (1000 * 60 * 60 * 24))
  : null;

async function fetchMovers(type: 'tool' | 'skill'): Promise<{ gainers: MoverRow[]; losers: MoverRow[]; new_entries: NewEntryRow[] }> {
  if (!hasData || !todaySnapshotDate || !comparisonDate) {
    return { gainers: [], losers: [], new_entries: [] };
  }

  const nameJoin = type === 'tool'
    ? `LEFT JOIN tools t ON t.full_name = cur.tool_full_name`
    : `LEFT JOIN skills s ON s.slug = cur.tool_full_name`;
  const nameCol = type === 'tool' ? `t.full_name` : `s.name`;

  const moversResult = await env.DB.prepare(
    `SELECT
       cur.tool_full_name AS identifier,
       ${nameCol} AS name,
       cur.rank AS current_rank,
       cur.score AS current_score,
       prev.rank AS prev_rank,
       prev.score AS prev_score
     FROM rank_history cur
     JOIN rank_history prev
       ON cur.tool_full_name = prev.tool_full_name
      AND cur.tool_type = prev.tool_type
      AND prev.snapshot_date = ?2
     ${nameJoin}
     WHERE cur.snapshot_date = ?1
       AND cur.tool_type = ?3
       AND ABS(cur.score - prev.score) >= 0.1
     ORDER BY ABS(cur.score - prev.score) DESC
     LIMIT 50`
  ).bind(todaySnapshotDate, comparisonDate, type).all();

  const rows = (moversResult.results || []) as MoverRow[];

  const gainers = rows
    .filter(r => r.current_score > r.prev_score)
    .map(r => ({ ...r, score_change: Math.round((r.current_score - r.prev_score) * 100) / 100, rank_change: r.prev_rank - r.current_rank }))
    .slice(0, 20);

  const losers = rows
    .filter(r => r.current_score < r.prev_score)
    .map(r => ({ ...r, score_change: Math.round((r.current_score - r.prev_score) * 100) / 100, rank_change: r.prev_rank - r.current_rank }))
    .slice(0, 20);

  // New entries: in today's snapshot but not any earlier snapshot
  const newResult = await env.DB.prepare(
    `SELECT
       cur.tool_full_name AS identifier,
       ${nameCol} AS name,
       cur.rank,
       cur.score
     FROM rank_history cur
     ${nameJoin}
     WHERE cur.snapshot_date = ?1
       AND cur.tool_type = ?2
       AND NOT EXISTS (
         SELECT 1 FROM rank_history old
         WHERE old.tool_full_name = cur.tool_full_name
           AND old.tool_type = cur.tool_type
           AND old.snapshot_date < ?1
       )
     ORDER BY cur.score DESC
     LIMIT 20`
  ).bind(todaySnapshotDate, type).all();

  const new_entries = (newResult.results || []) as NewEntryRow[];

  return { gainers, losers, new_entries };
}

const [toolMovers, skillMovers] = await Promise.all([
  fetchMovers('tool'),
  fetchMovers('skill'),
]);

interface MoverWithChange extends MoverRow {
  score_change: number;
  rank_change: number;
}
---

<Base
  title="AgentRank — Weekly Movers"
  description="See which MCP servers and AI agent tools are rising and falling in the AgentRank index this week. Track momentum in the agent tool ecosystem."
  keywords="MCP server trends, agent tool rankings, rising MCP servers, weekly movers, AI tools ranking changes"
  activeTab="movers"
  canonicalUrl="https://agentrank-ai.com/movers/"
>
  {!hasData ? (
    <div class="empty-state">
      <h2>Weekly Movers</h2>
      <p>Movers data will be available after the first week of tracking. Check back soon.</p>
    </div>
  ) : (
    <>
      <div class="header-info">
        <h2>Weekly Movers</h2>
        <span class="meta">vs {comparisonDate} ({daysSpan}d ago)</span>
      </div>

      <div class="tabs" id="mover-tabs">
        <button class="tab active" data-tab="skills">Skills</button>
        <button class="tab" data-tab="tools">Tools</button>
      </div>

      <div class="tab-content active" id="tab-skills">
        {skillMovers.gainers.length > 0 && (
          <>
            <h3 class="section-title">Top Gainers</h3>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Rank</th>
                    <th>Name</th>
                    <th>Score</th>
                    <th>Change</th>
                    <th>Rank Move</th>
                  </tr>
                </thead>
                <tbody>
                  {(skillMovers.gainers as unknown as MoverWithChange[]).map((m) => (
                    <tr>
                      <td class="rank">{m.current_rank}</td>
                      <td class="name"><a href={`/skill/${toSkillSlug(m.identifier)}/`}>{m.name || m.identifier}</a></td>
                      <td class="score">{m.current_score.toFixed(1)}</td>
                      <td class="change positive">+{m.score_change.toFixed(2)}</td>
                      <td class="rank-move">{m.rank_change > 0 ? `+${m.rank_change}` : m.rank_change === 0 ? '—' : String(m.rank_change)}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </>
        )}

        {skillMovers.losers.length > 0 && (
          <>
            <h3 class="section-title">Top Losers</h3>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Rank</th>
                    <th>Name</th>
                    <th>Score</th>
                    <th>Change</th>
                    <th>Rank Move</th>
                  </tr>
                </thead>
                <tbody>
                  {(skillMovers.losers as unknown as MoverWithChange[]).map((m) => (
                    <tr>
                      <td class="rank">{m.current_rank}</td>
                      <td class="name"><a href={`/skill/${toSkillSlug(m.identifier)}/`}>{m.name || m.identifier}</a></td>
                      <td class="score">{m.current_score.toFixed(1)}</td>
                      <td class="change negative">{m.score_change.toFixed(2)}</td>
                      <td class="rank-move">{m.rank_change > 0 ? `+${m.rank_change}` : m.rank_change === 0 ? '—' : String(m.rank_change)}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </>
        )}

        {skillMovers.new_entries.length > 0 && (
          <>
            <h3 class="section-title">New This Week</h3>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Rank</th>
                    <th>Name</th>
                    <th>Score</th>
                  </tr>
                </thead>
                <tbody>
                  {skillMovers.new_entries.map((e) => (
                    <tr>
                      <td class="rank">{e.rank}</td>
                      <td class="name"><a href={`/skill/${toSkillSlug(e.identifier)}/`}>{e.name || e.identifier}</a></td>
                      <td class="score">{e.score.toFixed(1)}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </>
        )}

        {skillMovers.gainers.length === 0 && skillMovers.losers.length === 0 && skillMovers.new_entries.length === 0 && (
          <p class="no-data">No skill score changes this week.</p>
        )}
      </div>

      <div class="tab-content" id="tab-tools">
        {toolMovers.gainers.length > 0 && (
          <>
            <h3 class="section-title">Top Gainers</h3>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Rank</th>
                    <th>Name</th>
                    <th>Score</th>
                    <th>Change</th>
                    <th>Rank Move</th>
                  </tr>
                </thead>
                <tbody>
                  {(toolMovers.gainers as unknown as MoverWithChange[]).map((m) => (
                    <tr>
                      <td class="rank">{m.current_rank}</td>
                      <td class="name"><a href={`/tool/${toSlug(m.identifier)}/`}>{m.name || m.identifier}</a></td>
                      <td class="score">{m.current_score.toFixed(1)}</td>
                      <td class="change positive">+{m.score_change.toFixed(2)}</td>
                      <td class="rank-move">{m.rank_change > 0 ? `+${m.rank_change}` : m.rank_change === 0 ? '—' : String(m.rank_change)}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </>
        )}

        {toolMovers.losers.length > 0 && (
          <>
            <h3 class="section-title">Top Losers</h3>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Rank</th>
                    <th>Name</th>
                    <th>Score</th>
                    <th>Change</th>
                    <th>Rank Move</th>
                  </tr>
                </thead>
                <tbody>
                  {(toolMovers.losers as unknown as MoverWithChange[]).map((m) => (
                    <tr>
                      <td class="rank">{m.current_rank}</td>
                      <td class="name"><a href={`/tool/${toSlug(m.identifier)}/`}>{m.name || m.identifier}</a></td>
                      <td class="score">{m.current_score.toFixed(1)}</td>
                      <td class="change negative">{m.score_change.toFixed(2)}</td>
                      <td class="rank-move">{m.rank_change > 0 ? `+${m.rank_change}` : m.rank_change === 0 ? '—' : String(m.rank_change)}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </>
        )}

        {toolMovers.new_entries.length > 0 && (
          <>
            <h3 class="section-title">New This Week</h3>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Rank</th>
                    <th>Name</th>
                    <th>Score</th>
                  </tr>
                </thead>
                <tbody>
                  {toolMovers.new_entries.map((e) => (
                    <tr>
                      <td class="rank">{e.rank}</td>
                      <td class="name"><a href={`/tool/${toSlug(e.identifier)}/`}>{e.name || e.identifier}</a></td>
                      <td class="score">{e.score.toFixed(1)}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </>
        )}

        {toolMovers.gainers.length === 0 && toolMovers.losers.length === 0 && toolMovers.new_entries.length === 0 && (
          <p class="no-data">No tool score changes this week.</p>
        )}
      </div>
    </>
  )}
</Base>

<style>
  .empty-state {
    text-align: center;
    padding: 3rem 1rem;
  }

  .empty-state h2 {
    margin-bottom: 0.75rem;
  }

  .empty-state p {
    color: var(--text-muted);
  }

  .header-info {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .header-info h2 {
    font-size: 1.1rem;
  }

  .meta {
    color: var(--text-muted);
    font-size: 0.8rem;
  }

  .tabs {
    display: flex;
    gap: 0.25rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .tab {
    background: none;
    border: none;
    color: var(--text-muted);
    font-family: inherit;
    font-size: 0.85rem;
    padding: 0.4rem 0.75rem;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
  }

  .tab:hover {
    color: var(--text);
  }

  .tab.active {
    color: var(--accent);
    font-weight: 700;
    border-bottom-color: var(--accent);
  }

  .tab-content {
    display: none;
  }

  .tab-content.active {
    display: block;
  }

  .section-title {
    font-size: 0.9rem;
    margin: 1.5rem 0 0.5rem;
    color: var(--text-muted);
  }

  .section-title:first-child {
    margin-top: 0;
  }

  .table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
    margin-bottom: 1rem;
  }

  th {
    background: var(--bg-surface);
    border-bottom: 2px solid var(--border);
    padding: 0.5rem 0.75rem;
    text-align: left;
    font-weight: 600;
    white-space: nowrap;
    color: var(--text-muted);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  td {
    padding: 0.4rem 0.75rem;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }

  tr:hover td {
    background: var(--bg-hover);
  }

  .rank {
    color: var(--text-muted);
    width: 3rem;
  }

  .name a {
    color: var(--text);
    font-weight: 500;
  }

  .name a:hover {
    color: var(--accent);
  }

  .change.positive {
    color: #22c55e;
    font-weight: 600;
  }

  .change.negative {
    color: #ef4444;
    font-weight: 600;
  }

  .rank-move {
    color: var(--text-muted);
  }

  .no-data {
    color: var(--text-muted);
    padding: 2rem 0;
    text-align: center;
  }
</style>

<script>
  const tabs = document.querySelectorAll('.tab');
  const contents = document.querySelectorAll('.tab-content');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = (tab as HTMLElement).dataset.tab!;
      tabs.forEach((t) => t.classList.remove('active'));
      contents.forEach((c) => c.classList.remove('active'));
      tab.classList.add('active');
      document.getElementById(`tab-${target}`)!.classList.add('active');
    });
  });
</script>

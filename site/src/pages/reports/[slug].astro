---
export const prerender = false;

import Base from '../../layouts/Base.astro';

interface WeeklyReport {
  id: string;
  week_start: string;
  week_end: string;
  week_number: number;
  year: number;
  total_tools: number;
  new_tools_count: number;
  top_10: string;
  biggest_movers: string;
  new_tools: string;
  notable_releases: string;
  category_stats: string;
  generated_at: string;
}

interface TopTool {
  full_name: string;
  rank: number;
  score: number;
  stars: number;
  category?: string | null;
}

interface Mover {
  full_name: string;
  tool_type: string;
  current_rank: number;
  prev_rank: number;
  rank_delta: number;
  current_score: number;
  stars?: number;
}

interface NewTool {
  full_name: string;
  tool_type: string;
  rank: number;
  score: number;
  stars: number;
}

interface Release {
  title: string;
  summary: string | null;
  source_url: string;
  related_tool_slugs: string | null;
  published_at: string;
}

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/reports/');

const { env } = Astro.locals.runtime;
const row = await env.DB.prepare(
  'SELECT * FROM weekly_reports WHERE id = ?'
).bind(slug).first<WeeklyReport>();

if (!row) {
  return Astro.redirect('/reports/');
}

function parseJson<T>(s: string | null | undefined, fallback: T): T {
  try { return s ? JSON.parse(s) : fallback; } catch { return fallback; }
}

const top10: TopTool[] = parseJson(row.top_10, []);
const movers: Mover[] = parseJson(row.biggest_movers, []);
const newTools: NewTool[] = parseJson(row.new_tools, []);
const releases: Release[] = parseJson(row.notable_releases, []);
const categoryStats: Record<string, number> = parseJson(row.category_stats, {});

const gainers = movers.filter(m => m.rank_delta > 0);
const losers = movers.filter(m => m.rank_delta < 0);

function formatDate(iso: string): string {
  return new Date(iso + (iso.length === 10 ? 'T00:00:00Z' : '')).toLocaleDateString('en-US', {
    month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC',
  });
}

function shortName(full: string): string {
  return full.split('/').pop() ?? full;
}

function repoSlug(full: string): string {
  return full.replace('/', '--');
}

const title = `Week ${row.week_number}, ${row.year} — AgentRank Ecosystem Report`;
const description = `AgentRank weekly report for ${formatDate(row.week_start)} – ${formatDate(row.week_end)}. ${row.new_tools_count} new tools, ${movers.length} movers, top 10 snapshot.`;
const canonicalUrl = `https://agentrank-ai.com/reports/${row.id}/`;

// Get adjacent reports for prev/next navigation
const adjacent = await env.DB.prepare(
  `SELECT id, week_start, week_number, year FROM weekly_reports
   WHERE id != ?
   ORDER BY week_start DESC LIMIT 10`
).bind(row.id).all<{ id: string; week_start: string; week_number: number; year: number }>();

const allReports = adjacent.results ?? [];
const currentIdx = -1; // we just need prev/next relative to current week_start

const prevReport = allReports.find(r => r.week_start < row.week_start) ?? null;
const nextReport = [...allReports].reverse().find(r => r.week_start > row.week_start) ?? null;

const sortedCategories = Object.entries(categoryStats)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 10);
---

<Base
  title={title}
  description={description}
  keywords={`MCP ecosystem report, agent tools week ${row.week_number}, ${row.year}, AgentRank weekly`}
  activeTab="news"
  canonicalUrl={canonicalUrl}
>
  <div class="report-page">
    <div class="report-header">
      <div class="report-breadcrumb">
        <a href="/reports/">Weekly Reports</a>
        <span class="sep">/</span>
        <span>Week {row.week_number}, {row.year}</span>
      </div>
      <h1 class="report-title">MCP Ecosystem Report</h1>
      <div class="report-meta">
        <span class="report-dates">{formatDate(row.week_start)} – {formatDate(row.week_end)}</span>
        <span class="report-badge">Week {row.week_number}</span>
      </div>
      <div class="report-stats-row">
        <div class="report-stat">
          <span class="stat-num">{row.total_tools.toLocaleString('en-US')}</span>
          <span class="stat-label">tools indexed</span>
        </div>
        <div class="report-stat">
          <span class="stat-num">{row.new_tools_count}</span>
          <span class="stat-label">new this week</span>
        </div>
        <div class="report-stat">
          <span class="stat-num">{gainers.length}</span>
          <span class="stat-label">big gainers</span>
        </div>
        <div class="report-stat">
          <span class="stat-num">{releases.length}</span>
          <span class="stat-label">notable releases</span>
        </div>
      </div>
    </div>

    <div class="report-body">

      <!-- Top 10 -->
      {top10.length > 0 && (
        <section class="report-section">
          <h2 class="section-title">Top 10 This Week</h2>
          <p class="section-sub">Current leaderboard snapshot — scored nightly from GitHub signals.</p>
          <table class="report-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Tool</th>
                <th class="ta-right">Score</th>
                <th class="ta-right">Stars</th>
                <th class="hide-sm">Category</th>
              </tr>
            </thead>
            <tbody>
              {top10.map(t => (
                <tr>
                  <td class="rank-cell">#{t.rank}</td>
                  <td>
                    <a href={`/tool/${repoSlug(t.full_name)}/`} class="tool-link">{shortName(t.full_name)}</a>
                    <span class="org-label">/{t.full_name.split('/')[0]}</span>
                  </td>
                  <td class="ta-right score-cell">{t.score.toFixed(1)}</td>
                  <td class="ta-right stars-cell">&#9733; {t.stars.toLocaleString('en-US')}</td>
                  <td class="hide-sm cat-cell">{t.category ?? '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
          <a href="/tools/" class="section-cta">View full leaderboard &rarr;</a>
        </section>
      )}

      <!-- Biggest Movers -->
      {movers.length > 0 && (
        <section class="report-section">
          <h2 class="section-title">Biggest Movers</h2>
          <p class="section-sub">Largest rank changes over the past 7 days.</p>
          <div class="movers-grid">
            {gainers.length > 0 && (
              <div class="movers-col">
                <h3 class="movers-heading movers-up">Gainers</h3>
                {gainers.map(m => (
                  <div class="mover-row">
                    <a href={`/tool/${repoSlug(m.full_name)}/`} class="tool-link">{shortName(m.full_name)}</a>
                    <span class="mover-delta mover-up">+{m.rank_delta} <span class="mover-ranks">(#{m.prev_rank} &rarr; #{m.current_rank})</span></span>
                  </div>
                ))}
              </div>
            )}
            {losers.length > 0 && (
              <div class="movers-col">
                <h3 class="movers-heading movers-down">Losers</h3>
                {losers.map(m => (
                  <div class="mover-row">
                    <a href={`/tool/${repoSlug(m.full_name)}/`} class="tool-link">{shortName(m.full_name)}</a>
                    <span class="mover-delta mover-down">{m.rank_delta} <span class="mover-ranks">(#{m.prev_rank} &rarr; #{m.current_rank})</span></span>
                  </div>
                ))}
              </div>
            )}
          </div>
        </section>
      )}

      <!-- New Tools -->
      {newTools.length > 0 && (
        <section class="report-section">
          <h2 class="section-title">New in the Index</h2>
          <p class="section-sub">{newTools.length} tool{newTools.length !== 1 ? 's' : ''} entered the AgentRank index this week for the first time.</p>
          <div class="new-tools-grid">
            {newTools.slice(0, 12).map(t => (
              <a href={`/tool/${repoSlug(t.full_name)}/`} class="new-tool-card">
                <span class="ntc-name">{shortName(t.full_name)}</span>
                <span class="ntc-org">{t.full_name.split('/')[0]}</span>
                <span class="ntc-meta">
                  <span class="ntc-score">{t.score.toFixed(1)}</span>
                  <span class="ntc-sep">·</span>
                  <span class="ntc-stars">&#9733; {t.stars.toLocaleString('en-US')}</span>
                </span>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Notable Releases -->
      {releases.length > 0 && (
        <section class="report-section">
          <h2 class="section-title">Notable Releases</h2>
          <p class="section-sub">Significant new versions shipped this week.</p>
          <div class="releases-list">
            {releases.map(r => (
              <div class="release-item">
                <a href={r.source_url} target="_blank" rel="noopener noreferrer" class="release-title">{r.title}</a>
                {r.summary && <p class="release-summary">{r.summary.slice(0, 200)}{r.summary.length > 200 ? '…' : ''}</p>}
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Category Stats -->
      {sortedCategories.length > 0 && (
        <section class="report-section">
          <h2 class="section-title">Index by Category</h2>
          <p class="section-sub">Tool distribution across categories this week.</p>
          <div class="category-bars">
            {(() => {
              const max = sortedCategories[0]?.[1] ?? 1;
              return sortedCategories.map(([cat, count]) => (
                <div class="cat-bar-row">
                  <a href={`/category/${cat}/`} class="cat-name">{cat}</a>
                  <div class="cat-bar-wrap">
                    <div class="cat-bar-fill" style={`width:${Math.round((count / max) * 100)}%`}></div>
                  </div>
                  <span class="cat-count">{count.toLocaleString('en-US')}</span>
                </div>
              ));
            })()}
          </div>
        </section>
      )}

      <!-- Navigation -->
      <nav class="report-nav">
        {prevReport ? (
          <a href={`/reports/${prevReport.id}/`} class="nav-link nav-prev">
            &larr; Week {prevReport.week_number}, {prevReport.year}
          </a>
        ) : <span></span>}
        {nextReport ? (
          <a href={`/reports/${nextReport.id}/`} class="nav-link nav-next">
            Week {nextReport.week_number}, {nextReport.year} &rarr;
          </a>
        ) : <span></span>}
      </nav>

      <p class="report-footer-note">
        Report auto-generated by AgentRank on {new Date(row.generated_at).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' })}.
        Data sourced from GitHub via the nightly crawler. <a href="/methodology/">Scoring methodology</a>.
      </p>

    </div>
  </div>
</Base>

<style>
.report-page {
  max-width: 820px;
  margin: 0 auto;
  padding: 32px 16px 64px;
}

.report-header {
  margin-bottom: 40px;
  padding-bottom: 32px;
  border-bottom: 1px solid #1f2937;
}

.report-breadcrumb {
  font-size: 13px;
  color: #6b7280;
  margin-bottom: 16px;
}
.report-breadcrumb a { color: #818cf8; text-decoration: none; }
.report-breadcrumb a:hover { text-decoration: underline; }
.report-breadcrumb .sep { margin: 0 6px; }

.report-title {
  font-size: 28px;
  font-weight: 700;
  color: #f9fafb;
  margin: 0 0 8px;
}

.report-meta {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 24px;
}

.report-dates {
  font-size: 14px;
  color: #9ca3af;
}

.report-badge {
  font-size: 11px;
  font-weight: 600;
  background: #312e81;
  color: #a5b4fc;
  padding: 2px 8px;
  border-radius: 12px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.report-stats-row {
  display: flex;
  gap: 32px;
  flex-wrap: wrap;
}

.report-stat {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.stat-num {
  font-size: 24px;
  font-weight: 700;
  color: #e5e7eb;
  font-variant-numeric: tabular-nums;
}

.stat-label {
  font-size: 12px;
  color: #6b7280;
  text-transform: uppercase;
  letter-spacing: 0.4px;
}

.report-section {
  margin-bottom: 48px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #f9fafb;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin: 0 0 4px;
}

.section-sub {
  font-size: 13px;
  color: #6b7280;
  margin: 0 0 20px;
}

/* Table */
.report-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 14px;
}

.report-table th {
  text-align: left;
  font-size: 11px;
  color: #4b5563;
  padding: 0 0 8px;
  border-bottom: 1px solid #1f2937;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.4px;
}

.report-table th.ta-right { text-align: right; }

.report-table td {
  padding: 10px 0;
  border-bottom: 1px solid #111827;
  color: #e5e7eb;
  vertical-align: middle;
}

.report-table td.ta-right { text-align: right; }

.rank-cell { color: #6b7280; font-size: 13px; padding-right: 12px; white-space: nowrap; }

.tool-link { color: #818cf8; text-decoration: none; font-weight: 600; }
.tool-link:hover { text-decoration: underline; }

.org-label { color: #4b5563; font-size: 12px; margin-left: 2px; }

.score-cell { color: #e5e7eb; font-variant-numeric: tabular-nums; }
.stars-cell { color: #9ca3af; font-size: 13px; font-variant-numeric: tabular-nums; }
.cat-cell { color: #6b7280; font-size: 12px; }

@media (max-width: 600px) {
  .hide-sm { display: none; }
}

.section-cta {
  display: inline-block;
  margin-top: 16px;
  font-size: 13px;
  color: #818cf8;
  text-decoration: none;
}
.section-cta:hover { text-decoration: underline; }

/* Movers */
.movers-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
}
@media (max-width: 560px) {
  .movers-grid { grid-template-columns: 1fr; }
}

.movers-heading {
  font-size: 12px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin: 0 0 12px;
}
.movers-up { color: #22c55e; }
.movers-down { color: #f87171; }

.mover-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 8px;
  padding: 8px 0;
  border-bottom: 1px solid #111827;
  font-size: 14px;
}

.mover-delta {
  white-space: nowrap;
  font-weight: 600;
  font-size: 13px;
  font-variant-numeric: tabular-nums;
}
.mover-up { color: #22c55e; }
.mover-down { color: #f87171; }
.mover-ranks { color: #6b7280; font-weight: 400; font-size: 12px; }

/* New Tools */
.new-tools-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 12px;
}

.new-tool-card {
  display: flex;
  flex-direction: column;
  gap: 2px;
  background: #111827;
  border: 1px solid #1f2937;
  border-radius: 8px;
  padding: 12px 14px;
  text-decoration: none;
  transition: border-color 0.15s;
}
.new-tool-card:hover { border-color: #6366f1; }

.ntc-name { font-size: 14px; font-weight: 600; color: #818cf8; }
.ntc-org { font-size: 11px; color: #4b5563; }
.ntc-meta { font-size: 12px; color: #6b7280; margin-top: 4px; }
.ntc-score { color: #9ca3af; }
.ntc-sep { margin: 0 4px; }
.ntc-stars { color: #9ca3af; }

/* Releases */
.releases-list { display: flex; flex-direction: column; gap: 16px; }

.release-item {
  padding: 14px 0;
  border-bottom: 1px solid #111827;
}

.release-title {
  font-size: 14px;
  font-weight: 600;
  color: #818cf8;
  text-decoration: none;
  line-height: 1.4;
}
.release-title:hover { text-decoration: underline; }

.release-summary {
  font-size: 13px;
  color: #6b7280;
  margin: 6px 0 0;
  line-height: 1.5;
}

/* Category bars */
.category-bars { display: flex; flex-direction: column; gap: 10px; }

.cat-bar-row {
  display: grid;
  grid-template-columns: 140px 1fr 60px;
  align-items: center;
  gap: 12px;
  font-size: 13px;
}

.cat-name { color: #818cf8; text-decoration: none; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.cat-name:hover { text-decoration: underline; }

.cat-bar-wrap {
  background: #111827;
  border-radius: 3px;
  height: 6px;
  overflow: hidden;
}

.cat-bar-fill {
  height: 100%;
  background: #4f46e5;
  border-radius: 3px;
  min-width: 2px;
}

.cat-count { color: #6b7280; text-align: right; font-variant-numeric: tabular-nums; }

/* Navigation */
.report-nav {
  display: flex;
  justify-content: space-between;
  padding: 24px 0;
  border-top: 1px solid #1f2937;
  margin-top: 8px;
}

.nav-link {
  font-size: 13px;
  color: #818cf8;
  text-decoration: none;
}
.nav-link:hover { text-decoration: underline; }

.report-footer-note {
  font-size: 12px;
  color: #4b5563;
  line-height: 1.6;
  margin-top: 16px;
}
.report-footer-note a { color: #6b7280; text-decoration: underline; }
</style>

---
export const prerender = false;
import Base from '../../layouts/Base.astro';

const { env } = (Astro.locals as any).runtime;
const token = Astro.url.searchParams.get('token') || '';

let metrics: any = null;
let error: string | null = null;

if (!env.DASH_TOKEN) {
  error = 'DASH_TOKEN not configured.';
} else if (!token || token !== env.DASH_TOKEN) {
  error = 'Unauthorized. Add ?token=YOUR_DASH_TOKEN to the URL.';
} else {
  try {
    const db = env.DB;

    function totalsQuery(window: string) {
      return db.prepare(`
        SELECT
          SUM(CASE WHEN type='page' THEN 1 ELSE 0 END) AS page_visits,
          SUM(CASE WHEN type='api' THEN 1 ELSE 0 END) AS api_calls,
          SUM(CASE WHEN type='mcp' THEN 1 ELSE 0 END) AS mcp_calls,
          COUNT(*) AS total,
          SUM(CASE WHEN is_bot = 0 AND type='page' THEN 1 ELSE 0 END) AS human_page_visits,
          SUM(CASE WHEN is_bot = 0 AND type='api' THEN 1 ELSE 0 END) AS human_api_calls,
          SUM(CASE WHEN is_bot = 0 AND type='mcp' THEN 1 ELSE 0 END) AS human_mcp_calls,
          SUM(CASE WHEN is_bot = 0 THEN 1 ELSE 0 END) AS human_total,
          SUM(CASE WHEN is_bot = 1 THEN 1 ELSE 0 END) AS bot_total
        FROM request_log WHERE ts > datetime('now', '${window}')
      `).first();
    }

    const [
      totals24h,
      totals7d,
      totals30d,
      errorRates24h,
      topEndpoints30d,
      topReferrers30d,
      skillInstalls,
      dailyTraffic30d,
      emailSubscribers,
      apiKeysSummary,
      apiKeysActive,
      topPages30d,
      utmSources30d,
    ] = await Promise.all([
      totalsQuery('-1 day'),
      totalsQuery('-7 days'),
      totalsQuery('-30 days'),
      db.prepare(`
        SELECT path, COUNT(*) AS errors
        FROM request_log
        WHERE ts > datetime('now', '-1 day') AND status >= 400
        GROUP BY path ORDER BY errors DESC LIMIT 15
      `).all(),
      db.prepare(`
        SELECT path, COUNT(*) AS calls, ROUND(AVG(duration_ms), 0) AS avg_ms
        FROM request_log
        WHERE ts > datetime('now', '-30 days') AND type IN ('api', 'mcp') AND is_bot = 0
        GROUP BY path ORDER BY calls DESC LIMIT 15
      `).all(),
      db.prepare(`
        SELECT referrer, COUNT(*) AS visits
        FROM request_log
        WHERE ts > datetime('now', '-30 days')
          AND type = 'page'
          AND is_bot = 0
          AND referrer IS NOT NULL AND referrer != ''
          AND referrer NOT LIKE '%agentrank-ai.com%'
        GROUP BY referrer ORDER BY visits DESC LIMIT 15
      `).all(),
      db.prepare(`
        SELECT slug, COUNT(*) AS pings, COUNT(DISTINCT ip_hash) AS unique_installs
        FROM skill_pings
        WHERE ts > datetime('now', '-30 days')
        GROUP BY slug ORDER BY unique_installs DESC
      `).all().catch(() => ({ results: [] })),
      db.prepare(`
        SELECT date(ts) AS day,
          SUM(CASE WHEN type='page' THEN 1 ELSE 0 END) AS page_visits,
          SUM(CASE WHEN type='api' THEN 1 ELSE 0 END) AS api_calls,
          SUM(CASE WHEN type='mcp' THEN 1 ELSE 0 END) AS mcp_calls,
          COUNT(*) AS total,
          SUM(CASE WHEN is_bot = 0 AND type='page' THEN 1 ELSE 0 END) AS human_page_visits,
          SUM(CASE WHEN is_bot = 0 THEN 1 ELSE 0 END) AS human_total,
          SUM(CASE WHEN is_bot = 1 THEN 1 ELSE 0 END) AS bot_total
        FROM request_log WHERE ts > datetime('now', '-30 days')
        GROUP BY day ORDER BY day ASC
      `).all(),
      db.prepare(`SELECT COUNT(*) AS total FROM email_subscribers`).first(),
      // API keys by tier
      db.prepare(`
        SELECT
          COUNT(*) AS total_keys,
          SUM(CASE WHEN tier='free' THEN 1 ELSE 0 END) AS free_keys,
          SUM(CASE WHEN tier='pro' THEN 1 ELSE 0 END) AS pro_keys,
          SUM(CASE WHEN tier='enterprise' THEN 1 ELSE 0 END) AS enterprise_keys
        FROM api_keys WHERE is_active = 1
      `).first().catch(() => null),
      // Active keys in different windows (from api_usage)
      Promise.all([
        db.prepare(`SELECT COUNT(DISTINCT api_key_id) AS n FROM api_usage WHERE date >= date('now', '-1 day')`).first().catch(() => ({ n: 0 })),
        db.prepare(`SELECT COUNT(DISTINCT api_key_id) AS n FROM api_usage WHERE date >= date('now', '-7 days')`).first().catch(() => ({ n: 0 })),
        db.prepare(`SELECT COUNT(DISTINCT api_key_id) AS n FROM api_usage WHERE date >= date('now', '-30 days')`).first().catch(() => ({ n: 0 })),
      ]),
      // Top page paths (30d, human only)
      db.prepare(`
        SELECT path, COUNT(*) AS views
        FROM request_log
        WHERE ts > datetime('now', '-30 days') AND type = 'page' AND is_bot = 0
        GROUP BY path ORDER BY views DESC LIMIT 15
      `).all(),
      // UTM sources (30d)
      db.prepare(`
        SELECT utm_source, COUNT(*) AS visits
        FROM request_log
        WHERE ts > datetime('now', '-30 days')
          AND utm_source IS NOT NULL AND utm_source != ''
        GROUP BY utm_source ORDER BY visits DESC LIMIT 15
      `).all(),
    ]);

    metrics = {
      totals24h,
      totals7d,
      totals30d,
      errorRates24h: errorRates24h.results,
      topEndpoints30d: topEndpoints30d.results,
      topReferrers30d: topReferrers30d.results,
      skillInstalls: skillInstalls.results,
      dailyTraffic30d: dailyTraffic30d.results,
      emailSubscribers: emailSubscribers?.total ?? 0,
      apiKeysSummary,
      apiKeysActive: {
        last24h: (apiKeysActive[0] as any)?.n ?? 0,
        last7d: (apiKeysActive[1] as any)?.n ?? 0,
        last30d: (apiKeysActive[2] as any)?.n ?? 0,
      },
      topPages30d: topPages30d.results,
      utmSources30d: utmSources30d.results,
    };
  } catch (e: any) {
    error = e.message;
  }
}

function fmtNum(n: any) {
  return n != null ? Number(n).toLocaleString() : '—';
}
---

<Base title="Admin Dashboard — AgentRank" noindex={true}>
  <style>
    .dash-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 1rem;
      margin-bottom: 2rem;
    }
    .stat-card {
      background: var(--bg-surface);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 1rem;
    }
    .stat-card .label {
      font-size: 0.75rem;
      color: var(--text-muted);
      margin-bottom: 0.25rem;
    }
    .stat-card .value {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--accent);
    }
    .stat-card .sub {
      font-size: 0.72rem;
      color: var(--text-muted);
      margin-top: 0.25rem;
    }
    section {
      margin-bottom: 2.5rem;
    }
    h2 {
      font-size: 1rem;
      font-weight: 600;
      margin-bottom: 0.75rem;
      border-bottom: 1px solid var(--border);
      padding-bottom: 0.4rem;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.82rem;
    }
    th {
      text-align: left;
      padding: 0.4rem 0.6rem;
      color: var(--text-muted);
      font-weight: 500;
      border-bottom: 1px solid var(--border);
    }
    td {
      padding: 0.4rem 0.6rem;
      border-bottom: 1px solid var(--border);
      word-break: break-all;
    }
    tr:last-child td { border-bottom: none; }
    .error-box {
      background: #2a1212;
      border: 1px solid #7f1d1d;
      border-radius: 6px;
      padding: 1.25rem;
      color: #fca5a5;
      margin-bottom: 1.5rem;
    }
    .chart-bar-row { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.35rem; }
    .chart-bar-label { width: 80px; font-size: 0.75rem; color: var(--text-muted); text-align: right; flex-shrink: 0; }
    .chart-bar-track { flex: 1; height: 12px; background: var(--bg-surface); border-radius: 3px; overflow: hidden; }
    .chart-bar-fill { height: 100%; background: var(--accent); border-radius: 3px; transition: width 0.3s; }
    .chart-bar-val { font-size: 0.72rem; color: var(--text-muted); width: 40px; text-align: right; flex-shrink: 0; }
    .page-header { margin-bottom: 1.5rem; }
    .page-header h1 { font-size: 1.1rem; font-weight: 700; }
    .page-header p { color: var(--text-muted); font-size: 0.82rem; margin-top: 0.25rem; }
    .bot-toggle-bar {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1.5rem;
      padding: 0.6rem 0.9rem;
      background: var(--bg-surface);
      border: 1px solid var(--border);
      border-radius: 6px;
      font-size: 0.82rem;
    }
    .bot-toggle-bar .mode-label {
      font-weight: 600;
    }
    #bot-toggle-btn {
      background: var(--bg-surface);
      border: 1px solid var(--border);
      color: var(--text-muted);
      border-radius: 4px;
      padding: 0.3rem 0.65rem;
      font-size: 0.78rem;
      cursor: pointer;
      transition: border-color 0.15s, color 0.15s;
    }
    #bot-toggle-btn:hover {
      border-color: var(--accent);
      color: var(--accent);
    }
    .bot-count-badge {
      font-size: 0.72rem;
      color: var(--text-muted);
      margin-left: auto;
    }
  </style>

  <div class="page-header">
    <h1>Admin Dashboard</h1>
    <p>Request metrics, referral sources, and skill installs. Updated on page load.</p>
  </div>

  {error && (
    <div class="error-box">{error}</div>
  )}

  {metrics && (
    <>
      <!-- Bot/Human toggle -->
      <div class="bot-toggle-bar">
        <span class="mode-label" id="mode-label">Human traffic only</span>
        <button id="bot-toggle-btn">Show all (incl. bots)</button>
        <span class="bot-count-badge" id="bot-badge">
          Bots (30d): {fmtNum(metrics.totals30d?.bot_total ?? 0)} &middot;
          Humans (30d): {fmtNum(metrics.totals30d?.human_total ?? 0)}
        </span>
      </div>

      <!-- Summary Stats -->
      <section>
        <h2>Traffic Overview</h2>
        <div class="dash-grid">
          <div class="stat-card">
            <div class="label">Requests (24h)</div>
            <div class="value"
              data-human={fmtNum(metrics.totals24h?.human_total)}
              data-all={fmtNum(metrics.totals24h?.total)}
            >{fmtNum(metrics.totals24h?.human_total)}</div>
            <div class="sub"
              data-human={`${fmtNum(metrics.totals24h?.human_page_visits)} pages · ${fmtNum(metrics.totals24h?.human_api_calls)} API · ${fmtNum(metrics.totals24h?.human_mcp_calls)} MCP`}
              data-all={`${fmtNum(metrics.totals24h?.page_visits)} pages · ${fmtNum(metrics.totals24h?.api_calls)} API · ${fmtNum(metrics.totals24h?.mcp_calls)} MCP`}
            >{`${fmtNum(metrics.totals24h?.human_page_visits)} pages · ${fmtNum(metrics.totals24h?.human_api_calls)} API · ${fmtNum(metrics.totals24h?.human_mcp_calls)} MCP`}</div>
          </div>
          <div class="stat-card">
            <div class="label">Requests (7d)</div>
            <div class="value"
              data-human={fmtNum(metrics.totals7d?.human_total)}
              data-all={fmtNum(metrics.totals7d?.total)}
            >{fmtNum(metrics.totals7d?.human_total)}</div>
            <div class="sub"
              data-human={`${fmtNum(metrics.totals7d?.human_page_visits)} pages · ${fmtNum(metrics.totals7d?.human_api_calls)} API · ${fmtNum(metrics.totals7d?.human_mcp_calls)} MCP`}
              data-all={`${fmtNum(metrics.totals7d?.page_visits)} pages · ${fmtNum(metrics.totals7d?.api_calls)} API · ${fmtNum(metrics.totals7d?.mcp_calls)} MCP`}
            >{`${fmtNum(metrics.totals7d?.human_page_visits)} pages · ${fmtNum(metrics.totals7d?.human_api_calls)} API · ${fmtNum(metrics.totals7d?.human_mcp_calls)} MCP`}</div>
          </div>
          <div class="stat-card">
            <div class="label">Requests (30d)</div>
            <div class="value"
              data-human={fmtNum(metrics.totals30d?.human_total)}
              data-all={fmtNum(metrics.totals30d?.total)}
            >{fmtNum(metrics.totals30d?.human_total)}</div>
            <div class="sub"
              data-human={`${fmtNum(metrics.totals30d?.human_page_visits)} pages · ${fmtNum(metrics.totals30d?.human_api_calls)} API · ${fmtNum(metrics.totals30d?.human_mcp_calls)} MCP`}
              data-all={`${fmtNum(metrics.totals30d?.page_visits)} pages · ${fmtNum(metrics.totals30d?.api_calls)} API · ${fmtNum(metrics.totals30d?.mcp_calls)} MCP`}
            >{`${fmtNum(metrics.totals30d?.human_page_visits)} pages · ${fmtNum(metrics.totals30d?.human_api_calls)} API · ${fmtNum(metrics.totals30d?.human_mcp_calls)} MCP`}</div>
          </div>
          <div class="stat-card">
            <div class="label">Email subscribers</div>
            <div class="value">{fmtNum(metrics.emailSubscribers)}</div>
            <div class="sub">all time</div>
          </div>
          <div class="stat-card">
            <div class="label">Skill installs (30d)</div>
            <div class="value">
              {fmtNum(metrics.skillInstalls?.reduce((s: number, r: any) => s + (r.unique_installs || 0), 0))}
            </div>
            <div class="sub">unique IPs across all slugs</div>
          </div>
        </div>
      </section>

      <!-- Daily Traffic Chart -->
      {metrics.dailyTraffic30d?.length > 0 && (
        <section>
          <h2>Daily Traffic (30d)</h2>
          {(() => {
            const maxHuman = Math.max(...metrics.dailyTraffic30d.map((r: any) => r.human_total || 0), 1);
            const maxAll = Math.max(...metrics.dailyTraffic30d.map((r: any) => r.total || 0), 1);
            return (
              <div id="daily-chart">
                {metrics.dailyTraffic30d.map((r: any) => {
                  const humanPct = Math.round(((r.human_total || 0) / maxHuman) * 100);
                  const allPct = Math.round(((r.total || 0) / maxAll) * 100);
                  return (
                    <div class="chart-bar-row">
                      <span class="chart-bar-label">{String(r.day).slice(5)}</span>
                      <div class="chart-bar-track">
                        <div class="chart-bar-fill"
                          style={`width: ${humanPct}%`}
                          data-human-pct={`${humanPct}%`}
                          data-all-pct={`${allPct}%`}
                        ></div>
                      </div>
                      <span class="chart-bar-val"
                        data-human={fmtNum(r.human_total)}
                        data-all={fmtNum(r.total)}
                      >{fmtNum(r.human_total)}</span>
                    </div>
                  );
                })}
              </div>
            );
          })()}
        </section>
      )}

      <!-- Top Referrers -->
      <section>
        <h2>Top Referral Sources (30d, human only)</h2>
        {metrics.topReferrers30d?.length > 0 ? (
          <table>
            <thead>
              <tr><th>Referrer</th><th>Visits</th></tr>
            </thead>
            <tbody>
              {metrics.topReferrers30d.map((r: any) => (
                <tr>
                  <td>{r.referrer}</td>
                  <td>{fmtNum(r.visits)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        ) : (
          <p style="color: var(--text-muted); font-size: 0.82rem;">No external referrers recorded yet.</p>
        )}
      </section>

      <!-- Top API Endpoints -->
      <section>
        <h2>Top API Endpoints (30d, human only)</h2>
        {metrics.topEndpoints30d?.length > 0 ? (
          <table>
            <thead>
              <tr><th>Endpoint</th><th>Calls</th><th>Avg ms</th></tr>
            </thead>
            <tbody>
              {metrics.topEndpoints30d.map((r: any) => (
                <tr>
                  <td>{r.path}</td>
                  <td>{fmtNum(r.calls)}</td>
                  <td>{r.avg_ms ?? '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        ) : (
          <p style="color: var(--text-muted); font-size: 0.82rem;">No API requests recorded yet.</p>
        )}
      </section>

      <!-- Error Rates -->
      <section>
        <h2>Errors by Endpoint (24h)</h2>
        {metrics.errorRates24h?.length > 0 ? (
          <table>
            <thead>
              <tr><th>Endpoint</th><th>Errors (4xx/5xx)</th></tr>
            </thead>
            <tbody>
              {metrics.errorRates24h.map((r: any) => (
                <tr>
                  <td>{r.path}</td>
                  <td>{fmtNum(r.errors)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        ) : (
          <p style="color: var(--text-muted); font-size: 0.82rem;">No errors in the last 24h.</p>
        )}
      </section>

      <!-- Skill Installs -->
      <section>
        <h2>Skill Installs (30d)</h2>
        {metrics.skillInstalls?.length > 0 ? (
          <table>
            <thead>
              <tr><th>Slug</th><th>Total Pings</th><th>Unique Installs</th></tr>
            </thead>
            <tbody>
              {metrics.skillInstalls.map((r: any) => (
                <tr>
                  <td>{r.slug}</td>
                  <td>{fmtNum(r.pings)}</td>
                  <td>{fmtNum(r.unique_installs)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        ) : (
          <p style="color: var(--text-muted); font-size: 0.82rem;">No skill pings recorded yet. Pings arrive when the AgentRank skill loads.</p>
        )}
      </section>

      <!-- API Keys -->
      {metrics.apiKeysSummary && (
        <section>
          <h2>API Keys</h2>
          <div class="dash-grid">
            <div class="stat-card">
              <div class="label">Total active keys</div>
              <div class="value">{fmtNum(metrics.apiKeysSummary?.total_keys ?? 0)}</div>
              <div class="sub">
                {fmtNum(metrics.apiKeysSummary?.free_keys ?? 0)} free ·
                {fmtNum(metrics.apiKeysSummary?.pro_keys ?? 0)} pro ·
                {fmtNum(metrics.apiKeysSummary?.enterprise_keys ?? 0)} enterprise
              </div>
            </div>
            <div class="stat-card">
              <div class="label">Keys used (24h)</div>
              <div class="value">{fmtNum(metrics.apiKeysActive?.last24h ?? 0)}</div>
              <div class="sub">unique keys with requests</div>
            </div>
            <div class="stat-card">
              <div class="label">Keys used (7d)</div>
              <div class="value">{fmtNum(metrics.apiKeysActive?.last7d ?? 0)}</div>
              <div class="sub">unique keys with requests</div>
            </div>
            <div class="stat-card">
              <div class="label">Keys used (30d)</div>
              <div class="value">{fmtNum(metrics.apiKeysActive?.last30d ?? 0)}</div>
              <div class="sub">unique keys with requests</div>
            </div>
          </div>
        </section>
      )}

      <!-- Top Pages -->
      <section>
        <h2>Top Pages (30d, human only)</h2>
        {metrics.topPages30d?.length > 0 ? (
          <table>
            <thead>
              <tr><th>Path</th><th>Views</th></tr>
            </thead>
            <tbody>
              {metrics.topPages30d.map((r: any) => (
                <tr>
                  <td>{r.path}</td>
                  <td>{fmtNum(r.views)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        ) : (
          <p style="color: var(--text-muted); font-size: 0.82rem;">No page views recorded yet.</p>
        )}
      </section>

      <!-- UTM Sources -->
      <section>
        <h2>Traffic Sources / UTM (30d)</h2>
        {metrics.utmSources30d?.length > 0 ? (
          <table>
            <thead>
              <tr><th>utm_source</th><th>Visits</th></tr>
            </thead>
            <tbody>
              {metrics.utmSources30d.map((r: any) => (
                <tr>
                  <td>{r.utm_source}</td>
                  <td>{fmtNum(r.visits)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        ) : (
          <p style="color: var(--text-muted); font-size: 0.82rem;">No UTM-tagged traffic recorded yet.</p>
        )}
      </section>

      <p style="color: var(--text-muted); font-size: 0.75rem;">
        Note: Site visitor counts are also tracked via Cloudflare Web Analytics (real-time, privacy-friendly).
        API request metrics above come from the request_log D1 table. Human-only view excludes known bot UAs.
      </p>
    </>
  )}
</Base>

<script>
  const btn = document.getElementById('bot-toggle-btn') as HTMLButtonElement | null;
  const modeLabel = document.getElementById('mode-label');
  if (btn) {
    let showAll = false;
    btn.addEventListener('click', () => {
      showAll = !showAll;

      // Toggle stat card values and sub-labels
      document.querySelectorAll<HTMLElement>('[data-human][data-all]').forEach(el => {
        el.textContent = showAll ? (el.dataset.all ?? '') : (el.dataset.human ?? '');
      });

      // Toggle chart bar widths and values
      document.querySelectorAll<HTMLElement>('[data-human-pct][data-all-pct]').forEach(el => {
        el.style.width = showAll ? (el.dataset.allPct ?? '0%') : (el.dataset.humanPct ?? '0%');
      });

      if (modeLabel) modeLabel.textContent = showAll ? 'All traffic (incl. bots)' : 'Human traffic only';
      btn.textContent = showAll ? 'Show human only' : 'Show all (incl. bots)';
    });
  }
</script>

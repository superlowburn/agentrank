---
import Base from '../../../layouts/Base.astro';

export const prerender = false;

const { env } = Astro.locals.runtime;

// Parse session cookie
function parseCookies(header: string): Record<string, string> {
  return Object.fromEntries(
    header.split('; ').filter(Boolean).map((c) => {
      const i = c.indexOf('=');
      return [c.slice(0, i), c.slice(i + 1)];
    })
  );
}

const cookies = parseCookies(Astro.request.headers.get('cookie') || '');
const rawSession = cookies.claim_session ? decodeURIComponent(cookies.claim_session) : null;

if (!rawSession) {
  return Astro.redirect('/pricing/?ref=dashboard_noauth');
}

const colonIdx = rawSession.indexOf(':');
const sessionSlug = rawSession.slice(0, colonIdx);
const githubUsername = rawSession.slice(colonIdx + 1);

if (!githubUsername) {
  return Astro.redirect('/pricing/?ref=dashboard_noauth');
}

// Get all verified claims for this user
const claimsResult = await env.DB.prepare(
  'SELECT tool_full_name FROM claims WHERE github_username = ? AND verified = 1 AND status = ? ORDER BY created_at ASC'
).bind(githubUsername, 'active').all();

const claimedToolsList = (claimsResult.results || []) as { tool_full_name: string }[];

if (claimedToolsList.length === 0) {
  return Astro.redirect('/pricing/?ref=dashboard_unclaimed');
}

// Which tool to show
const urlParams = new URL(Astro.request.url).searchParams;
const requestedSlug = urlParams.get('slug');
const requestedFullName = requestedSlug ? requestedSlug.replace('--', '/') : null;

let currentFullName: string;
if (requestedFullName && claimedToolsList.some((c) => c.tool_full_name === requestedFullName)) {
  currentFullName = requestedFullName;
} else {
  const cookieFullName = sessionSlug.replace('--', '/');
  currentFullName = claimedToolsList.some((c) => c.tool_full_name === cookieFullName)
    ? cookieFullName
    : claimedToolsList[0].tool_full_name;
}

const currentSlug = currentFullName.replace('/', '--');

// Tool data
const tool = await env.DB.prepare(
  `SELECT full_name, url, description, rank, score, stars, open_issues, closed_issues,
          contributors, dependents, last_commit_at, language, license, category
   FROM tools WHERE full_name = ?`
).bind(currentFullName).first() as Record<string, unknown> | null;

if (!tool) {
  return Astro.redirect('/pricing/?ref=dashboard_unclaimed');
}

// Claim enrichment
const claim = await env.DB.prepare(
  'SELECT tagline, category, logo_url, is_deprecated FROM claims WHERE tool_full_name = ? AND github_username = ? AND verified = 1'
).bind(currentFullName, githubUsername).first() as Record<string, unknown> | null;

// 7-day page views (human only)
const viewResult = await env.DB.prepare(
  `SELECT COUNT(*) as count FROM request_log
   WHERE path LIKE ? AND type = 'page' AND is_bot = 0 AND ts >= datetime('now', '-7 days')`
).bind(`/tool/${currentSlug}%`).first() as { count: number } | null;

const viewCount7d = viewResult?.count ?? 0;

// 30-day page views (human only)
const view30Result = await env.DB.prepare(
  `SELECT COUNT(*) as count FROM request_log
   WHERE path LIKE ? AND type = 'page' AND is_bot = 0 AND ts >= datetime('now', '-30 days')`
).bind(`/tool/${currentSlug}%`).first() as { count: number } | null;

const viewCount30d = view30Result?.count ?? 0;

// Total tools for rank context
const totalResult = await env.DB.prepare(
  'SELECT COUNT(*) as count FROM tools WHERE is_archived = 0'
).first() as { count: number } | null;

const totalTools = (totalResult?.count ?? 0).toLocaleString();

// 30-day rank/score history
const histResult = await env.DB.prepare(
  `SELECT snapshot_date, score, rank
   FROM rank_history
   WHERE tool_full_name = ? AND tool_type = 'tool'
   ORDER BY snapshot_date DESC
   LIMIT 30`
).bind(currentFullName).all();

const histRowsDesc = (histResult.results || []) as { snapshot_date: string; score: number; rank: number }[];
const histRows = [...histRowsDesc].reverse(); // oldest-first

// Rank and score changes vs 7 days ago
let rankChange: number | null = null;
let scoreChange: number | null = null;
if (histRows.length >= 2) {
  const latest = histRows[histRows.length - 1];
  const cutoffDate = new Date(latest.snapshot_date + 'T00:00:00Z');
  cutoffDate.setUTCDate(cutoffDate.getUTCDate() - 7);
  const cutoffStr = cutoffDate.toISOString().slice(0, 10);
  const baseline = histRowsDesc.find((h) => h.snapshot_date <= cutoffStr);
  if (baseline) {
    rankChange = baseline.rank - latest.rank; // positive = rank improved
    scoreChange = Math.round((latest.score - baseline.score) * 10) / 10;
  }
}

// Top referrers (30d) for tool listing
const refResult = await env.DB.prepare(
  `SELECT referrer, COUNT(*) as cnt FROM request_log
   WHERE path LIKE ? AND type = 'page' AND is_bot = 0
   AND referrer IS NOT NULL AND ts >= datetime('now', '-30 days')
   GROUP BY referrer ORDER BY cnt DESC LIMIT 6`
).bind(`/tool/${currentSlug}%`).all();

const topReferrers = (refResult.results || []) as { referrer: string; cnt: number }[];

// Category average score
const toolCategory = (tool.category as string) || (claim?.category as string) || null;
let categoryAvgScore: number | null = null;
let categoryToolCount = 0;
if (toolCategory) {
  const catResult = await env.DB.prepare(
    `SELECT AVG(score) as avg_score, COUNT(*) as cnt FROM tools WHERE category = ? AND is_archived = 0`
  ).bind(toolCategory).first() as { avg_score: number | null; cnt: number } | null;
  categoryAvgScore = catResult?.avg_score ? Math.round(catResult.avg_score * 10) / 10 : null;
  categoryToolCount = catResult?.cnt ?? 0;
}

// Score signals
const stars = (tool.stars as number) || 0;
const openIssues = (tool.open_issues as number) || 0;
const closedIssues = (tool.closed_issues as number) || 0;
const contributors = (tool.contributors as number) || 0;
const dependents = (tool.dependents as number) || 0;
const lastCommitAt = tool.last_commit_at as string | null;
const score = Math.round((tool.score as number) || 0);
const rank = (tool.rank as number) || 0;

const starsScore = Math.min(1, Math.log10(Math.max(1, stars)) / 4);
const totalIssues = openIssues + closedIssues;
const issueHealth = totalIssues > 0 ? closedIssues / totalIssues : 0.5;
const contributorsScore = Math.min(1, Math.log10(Math.max(1, contributors)) / 2);
const dependentsScore = Math.min(1, Math.log10(Math.max(1, dependents)) / 3);

let freshnessScore = 0;
let daysSinceCommit: number | null = null;
if (lastCommitAt) {
  daysSinceCommit = Math.floor((Date.now() - new Date(lastCommitAt).getTime()) / (1000 * 60 * 60 * 24));
  freshnessScore = Math.max(0, 1 - daysSinceCommit / 180);
}

function formatDaysAgo(days: number | null): string {
  if (days === null) return 'unknown';
  if (days === 0) return 'today';
  if (days === 1) return '1 day ago';
  if (days < 30) return `${days} days ago`;
  const months = Math.floor(days / 30);
  if (months === 1) return '1 month ago';
  if (months < 12) return `${months} months ago`;
  const years = Math.floor(months / 12);
  return years === 1 ? '1 year ago' : `${years} years ago`;
}

// Listing completeness
const hasLogo = !!claim?.logo_url;
const hasTagline = !!claim?.tagline;
const hasCategory = !!(claim?.category || tool.category);
const isVerifiedPro = false;

const tagline = (claim?.tagline as string) || '';
const category = (claim?.category as string) || (tool.category as string) || '';
const logoUrl = (claim?.logo_url as string) || '';

const claimedToolsForSwitcher = claimedToolsList.map((c) => ({
  full_name: c.tool_full_name,
  slug: c.tool_full_name.replace('/', '--'),
}));

// Build SVG score trend chart
const CHART_W = 480;
const CHART_H = 72;
const CHART_PAD_X = 4;
const CHART_PAD_Y = 8;

let scorePolyline = '';
let scoreAreaPath = '';
let rankPolyline = '';

if (histRows.length >= 2) {
  const scores = histRows.map((h) => h.score);
  const minScore = Math.min(...scores);
  const maxScore = Math.max(...scores);
  const scoreRange = maxScore - minScore || 1;
  const n = histRows.length;

  const pts = histRows.map((h, i) => {
    const x = CHART_PAD_X + (i / (n - 1)) * (CHART_W - 2 * CHART_PAD_X);
    const y = CHART_PAD_Y + (1 - (h.score - minScore) / scoreRange) * (CHART_H - 2 * CHART_PAD_Y);
    return { x: x.toFixed(1), y: y.toFixed(1) };
  });

  scorePolyline = pts.map((p) => `${p.x},${p.y}`).join(' ');
  const firstX = pts[0].x;
  const lastX = pts[pts.length - 1].x;
  const bottom = CHART_H - CHART_PAD_Y;
  scoreAreaPath = `M${firstX},${bottom} ` + pts.map((p) => `L${p.x},${p.y}`).join(' ') + ` L${lastX},${bottom} Z`;
}

// Rank trend (inverted - lower rank = better = higher on chart)
let rankPolylineStr = '';
if (histRows.length >= 2) {
  const ranks = histRows.map((h) => h.rank);
  const minRank = Math.min(...ranks);
  const maxRank = Math.max(...ranks);
  const rankRange = maxRank - minRank || 1;
  const n = histRows.length;

  const pts = histRows.map((h, i) => {
    const x = CHART_PAD_X + (i / (n - 1)) * (CHART_W - 2 * CHART_PAD_X);
    // Invert: lower rank = higher on chart (better)
    const y = CHART_PAD_Y + ((h.rank - minRank) / rankRange) * (CHART_H - 2 * CHART_PAD_Y);
    return `${x.toFixed(1)},${y.toFixed(1)}`;
  });

  rankPolylineStr = pts.join(' ');
}

const hasHistory = histRows.length >= 2;
---

<Base title={`Publisher Dashboard — ${currentFullName} — AgentRank`} description="AgentRank publisher dashboard">
  <div class="dash-header">
    <div class="dash-title-row">
      <h2>Publisher Dashboard</h2>
      {isVerifiedPro && <span class="pro-badge">Verified Publisher</span>}
    </div>
    <div class="tool-row">
      <span class="tool-name">{currentFullName}</span>
      <div class="tool-actions">
        <a href={`/tool/${currentSlug}/`} class="action-link">View listing</a>
        <a href={`/claim/${currentSlug}/`} class="action-link">Edit listing</a>
        {claimedToolsForSwitcher.length > 1 && (
          <div class="switcher-wrap">
            <select id="tool-switcher" class="tool-switcher">
              {claimedToolsForSwitcher.map((t) => (
                <option value={t.slug} selected={t.full_name === currentFullName}>
                  {t.full_name}
                </option>
              ))}
            </select>
          </div>
        )}
      </div>
    </div>
  </div>

  <!-- Stats row -->
  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-label">AgentRank Score</div>
      <div class="stat-value score-value">{score}</div>
      <div class="stat-sub">
        {scoreChange !== null && (
          <span class={scoreChange >= 0 ? 'delta-up' : 'delta-down'}>
            {scoreChange >= 0 ? '+' : ''}{scoreChange} vs 7d ago
          </span>
        )}
        {scoreChange === null && 'of 100'}
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Global Rank</div>
      <div class="stat-value">#{rank.toLocaleString()}</div>
      <div class="stat-sub">
        {rankChange !== null && rankChange !== 0 && (
          <span class={rankChange > 0 ? 'delta-up' : 'delta-down'}>
            {rankChange > 0 ? `+${rankChange}` : rankChange} vs 7d ago
          </span>
        )}
        {rankChange === 0 && <span class="delta-stable">no change</span>}
        {rankChange === null && `of ${totalTools}+`}
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Views (7d)</div>
      <div class="stat-value">{viewCount7d.toLocaleString()}</div>
      <div class="stat-sub">human visitors</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Views (30d)</div>
      <div class="stat-value">{viewCount30d.toLocaleString()}</div>
      <div class="stat-sub">human visitors</div>
    </div>
  </div>

  <!-- Score trend chart -->
  <div class="section">
    <div class="section-header">
      Score trend — last 30 days
    </div>
    {hasHistory ? (
      <div class="chart-wrap">
        <svg viewBox={`0 0 ${CHART_W} ${CHART_H}`} class="trend-chart" aria-label="Score trend over 30 days" role="img">
          <!-- Area fill -->
          <path d={scoreAreaPath} class="chart-area" />
          <!-- Line -->
          <polyline points={scorePolyline} class="chart-line" fill="none" />
          <!-- Latest dot -->
          {(() => {
            const lastPt = scorePolyline.split(' ').pop();
            if (!lastPt) return null;
            const [lx, ly] = lastPt.split(',');
            return <circle cx={lx} cy={ly} r="3" class="chart-dot" />;
          })()}
        </svg>
        <div class="chart-labels">
          <span>{histRows[0]?.snapshot_date.slice(5)}</span>
          <span>{histRows[histRows.length - 1]?.snapshot_date.slice(5)}</span>
        </div>
      </div>
    ) : (
      <div class="chart-empty">
        No history yet — trend data populates after the first daily snapshot.
      </div>
    )}
  </div>

  <!-- Rank trend chart -->
  {hasHistory && (
    <div class="section">
      <div class="section-header">
        Rank trend — last 30 days
        <span class="section-note">lower is better</span>
      </div>
      <div class="chart-wrap">
        <svg viewBox={`0 0 ${CHART_W} ${CHART_H}`} class="trend-chart rank-chart" aria-label="Rank trend over 30 days" role="img">
          <polyline points={rankPolylineStr} class="chart-line rank-line" fill="none" />
          {(() => {
            const lastPt = rankPolylineStr.split(' ').pop();
            if (!lastPt) return null;
            const [lx, ly] = lastPt.split(',');
            return <circle cx={lx} cy={ly} r="3" class="chart-dot rank-dot" />;
          })()}
        </svg>
        <div class="chart-labels">
          <span>{histRows[0]?.snapshot_date.slice(5)}</span>
          <span>#{rank.toLocaleString()} today</span>
        </div>
      </div>
    </div>
  )}

  <!-- Traffic sources -->
  <div class="section">
    <div class="section-header">Traffic sources — last 30 days</div>
    {topReferrers.length > 0 ? (
      <div class="referrer-table">
        {topReferrers.map((r) => {
          const label = r.referrer === 'direct' ? 'Direct / unknown' : r.referrer;
          const pct = viewCount30d > 0 ? Math.round((r.cnt / viewCount30d) * 100) : 0;
          return (
            <div class="referrer-row">
              <span class="referrer-src">{label}</span>
              <div class="referrer-bar-wrap">
                <div class="referrer-bar" style={`width:${Math.min(pct, 100)}%`}></div>
              </div>
              <span class="referrer-cnt">{r.cnt.toLocaleString()}</span>
              <span class="referrer-pct">{pct}%</span>
            </div>
          );
        })}
      </div>
    ) : (
      <p class="empty-note">No referrer data yet for this period.</p>
    )}
  </div>

  <!-- Category comparison -->
  {toolCategory && categoryAvgScore !== null && (
    <div class="section">
      <div class="section-header">Category comparison</div>
      <div class="category-cmp">
        <div class="cmp-label-row">
          <span class="cmp-tool-label">{currentFullName.split('/')[1]} — score {score}</span>
          <span class="cmp-cat-label">Category avg — {categoryAvgScore} ({categoryToolCount} tools in "{toolCategory}")</span>
        </div>
        <div class="cmp-bars">
          <div class="cmp-row">
            <span class="cmp-row-label">Your score</span>
            <div class="cmp-bar-wrap">
              <div class="cmp-bar cmp-bar-tool" style={`width:${score}%`}></div>
            </div>
            <span class="cmp-bar-val">{score}</span>
          </div>
          <div class="cmp-row">
            <span class="cmp-row-label">Category avg</span>
            <div class="cmp-bar-wrap">
              <div class="cmp-bar cmp-bar-avg" style={`width:${categoryAvgScore}%`}></div>
            </div>
            <span class="cmp-bar-val">{categoryAvgScore}</span>
          </div>
        </div>
        {score > categoryAvgScore && (
          <p class="cmp-note cmp-note-good">You are above the category average by {(score - categoryAvgScore).toFixed(1)} points.</p>
        )}
        {score <= categoryAvgScore && (
          <p class="cmp-note cmp-note-warn">You are below the category average by {(categoryAvgScore - score).toFixed(1)} points. <a href="/methodology/" class="cmp-link">How to improve &rarr;</a></p>
        )}
      </div>
    </div>
  )}

  <!-- Score breakdown -->
  <div class="section">
    <div class="section-header">
      Score breakdown
      <a href="/methodology/" class="section-link">How to improve &rarr;</a>
    </div>
    <div class="signals">
      <div class="signal-row">
        <span class="signal-label">Stars</span>
        <div class="signal-bar-wrap">
          <div class="signal-bar" style={`width:${Math.round(starsScore * 100)}%`}></div>
        </div>
        <span class="signal-val">{starsScore.toFixed(2)}</span>
        <span class="signal-detail">{stars.toLocaleString()} stars · weight 15%</span>
      </div>
      <div class="signal-row">
        <span class="signal-label">Freshness</span>
        <div class="signal-bar-wrap">
          <div class="signal-bar" style={`width:${Math.round(freshnessScore * 100)}%`}></div>
        </div>
        <span class="signal-val">{freshnessScore.toFixed(2)}</span>
        <span class="signal-detail">Last commit: {formatDaysAgo(daysSinceCommit)} · weight 25%</span>
      </div>
      <div class="signal-row">
        <span class="signal-label">Issue health</span>
        <div class="signal-bar-wrap">
          <div class={`signal-bar ${issueHealth < 0.4 ? 'signal-bar-warn' : ''}`} style={`width:${Math.round(issueHealth * 100)}%`}></div>
        </div>
        <span class="signal-val">{issueHealth.toFixed(2)}</span>
        <span class="signal-detail">
          {openIssues} open, {closedIssues} closed · weight 25%
          {issueHealth < 0.4 && <span class="signal-hint"> — needs work</span>}
        </span>
      </div>
      <div class="signal-row">
        <span class="signal-label">Contributors</span>
        <div class="signal-bar-wrap">
          <div class="signal-bar" style={`width:${Math.round(contributorsScore * 100)}%`}></div>
        </div>
        <span class="signal-val">{contributorsScore.toFixed(2)}</span>
        <span class="signal-detail">{contributors} contributor{contributors !== 1 ? 's' : ''} · weight 10%</span>
      </div>
      <div class="signal-row">
        <span class="signal-label">Dependents</span>
        <div class="signal-bar-wrap">
          <div class="signal-bar" style={`width:${Math.round(dependentsScore * 100)}%`}></div>
        </div>
        <span class="signal-val">{dependentsScore.toFixed(2)}</span>
        <span class="signal-detail">{dependents.toLocaleString()} dependent repos · weight 25%</span>
      </div>
    </div>
  </div>

  <!-- Verified Publisher upgrade CTA -->
  {!isVerifiedPro && (
    <div class="upgrade-panel">
      <div class="upgrade-panel-header">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M7 1C5.343 1 4 2.343 4 4v1H3a1 1 0 0 0-1 1v6a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V6a1 1 0 0 0-1-1h-1V4c0-1.657-1.343-3-3-3zm0 1.5c.828 0 1.5.672 1.5 1.5v1h-3V4c0-.828.672-1.5 1.5-1.5z" fill="currentColor"/>
        </svg>
        Upgrade to Verified Publisher Pro
      </div>
      <p class="upgrade-desc">Get a Verified Publisher badge on your listing, priority placement in category pages, and score-change email alerts.</p>
      <a href="/pricing/" class="upgrade-cta">Upgrade — $29/mo &rarr;</a>
    </div>
  )}

  <!-- Listing status -->
  <div class="section">
    <div class="section-header">Listing status</div>
    <div class="checklist">
      <div class="check-row check-done">
        <span class="check-icon">&#10003;</span>
        <span>Claimed by <strong>@{githubUsername}</strong></span>
      </div>
      <div class={`check-row ${hasLogo ? 'check-done' : 'check-missing'}`}>
        <span class="check-icon">{hasLogo ? '✓' : '✗'}</span>
        <span>
          Logo
          {!hasLogo && <a href={`/claim/${currentSlug}/`} class="check-link">Add logo &rarr;</a>}
          {hasLogo && <span class="check-val">{logoUrl.replace(/^https?:\/\//, '').slice(0, 40)}{logoUrl.length > 40 ? '...' : ''}</span>}
        </span>
      </div>
      <div class={`check-row ${hasTagline ? 'check-done' : 'check-missing'}`}>
        <span class="check-icon">{hasTagline ? '✓' : '✗'}</span>
        <span>
          Tagline
          {!hasTagline && <a href={`/claim/${currentSlug}/`} class="check-link">Add tagline &rarr;</a>}
          {hasTagline && <span class="check-val">"{tagline}"</span>}
        </span>
      </div>
      <div class={`check-row ${hasCategory ? 'check-done' : 'check-missing'}`}>
        <span class="check-icon">{hasCategory ? '✓' : '✗'}</span>
        <span>
          Category
          {!hasCategory && <a href={`/claim/${currentSlug}/`} class="check-link">Add category &rarr;</a>}
          {hasCategory && <span class="check-val">{category}</span>}
        </span>
      </div>
      <div class={`check-row ${isVerifiedPro ? 'check-done' : 'check-locked'}`}>
        <span class="check-icon check-icon-lock">
          {isVerifiedPro ? '✓' : (
            <svg width="10" height="10" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M7 1C5.343 1 4 2.343 4 4v1H3a1 1 0 0 0-1 1v6a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V6a1 1 0 0 0-1-1h-1V4c0-1.657-1.343-3-3-3zm0 1.5c.828 0 1.5.672 1.5 1.5v1h-3V4c0-.828.672-1.5 1.5-1.5z" fill="currentColor"/>
            </svg>
          )}
        </span>
        <span>
          Verified Publisher badge
          {!isVerifiedPro && <a href="/pricing/" class="check-link">Upgrade to add badge &rarr;</a>}
        </span>
      </div>
    </div>
    <a href={`/claim/${currentSlug}/`} class="edit-link">Edit listing &rarr;</a>
  </div>
</Base>

<script>
  const switcher = document.getElementById('tool-switcher') as HTMLSelectElement | null;
  if (switcher) {
    switcher.addEventListener('change', () => {
      const slug = switcher.value;
      window.location.href = `/dashboard/publisher/?slug=${slug}`;
    });
  }
</script>

<style>
  .dash-header {
    margin-bottom: 2rem;
  }

  .dash-title-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .dash-title-row h2 {
    font-size: 1.2rem;
    font-weight: 700;
  }

  .pro-badge {
    font-size: 0.7rem;
    font-weight: 700;
    background: var(--accent);
    color: #000;
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
    letter-spacing: 0.04em;
  }

  .tool-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .tool-name {
    font-size: 0.9rem;
    color: var(--accent);
    font-weight: 600;
  }

  .tool-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;

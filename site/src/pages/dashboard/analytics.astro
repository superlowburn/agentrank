---
import Base from '../../layouts/Base.astro';

export const prerender = false;

const { env } = Astro.locals.runtime;

const token = Astro.url.searchParams.get('token');
if (!env.DASH_TOKEN || token !== env.DASH_TOKEN) {
  return new Response('Unauthorized', { status: 403 });
}

const db = env.DB;

// ── Summary counts ──────────────────────────────────────────────────────────
const [checks24h, checks7d, checks30d] = await Promise.all([
  db.prepare(`
    SELECT
      COUNT(*) AS total,
      SUM(found) AS found,
      COUNT(*) - SUM(found) AS not_found
    FROM analytics_events
    WHERE event_type = 'check' AND ts > datetime('now', '-1 day')
  `).first() as Promise<{ total: number; found: number; not_found: number } | null>,

  db.prepare(`
    SELECT
      COUNT(*) AS total,
      SUM(found) AS found,
      COUNT(*) - SUM(found) AS not_found
    FROM analytics_events
    WHERE event_type = 'check' AND ts > datetime('now', '-7 days')
  `).first() as Promise<{ total: number; found: number; not_found: number } | null>,

  db.prepare(`
    SELECT
      COUNT(*) AS total,
      SUM(found) AS found,
      COUNT(*) - SUM(found) AS not_found
    FROM analytics_events
    WHERE event_type = 'check' AND ts > datetime('now', '-30 days')
  `).first() as Promise<{ total: number; found: number; not_found: number } | null>,
]);

// ── Daily /check volume (30d) for chart ────────────────────────────────────
const dailyChecksResult = await db.prepare(`
  SELECT
    date(ts) AS day,
    COUNT(*) AS total,
    SUM(found) AS found,
    COUNT(*) - SUM(found) AS not_found
  FROM analytics_events
  WHERE event_type = 'check' AND ts > datetime('now', '-30 days')
  GROUP BY day
  ORDER BY day ASC
`).all();
const dailyChecks = (dailyChecksResult.results || []) as { day: string; total: number; found: number; not_found: number }[];

// ── Top repos checked (30d) ────────────────────────────────────────────────
const topReposResult = await db.prepare(`
  SELECT repo, COUNT(*) AS checks, SUM(found) AS found
  FROM analytics_events
  WHERE event_type = 'check' AND repo IS NOT NULL AND ts > datetime('now', '-30 days')
  GROUP BY repo
  ORDER BY checks DESC
  LIMIT 20
`).all();
const topRepos = (topReposResult.results || []) as { repo: string; checks: number; found: number }[];

// ── Top referrers for API calls (30d) ─────────────────────────────────────
const topReferrersResult = await db.prepare(`
  SELECT referrer, COUNT(*) AS calls
  FROM request_log
  WHERE type IN ('api', 'mcp')
    AND ts > datetime('now', '-30 days')
    AND referrer IS NOT NULL AND referrer != ''
    AND referrer NOT LIKE '%agentrank-ai.com%'
  GROUP BY referrer
  ORDER BY calls DESC
  LIMIT 15
`).all();
const topReferrers = (topReferrersResult.results || []) as { referrer: string; calls: number }[];

// ── Daily API calls total (30d) ────────────────────────────────────────────
const dailyApiResult = await db.prepare(`
  SELECT
    date(ts) AS day,
    SUM(CASE WHEN type='api' THEN 1 ELSE 0 END) AS api_calls,
    SUM(CASE WHEN type='mcp' THEN 1 ELSE 0 END) AS mcp_calls,
    COUNT(*) AS total
  FROM request_log
  WHERE type IN ('api', 'mcp') AND ts > datetime('now', '-30 days')
  GROUP BY day
  ORDER BY day ASC
`).all();
const dailyApi = (dailyApiResult.results || []) as { day: string; api_calls: number; mcp_calls: number; total: number }[];

// ── SVG chart helpers ──────────────────────────────────────────────────────
const CHART_W = 640;
const CHART_H = 80;
const PAD_X = 4;
const PAD_Y = 8;

function buildPolyline(values: number[]): string {
  if (values.length < 2) return '';
  const max = Math.max(...values) || 1;
  const n = values.length;
  return values.map((v, i) => {
    const x = (PAD_X + (i / (n - 1)) * (CHART_W - 2 * PAD_X)).toFixed(1);
    const y = (PAD_Y + (1 - v / max) * (CHART_H - 2 * PAD_Y)).toFixed(1);
    return `${x},${y}`;
  }).join(' ');
}

function buildArea(values: number[]): string {
  if (values.length < 2) return '';
  const max = Math.max(...values) || 1;
  const n = values.length;
  const pts = values.map((v, i) => ({
    x: (PAD_X + (i / (n - 1)) * (CHART_W - 2 * PAD_X)).toFixed(1),
    y: (PAD_Y + (1 - v / max) * (CHART_H - 2 * PAD_Y)).toFixed(1),
  }));
  const bottom = (CHART_H - PAD_Y).toFixed(1);
  return `M${pts[0].x},${bottom} ${pts.map(p => `L${p.x},${p.y}`).join(' ')} L${pts[pts.length-1].x},${bottom} Z`;
}

const checkTotals = dailyChecks.map(d => d.total);
const checkFoundArr = dailyChecks.map(d => d.found);
const apiTotals = dailyApi.map(d => d.total);

const checkPolyline = buildPolyline(checkTotals);
const checkArea = buildArea(checkTotals);
const foundPolyline = buildPolyline(checkFoundArr);
const apiPolyline = buildPolyline(apiTotals);
const apiArea = buildArea(apiTotals);

// ── Formatting helpers ─────────────────────────────────────────────────────
const c24 = checks24h ?? { total: 0, found: 0, not_found: 0 };
const c7 = checks7d ?? { total: 0, found: 0, not_found: 0 };
const c30 = checks30d ?? { total: 0, found: 0, not_found: 0 };

const foundPct = c30.total > 0 ? Math.round((c30.found / c30.total) * 100) : 0;
const maxCheckCalls = Math.max(...topRepos.map(r => r.checks), 1);
const maxRefCalls = Math.max(...topReferrers.map(r => r.calls), 1);
---

<Base title="Analytics — AgentRank Admin">
  <style>
    body { background: #0a0a0a; }
    .admin-wrap { max-width: 960px; margin: 0 auto; padding: 2rem 1.5rem; }
    h1 { font-size: 1.4rem; font-weight: 700; color: #f0f0f0; margin-bottom: 0.25rem; }
    .subtitle { color: #666; font-size: 0.85rem; margin-bottom: 2rem; }
    .section-title { font-size: 0.75rem; font-weight: 600; color: #888; text-transform: uppercase; letter-spacing: 0.08em; margin: 2rem 0 0.75rem; }

    .stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 1rem; margin-bottom: 1rem; }
    .stat-card { background: #111; border: 1px solid #222; border-radius: 8px; padding: 1rem 1.25rem; }
    .stat-label { font-size: 0.7rem; color: #666; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.3rem; }
    .stat-value { font-size: 1.8rem; font-weight: 700; color: #f0f0f0; line-height: 1; }
    .stat-sub { font-size: 0.72rem; color: #555; margin-top: 0.3rem; }

    .chart-card { background: #111; border: 1px solid #222; border-radius: 8px; padding: 1rem 1.25rem; margin-bottom: 1rem; }
    .chart-card h3 { font-size: 0.78rem; color: #888; text-transform: uppercase; letter-spacing: 0.06em; margin: 0 0 0.75rem; }
    svg { display: block; width: 100%; overflow: visible; }

    .table-card { background: #111; border: 1px solid #222; border-radius: 8px; overflow: hidden; margin-bottom: 1rem; }
    .table-card h3 { font-size: 0.78rem; color: #888; text-transform: uppercase; letter-spacing: 0.06em; padding: 0.75rem 1rem; border-bottom: 1px solid #1a1a1a; margin: 0; }
    table { width: 100%; border-collapse: collapse; }
    th { font-size: 0.68rem; color: #555; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.5rem 1rem; text-align: left; border-bottom: 1px solid #1a1a1a; }
    td { font-size: 0.8rem; color: #ccc; padding: 0.5rem 1rem; border-bottom: 1px solid #111; vertical-align: middle; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #141414; }
    .bar-wrap { background: #1a1a1a; border-radius: 2px; height: 6px; flex: 1; min-width: 60px; overflow: hidden; }
    .bar-inner { height: 100%; border-radius: 2px; background: #3b82f6; }
    .bar-row { display: flex; align-items: center; gap: 0.5rem; }
    .found-badge { display: inline-block; font-size: 0.65rem; padding: 0.1em 0.4em; border-radius: 3px; background: #0d2b0d; color: #4ade80; }
    .miss-badge { display: inline-block; font-size: 0.65rem; padding: 0.1em 0.4em; border-radius: 3px; background: #2b1a0d; color: #fb923c; }
    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    @media (max-width: 600px) { .two-col { grid-template-columns: 1fr; } }
    .pct-found { color: #4ade80; font-weight: 700; }
    .pct-miss { color: #fb923c; font-weight: 700; }
    a.back { font-size: 0.78rem; color: #555; text-decoration: none; display: inline-block; margin-bottom: 1.5rem; }
    a.back:hover { color: #999; }
  </style>

  <div class="admin-wrap">
    <a href="/dash" class="back">← Admin</a>
    <h1>Usage Analytics</h1>
    <p class="subtitle">API calls, /check usage, top referrers — last 30 days</p>

    <p class="section-title">/check endpoint</p>
    <div class="stat-grid">
      <div class="stat-card">
        <div class="stat-label">Checks 24h</div>
        <div class="stat-value">{c24.total.toLocaleString()}</div>
        <div class="stat-sub">{c24.found} found / {c24.not_found} miss</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Checks 7d</div>
        <div class="stat-value">{c7.total.toLocaleString()}</div>
        <div class="stat-sub">{c7.found} found / {c7.not_found} miss</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Checks 30d</div>
        <div class="stat-value">{c30.total.toLocaleString()}</div>
        <div class="stat-sub">{c30.found} found / {c30.not_found} miss</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Found Rate 30d</div>
        <div class="stat-value {foundPct >= 50 ? 'pct-found' : 'pct-miss'}">{foundPct}%</div>
        <div class="stat-sub">of repos are indexed</div>
      </div>
    </div>

    {dailyChecks.length >= 2 && (
      <div class="chart-card">
        <h3>/check calls — 30 day volume</h3>
        <svg viewBox={`0 0 ${CHART_W} ${CHART_H}`} preserveAspectRatio="none" height={CHART_H}>
          <defs>
            <linearGradient id="chkGrad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#3b82f6" stop-opacity="0.3"/>
              <stop offset="100%" stop-color="#3b82f6" stop-opacity="0.02"/>
            </linearGradient>
            <linearGradient id="foundGrad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#4ade80" stop-opacity="0.3"/>
              <stop offset="100%" stop-color="#4ade80" stop-opacity="0.02"/>
            </linearGradient>
          </defs>
          <path d={checkArea} fill="url(#chkGrad)"/>
          <polyline points={checkPolyline} fill="none" stroke="#3b82f6" stroke-width="1.5"/>
          <polyline points={foundPolyline} fill="none" stroke="#4ade80" stroke-width="1.5" stroke-dasharray="4,2"/>
        </svg>
        <div style="display:flex;gap:1rem;margin-top:0.5rem;">
          <span style="font-size:0.7rem;color:#3b82f6;">— total checks</span>
          <span style="font-size:0.7rem;color:#4ade80;">- - found</span>
        </div>
      </div>
    )}

    <div class="two-col">
      <div class="table-card">
        <h3>Top repos checked (30d)</h3>
        {topRepos.length === 0 ? (
          <div style="padding:1rem;color:#555;font-size:0.8rem;">No data yet</div>
        ) : (
          <table>
            <thead>
              <tr>
                <th>Repo</th>
                <th style="text-align:right">Checks</th>
                <th style="text-align:right">Status</th>
              </tr>
            </thead>
            <tbody>
              {topRepos.map(r => (
                <tr>
                  <td>
                    <div class="bar-row" style="flex-direction:column;align-items:flex-start;gap:0.3rem;">
                      <a href={`https://github.com/${r.repo}`} target="_blank" rel="noopener" style="color:#93c5fd;text-decoration:none;font-size:0.78rem;">{r.repo}</a>
                      <div class="bar-wrap" style="width:100%">
                        <div class="bar-inner" style={`width:${Math.round((r.checks / maxCheckCalls) * 100)}%`}></div>
                      </div>
                    </div>
                  </td>
                  <td style="text-align:right;font-variant-numeric:tabular-nums;">{r.checks}</td>
                  <td style="text-align:right">
                    {r.found > 0 ? <span class="found-badge">indexed</span> : <span class="miss-badge">miss</span>}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </div>

      <div class="table-card">
        <h3>Top API referrers (30d)</h3>
        {topReferrers.length === 0 ? (
          <div style="padding:1rem;color:#555;font-size:0.8rem;">No data yet</div>
        ) : (
          <table>
            <thead>
              <tr>
                <th>Referrer</th>
                <th style="text-align:right">Calls</th>
              </tr>
            </thead>
            <tbody>
              {topReferrers.map(r => (
                <tr>
                  <td>
                    <div style="display:flex;flex-direction:column;gap:0.3rem;">
                      <span style="font-size:0.78rem;word-break:break-all;">{r.referrer}</span>
                      <div class="bar-wrap">
                        <div class="bar-inner" style={`width:${Math.round((r.calls / maxRefCalls) * 100)}%;background:#a78bfa`}></div>
                      </div>
                    </div>
                  </td>
                  <td style="text-align:right;font-variant-numeric:tabular-nums;">{r.calls}</td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </div>
    </div>

    <p class="section-title">API calls (all endpoints)</p>

    {dailyApi.length >= 2 && (
      <div class="chart-card">
        <h3>Daily API + MCP calls — 30 days</h3>
        <svg viewBox={`0 0 ${CHART_W} ${CHART_H}`} preserveAspectRatio="none" height={CHART_H}>
          <defs>
            <linearGradient id="apiGrad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#a78bfa" stop-opacity="0.3"/>
              <stop offset="100%" stop-color="#a78bfa" stop-opacity="0.02"/>
            </linearGradient>
          </defs>
          <path d={apiArea} fill="url(#apiGrad)"/>
          <polyline points={apiPolyline} fill="none" stroke="#a78bfa" stroke-width="1.5"/>
        </svg>
      </div>
    )}

    {dailyApi.length > 0 && (
      <div class="table-card">
        <h3>Daily breakdown</h3>
        <table>
          <thead>
            <tr>
              <th>Date</th>
              <th style="text-align:right">API calls</th>
              <th style="text-align:right">MCP calls</th>
              <th style="text-align:right">Total</th>
            </tr>
          </thead>
          <tbody>
            {[...dailyApi].reverse().map(d => (
              <tr>
                <td style="color:#888;">{d.day}</td>
                <td style="text-align:right;font-variant-numeric:tabular-nums;">{d.api_calls}</td>
                <td style="text-align:right;font-variant-numeric:tabular-nums;">{d.mcp_calls}</td>
                <td style="text-align:right;font-weight:600;">{d.total}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>
</Base>

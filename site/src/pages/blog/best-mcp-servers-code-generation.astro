  dateModified: publishDate,
  author: {
    '@type': 'Organization',
    name: 'AgentRank',
    url: 'https://agentrank-ai.com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'AgentRank',
    url: 'https://agentrank-ai.com',
    logo: {
      '@type': 'ImageObject',
      url: 'https://agentrank-ai.com/og-image.png',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': 'https://agentrank-ai.com/blog/best-mcp-servers-code-generation/',
  },
  image: 'https://agentrank-ai.com/og-image.png',
  keywords: 'best MCP servers code generation, coding agent MCP, GitHub MCP server, code execution MCP, code editing AI agent, Serena MCP server, developer tools MCP 2026',
};

const tools = [
  {
    rank: 1,
    name: 'oraios/serena',
    slug: 'oraios--serena',
    score: 66.6,
    stars: 21474,
    lang: 'Python',
    contributors: 134,
    lastCommit: '2026-03-13',
    desc: 'Semantic code retrieval and editing toolkit for coding agents',
    useCase: 'Code editing / Semantic search',
    highlight: 'Best overall coding agent toolkit. 21K stars and 134 contributors signal broad adoption.',
  },
  {
    rank: 2,
    name: 'microsoft/azure-devops-mcp',
    slug: 'microsoft--azure-devops-mcp',
    score: 65.2,
    stars: 1406,
    lang: 'TypeScript',
    contributors: 45,
    lastCommit: '2026-03-12',
    desc: 'Official MCP server for Azure DevOps — work items, PRs, pipelines, and repos',
    useCase: 'DevOps / Code review',
    highlight: 'Official Microsoft server. 97% issue close rate is exceptional for a project of this scope.',
  },
  {
    rank: 3,
    name: 'MCPJam/inspector',
    slug: 'MCPJam--inspector',
    score: 62.0,
    stars: 1798,
    lang: 'TypeScript',
    contributors: 136,
    lastCommit: '2026-03-13',
    desc: 'Interactive testing and debugging tool for MCP servers and AI apps',
    useCase: 'Dev tooling / Testing',
    highlight: '136 contributors — the most active contributor base of any MCP dev tool in the index.',
  },
  {
    rank: 4,

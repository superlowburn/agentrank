---
export const prerender = true;

import Base from '../../layouts/Base.astro';
import BlogSubscribeCTA from '../../components/BlogSubscribeCTA.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';

const relatedPosts = [
  { href: '/blog/how-to-choose-an-mcp-server/', title: 'How to Choose an MCP Server in 2026' },
  { href: '/blog/best-mcp-servers-database/', title: 'Best MCP Servers for Database Management in 2026' },
  { href: '/blog/best-mcp-servers-devops/', title: 'Best MCP Servers for DevOps & Infrastructure in 2026' },
  { href: '/blog/best-mcp-servers-security/', title: 'Best MCP Servers for Security in 2026' },
  { href: '/blog/best-python-mcp-libraries/', title: 'Best Python Libraries for Building MCP Servers in 2026' },

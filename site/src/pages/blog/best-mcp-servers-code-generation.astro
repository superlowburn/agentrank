    stars: 1082,
    lang: 'Python',
    contributors: 21,
    lastCommit: '2026-03-13',
    desc: 'Token-efficient GitHub source code exploration via tree-sitter AST parsing',
    useCase: 'Code exploration / AST',
    highlight: '96% issue close rate. AST-based parsing reduces token usage vs naive file reading.',
  },
  {
    rank: 5,
    name: 'GLips/Figma-Context-MCP',
    slug: 'GLips--Figma-Context-MCP',
    score: 61.1,
    stars: 13663,
    lang: 'TypeScript',
    contributors: 24,
    lastCommit: '2026-03-11',
    desc: 'Provides Figma layout context to AI coding agents like Cursor',
    useCase: 'Design-to-code',
    highlight: '13K stars demonstrates demand for design-aware coding agents. Best design-to-code bridge in the index.',
  },
  {
    rank: 6,
    name: 'github/github-mcp-server',
    slug: 'github--github-mcp-server',
    score: 60.2,
    stars: 27865,
    lang: 'Go',
    contributors: 111,
    lastCommit: '2026-03-13',
    desc: "GitHub's official MCP Server — repos, issues, PRs, and code search",
    useCase: 'Code access / GitHub',
    highlight: 'Most-starred code tool at 27K. Official GitHub backing. 100 tool definitions built in.',

    }

    .toc {
      background: var(--bg-surface);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 1rem 1.25rem;
      margin-bottom: 2.5rem;
      font-size: 0.82rem;
    }

    .toc strong {
      display: block;
      margin-bottom: 0.6rem;
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-muted);
    }

    .toc ol {
      margin: 0;
      padding-left: 1.2rem;
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }

    .toc a {
      color: var(--text-muted);
    }

    .toc a:hover {
      color: var(--accent);
    }

    section {
      margin-bottom: 3rem;
    }

    section h2 {
      font-size: 1.2rem;
      font-weight: 700;
      margin-bottom: 0.75rem;
      padding-bottom: 0.4rem;
      border-bottom: 2px solid var(--accent);
      display: inline-block;
    }

    section h3 {
      font-size: 0.95rem;
      font-weight: 700;
      margin: 1.5rem 0 0.5rem;
      color: var(--text);
    }

    section p {
      font-size: 0.9rem;
      line-height: 1.75;
      color: var(--text);
      opacity: 0.9;

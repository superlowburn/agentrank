    }

    .inline-link {
      color: var(--accent);
      font-weight: 600;
    }

    .data-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.82rem;
      margin: 1rem 0 1.25rem;
    }

    .data-table th {
      text-align: left;
      font-weight: 600;
      color: var(--text-muted);
      border-bottom: 1px solid var(--border);
      padding: 0.4rem 0.75rem 0.4rem 0;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }

    .data-table td {
      padding: 0.45rem 0.75rem 0.45rem 0;
      border-bottom: 1px solid var(--border);
      color: var(--text);
      vertical-align: top;
    }

    .data-table tr:last-child td {
      border-bottom: none;
    }

    .num {
      text-align: right;
      font-variant-numeric: tabular-nums;
    }

    .rank-num {
      color: var(--text-muted);
      font-weight: 700;
    }

    .top-table .tool-cell {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
    }

    .tool-link {
      font-weight: 600;
      color: var(--accent);
      font-size: 0.82rem;
    }

    .tool-desc {
      font-size: 0.75rem;
      color: var(--text-muted);
      font-weight: 400;
    }

    .score-cell {
      color: var(--accent);
      font-weight: 700;
    }

    .use-case {

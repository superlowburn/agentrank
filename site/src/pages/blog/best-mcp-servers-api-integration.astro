      color: var(--text-muted);
      white-space: nowrap;
    }

    .lang-badge {
      font-size: 0.75rem;
      color: var(--text-muted);
      white-space: nowrap;
    }

    .cta-box {
      background: var(--bg-surface);
      border: 1px solid var(--border);
      border-left: 3px solid var(--accent);
      border-radius: 4px;
      padding: 1rem 1.25rem;
      margin-top: 1.5rem;
    }

    .cta-box p {
      margin-bottom: 0.5rem;
    }

    .cta-box p:last-child {
      margin-bottom: 0;
    }

    .post-footer {

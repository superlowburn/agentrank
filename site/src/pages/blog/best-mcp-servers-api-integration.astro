    }

    .methodology {
      font-size: 0.75rem !important;
      color: var(--text-muted) !important;
      opacity: 1 !important;
    }

    .share-line {
      font-size: 0.82rem !important;
      margin-top: 0.75rem;
    }

    @media (max-width: 640px) {
      .post-header h1 {
        font-size: 1.3rem;
      }

      .data-table {
        font-size: 0.75rem;
      }

      .use-case {
        display: none;
      }
    }
  </style>
</Base>

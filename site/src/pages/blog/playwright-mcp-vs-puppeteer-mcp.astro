      font-weight: 600;
      white-space: nowrap;
    }

    .fw-pw {
      color: var(--accent);
    }

    .fw-pup {
      color: var(--text-muted);
    }

    .table-note {
      font-size: 0.75rem !important;
      color: var(--text-muted) !important;
      margin-top: 0.5rem !important;
    }

    .verdict-box {
      border-radius: 4px;
      padding: 0.875rem 1rem;
      margin-top: 1.25rem;
      font-size: 0.88rem;
      line-height: 1.6;
    }

    .playwright-box {
      background: color-mix(in srgb, var(--accent) 8%, var(--bg-surface));
      border: 1px solid var(--accent);
    }

    .puppeteer-box {
      background: var(--bg-surface);
      border: 1px solid var(--border);
    }

    .verdict-list {
      margin: 0.75rem 0 1rem 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      font-size: 0.9rem;
      line-height: 1.65;
    }

    .code-block {
      background: var(--bg-surface);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 0.875rem 1rem;
      font-size: 0.78rem;
      line-height: 1.6;
      overflow-x: auto;
      margin: 0.75rem 0 1rem;
    }

    .code-block code {
      font-family: monospace;
      color: var(--text);
    }

    .cta-box {
      background: var(--bg-surface);
      border: 1px solid var(--border);
      border-left: 3px solid var(--accent);
      border-radius: 4px;
      padding: 1rem 1.25rem;
      margin-top: 1.5rem;
    }

    .cta-box p {
      margin-bottom: 0.5rem;
      font-size: 0.88rem !important;
    }

    .cta-box p:last-child {
      margin-bottom: 0;
    }

    .post-footer {
      margin-top: 3rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border);
    }

    .methodology {
      font-size: 0.75rem !important;
      color: var(--text-muted) !important;
      opacity: 1 !important;
    }

    .share-line {
      font-size: 0.82rem !important;
      margin-top: 0.75rem;
    }

    @media (max-width: 640px) {
      .post-header h1 {
        font-size: 1.3rem;
      }

      .fw-badge,
      .rank-global {
        display: none;
      }
    }
  </style>
</Base>

  },
  {
    rank: 4,
    name: 'deswong/Openhab-MCP',
    slug: 'deswong--Openhab-MCP',
    score: 57.16,
    stars: 4,
    lang: 'TypeScript',
    contributors: 0,
    lastCommit: '2026-03-13',
    desc: 'Full OpenHAB (v5+) control via MCP — Items, Things, Rules, Persistence, Semantic Tags',
    platform: 'OpenHAB',
    highlight: 'Only OpenHAB MCP server in the index. Full v5+ API coverage including semantic tags. Very fresh (March 2026).',
  },
  {
    rank: 5,
    name: 'voska/hass-mcp',
    slug: 'voska--hass-mcp',
    score: 51.53,
    stars: 284,
    lang: 'Python',
    contributors: 6,
    lastCommit: '2025-08-05',
    desc: 'Home Assistant MCP Server',
    platform: 'Home Assistant',
    highlight: '284 stars, 6 contributors. Earlier project that predates ha-mcp. Useful as a reference implementation.',
  },
  {
    rank: 6,
    name: 'achetronic/hass-mcp',
    slug: 'achetronic--hass-mcp',
    score: 52.03,
    stars: 4,
    lang: 'Go',
    contributors: 0,
    lastCommit: '2026-03-02',
    desc: 'A remote MCP server for Home Assistant to control your home using AI',
    platform: 'Home Assistant',
    highlight: 'The only Home Assistant MCP server written in Go. Designed as a remote server rather than local installation.',
  },
];

const stats = {
  totalHomeAutoTools: 24,
  topScore: 93.13,
  homeAssistantTools: 5,
  otherPlatforms: 2,
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is the best MCP server for Home Assistant?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'homeassistant-ai/ha-mcp scores 93.13 in the AgentRank index — the highest-rated home automation tool. It has 1,190 stars, 18 contributors, and was updated in March 2026. It provides full control of Home Assistant entities, automations, scenes, and scripts through AI agents.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can AI agents control smart home devices through MCP?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. MCP servers for Home Assistant act as a bridge between AI agents and smart home platforms. Through tools like ha-mcp, AI agents can read device states, control lights and thermostats, trigger automations, and manage Home Assistant configuration — all via natural language.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is there an MCP server for OpenHAB?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes — deswong/Openhab-MCP provides full OpenHAB v5+ control via MCP, covering Items, Things, Rules, Persistence, and Semantic Tags. It is the only OpenHAB MCP server currently indexed by AgentRank.',
      },
    },

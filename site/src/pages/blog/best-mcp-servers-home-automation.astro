  description: 'Top-ranked MCP servers for Home Assistant, smart home control, and IoT device management. Real scores from the AgentRank index, updated March 2026.',
  datePublished: publishDate,
  dateModified: publishDate,
  author: {
    '@type': 'Organization',
    name: 'AgentRank',
    url: 'https://agentrank-ai.com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'AgentRank',
    url: 'https://agentrank-ai.com',
    logo: {
      '@type': 'ImageObject',
      url: 'https://agentrank-ai.com/og-image.png',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': 'https://agentrank-ai.com/blog/best-mcp-servers-home-automation/',
  },
  image: 'https://agentrank-ai.com/og/best-mcp-servers-home-automation.png',
  keywords: 'best MCP servers home automation, Home Assistant MCP server, ha-mcp, IoT MCP server, smart home AI agent, home automation AI 2026',
};

const tools = [
  {
    rank: 1,
    name: 'homeassistant-ai/ha-mcp',
    slug: 'homeassistant-ai--ha-mcp',
    score: 93.13,
    stars: 1190,
    lang: 'Python',
    contributors: 18,
    lastCommit: '2026-03-14',
    desc: 'The Unofficial and Awesome Home Assistant MCP Server',
    platform: 'Home Assistant',
    highlight: 'Highest-scoring home automation tool by a wide margin. 1,190 stars, 18 contributors, updated March 2026.',
  },
  {
    rank: 2,
    name: 'Coolver/home-assistant-vibecode-agent',
    slug: 'Coolver--home-assistant-vibecode-agent',
    score: 82.05,
    stars: 482,
    lang: 'Python',
    contributors: 6,
    lastCommit: '2026-03-10',
    desc: 'Home Assistant MCP server agent for IDE integration — automations, dashboards, config via natural language',
    platform: 'Home Assistant',
    highlight: 'Designed for IDE use: Cursor, VS Code, Claude Code. Natural language config management and dashboard design.',
  },
  {
    rank: 3,
    name: 'c1pher-cn/ha-mcp-for-xiaozhi',
    slug: 'c1pher-cn--ha-mcp-for-xiaozhi',

            <td class="num">6,698</td>
            <td class="lang-cell">Rust</td>
          </tr>
        </tbody>
      </table>
      <p>
        <a href="/tools/" class="inline-link">Browse all 25,632 tools &rarr;</a>
      </p>
    </section>

    <section id="languages">
      <h2>Language breakdown (top 5)</h2>
      <table class="data-table">
        <thead>
          <tr>
            <th>Language</th>
            <th class="num">Tools</th>
            <th class="num">Share</th>
            <th>Bar</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Python</td>
            <td class="num">9,874</td>

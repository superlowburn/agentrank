---
export const prerender = true;

import Base from '../../layouts/Base.astro';
import BlogSubscribeCTA from '../../components/BlogSubscribeCTA.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';

const relatedPosts = [
  { href: '/blog/this-week-in-mcp-2026-03-17/', title: 'This Week in MCP — March 17, 2026' },
  { href: '/blog/mcp-server-landscape-q1-2026/', title: 'The MCP Server Landscape: Q1 2026' },
  { href: '/blog/how-to-choose-an-mcp-server/', title: 'How to Choose an MCP Server in 2026' },
];

const publishDate = '2026-03-24';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'This Week in MCP — March 24, 2026',
  description: 'Weekly ecosystem report: 25,632 MCP tools indexed, top 10 rankings reshuffled — PrefectHQ/fastmcp rises from #7 to #1, modelcontextprotocol SDKs surge into the top 10.',
  datePublished: publishDate,
  dateModified: publishDate,
  author: {
    '@type': 'Organization',
    name: 'AgentRank',
    url: 'https://agentrank-ai.com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'AgentRank',
    url: 'https://agentrank-ai.com',
    logo: {
      '@type': 'ImageObject',
      url: 'https://agentrank-ai.com/og-image.png',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': 'https://agentrank-ai.com/blog/this-week-in-mcp-2026-03-24/',
  },
  image: 'https://agentrank-ai.com/og-image.png',
  keywords: 'this week in MCP 2026-03-24, MCP weekly report, MCP server updates March 24 2026, AgentRank weekly, fastmcp, MCP SDK rankings',
};
---

<Base
  title="This Week in MCP — March 24, 2026 | AgentRank"
  description="Weekly ecosystem report: 25,632 MCP tools indexed, top 10 rankings reshuffled — PrefectHQ/fastmcp rises from #7 to #1, modelcontextprotocol SDKs surge into the top 10."
  activeTab="blog"
  keywords="this week in MCP 2026-03-24, MCP weekly report, MCP server updates March 24 2026, AgentRank weekly"
  canonicalUrl="https://agentrank-ai.com/blog/this-week-in-mcp-2026-03-24/"
  jsonLd={jsonLd}
>
  <article class="blog-post">
    <header class="post-header">
      <div class="breadcrumb"><a href="/blog/">Blog</a> <span>/</span></div>
      <h1>This Week in MCP</h1>
      <div class="post-meta">
        <time datetime={publishDate}>March 24, 2026</time>
        <span class="sep">&middot;</span>
        <span>5 min read</span>
        <span class="sep">&middot;</span>
        <span>AgentRank Index</span>
      </div>
      <p class="lede">
        Weekly data from the AgentRank index. Auto-generated from real GitHub signals every Monday.

        <strong>25,632 tools</strong> total,
        and <strong>3,124 agent skills</strong> indexed.
      </p>
    </header>

    <nav class="toc">
      <strong>Contents</strong>
      <ol>
        <li><a href="#stats">Ecosystem stats</a></li>
        <li><a href="#this-week">This week's story</a></li>
        <li><a href="#gainers">Biggest gainers</a></li>
        <li><a href="#drops">Biggest drops</a></li>
        <li><a href="#top10">Current top 10</a></li>
        <li><a href="#languages">Language breakdown</a></li>
        <li><a href="#tweet">Tweet this week</a></li>
      </ol>
    </nav>

    <section id="stats">
      <h2>Ecosystem stats</h2>
      <div class="stats-grid">
        <div class="stat-box">
          <div class="stat-value">25,632</div>
          <div class="stat-label">Tools indexed</div>
        </div>
        <div class="stat-box">
          <div class="stat-value">0</div>
          <div class="stat-label">New this week</div>
        </div>
        <div class="stat-box">
          <div class="stat-value">3,124</div>
          <div class="stat-label">Skills indexed</div>
        </div>
        <div class="stat-box">
          <div class="stat-value">22.6</div>
          <div class="stat-label">Avg score (0&ndash;100)</div>
        </div>
      </div>
    </section>

    <section id="this-week">
      <h2>This week's story</h2>
      <p>
        The top 10 saw its biggest shuffle since AgentRank launched. Seven of ten positions
        changed hands, driven by freshness signals catching up with repositories that had gone
        quiet since January. The scoring model weights <strong>recency of commits</strong> at
        25% — stale repos, even popular ones, pay a price when maintainers go silent.
      </p>
      <p>
        The winners are the tools maintainers are <em>actively shipping</em>:
        <a href="/tool/PrefectHQ--fastmcp/" class="inline-link">PrefectHQ/fastmcp</a> (23.6K stars, Python)
        vaulted from #7 to #1 on the back of sustained commit velocity.
        Anthropic's own <a href="/tools/" class="inline-link">modelcontextprotocol</a> SDKs — Go, Ruby, and the Inspector —
        all cracked the top 10 as official tooling matures.
      </p>
      <p>
        The losers are last week's darlings that have coasted on star counts without shipping.
        <a href="/tool/CoplayDev--unity-mcp/" class="inline-link">CoplayDev/unity-mcp</a> fell from #1 to #20 despite 7,003 stars.
        Stars without freshness is a liability in this index.
      </p>
    </section>

    <section id="gainers">
      <h2>Biggest gainers</h2>
      <p>Tools with the largest rank improvement compared to last week.</p>

      <table class="data-table movers-table">
        <thead>
          <tr>
            <th>Repository</th>
            <th class="num">Prev rank</th>
            <th class="num">Now</th>
            <th class="num">Change</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="tool-cell"><a href="/tool/PrefectHQ--fastmcp/" class="tool-link">PrefectHQ/fastmcp</a></td>
            <td class="num muted">#7</td>
            <td class="num">#1</td>
            <td class="num positive">+6</td>
          </tr>
          <tr>
            <td class="tool-cell"><a href="/tool/mark3labs--mcp-go/" class="tool-link">mark3labs/mcp-go</a></td>
            <td class="num muted">#5</td>
            <td class="num">#2</td>
            <td class="num positive">+3</td>
          </tr>
          <tr>
            <td class="tool-cell"><span class="tool-link">modelcontextprotocol/go-sdk</span></td>
            <td class="num muted">—</td>
            <td class="num">#4</td>
            <td class="num positive">new</td>
          </tr>
          <tr>
            <td class="tool-cell"><span class="tool-link">punkpeye/mcp-proxy</span></td>
            <td class="num muted">—</td>
            <td class="num">#5</td>
            <td class="num positive">new</td>
          </tr>
          <tr>
            <td class="tool-cell"><span class="tool-link">mcp-use/mcp-use</span></td>
            <td class="num muted">—</td>
            <td class="num">#6</td>
            <td class="num positive">new</td>
          </tr>
        </tbody>
      </table>
    </section>

    <section id="drops">
      <h2>Biggest drops</h2>
      <p>Tools with the largest rank decrease compared to last week.</p>
      <table class="data-table movers-table">
        <thead>
          <tr>
            <th>Repository</th>
            <th class="num">Prev rank</th>
            <th class="num">Now</th>
            <th class="num">Change</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="tool-cell"><a href="/tool/CoplayDev--unity-mcp/" class="tool-link">CoplayDev/unity-mcp</a></td>
            <td class="num muted">#1</td>
            <td class="num">#20</td>
            <td class="num negative">&minus;19</td>
          </tr>
          <tr>
            <td class="tool-cell"><a href="/tool/CoderGamester--mcp-unity/" class="tool-link">CoderGamester/mcp-unity</a></td>
            <td class="num muted">#4</td>
            <td class="num">#43</td>
            <td class="num negative">&minus;39</td>
          </tr>
          <tr>
            <td class="tool-cell"><a href="/tool/microsoft--azure-devops-mcp/" class="tool-link">microsoft/azure-devops-mcp</a></td>
            <td class="num muted">#2</td>
            <td class="num">#32</td>
            <td class="num negative">&minus;30</td>
          </tr>
          <tr>
            <td class="tool-cell"><a href="/tool/Pimzino--spec-workflow-mcp/" class="tool-link">Pimzino/spec-workflow-mcp</a></td>
            <td class="num muted">#6</td>
            <td class="num">#29</td>
            <td class="num negative">&minus;23</td>
          </tr>
          <tr>
            <td class="tool-cell"><a href="/tool/samanhappy--mcphub/" class="tool-link">samanhappy/mcphub</a></td>
            <td class="num muted">#9</td>
            <td class="num">#50</td>
            <td class="num negative">&minus;41</td>
          </tr>
        </tbody>
      </table>
    </section>

    <section id="top10">
      <h2>Current top 10</h2>
      <p>
        The highest-scoring tools in the index right now, scored by stars, freshness,

            <td class="num">3,333</td>
            <td class="lang-cell">PHP</td>
          </tr>
          <tr>
            <td class="num rank-cell">#4</td>
            <td class="tool-cell"><span class="tool-link">modelcontextprotocol/go-sdk</span></td>
            <td class="num score-cell">80.92</td>
            <td class="num">4,120</td>
            <td class="lang-cell">Go</td>
          </tr>
          <tr>
            <td class="num rank-cell">#5</td>
            <td class="tool-cell"><span class="tool-link">punkpeye/mcp-proxy</span></td>
            <td class="num score-cell">78.50</td>
            <td class="num">241</td>
            <td class="lang-cell">TypeScript</td>
          </tr>
          <tr>
            <td class="num rank-cell">#6</td>
            <td class="tool-cell"><span class="tool-link">mcp-use/mcp-use</span></td>
            <td class="num score-cell">77.83</td>
            <td class="num">9,434</td>
            <td class="lang-cell">TypeScript</td>
          </tr>
          <tr>
            <td class="num rank-cell">#7</td>
            <td class="tool-cell"><span class="tool-link">punkpeye/fastmcp</span></td>
            <td class="num score-cell">76.44</td>
            <td class="num">2,993</td>
            <td class="lang-cell">TypeScript</td>
          </tr>
          <tr>
            <td class="num rank-cell">#8</td>
            <td class="tool-cell"><span class="tool-link">modelcontextprotocol/ruby-sdk</span></td>
            <td class="num score-cell">76.36</td>
            <td class="num">751</td>
            <td class="lang-cell">Ruby</td>
          </tr>
          <tr>
            <td class="num rank-cell">#9</td>
            <td class="tool-cell"><span class="tool-link">modelcontextprotocol/inspector</span></td>
            <td class="num score-cell">75.26</td>

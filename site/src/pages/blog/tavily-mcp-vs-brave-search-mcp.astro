    }

    .cta-box p:last-child { margin-bottom: 0; }

    .post-footer {
      margin-top: 3rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border);
    }

    .methodology {
      font-size: 0.75rem !important;
      color: var(--text-muted) !important;
      opacity: 1 !important;
    }

    .share-line {
      font-size: 0.82rem !important;
      margin-top: 0.75rem;
    }

    @media (max-width: 640px) {
      .post-header h1 { font-size: 1.3rem; }
      .date-cell, .use-cell { display: none; }
    }
  </style>
</Base>

    .toc a:hover { color: var(--accent); }

    section { margin-bottom: 3rem; }

    section h2 {
      font-size: 1.2rem;
      font-weight: 700;
      margin-bottom: 0.75rem;
      padding-bottom: 0.4rem;
      border-bottom: 2px solid var(--accent);
      display: inline-block;
    }

    section h3 {
      font-size: 0.95rem;
      font-weight: 700;
      margin: 1.5rem 0 0.5rem;
      color: var(--text);
    }


      font-size: 0.88rem;
      line-height: 1.6;
    }

    .fastmcp-box {
      background: color-mix(in srgb, var(--accent) 8%, var(--bg-surface));
      border: 1px solid var(--accent);
    }

    .official-box {
      background: var(--bg-surface);
      border: 1px solid var(--border);
    }

    .verdict-list {
      margin: 0.75rem 0 1rem 1.25rem;

    section h2 {
      font-size: 1.2rem;
      font-weight: 700;
      margin-bottom: 0.75rem;
      padding-bottom: 0.4rem;
      border-bottom: 2px solid var(--accent);
      display: inline-block;
    }

    section h3 {
      font-size: 0.95rem;
      font-weight: 700;
      margin: 1.5rem 0 0.5rem;
      color: var(--text);
    }

    section p {
      font-size: 0.9rem;
      line-height: 1.75;
      color: var(--text);
      opacity: 0.9;
      margin-bottom: 0.9rem;
    }

    .table-wrapper {
      overflow-x: auto;
      margin: 1rem 0 0.5rem;
      -webkit-overflow-scrolling: touch;
    }

    .data-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.82rem;
    }

    .data-table th {
      text-align: left;
      font-weight: 600;
      color: var(--text-muted);
      border-bottom: 1px solid var(--border);
      padding: 0.4rem 0.75rem 0.4rem 0;
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      white-space: nowrap;
    }

    .data-table td {
      padding: 0.45rem 0.75rem 0.45rem 0;
      border-bottom: 1px solid var(--border);
      color: var(--text);
      vertical-align: top;
    }

    .data-table tr:last-child td { border-bottom: none; }

    .row-fastmcp td {
      background: color-mix(in srgb, var(--accent) 4%, transparent);
    }

    .num {
      text-align: right;
      font-variant-numeric: tabular-nums;
    }

    .tool-cell {
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
    }

    .tool-link {
      font-weight: 600;
      color: var(--accent);
      font-size: 0.78rem;
    }

    .tool-meta {
      font-size: 0.7rem;
      color: var(--text-muted);
    }

    .score-cell {
      color: var(--accent);
      font-weight: 700;
    }

    .rank-global {
      color: var(--text-muted);
      font-size: 0.75rem;
    }

    .table-note {
      font-size: 0.75rem !important;

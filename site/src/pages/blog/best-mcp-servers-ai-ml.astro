      font-size: 0.82rem;
    }

    .tool-desc {
      font-size: 0.75rem;
      color: var(--text-muted);
      font-weight: 400;
    }

    .score-cell {
      color: var(--accent);
      font-weight: 700;
    }

    .org-badge, .date-cell {
      font-size: 0.75rem;
      color: var(--text-muted);
      white-space: nowrap;
    }

    .tool-spotlight {
      background: var(--bg-surface);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 0.75rem 1rem;
      margin: 0.75rem 0;
    }

    .spotlight-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 0.4rem;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .score-pill {
      font-size: 0.75rem;
      font-weight: 700;

      font-weight: 600;
      color: var(--text-muted);
      border-bottom: 1px solid var(--border);
      padding: 0.4rem 0.75rem 0.4rem 0;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }


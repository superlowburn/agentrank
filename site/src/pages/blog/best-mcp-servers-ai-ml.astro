      opacity: 0.9;
      padding-left: 1.4rem;
      margin-bottom: 1rem;
    }

    section ul li {
      margin-bottom: 0.4rem;
    }

    .inline-link {
      color: var(--accent);
      font-weight: 600;
    }

    .data-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.82rem;
      margin: 1rem 0 1.25rem;
    }


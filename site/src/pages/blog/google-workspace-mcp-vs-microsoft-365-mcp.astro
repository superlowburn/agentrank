      font-size: 0.78rem;
      line-height: 1.6;
      overflow-x: auto;
      margin: 0.75rem 0 1rem;
    }

    .code-block code {
      font-family: monospace;
      color: var(--text);
    }

    .cta-box {
      background: var(--bg-surface);
      border: 1px solid var(--border);
      border-left: 3px solid var(--accent);
      border-radius: 4px;
      padding: 1rem 1.25rem;

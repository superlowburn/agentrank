    }

    .tool-cell {
      min-width: 200px;
    }

    .tool-link {
      display: block;
      font-weight: 600;
      color: var(--accent);
      text-decoration: none;
      font-size: 0.85rem;
    }

    .tool-link:hover {
      text-decoration: underline;
    }


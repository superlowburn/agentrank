    }

    .methodology {
      font-size: 0.8rem;
      color: var(--text-muted);
      line-height: 1.6;
      margin-bottom: 1rem;
    }

    .share-line {
      font-size: 0.85rem;
      color: var(--text-muted);
    }

    .share-line a {

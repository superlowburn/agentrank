---
export const prerender = true;

import Base from '../../layouts/Base.astro';
import BlogSubscribeCTA from '../../components/BlogSubscribeCTA.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';

const relatedPosts = [
  { href: '/blog/best-mcp-servers-code-generation/', title: 'Best MCP Servers for Code Generation in 2026' },
  { href: '/blog/best-mcp-servers-devops/', title: 'Best MCP Servers for DevOps & Infrastructure in 2026' },
  { href: '/blog/best-mcp-servers-design/', title: 'Best MCP Servers for Design (Figma, UI/UX Workflows) in 2026' },
  { href: '/blog/best-mcp-servers-ai-ml/', title: 'Best MCP Servers for AI & Machine Learning in 2026' },
];

const publishDate = '2026-03-18';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Best MCP Servers for Game Development in 2026 (Unity, Xcode, KiCAD)',
  description: 'The top-ranked MCP servers for game development, including Unity, Unreal Engine, Xcode, and KiCAD. Scored by stars, freshness, issue health, and real usage signals from the AgentRank index.',
  datePublished: publishDate,
  dateModified: publishDate,
  author: {
    '@type': 'Organization',
    name: 'AgentRank',
    url: 'https://agentrank-ai.com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'AgentRank',
    url: 'https://agentrank-ai.com',
    logo: {
      '@type': 'ImageObject',
      url: 'https://agentrank-ai.com/og-image.png',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': 'https://agentrank-ai.com/blog/best-mcp-servers-game-dev/',
  },
  image: 'https://agentrank-ai.com/og/best-mcp-servers-game-dev.png',
  keywords: 'best MCP servers game development, Unity MCP server, Xcode MCP server, KiCAD MCP, Unreal Engine MCP, game dev AI tools 2026',
};

const tools = [
  {
    rank: 1,
    name: 'CoplayDev/unity-mcp',
    slug: 'CoplayDev--unity-mcp',
    score: 98.67,
    stars: 7003,
    lang: 'C#',
    contributors: 43,
    lastCommit: '2026-03-12',
    desc: 'AI assistant bridge for Unity Editor — manage assets, scenes, scripts, and tasks',
    useCase: 'Unity Editor',
    highlight: 'Rank #1 in the entire AgentRank index. 7,003 stars and 43 contributors.',
  },
  {
    rank: 2,
    name: 'CoderGamester/mcp-unity',
    slug: 'CoderGamester--mcp-unity',
    score: 96.37,
    stars: 1412,
    lang: 'C#',
    contributors: 20,
    lastCommit: '2026-03-10',
    desc: 'MCP plugin to connect with Unity Editor — designed for Cursor, Claude Code, Codex, Windsurf',
    useCase: 'Unity Editor',
    highlight: 'Rank #4 overall. IDE-first design optimized for Cursor and Claude Code workflows.',
  },
  {
    rank: 3,
    name: 'IvanMurzak/Unity-MCP',
    slug: 'IvanMurzak--Unity-MCP',
    score: 93.58,
    stars: 1287,
    lang: 'C#',
    contributors: 15,
    lastCommit: '2026-03-14',
    desc: 'AI-powered bridge connecting LLMs and agents to the Unity Editor via MCP',
    useCase: 'Unity Editor',
    highlight: 'Most recently updated Unity server. Apache-2.0 license, 15 contributors.',
  },
  {
    rank: 4,
    name: 'mixelpixx/KiCAD-MCP-Server',
    slug: 'mixelpixx--KiCAD-MCP-Server',
    score: 93.28,
    stars: 441,
    lang: 'Python',
    contributors: 11,
    lastCommit: '2026-03-11',
    desc: 'MCP implementation enabling LLMs to interact with KiCAD for PCB design',
    useCase: 'PCB / Hardware',
    highlight: 'Rank #15 overall. The only high-scoring hardware design MCP server in the index.',
  },
  {
    rank: 5,
    name: 'ChiR24/Unreal_mcp',
    slug: 'ChiR24--Unreal_mcp',
    score: 86.21,
    stars: 371,
    lang: 'C++',
    contributors: 8,
    lastCommit: '2026-03-13',
    desc: 'MCP server enabling AI assistants to control Unreal Engine via C++ Automation Bridge',
    useCase: 'Unreal Engine',
    highlight: 'Rank #75 overall. Native C++ Automation Bridge — no Python shims.',
  },
  {
    rank: 6,
    name: 'getsentry/XcodeBuildMCP',
    slug: 'getsentry--XcodeBuildMCP',
    score: 79.64,
    stars: 4720,
    lang: 'TypeScript',
    contributors: 32,
    lastCommit: '2026-03-12',
    desc: 'MCP server and CLI providing tools for agent use on iOS and macOS projects',
    useCase: 'iOS / macOS',
    highlight: '4,720 stars, 32 contributors, maintained by Sentry. Best tool for iOS/macOS agent workflows.',
  },
];

const stats = {
  totalGameDevTools: 178,
  avgGameDevScore: 37.7,
  topScore: 98.67,
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is the best MCP server for Unity development?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'CoplayDev/unity-mcp is the #1 ranked tool in the entire AgentRank index with a score of 98.67, 7,003 stars, and 43 contributors. It lets AI assistants like Claude and Cursor interact directly with the Unity Editor to manage assets, scenes, and scripts.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is there an MCP server for Unreal Engine?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes — ChiR24/Unreal_mcp is the top-scoring Unreal Engine MCP server in the AgentRank index (score 86.21, rank #75 overall). It connects AI assistants to UE5 through a native C++ Automation Bridge plugin.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can Claude build iOS apps with an MCP server?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes — getsentry/XcodeBuildMCP (score 79.64, 4,720 stars) provides tools for building, testing, and working with Xcode projects. It is maintained by the Sentry team with 32 contributors and is the most-starred iOS/macOS MCP server in the index.',
      },
    },
    {
      '@type': 'Question',
      name: 'What are the differences between the three Unity MCP servers?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'CoplayDev/unity-mcp (score 98.67) is the highest-ranked and most starred (7,003). CoderGamester/mcp-unity (score 96.37) is built specifically for IDE integrations like Cursor and Claude Code. IvanMurzak/Unity-MCP (score 93.58) is the most recently updated and uses the Apache-2.0 license. All three are active and in the top 15 overall.',
      },
    },
  ],
};
---

<Base
  title="Best MCP Servers for Game Development in 2026 (Unity, Xcode, KiCAD) — AgentRank"
  description="The top-ranked MCP servers for game development: Unity Editor, Unreal Engine, iOS/Xcode, and KiCAD PCB design. Scored by real signals — updated March 2026."
  activeTab="blog"
  keywords="best MCP servers game development, Unity MCP server, Xcode MCP server, KiCAD MCP, Unreal Engine MCP, game dev AI tools 2026, iOS MCP server"
  canonicalUrl="https://agentrank-ai.com/blog/best-mcp-servers-game-dev/"
  jsonLd={[jsonLd, faqJsonLd]}
  ogImage="/og/best-mcp-servers-game-dev.png"
>
  <article class="blog-post">
    <header class="post-header">
      <div class="breadcrumb"><a href="/blog/">Blog</a> <span>/</span></div>
      <h1>Best MCP Servers for Game Development in 2026</h1>
      <div class="post-meta">
        <time datetime={publishDate}>March 18, 2026</time>
        <span class="sep">&middot;</span>
        <span>5 min read</span>
        <span class="sep">&middot;</span>
        <span>AgentRank Index</span>
      </div>
      <p class="lede">
        Game development is one of the strongest MCP adoption stories in the ecosystem — and the rankings
        show it. The <strong>#1 ranked tool in the entire AgentRank index</strong> is a Unity MCP server
        with 7,003 stars. We indexed <strong>{stats.totalGameDevTools} game-dev-related tools</strong>.
        These are the ones that score high enough to depend on.
      </p>
    </header>

    <nav class="toc">
      <strong>Contents</strong>
      <ol>
        <li><a href="#rankings">Rankings by score</a></li>
        <li><a href="#unity">Unity (three servers compared)</a></li>
        <li><a href="#ios-macos">iOS &amp; macOS (XcodeBuildMCP)</a></li>
        <li><a href="#unreal">Unreal Engine</a></li>
        <li><a href="#kicad">KiCAD &amp; hardware design</a></li>
        <li><a href="#what-to-watch">What to watch for</a></li>
        <li><a href="#methodology">Methodology</a></li>
      </ol>
    </nav>

    <section id="rankings">
      <h2>Top game dev MCP servers</h2>
      <p>
        Ranked by the composite AgentRank score — a weighted blend of stars (15%), freshness (25%),
        issue health (25%), contributors (10%), and inbound dependents (25%).
        Average score across all {stats.totalGameDevTools} game-dev tools is <strong>{stats.avgGameDevScore}</strong>.
        The tools below are in the top tier.
      </p>

      <table class="data-table top-table">
        <thead>
          <tr>
            <th class="num">#</th>
            <th>Repository</th>
            <th class="num">Score</th>
            <th class="num">Stars</th>
            <th>Use Case</th>
            <th>Lang</th>
          </tr>
        </thead>
        <tbody>
          {tools.map((tool) => (
            <tr>
              <td class="num rank-num">{tool.rank}</td>
              <td class="tool-cell">
                <a href={`/tool/${tool.slug}/`} class="tool-link">{tool.name}</a>
                <span class="tool-desc">{tool.desc}</span>
              </td>
              <td class="num score-cell">{tool.score}</td>
              <td class="num">{tool.stars.toLocaleString('en-US')}</td>
              <td class="use-case">{tool.useCase}</td>
              <td class="lang-badge">{tool.lang}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <section id="unity">
      <h2>Unity: three servers, one clear leader</h2>
      <p>
        Unity has three separate MCP servers in the top 15 overall — an unusual concentration at the top
        of the index. They are not interchangeable; each has a distinct focus.
      </p>

      <h3>CoplayDev/unity-mcp — rank #1 overall</h3>
      <p>
        <a href="/tool/CoplayDev--unity-mcp/" class="inline-link">CoplayDev/unity-mcp</a> scores
        <strong>98.67</strong> — the highest score of any tool in the entire AgentRank index. It works as
        a bridge between AI assistants (Claude, Cursor) and the Unity Editor over a local MCP connection.
        The server exposes tools for managing assets, controlling scenes, editing scripts, and automating
        editor tasks. 7,003 stars and 43 contributors make it the most validated game dev MCP tool in
        existence. If you use Unity, start here.
      </p>

      <h3>CoderGamester/mcp-unity — rank #4 overall</h3>
      <p>
        <a href="/tool/CoderGamester--mcp-unity/" class="inline-link">CoderGamester/mcp-unity</a> scores
        <strong>96.37</strong> with 1,412 stars and 20 contributors. Where CoplayDev/unity-mcp is general-purpose,
        mcp-unity is built specifically for IDE-native workflows — it explicitly targets Cursor, Claude Code,
        Codex, and Windsurf. If your Unity workflow lives inside an AI coding IDE rather than a standalone
        Claude Desktop session, this server is designed for your setup. Low open issue count (4 open,
        65 closed) signals a responsive maintainer.
      </p>

      <h3>IvanMurzak/Unity-MCP — rank #14 overall</h3>
      <p>
        <a href="/tool/IvanMurzak--Unity-MCP/" class="inline-link">IvanMurzak/Unity-MCP</a> scores
        <strong>93.58</strong> with 1,287 stars and 15 contributors. It positions itself as a tool for
        advanced AI agents — LLMs that generate code, debug errors, and automate game development tasks
        inside your Unity project. The Apache-2.0 license (vs MIT on the other two) matters if your
        organization has license restrictions. Last commit was March 14 — the most recently updated of
        the three.
      </p>

      <div class="cta-box">
        <p>
          <strong>Which Unity server should you pick?</strong> CoplayDev/unity-mcp if you want maximum adoption signals.
          CoderGamester/mcp-unity if you work in Cursor or Claude Code. IvanMurzak/Unity-MCP if you need
          Apache-2.0 licensing or want the most active commit stream.
        </p>
      </div>
    </section>

    <section id="ios-macos">
      <h2>iOS &amp; macOS: XcodeBuildMCP</h2>
      <p>
        <a href="/tool/getsentry--XcodeBuildMCP/" class="inline-link">getsentry/XcodeBuildMCP</a> scores
        <strong>79.64</strong> with 4,720 stars and 32 contributors. It is the only high-scoring iOS/macOS
        development MCP server in the index and it is maintained by the Sentry engineering team — not a
        solo developer project.
      </p>
      <p>
        The server provides a CLI alongside the MCP protocol surface, targeting agent use cases: building
        Xcode projects, running tests, reading build output, and working with iOS and macOS project
        structures. 98 closed issues against 12 open (89% close rate) is a strong signal of active
        maintenance. If you are shipping iOS apps and want Claude or Cursor to participate in the
        build-and-test loop, this is the tool.
      </p>
      <p>
        Note the score gap: XcodeBuildMCP scores 79.64 vs the Unity servers at 93-98. The gap is almost
        entirely explained by inbound dependents — Unity tools have more downstream repos depending on them.
        The XcodeBuildMCP maintenance signal is excellent; this is not a quality gap.
      </p>
    </section>

    <section id="unreal">
      <h2>Unreal Engine</h2>
      <p>
        <a href="/tool/ChiR24--Unreal_mcp/" class="inline-link">ChiR24/Unreal_mcp</a> scores
        <strong>86.21</strong> — rank #75 overall. It connects AI assistants to Unreal Engine through
        a native C++ Automation Bridge plugin, using TypeScript as the MCP server layer and C++ for
        the engine integration. 371 stars and 8 contributors.
      </p>
      <p>
        The Unreal ecosystem does not yet have the Unity-level adoption density — one server dominates
        where Unity has three. Unreal_mcp is a community project (not from Epic Games), but the recent
        commit activity (last commit March 13) and reasonable issue health (36 closed vs 13 open) suggest
        an active maintainer. If you are on Unreal, this is the only option in the high-score tier.
      </p>
    </section>

    <section id="kicad">
      <h2>KiCAD &amp; hardware design</h2>
      <p>
        <a href="/tool/mixelpixx--KiCAD-MCP-Server/" class="inline-link">mixelpixx/KiCAD-MCP-Server</a> scores
        <strong>93.28</strong> — rank #15 overall. KiCAD is PCB design software, which makes this the
        only hardware/electronics design tool in the top 20 of the entire index.
      </p>
      <p>
        The server lets Claude interact directly with KiCAD: create and modify schematics, manage PCB
        layouts, and automate design tasks that would otherwise require manual navigation of the KiCAD
        GUI. 441 stars and 11 contributors with a 91% issue close rate (32 closed, 3 open). The Python
        implementation keeps setup simple for the typical KiCAD user who is comfortable in a Python
        environment.
      </p>
      <p>
        The hardware design category is sparse in the MCP ecosystem — KiCAD-MCP-Server has essentially
        no competition at this score tier. If you do PCB design and want to bring AI into that workflow,
        this is the clear pick.
      </p>
    </section>

    <section id="what-to-watch">
      <h2>What to watch for</h2>

      <h3>Three Unity servers is unusual</h3>
      <p>
        Most tool categories in the index have one dominant server and several low-scoring alternatives.
        Unity has three servers in the top 15 overall, all scoring above 93. This signals both the size
        of the Unity developer community adopting MCP and the fact that each server is solving a slightly
        different workflow. Consolidation may happen; for now, pick based on your IDE and licensing
        requirements, not just stars.
      </p>

      <h3>Score vs stars diverge sharply here</h3>
      <p>
        <a href="/tool/getsentry--XcodeBuildMCP/" class="inline-link">getsentry/XcodeBuildMCP</a> has
        4,720 stars but scores 79.64. <a href="/tool/mixelpixx--KiCAD-MCP-Server/" class="inline-link">mixelpixx/KiCAD-MCP-Server</a>
        has only 441 stars but scores 93.28 — nearly as high as the #1 Unity server. Stars reflect community
        size; the AgentRank score reflects maintenance quality and ecosystem integration. The KiCAD server
        punches far above its star count because the maintainer closes issues fast and keeps commits recent.
      </p>

      <h3>Godot is underserved</h3>
      <p>
        Coding-Solo/godot-mcp has 2,339 stars but scores 61.37 (rank #439). The contributor count is low
        (7) and the issue health lags the Unity and KiCAD tools. The Godot ecosystem is large enough that
        a high-quality MCP server should eventually emerge — this is a gap in the current index.
      </p>

      <div class="cta-box">
        <p>
          <strong>Browse the full game dev category:</strong> <a href="/?q=game+dev">Search game dev tools</a> —
          {stats.totalGameDevTools} tools indexed, scored, and updated daily.
        </p>
        <p>
          <strong>Building a game engine MCP server?</strong> <a href="/submit/">Submit it</a> to get indexed and scored.
        </p>
      </div>
    </section>

    <RelatedPosts posts={relatedPosts} />
    <BlogSubscribeCTA source="blog" />
    <footer class="post-footer">
      <p class="methodology">
        <strong>Methodology:</strong> Data from the AgentRank index crawled March 2026.
        Scores computed using: stars 15%, freshness 25%, issue health 25%, contributors 10%, inbound dependents 25%.
        Tools classified as "game development" via keyword matching on description, topics, and repo name.
        Only non-archived repositories included.
      </p>
      <p class="share-line">
        Found this useful? <a href="https://x.com/AgentRank_ai" target="_blank" rel="noopener noreferrer">Follow @AgentRank_ai</a> for
        weekly ecosystem updates, biggest movers, and new tool spotlights.
      </p>
    </footer>
  </article>

  <style>
    .blog-post {
      max-width: 720px;
      margin: 0 auto;
      padding: 2rem 0 3rem;
    }

    .breadcrumb {
      font-size: 0.78rem;
      color: var(--text-muted);
      margin-bottom: 0.75rem;
    }

    .breadcrumb span {
      margin: 0 0.25rem;
      opacity: 0.5;
    }

    .post-header {
      margin-bottom: 2rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--border);
    }

    .post-header h1 {
      font-size: 1.6rem;
      font-weight: 700;
      line-height: 1.3;
      margin-bottom: 0.75rem;
    }

    .post-meta {
      font-size: 0.78rem;
      color: var(--text-muted);
      display: flex;
      align-items: center;
      gap: 0.4rem;
      flex-wrap: wrap;
      margin-bottom: 1rem;
    }

    .sep {
      opacity: 0.4;
    }

    .lede {
      font-size: 1rem;
      line-height: 1.7;
      color: var(--text);
      opacity: 0.9;
    }

    .toc {
      background: var(--bg-surface);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 1rem 1.25rem;
      margin-bottom: 2.5rem;
      font-size: 0.82rem;
    }

    .toc strong {
      display: block;
      margin-bottom: 0.6rem;
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-muted);
    }

    .toc ol {
      margin: 0;
      padding-left: 1.2rem;
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }

    .toc a {
      color: var(--text-muted);
    }

    .toc a:hover {
      color: var(--accent);
    }

    section {
      margin-bottom: 3rem;
    }

    section h2 {
      font-size: 1.2rem;
      font-weight: 700;
      margin-bottom: 0.75rem;
      padding-bottom: 0.4rem;
      border-bottom: 2px solid var(--accent);
      display: inline-block;
    }

    section h3 {
      font-size: 0.95rem;
      font-weight: 700;
      margin: 1.5rem 0 0.5rem;
      color: var(--text);
    }

    section p {
      font-size: 0.9rem;
      line-height: 1.75;
      color: var(--text);
      opacity: 0.9;
      margin-bottom: 0.9rem;
    }

    .inline-link {
      color: var(--accent);
      font-weight: 600;
    }

    .data-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.82rem;
      margin: 1rem 0 1.25rem;
    }

    .data-table th {
      text-align: left;
      font-weight: 600;
      color: var(--text-muted);
      border-bottom: 1px solid var(--border);
      padding: 0.4rem 0.75rem 0.4rem 0;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }

    .data-table td {
      padding: 0.45rem 0.75rem 0.45rem 0;
      border-bottom: 1px solid var(--border);
      color: var(--text);
      vertical-align: top;
    }

    .data-table tr:last-child td {
      border-bottom: none;
    }

    .num {
      text-align: right;
      font-variant-numeric: tabular-nums;
    }

    .rank-num {
      color: var(--text-muted);
      font-weight: 700;
    }

    .top-table .tool-cell {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
    }

    .tool-link {
      font-weight: 600;
      color: var(--accent);
      font-size: 0.82rem;
    }

    .tool-desc {
      font-size: 0.75rem;
      color: var(--text-muted);
      font-weight: 400;
    }

    .score-cell {
      color: var(--accent);
      font-weight: 700;
    }

    .use-case {
      font-size: 0.75rem;
      color: var(--text-muted);
      white-space: nowrap;
    }

    .lang-badge {
      font-size: 0.75rem;
      color: var(--text-muted);
      white-space: nowrap;
    }

    .cta-box {
      background: var(--bg-surface);
      border: 1px solid var(--border);
      border-left: 3px solid var(--accent);
      border-radius: 4px;
      padding: 1rem 1.25rem;
      margin-top: 1.5rem;
    }

    .cta-box p {
      margin-bottom: 0.5rem;
    }

    .cta-box p:last-child {
      margin-bottom: 0;
    }

    .post-footer {
      margin-top: 3rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border);
    }

    .methodology {
      font-size: 0.75rem !important;
      color: var(--text-muted) !important;
      opacity: 1 !important;
    }

    .share-line {
      font-size: 0.82rem !important;
      margin-top: 0.75rem;
    }

    @media (max-width: 640px) {
      .post-header h1 {
        font-size: 1.3rem;
      }

      .data-table {
        font-size: 0.75rem;
      }

      .use-case {
        display: none;
      }
    }
  </style>
</Base>

      font-size: 0.9rem;
      line-height: 1.75;
      color: var(--text);
      opacity: 0.9;
      margin-bottom: 0.9rem;
    }

    /* Comparison table */
    .table-wrapper {
      overflow-x: auto;
      margin: 1rem 0 0.5rem;

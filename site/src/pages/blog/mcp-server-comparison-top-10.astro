    }

    .data-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.82rem;
    }

    .data-table th {
      text-align: left;
      font-weight: 600;
      color: var(--text-muted);
      border-bottom: 1px solid var(--border);
      padding: 0.4rem 0.75rem 0.4rem 0;
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      white-space: nowrap;
    }

    .data-table td {
      padding: 0.45rem 0.75rem 0.45rem 0;
      border-bottom: 1px solid var(--border);
      color: var(--text);
      vertical-align: top;
    }

    .data-table tr:last-child td {
      border-bottom: none;
    }

    .num {
      text-align: right;
      font-variant-numeric: tabular-nums;
    }

    .rank-num {
      color: var(--text-muted);
      font-weight: 700;
    }

    .tool-cell {
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
    }

    .tool-link {
      font-weight: 600;
      color: var(--accent);
      font-size: 0.78rem;
    }

    .tool-meta {
      font-size: 0.7rem;
      color: var(--text-muted);
    }

    .score-cell {
      color: var(--accent);
      font-weight: 700;
    }

    .close-rate {
      color: var(--text-muted);
    }

    .cat-badge {
      font-size: 0.72rem;
      color: var(--text-muted);
      white-space: nowrap;
    }

    .table-note {
      font-size: 0.75rem !important;
      color: var(--text-muted) !important;
      margin-top: 0.5rem !important;
    }

    /* Insights */
    .insight-list {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      margin-top: 1rem;
    }

    .insight-card {
      border-left: 3px solid var(--accent);
      padding: 0.75rem 0 0.75rem 1rem;
    }

    .insight-card h3 {
      margin-top: 0 !important;
      margin-bottom: 0.4rem !important;
    }

    .insight-card p {
      margin-bottom: 0 !important;
      font-size: 0.85rem !important;
    }

    /* Tool profiles */
    .tool-profile {
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 0.875rem 1rem;
      margin-bottom: 0.75rem;
    }

    .profile-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 0.5rem;
    }

    .profile-name {
      font-weight: 700;
      font-size: 0.85rem;
      color: var(--accent);
    }

    .profile-score {
      font-weight: 700;
      font-size: 0.85rem;
      color: var(--accent);
    }

    .profile-signals {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-bottom: 0.6rem;
    }

    .sig {
      font-size: 0.75rem;
      color: var(--text-muted);
    }

    .sig-label {
      font-weight: 600;

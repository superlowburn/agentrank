  dateModified: publishDate,
  author: {
    '@type': 'Organization',
    name: 'AgentRank',
    url: 'https://agentrank-ai.com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'AgentRank',
    url: 'https://agentrank-ai.com',

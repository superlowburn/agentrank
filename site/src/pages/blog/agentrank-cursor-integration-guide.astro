    letter-spacing: 0.03em;
  }

  .data-table td {
    padding: 0.45rem 0.75rem 0.45rem 0;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    vertical-align: top;
  }

  .data-table tr:last-child td { border-bottom: none; }

  .feature-list {
    padding-left: 0;
    list-style: none;
  }


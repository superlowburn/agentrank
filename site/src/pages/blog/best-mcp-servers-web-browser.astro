      font-variant-numeric: tabular-nums;
    }

    .rank-num {
      color: var(--text-muted);
      font-weight: 700;
    }

    .top-table .tool-cell {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
    }

    .tool-link {
      font-weight: 600;

      padding: 2rem 0 3rem;
    }

    .breadcrumb {
      font-size: 0.78rem;
      color: var(--text-muted);
      margin-bottom: 0.75rem;
    }

    .breadcrumb span {
      margin: 0 0.25rem;
      opacity: 0.5;
    }

    .post-header {
      margin-bottom: 2rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--border);
    }

    .post-header h1 {
      font-size: 1.6rem;
      font-weight: 700;
      line-height: 1.3;
      margin-bottom: 0.75rem;
    }

    .post-meta {
      font-size: 0.78rem;
      color: var(--text-muted);

};

const tools = [
  {
    rank: 1,
    name: 'microsoft/playwright-mcp',
    slug: 'microsoft--playwright-mcp',
    score: 85.0,
    stars: 28849,
    lang: 'TypeScript',
    contributors: 52,
    lastCommit: '2026-03-14',
    desc: 'Official Microsoft Playwright MCP server — browser automation via accessibility tree, not pixel screenshots',
    useCase: 'Browser Automation',
    highlight: '28,849 stars. Microsoft-maintained. Uses Playwright accessibility tree for reliable, vision-free browser control.',
  },
  {
    rank: 2,
    name: 'ChromeDevTools/devtools-mcp',
    slug: 'ChromeDevTools--devtools-mcp',
    score: 69.2,
    stars: 3807,
    lang: 'TypeScript',
    contributors: 24,
    lastCommit: '2026-03-14',
    desc: 'Official Chrome DevTools MCP — control and inspect a live Chrome browser via the DevTools Protocol',
    useCase: 'Browser Inspection / CDP',
    highlight: 'Maintained by the Chrome DevTools team. Exposes the full Chrome DevTools Protocol to AI agents.',
  },
  {
    rank: 3,
    name: 'apify/apify-mcp-server',
    slug: 'apify--apify-mcp-server',
    score: 64.4,
    stars: 899,
    lang: 'TypeScript',
    contributors: 14,
    lastCommit: '2026-03-13',

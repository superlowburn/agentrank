    score: 39.9,
    stars: 8,
    lang: 'JavaScript',
    contributors: 3,
    lastCommit: '2026-02-16',
    desc: 'Puppeteer-based Chrome MCP server with persistent sessions — navigate, click, fill forms, extract content',
    useCase: 'Puppeteer Automation',
    highlight: 'Puppeteer alternative to Playwright-MCP. Persistent session support — useful for multi-step form automation.',

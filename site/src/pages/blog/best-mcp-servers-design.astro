---
export const prerender = true;

import Base from '../../layouts/Base.astro';
import BlogSubscribeCTA from '../../components/BlogSubscribeCTA.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import RelatedCategories from '../../components/RelatedCategories.astro';

const relatedPosts = [
  { href: '/blog/best-mcp-servers-code-generation/', title: 'Best MCP Servers for Code Generation in 2026' },
  { href: '/blog/best-mcp-servers-productivity/', title: 'Best MCP Servers for Productivity in 2026' },

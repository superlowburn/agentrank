---
import Base from '../layouts/Base.astro';
---

<Base title="404 — Page Not Found | AgentRank" description="The page you're looking for doesn't exist. Search AgentRank to find the best MCP servers and AI agent tools.">
  <div class="not-found">
    <div class="error-code">404</div>
    <h2 class="error-title">Page not found</h2>
    <p class="error-sub">That URL doesn't exist. Try searching for a tool or skill below.</p>

    <form class="search-form" action="/tools/" method="get">
      <input
        type="text"
        name="q"
        class="search-input"
        placeholder="Search tools and skills..."
        autofocus
      />
      <button type="submit" class="search-btn">Search</button>
    </form>

    <nav class="nav-links" aria-label="Helpful links">
      <a href="/">Skills leaderboard</a>
      <a href="/tools/">Tools leaderboard</a>
      <a href="/blog/">Blog</a>
      <a href="/submit/">Submit a tool</a>
    </nav>
  </div>
</Base>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 50vh;
    text-align: center;
    gap: 1.25rem;
    padding: 3rem 1rem;
  }

  .error-code {
    font-size: 5rem;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
    opacity: 0.6;
  }

  .error-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text);
  }

  .error-sub {
    color: var(--text-muted);
    font-size: 0.9rem;
    max-width: 36ch;
  }

  .search-form {
    display: flex;
    gap: 0.5rem;
    width: 100%;
    max-width: 420px;
    margin-top: 0.5rem;
  }

  .search-input {
    flex: 1;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.5rem 0.75rem;
    font-family: inherit;
    font-size: 0.85rem;
    color: var(--text);
    outline: none;
  }

  .search-input:focus {
    border-color: var(--accent);
  }

  .search-btn {
    background: var(--accent);
    color: #000;
    border: none;
    border-radius: 4px;
    padding: 0.5rem 1rem;
    font-family: inherit;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
  }

  .search-btn:hover {
    opacity: 0.85;
  }

  .nav-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .nav-links a {
    color: var(--text-muted);
    font-size: 0.8rem;
  }

  .nav-links a:hover {
    color: var(--accent);
  }
</style>

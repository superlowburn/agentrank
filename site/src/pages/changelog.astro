---
export const prerender = false;

import Base from '../layouts/Base.astro';

const { env } = Astro.locals.runtime;

// ── Ecosystem stats ───────────────────────────────────────────────────────────
interface StatsRow {
  total_tools: number;
  avg_score: number;
  total_skills: number;
}

let stats: StatsRow = { total_tools: 0, avg_score: 0, total_skills: 0 };
let latestSnapshotDate: string | null = null;
let newThisWeekCount = 0;
let totalCategories = 0;

const today = new Date().toISOString().slice(0, 10);
const weekAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);

try {
  const latestRow = await env.DB.prepare(
    `SELECT MAX(snapshot_date) as d FROM rank_history`
  ).first<{ d: string | null }>();
  latestSnapshotDate = latestRow?.d ?? null;
} catch { /* rank_history not yet populated */ }

if (latestSnapshotDate) {
  try {
    const statsRow = await env.DB.prepare(
      `SELECT
         SUM(CASE WHEN tool_type = 'tool' THEN 1 ELSE 0 END) as total_tools,
         AVG(CASE WHEN tool_type = 'tool' THEN score ELSE NULL END) as avg_score,
         SUM(CASE WHEN tool_type = 'skill' THEN 1 ELSE 0 END) as total_skills
       FROM rank_history WHERE snapshot_date = ?`
    ).bind(latestSnapshotDate).first<StatsRow>();

    if (statsRow) {
      stats = {
        total_tools: statsRow.total_tools ?? 0,
        avg_score: Math.round((statsRow.avg_score ?? 0) * 10) / 10,
        total_skills: statsRow.total_skills ?? 0,
      };
    }

    // New tools: first seen in any snapshot (no older entry)
    const newCountRow = await env.DB.prepare(
      `SELECT COUNT(*) as cnt FROM (
         SELECT cur.tool_full_name FROM rank_history cur
         WHERE cur.snapshot_date = ?1 AND cur.tool_type = 'tool'
           AND NOT EXISTS (
             SELECT 1 FROM rank_history old
             WHERE old.tool_full_name = cur.tool_full_name
               AND old.tool_type = cur.tool_type
               AND old.snapshot_date < ?1
           )
       )`
    ).bind(latestSnapshotDate).first<{ cnt: number }>();
    newThisWeekCount = newCountRow?.cnt ?? 0;
  } catch { /* ignore */ }
}

// Category count from tools table
try {
  const catRow = await env.DB.prepare(
    `SELECT COUNT(DISTINCT topics) as cnt FROM tools WHERE topics IS NOT NULL AND topics != ''`
  ).first<{ cnt: number }>();
  totalCategories = catRow?.cnt ?? 0;
  // Cap at a reasonable number — topics is a comma-separated field so the raw distinct count is huge
  if (totalCategories > 200) totalCategories = 0; // fallback: skip if raw topics field
} catch { /* ignore */ }

// ── Product updates (hardcoded, newest first) ─────────────────────────────────
const productUpdates = [
  {
    date: '2026-03-18',
    version: 'Sprint 12',
    title: 'FAQ page, monthly index blog, dev.to cross-posts, developer tutorial',
    items: [
      '/faq page with FAQPage schema markup (20+ questions)',
      'Monthly index blog posts — ecosystem state reports auto-generated from data',
      'Developer tutorial blog post series',
      'dev.to cross-posting pipeline for blog content distribution',
    ],
    tag: 'content',
  },
  {
    date: '2026-03-15',
    version: 'Sprint 11',
    title: '/alternatives programmatic SEO — 100 comparison pages',
    items: [
      '/alternatives/[slug] pages for the top 100 indexed tools',
      'Structured comparison data: category peers, score deltas, feature tags',
      'AlternativeTo-style JSON-LD with ItemList schema',
      'Internal linking from tool detail pages',
    ],
    tag: 'seo',
  },
  {
    date: '2026-03-12',
    version: 'Sprint 10',
    title: '/trends weekly dashboard and /movers page',
    items: [
      '/trends dashboard: biggest score gainers and losers vs 7-day prior snapshot',
      'New entrants section: tools appearing in the index for the first time',
      'Category momentum heatmap — which categories are trending up',
      '/movers weekly digest as standalone page',
    ],
    tag: 'feature',
  },
  {
    date: '2026-03-10',
    version: 'Sprint 9',
    title: 'MCP server security best-practices blog + CORS hardening',
    items: [
      'Published MCP server security best practices guide',
      '/badges redirect page with canonical badge URLs',
      'CORS headers added to all /api/badge/* endpoints',
      'Badge embed previews on tool and skill detail pages',
    ],
    tag: 'security',
  },
  {
    date: '2026-03-05',
    version: 'Sprint 8',
    title: 'API v2 — 13 endpoints, versioned schema, rate limiting',
    items: [
      '13 REST endpoints: /api/tools, /api/skills, /api/search, /api/score, /api/badge, /api/compare, and more',
      'Versioned API schema with OpenAPI 3.1 spec at /api-docs',
      'API key auth with rate limiting (100 req/min free, 1000 req/min Pro)',
      'MCP server published to npm: @agentrank/mcp-server',
    ],
    tag: 'api',
  },
  {
    date: '2026-02-28',
    version: 'Sprint 7',
    title: 'GitHub badge system — embed live scores in READMEs',
    items: [
      'SVG badge endpoint: /api/badge/{owner}/{repo}.svg',
      'Shields.io-compatible endpoint variant',
      'Badge generator UI at /badges with copy-paste snippets',
      'Dynamic score color coding (green ≥70, yellow 40–70, red <40)',
    ],
    tag: 'feature',
  },
  {
    date: '2026-02-20',
    version: 'Sprint 6',
    title: 'Score comparison pages and category indexes',
    items: [
      '/category/[slug] pages for all indexed categories',
      'Side-by-side score comparisons on tool detail pages',
      'Signal breakdown radar chart (stars, freshness, issue health, contributors, dependents)',
      '30-day score sparkline on every tool and skill page',
    ],
    tag: 'feature',
  },
  {
    date: '2026-02-10',
    version: 'Sprint 4–5',
    title: 'Request logging, analytics dashboard, nightly pipeline',
    items: [
      'Request logging to D1 — every API call recorded with latency and status',
      'Internal analytics dashboard with hourly request charts',
      'Nightly scoring pipeline via Cloudflare Workers Cron',
      '25,000+ tools and 13,000+ skills indexed from GitHub',
    ],
    tag: 'infra',
  },
  {
    date: '2026-01-25',
    version: 'v1.0',
    title: 'AgentRank launches — ranked index of every MCP server on GitHub',
    items: [
      'GitHub crawler: queries mcp-server, model-context-protocol, agent-tool across all repos',
      '5-signal composite score: stars, freshness, issue health, contributors, dependents',
      'Leaderboard website on Cloudflare Pages (agentrank-ai.com)',
      'Daily score updates via nightly cron',
    ],
    tag: 'launch',
  },
];

const tagColors: Record<string, string> = {
  launch: '#22c55e',
  feature: '#3b82f6',
  api: '#8b5cf6',
  seo: '#f59e0b',
  security: '#ef4444',
  infra: '#6b7280',
  content: '#06b6d4',
};

const formatDate = (d: string) =>
  new Date(d + 'T00:00:00Z').toLocaleDateString('en-US', {
    year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC',
  });

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'AgentRank Changelog',
  description: 'Product updates, ecosystem stats, and index changes for AgentRank — the ranked index of MCP servers and agent tools.',
  url: 'https://agentrank-ai.com/changelog/',
  isPartOf: { '@type': 'WebSite', name: 'AgentRank', url: 'https://agentrank-ai.com' },
  dateModified: today,
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'AgentRank', item: 'https://agentrank-ai.com' },
      { '@type': 'ListItem', position: 2, name: 'Changelog', item: 'https://agentrank-ai.com/changelog/' },
    ],
  },
};

Astro.response.headers.set('Cache-Control', 'public, max-age=60, s-maxage=3600, stale-while-revalidate=86400');
---

<Base
  title="Changelog — AgentRank"
  description="Product updates, ecosystem stats, and index changes for AgentRank — the ranked index of MCP servers and agent tools."
  activeTab="changelog"
  jsonLd={jsonLd}
  keywords="agentrank changelog, mcp server updates, agent tools index, product updates"
  canonicalUrl="https://agentrank-ai.com/changelog/"
>
  <div class="changelog-header">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">AgentRank</a>
      <span class="sep">/</span>
      <span>Changelog</span>
    </nav>
    <h1>Changelog</h1>
    <p class="subtitle">Product updates and ecosystem index changes. Updated as we ship.</p>
  </div>

  <!-- Ecosystem Stats -->
  <section class="stats-section" aria-label="Ecosystem statistics">
    <h2 class="section-label">ecosystem stats</h2>
    <div class="stats-grid">
      <div class="stat-card">
        <span class="stat-value">{stats.total_tools > 0 ? stats.total_tools.toLocaleString() : '25,000+'}</span>
        <span class="stat-label">tools indexed</span>
      </div>
      <div class="stat-card">
        <span class="stat-value">{stats.total_skills > 0 ? stats.total_skills.toLocaleString() : '13,000+'}</span>
        <span class="stat-label">skills indexed</span>
      </div>
      <div class="stat-card">
        <span class="stat-value">{stats.avg_score > 0 ? stats.avg_score.toFixed(1) : '—'}</span>
        <span class="stat-label">avg score</span>
      </div>
      <div class="stat-card">
        <span class="stat-value">{latestSnapshotDate ? formatDate(latestSnapshotDate) : 'daily'}</span>
        <span class="stat-label">last updated</span>
      </div>
    </div>
  </section>

  <!-- Recent Index Updates -->
  {latestSnapshotDate && (
    <section class="index-update" aria-label="Recent index updates">
      <h2 class="section-label">recent index run</h2>
      <div class="index-card">
        <div class="index-meta">
          <span class="index-dot"></span>
          <span class="index-date">Run completed {formatDate(latestSnapshotDate)}</span>
        </div>
        <div class="index-stats">
          {newThisWeekCount > 0 && (
            <span class="index-stat positive">+{newThisWeekCount} new tools added</span>
          )}
          <span class="index-stat">Scores recalculated across all indexed tools</span>
          <span class="index-stat">Rank history snapshot saved</span>
        </div>
        <div class="index-links">
          <a href="/trends/">View movers &rarr;</a>
          <a href="/tools/">Browse index &rarr;</a>
        </div>
      </div>
    </section>
  )}

  <!-- Product Updates Timeline -->
  <section class="timeline-section" aria-label="Product update history">
    <h2 class="section-label">product updates</h2>
    <ol class="timeline" role="list">
      {productUpdates.map((update, i) => (
        <li class="timeline-entry" style={`--tag-color: ${tagColors[update.tag] ?? '#22c55e'}`}>
          <div class="timeline-node" aria-hidden="true"></div>
          <div class="timeline-content">
            <div class="entry-meta">
              <time datetime={update.date} class="entry-date">{formatDate(update.date)}</time>
              <span class="entry-tag" style={`background: ${tagColors[update.tag] ?? '#22c55e'}1a; color: ${tagColors[update.tag] ?? '#22c55e'}; border-color: ${tagColors[update.tag] ?? '#22c55e'}40`}>
                {update.tag}
              </span>
              <span class="entry-version">{update.version}</span>
            </div>
            <h3 class="entry-title">{update.title}</h3>
            <ul class="entry-items" role="list">
              {update.items.map(item => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <div class="changelog-footer">
    <p>Have a feature request or bug report? <a href="https://github.com/superlowburn/agentrank/issues" target="_blank" rel="noopener noreferrer">Open an issue on GitHub</a> or <a href="https://x.com/AgentRank_ai" target="_blank" rel="noopener noreferrer">ping us on X</a>.</p>
  </div>
</Base>

<style>
  .changelog-header {
    margin-bottom: 2rem;
  }

  .breadcrumb {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .breadcrumb a {
    color: var(--text-muted);
  }

  .breadcrumb a:hover {
    color: var(--text);
    text-decoration: none;
  }

  .sep {
    opacity: 0.4;
  }

  h1 {
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  /* Section label */
  .section-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    font-weight: 600;
    margin-bottom: 0.85rem;
  }

  /* Stats */
  .stats-section {
    margin-bottom: 2rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
  }

  .stat-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-value {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--accent);
    line-height: 1.1;
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  /* Index update */
  .index-update {
    margin-bottom: 2rem;
  }

  .index-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1rem 1.25rem;
    border-left: 3px solid var(--accent);
  }

  .index-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.6rem;
  }

  .index-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
    box-shadow: 0 0 6px var(--accent);
  }

  .index-date {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text);
  }

  .index-stats {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    margin-bottom: 0.75rem;
  }

  .index-stat {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .index-stat::before {
    content: '· ';
    color: var(--border);
  }

  .index-stat.positive {
    color: var(--accent);
  }

  .index-links {
    display: flex;
    gap: 1rem;
    font-size: 0.78rem;
  }

  .index-links a {
    color: var(--accent);
  }

  /* Timeline */
  .timeline-section {
    margin-bottom: 2rem;
  }

  .timeline {
    list-style: none;
    position: relative;
    padding-left: 1.75rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 0.35rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 1px;
    background: var(--border);
  }

  .timeline-entry {
    position: relative;
    margin-bottom: 1.75rem;
  }

  .timeline-entry:last-child {
    margin-bottom: 0;
  }

  .timeline-node {
    position: absolute;
    left: -1.4rem;
    top: 0.25rem;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--tag-color, var(--accent));
    border: 2px solid var(--bg);
    box-shadow: 0 0 0 1px var(--tag-color, var(--accent));
    flex-shrink: 0;
  }

  .timeline-content {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1rem 1.25rem;
    transition: border-color 0.15s;
  }

  .timeline-content:hover {
    border-color: var(--tag-color, var(--accent));
  }

  .entry-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }

  .entry-date {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .entry-tag {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.1rem 0.45rem;
    border-radius: 3px;
    border: 1px solid;
  }

  .entry-version {
    font-size: 0.72rem;
    color: var(--text-muted);
    opacity: 0.7;
  }

  .entry-title {
    font-size: 0.92rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    line-height: 1.35;
  }

  .entry-items {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .entry-items li {
    font-size: 0.78rem;
    color: var(--text-muted);
    padding-left: 0.9rem;
    position: relative;
    line-height: 1.45;
  }

  .entry-items li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--border);
    font-size: 0.7rem;
  }

  /* Footer */
  .changelog-footer {
    padding: 1.25rem;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .changelog-footer a {
    color: var(--accent);
  }

  /* Responsive */
  @media (max-width: 640px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .timeline {
      padding-left: 1.25rem;
    }

    .timeline-node {
      left: -1rem;
    }
  }

  @media (max-width: 480px) {
    .stats-grid {
      grid-template-columns: 1fr 1fr;
    }

    .entry-meta {
      gap: 0.4rem;
    }
  }
</style>

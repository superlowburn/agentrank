---
export const prerender = true;

import Base from '../layouts/Base.astro';
import { getMovers } from '../data/movers';
import { toSlug, scoreColor } from '../data/tools';

const movers = getMovers();
const newTools = movers.tools.new_entries.slice(0, 25);
const generatedAt = movers.generated_at ? new Date(movers.generated_at).toISOString().slice(0, 10) : null;
const hasData = movers.has_data && newTools.length > 0;

const itemListJsonLd = hasData ? {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'New MCP Servers This Week',
  description: 'MCP servers and AI agent tools newly added to the AgentRank index this week, ranked by score.',
  itemListOrder: 'https://schema.org/ItemListOrderDescending',
  numberOfItems: newTools.length,
  itemListElement: newTools.slice(0, 10).map((e, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: e.name || e.identifier,
    url: `https://agentrank-ai.com/tool/${toSlug(e.identifier)}/`,
  })),
} : undefined;

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'AgentRank', item: 'https://agentrank-ai.com/' },
    { '@type': 'ListItem', position: 2, name: 'New MCP Servers This Week', item: 'https://agentrank-ai.com/new/' },
  ],
};

const jsonLd = itemListJsonLd ? [breadcrumbJsonLd, itemListJsonLd] : breadcrumbJsonLd;
---

<Base
  title="New MCP Servers This Week — AgentRank"
  description={`Discover the latest MCP servers added to the AgentRank index. ${newTools.length} new AI agent tools scored by real GitHub signals this week.`}
  keywords="new MCP servers, new MCP servers this week, latest MCP servers 2026, new AI agent tools"
  canonicalUrl="https://agentrank-ai.com/new/"
  jsonLd={jsonLd}
>
  <div class="breadcrumb">
    <a href="/">AgentRank</a> / <span>New This Week</span>
  </div>

  <h1 class="page-heading">New MCP Servers This Week</h1>
  <p class="page-sub">
    {hasData
      ? `${newTools.length} new tool${newTools.length !== 1 ? 's' : ''} indexed${generatedAt ? ` as of ${generatedAt}` : ''}. Scored by stars, freshness, issue health, and contributors.`
      : 'New tool data will appear after the first tracking snapshot.'}
  </p>

  {hasData && (
    <>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Rank</th>
              <th>Tool</th>
              <th>Score</th>
            </tr>
          </thead>
          <tbody>
            {newTools.map((e) => (
              <tr>
                <td class="rank">{e.rank}</td>
                <td class="name">
                  <a href={`/tool/${toSlug(e.identifier)}/`}>{e.name || e.identifier}</a>
                </td>
                <td class="score">
                  <span class="score-bar" style={`--w: ${e.score}%; --c: ${scoreColor(e.score)}`}>
                    {e.score.toFixed(1)}
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="related-links">
        <a href="/rising/" class="related-link">Rising MCP Servers &rarr;</a>
        <a href="/movers/" class="related-link">Weekly Movers &rarr;</a>
        <a href="/" class="related-link">Full Leaderboard &rarr;</a>
        <a href="/category/" class="related-link">Browse by Category &rarr;</a>
      </div>
    </>
  )}
</Base>

<style>
  .breadcrumb {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .breadcrumb a {
    color: var(--text-muted);
  }

  .breadcrumb a:hover {
    color: var(--accent);
  }

  .page-heading {
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }

  .page-sub {
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-bottom: 1.5rem;
  }

  .table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin-bottom: 2rem;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
  }

  th {
    background: var(--bg-surface);
    border-bottom: 2px solid var(--border);
    padding: 0.5rem 0.75rem;
    text-align: left;
    font-weight: 600;
    white-space: nowrap;
    color: var(--text-muted);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  td {
    padding: 0.4rem 0.75rem;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }

  tr:hover td {
    background: var(--bg-hover);
  }

  .rank {
    color: var(--text-muted);
    width: 3rem;
  }

  .name a {
    color: var(--text);
    font-weight: 500;
  }

  .name a:hover {
    color: var(--accent);
  }

  .score-bar {
    display: inline-block;
    padding: 0.1rem 0.5rem;
    border-radius: 3px;
    background: linear-gradient(90deg, var(--c) var(--w), transparent var(--w));
    background-color: var(--bg-surface);
    min-width: 4rem;
    font-weight: 600;
  }

  .related-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .related-link {
    font-size: 0.85rem;
    color: var(--accent);
    text-decoration: none;
    padding: 0.35rem 0.75rem;
    border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--border));
    border-radius: 4px;
    font-weight: 500;
  }

  .related-link:hover {
    background: color-mix(in srgb, var(--accent) 8%, transparent);
    text-decoration: none;
  }
</style>

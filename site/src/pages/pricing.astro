---
export const prerender = true;
import Base from '../layouts/Base.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'AgentRank Pricing',
  url: 'https://agentrank-ai.com/pricing/',
  description: 'AgentRank API pricing. Start free with 100 requests/day. Pro API at $49/mo for 10,000 requests/day. Sponsored listings at $299/mo for featured placement.',
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        item: {
          '@type': 'Offer',
          name: 'Free',
          description: 'Public API access. 100 requests/day, no key required.',
          price: '0',
          priceCurrency: 'USD',
          url: 'https://agentrank-ai.com/pricing/',
        },
      },
      {
        '@type': 'ListItem',
        position: 2,
        item: {
          '@type': 'Offer',
          name: 'Pro API',
          description: 'Programmatic access to the full AgentRank index. 10,000 requests/day, all endpoints, full score breakdowns.',
          price: '49',
          priceCurrency: 'USD',
          priceSpecification: { '@type': 'UnitPriceSpecification', billingIncrement: 1, unitCode: 'MON' },
          url: 'https://agentrank-ai.com/pricing/',
        },
      },
      {
        '@type': 'ListItem',
        position: 3,
        item: {
          '@type': 'Offer',
          name: 'Sponsored',
          description: 'Featured category placement for commercial MCP tools. Reach developers actively evaluating tools in your category.',
          price: '299',
          priceCurrency: 'USD',
          priceSpecification: { '@type': 'UnitPriceSpecification', billingIncrement: 1, unitCode: 'MON' },
          url: 'https://agentrank-ai.com/pricing/',
        },
      },
    ],
  },
};
---

<Base
  title="Pricing — AgentRank"
  description="Start free with 100 requests/day. Pro API at $49/mo for 10,000 requests/day and all endpoints. Sponsored listings at $299/mo for featured placement and analytics."
  activeTab="pricing"
  keywords="AgentRank pricing, MCP API pricing, agent tool API, sponsored listing MCP, Pro API access"
  canonicalUrl="https://agentrank-ai.com/pricing/"
  jsonLd={jsonLd}
>

  <div class="pricing-hero">
    <p class="eyebrow">API Pricing</p>
    <h1>Simple, transparent pricing</h1>
    <p class="hero-sub">Start free. Upgrade when you need more. No surprises.</p>
  </div>

  <div class="tiers">

    <!-- Free -->
    <div class="tier">
      <div class="tier-header">
        <span class="tier-name">Free</span>
        <div class="tier-price-block">
          <span class="tier-price">$0<span class="tier-per">/mo</span></span>
          <span class="tier-billing-note">no account needed &mdash; always free</span>
        </div>
        <p class="tier-best-for">For developers exploring the index or building hobby projects.</p>
      </div>
      <ul class="tier-features">
        <li class="check">100 requests/day per IP</li>
        <li class="check">Core endpoints: <code>/tools</code>, <code>/search</code>, <code>/badge</code></li>
        <li class="check">JSON responses with AgentRank scores</li>
        <li class="check">MCP server install: one command</li>
        <li class="check">No API key required</li>
      </ul>
      <a href="/docs/" class="cta cta-secondary">Read the API docs &rarr;</a>
      <p class="cta-note">Free tier is live now &middot; <a href="/docs/rate-limits/">rate limit docs</a></p>
      <p class="cta-note">Already have a key? <a href="/developer/dashboard/">Manage in dashboard &rarr;</a></p>
    </div>

    <!-- Pro API (featured) -->
    <div class="tier tier-featured">
      <div class="tier-badge">Most Popular</div>
      <div class="tier-header">
        <span class="tier-name">Pro API</span>
        <div class="tier-price-block">
          <span class="tier-price">$49<span class="tier-per">/mo</span></span>
          <span class="tier-billing-note">launching Phase 2 &mdash; join waitlist for early access</span>
        </div>
        <p class="tier-best-for">For developers building agents, plugins, and orchestration layers.</p>
      </div>
      <ul class="tier-features">
        <li class="check">10,000 requests/day</li>
        <li class="check">All endpoints: <code>/tools</code>, <code>/search</code>, <code>/categories</code>, <code>/skills</code>, <code>/score</code></li>
        <li class="check">API key &mdash; no IP restrictions</li>
        <li class="check">Full score breakdowns in every response</li>
        <li class="check">30-day historical score data</li>
        <li class="check">Usage dashboard &amp; call logs</li>
        <li class="check">Email support</li>
      </ul>
      <div class="waitlist-form-wrap" id="pro-form-wrap">
        <form class="waitlist-form" id="pro-waitlist-form" novalidate>
          <input type="text" name="_hp" class="hp-field" tabindex="-1" autocomplete="off" aria-hidden="true" />
          <div class="waitlist-row">
            <input
              type="email"
              id="pro-waitlist-email"
              name="email"
              placeholder="you@example.com"
              autocomplete="email"
              required
            />
            <button type="submit" id="pro-waitlist-btn">Join waitlist &rarr;</button>
          </div>
          <span id="pro-waitlist-msg" class="waitlist-msg" aria-live="polite"></span>
        </form>
      </div>
      <p class="cta-note">First notified when Pro launches &middot; no commitment</p>
    </div>

    <!-- Sponsored -->
    <div class="tier">
      <div class="tier-header">
        <span class="tier-name">Sponsored</span>
        <div class="tier-price-block">
          <span class="tier-price">$299<span class="tier-per">/mo</span></span>
          <span class="tier-billing-note">launching Phase 2 &mdash; limited slots available</span>
        </div>
        <p class="tier-best-for">For commercial tools competing for developer mindshare in their category.</p>
      </div>
      <ul class="tier-features">
        <li class="check">Featured placement at top of category page</li>
        <li class="check">Homepage sidebar placement</li>
        <li class="check">Full analytics: views, click-throughs, comparison events</li>
        <li class="check">Verified Publisher badge on listing</li>
        <li class="check">Enhanced listing: logo, description, docs links</li>
        <li class="check">Priority indexing &mdash; commits reflected within 24h</li>
        <li class="check">Slack channel for listing updates</li>
      </ul>
      <div class="waitlist-form-wrap" id="sponsored-form-wrap">
        <form class="waitlist-form" id="sponsored-waitlist-form" novalidate>
          <input type="text" name="_hp" class="hp-field" tabindex="-1" autocomplete="off" aria-hidden="true" />
          <div class="waitlist-row">
            <input
              type="email"
              id="sponsored-waitlist-email"
              name="email"
              placeholder="you@company.com"
              autocomplete="email"
              required
            />
            <button type="submit" id="sponsored-waitlist-btn">Get featured &rarr;</button>
          </div>
          <span id="sponsored-waitlist-msg" class="waitlist-msg" aria-live="polite"></span>
        </form>
      </div>
      <p class="cta-note">or email <a href="mailto:hello@agentrank-ai.com?subject=Sponsored%20Listing%20Inquiry">hello@agentrank-ai.com</a></p>
    </div>

  </div>

  <section class="comparison">
    <h2 class="section-header">Feature Comparison</h2>
    <div class="table-wrap">
      <table class="compare-table">
        <thead>
          <tr>
            <th>Feature</th>
            <th>Free</th>
            <th class="col-featured">Pro API</th>
            <th>Sponsored</th>
          </tr>
        </thead>
        <tbody>
          <tr class="row-group"><td colspan="4">API Access</td></tr>
          <tr>
            <td>Requests/day</td>
            <td>100</td>
            <td class="yes col-featured">10,000</td>
            <td class="no">&mdash;</td>
          </tr>
          <tr>
            <td>API key (no IP restriction)</td>
            <td class="no">&mdash;</td>
            <td class="yes col-featured">yes</td>
            <td class="no">&mdash;</td>
          </tr>
          <tr>
            <td><code>/tools</code>, <code>/search</code>, <code>/badge</code></td>
            <td class="yes">yes</td>
            <td class="yes col-featured">yes</td>
            <td class="no">&mdash;</td>
          </tr>
          <tr>
            <td><code>/categories</code>, <code>/skills</code>, <code>/score</code></td>
            <td class="no">&mdash;</td>
            <td class="yes col-featured">yes</td>
            <td class="no">&mdash;</td>
          </tr>
          <tr>
            <td>Full score breakdown in responses</td>
            <td class="no">&mdash;</td>
            <td class="yes col-featured">yes</td>
            <td class="no">&mdash;</td>
          </tr>
          <tr>
            <td>30-day historical score data</td>
            <td class="no">&mdash;</td>
            <td class="yes col-featured">yes</td>
            <td class="no">&mdash;</td>
          </tr>
          <tr>
            <td>Usage dashboard &amp; call logs</td>
            <td class="no">&mdash;</td>
            <td class="yes col-featured">yes</td>
            <td class="no">&mdash;</td>
          </tr>
          <tr class="row-group"><td colspan="4">Listing &amp; Visibility</td></tr>
          <tr>
            <td>Auto-indexed listing</td>
            <td class="yes">yes</td>
            <td class="no col-featured">&mdash;</td>
            <td class="yes">yes</td>
          </tr>
          <tr>
            <td>Verified Publisher badge</td>
            <td class="no">&mdash;</td>
            <td class="no col-featured">&mdash;</td>
            <td class="yes">yes</td>
          </tr>
          <tr>
            <td>Featured category placement</td>
            <td class="no">&mdash;</td>
            <td class="no col-featured">&mdash;</td>
            <td class="yes">yes</td>
          </tr>
          <tr>
            <td>Homepage sidebar placement</td>
            <td class="no">&mdash;</td>
            <td class="no col-featured">&mdash;</td>
            <td class="yes">yes</td>
          </tr>
          <tr>
            <td>Full analytics dashboard</td>
            <td class="no">&mdash;</td>
            <td class="no col-featured">&mdash;</td>
            <td class="yes">yes</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="faq">
    <h2 class="section-header">FAQ</h2>
    <dl class="faq-list">

      <dt>What counts as a request?</dt>
      <dd>One API call to any endpoint counts as one request. Fetching a tool by ID (<code>GET /tools/:id</code>), running a search (<code>GET /search</code>), listing a category, or pulling score history — each is one request. MCP server calls made by your AI assistant also count. Requests that return errors (4xx, 5xx) do not count against your limit.</dd>

      <dt>What is the rate limit on the free tier?</dt>
      <dd>The public free tier allows 100 requests per day, enforced per IP address. There is no per-minute burst limit for typical usage. If you hit the daily limit, requests return a <code>429 Too Many Requests</code> response and the limit resets at midnight UTC. For higher volume, join the Pro waitlist.</dd>

      <dt>How does billing work for Pro API?</dt>
      <dd>Pro API is billed monthly at $49/mo via Stripe. Your billing cycle starts the day you activate. You can cancel anytime — your key stays active through the end of the current period. Annual billing (2 months free) will be available at launch. Billing launches with Phase 2 — join the waitlist to be first notified.</dd>

      <dt>Is my MCP tool already in the index?</dt>
      <dd>Almost certainly yes. AgentRank crawls GitHub nightly and indexes every repo matching MCP server and agent tool patterns. <a href="/">Search the leaderboard</a> to find your listing. All indexed tools are visible for free — paid tiers add enhanced listings, analytics, and featured placement.</dd>

      <dt>Do I need to pay to appear in the index?</dt>
      <dd>No. The index is free and automatic. Listings are generated from public GitHub data. Sponsored tiers are for maintainers who want featured placement, analytics, and verified badges — not for basic indexing.</dd>

      <dt>How are Sponsored Listings labeled?</dt>
      <dd>Sponsored placements are labeled "Sponsored" — transparently and prominently. We don't hide paid placements as organic rankings. Traffic data is available before you commit. If the numbers don't justify the spend, we'll tell you.</dd>

    </dl>
  </section>

  <section class="free-note">
    <div class="free-note-inner">
      <span class="free-note-label">free forever</span>
      <p>The public API and MCP server are always free. No key needed. Install once, your AI finds the right tool automatically.</p>
      <pre class="code-snippet">claude mcp add agentrank -- npx -y agentrank-mcp-server</pre>
    </div>
  </section>

</Base>

<style>
  /* Hero */
  .pricing-hero {
    text-align: center;
    padding: 2.5rem 0 2rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .eyebrow {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .pricing-hero h1 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.2;
    margin-bottom: 0.6rem;
  }

  .hero-sub {
    font-size: 0.88rem;
    color: var(--text-muted);
  }

  /* Tier grid */
  .tiers {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1rem;
    margin-bottom: 3rem;
    align-items: start;
  }

  .tier {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem;
    position: relative;
  }

  .tier-featured {
    border-color: var(--accent);
  }

  .tier-badge {
    position: absolute;
    top: -0.65rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--accent);
    color: var(--bg);
    font-size: 0.6rem;
    font-weight: 700;
    padding: 0.18rem 0.6rem;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  .tier-header {
    margin-bottom: 1.25rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
  }

  .tier-name {
    display: block;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 0.6rem;
  }

  .tier-price-block {
    margin-bottom: 0.6rem;
  }

  .tier-price {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1;
    display: block;
    margin-bottom: 0.3rem;
  }

  .tier-per {
    font-size: 0.82rem;
    font-weight: 400;
    color: var(--text-muted);
  }

  .tier-billing-note {
    display: block;
    font-size: 0.72rem;
    color: var(--text-muted);
    line-height: 1.4;
  }

  .tier-best-for {
    font-size: 0.78rem;
    color: var(--text-muted);
    line-height: 1.4;
    margin-top: 0.5rem;
  }

  /* Feature list */
  .tier-features {
    list-style: none;
    padding: 0;
    margin-bottom: 1.5rem;
  }

  .tier-features li {
    font-size: 0.8rem;
    padding: 0.22rem 0;
    padding-left: 1.2rem;
    position: relative;
    color: var(--text);
    line-height: 1.4;
  }

  .tier-features li.check::before {
    content: '\2713';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 0.72rem;
  }

  .tier-features code {
    background: var(--bg-hover);
    border: 1px solid var(--border);
    padding: 0.08rem 0.28rem;
    border-radius: 2px;
    font-size: 0.7rem;
    font-family: inherit;
  }

  /* CTAs */
  .cta {
    display: block;
    text-align: center;
    padding: 0.6rem 1rem;
    border-radius: 4px;
    font-size: 0.82rem;
    font-weight: 700;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .cta:hover {
    opacity: 0.82;
    text-decoration: none;
  }

  .cta-secondary {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border);
  }

  .cta-secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .cta-note {
    font-size: 0.68rem;
    color: var(--text-muted);
    text-align: center;
    margin-top: 0.5rem;
    line-height: 1.4;
  }

  .cta-note a {
    color: var(--text-muted);
    text-decoration: underline;
  }

  .cta-note a:hover {
    color: var(--accent);
  }

  /* Waitlist forms */
  .waitlist-form-wrap {
    margin-bottom: 0;
  }

  .waitlist-form {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .waitlist-row {
    display: flex;
    gap: 0.35rem;
  }

  .waitlist-row input[type="email"] {
    flex: 1;
    min-width: 0;
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 0.5rem 0.65rem;
    border-radius: 4px;
    font-family: inherit;
    font-size: 0.78rem;
  }

  .waitlist-row input[type="email"]:focus {
    outline: 1px solid var(--accent);
    border-color: var(--accent);
  }

  .waitlist-row button {
    background: var(--accent);
    color: var(--bg);
    border: none;
    border-radius: 4px;
    padding: 0.5rem 0.85rem;
    font-family: inherit;
    font-size: 0.78rem;
    font-weight: 700;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.15s;
  }

  .waitlist-row button:hover { opacity: 0.85; }
  .waitlist-row button:disabled { opacity: 0.5; cursor: not-allowed; }

  .waitlist-msg {
    display: block;
    font-size: 0.72rem;
    min-height: 1em;
    line-height: 1.4;
  }

  .waitlist-msg.success { color: var(--accent); }
  .waitlist-msg.error { color: #ef4444; }

  .hp-field {
    position: absolute;
    left: -9999px;
    opacity: 0;
    height: 0;
    width: 0;
    pointer-events: none;
  }

  /* Comparison table */
  .comparison {
    margin-bottom: 2.5rem;
  }

  .section-header {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    font-weight: 700;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .table-wrap {
    overflow-x: auto;
  }

  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.78rem;
  }

  .compare-table th {
    text-align: left;
    padding: 0.45rem 0.75rem;
    border-bottom: 2px solid var(--border);
    color: var(--text-muted);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  .compare-table th.col-featured {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 5%, transparent);
  }

  .compare-table td {
    padding: 0.38rem 0.75rem;
    border-bottom: 1px solid var(--border);
    color: var(--text-muted);
  }

  .compare-table td:first-child {
    color: var(--text);
  }

  .compare-table td code {
    background: var(--bg-hover);
    border: 1px solid var(--border);
    padding: 0.05rem 0.25rem;
    border-radius: 2px;
    font-size: 0.68rem;
    font-family: inherit;
  }

  .compare-table td.col-featured {
    background: color-mix(in srgb, var(--accent) 5%, transparent);
  }

  .compare-table td.yes {
    color: var(--accent);
    font-weight: 600;
  }

  .compare-table td.no {
    color: var(--border);
  }

  .row-group td {
    background: var(--bg-hover);
    color: var(--text-muted);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    padding: 0.28rem 0.75rem;
    font-weight: 700;
  }

  /* FAQ */
  .faq {
    margin-bottom: 2.5rem;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .faq-list dt {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.3rem;
  }

  .faq-list dd {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-left: 0;
    line-height: 1.6;
  }

  .faq-list dd a {
    color: var(--accent);
    text-decoration: none;
  }

  .faq-list dd a:hover {
    text-decoration: underline;
  }

  .faq-list dd code {
    background: var(--bg-hover);
    border: 1px solid var(--border);
    padding: 0.1rem 0.3rem;
    border-radius: 2px;
    font-size: 0.72rem;
  }

  /* Free note */
  .free-note {
    margin-bottom: 2rem;
  }

  .free-note-inner {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 0 6px 6px 0;
    padding: 1.25rem 1.5rem;
  }

  .free-note-label {
    display: inline-block;
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .free-note-inner p {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
    line-height: 1.5;
  }

  .code-snippet {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.55rem 0.9rem;
    font-size: 0.76rem;
    overflow-x: auto;
    white-space: pre;
    color: var(--text);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .tiers {
      grid-template-columns: 1fr 1fr;
    }

    .tier:last-child {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 600px) {
    .tiers {
      grid-template-columns: 1fr;
    }

    .tier:last-child {
      grid-column: auto;
    }

    .tier-featured {
      order: -1;
    }

    .pricing-hero h1 {
      font-size: 1.2rem;
    }

    .waitlist-row {
      flex-direction: column;
    }

    .waitlist-row button {
      width: 100%;
    }
  }
</style>

<script>
  function setupWaitlistForm(
    formId: string,
    emailId: string,
    btnId: string,
    msgId: string,
    source: string,
  ) {
    const form = document.getElementById(formId) as HTMLFormElement | null;
    const emailInput = document.getElementById(emailId) as HTMLInputElement | null;
    const btn = document.getElementById(btnId) as HTMLButtonElement | null;
    const msg = document.getElementById(msgId) as HTMLSpanElement | null;
    if (!form || !emailInput || !btn || !msg) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const hp = (form.querySelector<HTMLInputElement>('.hp-field')?.value ?? '');
      if (hp) return;

      const email = emailInput.value.trim();
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        msg.textContent = 'Please enter a valid email address.';
        msg.className = 'waitlist-msg error';
        return;
      }

      btn.disabled = true;
      btn.textContent = 'Joining...';
      msg.textContent = '';
      msg.className = 'waitlist-msg';

      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, source, _hp: '' }),
        });
        const data = await res.json() as { success?: boolean; already?: boolean; error?: string };
        if (data.success) {
          msg.textContent = data.already
            ? "You're already on the list."
            : "You're on the list. We'll notify you at launch.";
          msg.className = 'waitlist-msg success';
          emailInput.value = '';
          btn.textContent = 'Joined!';
        } else {
          msg.textContent = data.error || 'Something went wrong. Try again.';
          msg.className = 'waitlist-msg error';
          btn.disabled = false;
          btn.textContent = source.includes('pro') ? 'Join waitlist \u2192' : 'Get featured \u2192';
        }
      } catch {
        msg.textContent = 'Network error. Please try again.';
        msg.className = 'waitlist-msg error';
        btn.disabled = false;
        btn.textContent = source.includes('pro') ? 'Join waitlist \u2192' : 'Get featured \u2192';
      }
    });
  }

  setupWaitlistForm(
    'pro-waitlist-form',
    'pro-waitlist-email',
    'pro-waitlist-btn',
    'pro-waitlist-msg',
    'pricing-pro-waitlist',
  );

  setupWaitlistForm(
    'sponsored-waitlist-form',
    'sponsored-waitlist-email',
    'sponsored-waitlist-btn',
    'sponsored-waitlist-msg',
    'pricing-sponsored-waitlist',
  );
</script>

  .preview-note code {
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 0.1rem 0.3rem;
    border-radius: 2px;
    font-size: 0.75rem;
  }

  .ide-source { font-size: 0.8rem; color: var(--text-muted); margin-top: 0.5rem; }
  .ide-source a { color: var(--accent); }

  /* ---- Pro API ---- */
  .pro-api-callout { background: var(--bg-surface); border: 1px solid var(--border); border-radius: 8px; padding: 1.25rem 1.5rem; margin-bottom: 2.5rem; }
  .pro-api-callout h2 { font-size: 1rem; font-weight: 700; margin-bottom: 0.5rem; }
  .pro-api-callout p { color: var(--text-muted); font-size: 0.85rem; margin-bottom: 0.75rem; }
  .pro-api-callout p a { color: var(--accent); }
  .pro-api-callout h3 { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); margin-top: 1rem; margin-bottom: 0.5rem; }

  @media (max-width: 480px) {
    .endpoint { padding-left: 0.75rem; }
    .endpoint h2 { font-size: 0.9rem; }
    .params-table { font-size: 0.75rem; }
    .platform-header { flex-wrap: wrap; }
  }
</style>

<script>
  // Copy buttons — injected into every .code-block-wrap
  document.querySelectorAll<HTMLElement>('.code-block-wrap').forEach((wrap) => {
    const pre = wrap.querySelector('pre');
    if (!pre) return;
    const btn = document.createElement('button');
    btn.className = 'copy-btn';
    btn.textContent = 'copy';
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(pre.textContent ?? '');
        btn.textContent = 'copied!';
        btn.classList.add('copied');
        setTimeout(() => { btn.textContent = 'copy'; btn.classList.remove('copied'); }, 2000);
      } catch {}
    });
    wrap.appendChild(btn);
  });

  // Try-it-live
  function buildUrl(endpointTpl: string, body: HTMLElement): string {
    const params = new URLSearchParams();
    let path = endpointTpl;
    body.querySelectorAll<HTMLInputElement | HTMLSelectElement>('.try-input').forEach((el) => {
      const key = el.dataset.param ?? '';
      const val = (el as HTMLInputElement).value.trim();
      if (!val) return;
      if (el.classList.contains('try-path-param')) {
        path = path.replace(`{${key}}`, encodeURIComponent(val));
      } else {
        params.set(key, val);
      }
    });
    const qs = params.toString();
    return 'https://agentrank-ai.com' + path + (qs ? '?' + qs : '');
  }

  document.querySelectorAll<HTMLButtonElement>('.try-send-btn').forEach((btn) => {
    const body = btn.closest<HTMLElement>('.try-it-body')!;
    const tpl = btn.dataset.endpoint ?? '';
    const urlEl = body.querySelector<HTMLElement>('.try-url-preview');
    const resultEl = body.querySelector<HTMLElement>('.try-result');
    const statusEl = body.querySelector<HTMLElement>('.try-status');
    const timingEl = body.querySelector<HTMLElement>('.try-timing');
    const responseEl = body.querySelector<HTMLPreElement>('.try-response');

    const updateUrl = () => { if (urlEl) urlEl.textContent = buildUrl(tpl, body); };
    body.querySelectorAll('.try-input').forEach((el) => el.addEventListener('input', updateUrl));
    updateUrl();

    btn.addEventListener('click', async () => {
      const url = buildUrl(tpl, body);
      btn.disabled = true;
      btn.textContent = 'Sending…';
      if (resultEl) resultEl.style.display = 'block';
      if (statusEl) { statusEl.textContent = ''; statusEl.className = 'try-status'; }
      if (timingEl) timingEl.textContent = '';
      if (responseEl) responseEl.textContent = '';

      const t0 = Date.now();
      try {
        const res = await fetch(url);
        const ms = Date.now() - t0;
        let text = await res.text();
        try { text = JSON.stringify(JSON.parse(text), null, 2); } catch {}
        if (statusEl) { statusEl.textContent = `${res.status} ${res.statusText}`; statusEl.className = `try-status ${res.ok ? 'ok' : 'err'}`; }
        if (timingEl) timingEl.textContent = `${ms}ms`;
        if (responseEl) responseEl.textContent = text;
      } catch (e) {
        if (statusEl) { statusEl.textContent = 'Network error'; statusEl.className = 'try-status err'; }
        if (responseEl) responseEl.textContent = String(e);
      }
      btn.disabled = false;
      btn.textContent = 'Send Request';
    });
  });

  // Sidebar active state via IntersectionObserver
  const sidebarLinks = document.querySelectorAll<HTMLAnchorElement>('.sidebar-link');
  const observed = document.querySelectorAll<HTMLElement>('section[id]');

  const io = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          const id = e.target.id;
          sidebarLinks.forEach((a) => a.classList.toggle('active', a.getAttribute('href') === `#${id}`));
          break;
        }
      }
    },
    { rootMargin: '-8% 0px -80% 0px' }
  );

  observed.forEach((s) => io.observe(s));
</script>

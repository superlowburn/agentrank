---
import Base from '../../layouts/Base.astro';
import { toSlug, formatStars, relativeTime, scoreColor, type Tool } from '../../data/tools';
import { getAdvice } from '../../data/advice';
import { generateToolSummary, generateContextSentences, getLicenseClass, generateToolJsonLd } from '../../data/content-gen';

const { slug } = Astro.params;
const fullName = slug!.replace('--', '/');

const { env } = Astro.locals.runtime;
const row = await env.DB.prepare('SELECT * FROM tools WHERE full_name = ?').bind(fullName).first();

if (!row) {
  return Astro.redirect('/404');
}

const claim = await env.DB.prepare(
  'SELECT github_username, tagline, logo_url, is_deprecated FROM claims WHERE tool_full_name = ? AND status = ? LIMIT 1'
).bind(fullName, 'active').first();

const tool: Tool = {
  rank: row.rank as number,
  full_name: row.full_name as string,
  url: row.url as string,
  description: row.description as string | null,
  score: row.score as number,
  stars: row.stars as number,
  forks: row.forks as number,
  open_issues: row.open_issues as number,
  closed_issues: row.closed_issues as number,
  contributors: row.contributors as number,
  dependents: row.dependents as number,
  language: row.language as string | null,
  license: row.license as string | null,
  last_commit_at: row.last_commit_at as string,
  is_archived: (row.is_archived as number) === 1,
  matched_queries: JSON.parse(row.matched_queries as string || '[]'),
};

const readmeExcerpt = row.readme_excerpt as string | null;
const githubTopics: string[] = JSON.parse(row.github_topics as string || '[]');
const glamaDownloads = (row.glama_weekly_downloads as number) || 0;
const glamaToolCalls = (row.glama_tool_calls as number) || 0;

const totalIssues = tool.open_issues + tool.closed_issues;
const issueHealth = totalIssues > 0 ? (tool.closed_issues / totalIssues) : 0.5;

const descLen = tool.description?.length ?? 0;
const descQuality = !tool.description ? 0 : descLen < 50 ? 0.3 : descLen < 150 ? 0.7 : 1.0;

const PERMISSIVE = ['MIT', 'Apache-2.0', 'BSD-2-Clause', 'BSD-3-Clause', 'ISC', 'Unlicense'];
const licHealth = !tool.license || tool.license === 'NOASSERTION' ? 0.2 : PERMISSIVE.includes(tool.license) ? 1.0 : 0.6;

const signals = [
  { name: 'Stars', value: tool.stars.toLocaleString('en-US'), bar: Math.min(100, Math.log(1 + tool.stars) / Math.log(1 + 200000) * 100), weight: 15 },
  { name: 'Freshness', value: relativeTime(tool.last_commit_at), bar: (() => {
    const days = Math.floor((Date.now() - new Date(tool.last_commit_at).getTime()) / (1000 * 60 * 60 * 24));
    if (days <= 7) return 100;
    if (days <= 90) return 100 - ((days - 7) / 83) * 60;
    return Math.max(0, 40 * Math.exp(-(days - 90) / 180));
  })(), weight: 25 },
  { name: 'Issue Health', value: `${(issueHealth * 100).toFixed(0)}%`, bar: issueHealth * 100, weight: 25 },
  { name: 'Contributors', value: tool.contributors, bar: Math.min(100, Math.log(1 + tool.contributors) / Math.log(1 + 500) * 100), weight: 10 },
  { name: 'Dependents', value: tool.dependents > 0 ? tool.dependents.toLocaleString('en-US') : '0', bar: Math.min(100, tool.dependents > 0 ? Math.log(1 + tool.dependents) / Math.log(1 + 100000) * 100 : 0), weight: 25 },
  { name: 'Forks', value: tool.forks.toLocaleString('en-US'), bar: Math.min(100, Math.log(1 + tool.forks) / Math.log(1 + 50000) * 100), weight: 0 },
  { name: 'Description', value: descQuality === 0 ? 'None' : descQuality === 0.3 ? 'Brief' : descQuality === 0.7 ? 'Good' : 'Detailed', bar: descQuality * 100, weight: 0 },
  { name: 'License', value: tool.license || 'None', bar: licHealth * 100, weight: 0 },
];

const advice = tool.score <= 85 ? getAdvice(tool) : [];

const totalTools = (await env.DB.prepare('SELECT COUNT(*) as count FROM tools').first())?.count as number || 0;
const summary = generateToolSummary({ ...tool, github_topics: githubTopics });
const contextSentences = generateContextSentences({
  rank: tool.rank,
  score: tool.score,
  stars: tool.stars,
  dependents: tool.dependents,
  contributors: tool.contributors,
  last_commit_at: tool.last_commit_at,
}, totalTools);
const licenseClass = getLicenseClass(tool.license);

const SITE_URL = 'https://agentrank-ai.com';
const badgeUrl = `${SITE_URL}/api/badge/tool/${slug}`;
const pageUrl = `${SITE_URL}/tool/${slug}`;
const mdSnippet = `[![AgentRank](${badgeUrl})](${pageUrl})`;
const htmlSnippet = `<a href="${pageUrl}"><img src="${badgeUrl}" alt="AgentRank"></a>`;
const jsonLd = generateToolJsonLd({ ...tool, github_topics: githubTopics }, pageUrl);
const keywordsStr = [...new Set([...tool.matched_queries, ...githubTopics])].join(', ');

// Try to find related tools by category (matched queries), fall back to top-scored
const primaryQuery = tool.matched_queries[0] || null;
let relatedTools: Record<string, unknown>[] = [];
if (primaryQuery) {
  const categoryRows = await env.DB.prepare(
    `SELECT full_name, score, rank, description FROM tools
     WHERE full_name != ? AND score IS NOT NULL AND matched_queries LIKE ?
     ORDER BY score DESC LIMIT 5`
  ).bind(tool.full_name, `%${primaryQuery}%`).all();
  relatedTools = (categoryRows.results || []) as Record<string, unknown>[];
}
if (relatedTools.length < 3) {
  const topRows = await env.DB.prepare(
    `SELECT full_name, score, rank, description FROM tools
     WHERE full_name != ? AND score IS NOT NULL
     ORDER BY score DESC LIMIT 5`
  ).bind(tool.full_name).all();
  relatedTools = (topRows.results || []) as Record<string, unknown>[];
}
---

<Base title={`${tool.full_name} — AgentRank`} description={summary} activeTab="tools" jsonLd={jsonLd} keywords={keywordsStr} canonicalUrl={pageUrl}>
  <div class="back">
    <a href="/tools/">&larr; Back to tools leaderboard</a>
  </div>

  <div class="tool-header">
    <h2>{tool.full_name}</h2>
    <div class="tool-meta">
      <span class="score-badge" style={`color: ${scoreColor(tool.score)}`}>
        Score: {tool.score.toFixed(1)}
      </span>
      <span class="rank-badge">Rank #{tool.rank}</span>
      {tool.is_archived && <span class="badge archived">Archived</span>}
    </div>
    {claim && (
      <div class="claimed-badge">
        Maintained by <a href={`https://github.com/${claim.github_username as string}`} target="_blank" rel="noopener noreferrer">@{claim.github_username as string}</a>
        {(claim.is_deprecated as number) === 1 && <span class="deprecated-badge">deprecated</span>}
      </div>
    )}
    {claim && (claim.tagline as string) && (
      <p class="claim-tagline">{claim.tagline as string}</p>
    )}
  </div>

  {tool.description && <p class="description">{tool.description}</p>}

  <section class="summary">
    <h3>Overview</h3>
    <p class="summary-text">{summary}</p>
    <div class="context-sentences">
      {contextSentences.map((s) => (
        <p class="context-line">{s}</p>
      ))}
    </div>
  </section>

  <section class="ecosystem">
    <h3>Ecosystem</h3>
    <div class="eco-badges">
      {tool.language && <span class="eco-pill lang-pill">{tool.language}</span>}
      <span class={`eco-pill license-${licenseClass}`}>
        {tool.license || 'No license'}
      </span>
      {glamaDownloads > 0 && <span class="eco-pill">{glamaDownloads.toLocaleString('en-US')} weekly downloads</span>}
      {glamaToolCalls > 0 && <span class="eco-pill">{glamaToolCalls.toLocaleString('en-US')} tool calls</span>}
    </div>
    {githubTopics.length > 0 && (
      <div class="topics">
        {githubTopics.map((t) => (
          <span class="topic-tag">{t}</span>
        ))}
      </div>
    )}
  </section>

  <section class="signals">
    <h3>Score Breakdown</h3>
    <div class="signal-list">
      {signals.map((s) => (
        <div class="signal">
          <div class="signal-label">
            <span class="signal-name">
              {s.name}
              {s.weight > 0 && <span class="signal-weight">{s.weight}%</span>}
            </span>
            <span class={`signal-value${s.bar === -1 ? ' coming-soon' : ''}`}>{s.value}</span>
          </div>
          {s.bar >= 0 && (
            <div class="signal-track">
              <div class="signal-fill" style={`width: ${s.bar}%; background: ${scoreColor(s.bar)}`}></div>
            </div>
          )}
        </div>
      ))}
    </div>
    <p class="signal-note">Score weights: Freshness 25% · Issue Health 25% · Dependents 25% · Stars 15% · Contributors 10%</p>
  </section>

  {advice.length > 0 && (
    <section class="advice">
      <h3>How to Improve</h3>
      <div class="advice-list">
        {advice.map((a) => (
          <div class="advice-card">
            <div class="advice-header">
              <span class={`impact-dot impact-${a.impact}`}></span>
              <span class="advice-signal">{a.signal}</span>
              <span class={`impact-label impact-${a.impact}`}>{a.impact} impact</span>
            </div>
            <p class="advice-message">{a.message}</p>
          </div>
        ))}
      </div>
    </section>
  )}

  <section class="badge-embed">
    <h3>Badge</h3>
    <div class="badge-preview">
      <img src={`/api/badge/tool/${slug}`} alt={`AgentRank score for ${tool.full_name}`} />
    </div>
    <div class="snippet">
      <label>Markdown</label>
      <div class="snippet-row">
        <code class="snippet-code">{mdSnippet}</code>
        <button class="copy-btn" data-copy={mdSnippet}>Copy</button>
      </div>
    </div>
    <div class="snippet">
      <label>HTML</label>
      <div class="snippet-row">
        <code class="snippet-code">{htmlSnippet}</code>
        <button class="copy-btn" data-copy={htmlSnippet}>Copy</button>
      </div>
    </div>
  </section>

  <section class="metadata">
    <h3>Details</h3>
    <dl>
      <dt>Stars</dt><dd>{tool.stars.toLocaleString('en-US')}</dd>
      <dt>Forks</dt><dd>{tool.forks.toLocaleString('en-US')}</dd>
      <dt>Open Issues</dt><dd>{tool.open_issues.toLocaleString('en-US')}</dd>
      <dt>Closed Issues</dt><dd>{tool.closed_issues.toLocaleString('en-US')}</dd>
      <dt>Contributors</dt><dd>{tool.contributors}</dd>
      <dt>Dependents</dt><dd>{tool.dependents > 0 ? tool.dependents.toLocaleString('en-US') : '—'}</dd>
      <dt>Language</dt><dd>{tool.language || '—'}</dd>
      <dt>License</dt><dd>{tool.license || '—'}</dd>
      <dt>Last Commit</dt><dd>{relativeTime(tool.last_commit_at)}</dd>
    </dl>
  </section>

  {tool.matched_queries.length > 0 && (
    <section class="queries">
      <h3>Matched Queries</h3>
      <div class="tags">
        {tool.matched_queries.map((q) => (
          <span class="tag">{q}</span>
        ))}
      </div>
    </section>
  )}

  {readmeExcerpt && (
    <section class="readme-excerpt">
      <h3>From the README</h3>
      <pre class="readme-text">{readmeExcerpt}</pre>
      <a href={`${tool.url}#readme`} class="readme-link" target="_blank" rel="noopener noreferrer">Read full README on GitHub &rarr;</a>
    </section>
  )}

  {relatedTools.length > 0 && (
    <section class="related">
      <h3>{primaryQuery ? `Related: ${primaryQuery}` : 'Top Ranked Tools'}</h3>
      <div class="related-list">
        {relatedTools.map((r) => (
          <a href={`/tool/${(r.full_name as string).replace('/', '--')}/`} class="related-item">
            <div class="related-left">
              <span class="related-name">{r.full_name as string}</span>
              {(r.description as string | null) && (
                <span class="related-desc">{(r.description as string).slice(0, 80)}{(r.description as string).length > 80 ? '…' : ''}</span>
              )}
            </div>
            <span class="related-score" style={`color: ${scoreColor(r.score as number)}`}>
              {(r.score as number).toFixed(1)}
            </span>
          </a>
        ))}
      </div>
    </section>
  )}

  <div class="github-link">
    <a href={tool.url} target="_blank" rel="noopener noreferrer">View on GitHub &rarr;</a>
  </div>

  <div class="share-section">
    <h3>Share</h3>
    <div class="share-buttons">
      <a
        href={`https://x.com/intent/tweet?text=${encodeURIComponent(`${tool.full_name} scored ${tool.score.toFixed(1)} on AgentRank`)}&url=${encodeURIComponent(pageUrl)}`}
        target="_blank"
        rel="noopener noreferrer"
        class="share-btn share-twitter"
      >Share on X</a>
      <button class="share-btn copy-link-btn" data-copy={pageUrl}>Copy link</button>
    </div>
  </div>

  {!claim && (
    <section class="claim-cta-section">
      <div class="claim-cta-box">
        <div class="claim-cta-text">
          <strong>Are you the maintainer of {tool.full_name}?</strong>
          <p>Claim this listing to add a tagline, mark deprecation status, and get a verified maintainer badge.</p>
        </div>
        <a href={`/claim/${slug}/`} class="claim-cta-btn">Claim this tool &rarr;</a>
      </div>
    </section>
  )}

  <script>
    document.querySelectorAll('.copy-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const text = btn.getAttribute('data-copy') || '';
        navigator.clipboard.writeText(text).then(() => {
          btn.textContent = 'Copied!';
          setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
        });
      });
    });
    document.querySelectorAll('.copy-link-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const text = btn.getAttribute('data-copy') || '';
        navigator.clipboard.writeText(text).then(() => {
          btn.textContent = 'Copied!';
          setTimeout(() => { btn.textContent = 'Copy link'; }, 2000);
        });
      });
    });
  </script>
</Base>

<style>
  .back {
    margin-bottom: 1.5rem;
  }

  .back a {
    color: var(--text-muted);
    font-size: 0.8rem;
  }

  .back a:hover {
    color: var(--accent);
  }

  .tool-header {
    margin-bottom: 1rem;
  }

  .tool-header h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .tool-meta {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .score-badge {
    font-weight: 700;
    font-size: 1rem;
  }

  .rank-badge {
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .badge {
    font-size: 0.65rem;
    padding: 0.1rem 0.35rem;
    border-radius: 3px;
  }

  .archived {
    background: #78350f;
    color: #fbbf24;
  }

  .description {
    color: var(--text-muted);
    margin-bottom: 2rem;
    font-size: 0.9rem;
  }

  section {
    margin-bottom: 2rem;
  }

  h3 {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .signal-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .signal-label {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.8rem;
    margin-bottom: 0.25rem;
  }

  .signal-name {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .signal-weight {
    font-size: 0.65rem;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
    padding: 0.05rem 0.3rem;
    border-radius: 3px;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .signal-note {
    margin-top: 0.75rem;
    font-size: 0.7rem;
    color: var(--text-muted);
    opacity: 0.7;
  }

  .signal-value {
    color: var(--text-muted);
  }

  .signal-value.coming-soon {
    font-style: italic;
    opacity: 0.5;
  }

  .signal-track {
    height: 6px;
    background: var(--bg-surface);
    border-radius: 3px;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .signal-fill {
    height: 100%;
    border-radius: 3px;
    transition: width 0.3s;
  }

  dl {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.35rem 1.5rem;
    font-size: 0.85rem;
  }

  dt {
    color: var(--text-muted);
  }

  dd {
    font-weight: 500;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    padding: 0.2rem 0.6rem;
    border-radius: 3px;
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .github-link {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .github-link a {
    font-weight: 600;
  }

  .advice-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .advice-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.75rem;
  }

  .advice-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.35rem;
  }

  .impact-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .impact-dot.impact-high { background: #22c55e; }
  .impact-dot.impact-medium { background: #eab308; }
  .impact-dot.impact-low { background: #6b7280; }

  .advice-signal {
    font-weight: 600;
    font-size: 0.8rem;
  }

  .impact-label {
    font-size: 0.7rem;
    margin-left: auto;
  }

  .impact-label.impact-high { color: #22c55e; }
  .impact-label.impact-medium { color: #eab308; }
  .impact-label.impact-low { color: #6b7280; }

  .advice-message {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.4;
  }

  .badge-embed {
    margin-bottom: 2rem;
  }

  .badge-preview {
    margin-bottom: 0.75rem;
  }

  .badge-preview img {
    height: 20px;
  }

  .snippet {
    margin-bottom: 0.5rem;
  }

  .snippet label {
    font-size: 0.7rem;
    color: var(--text-muted);
    display: block;
    margin-bottom: 0.25rem;
  }

  .snippet-row {
    display: flex;
    gap: 0.5rem;
    align-items: stretch;
  }

  .snippet-code {
    flex: 1;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    padding: 0.35rem 0.5rem;
    border-radius: 3px;
    font-size: 0.7rem;
    overflow-x: auto;
    white-space: nowrap;
  }

  .copy-btn {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 0.35rem 0.6rem;
    font-size: 0.7rem;
    cursor: pointer;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .copy-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .share-section {
    margin-top: 2rem;
  }

  .share-buttons {
    display: flex;
    gap: 0.5rem;
  }

  .share-btn {
    font-size: 0.75rem;
    padding: 0.35rem 0.75rem;
    border-radius: 3px;
    border: 1px solid var(--border);
    background: var(--bg-surface);
    color: var(--text-muted);
    cursor: pointer;
    text-decoration: none;
    font-family: inherit;
  }

  .share-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    text-decoration: none;
  }

  .claim-cta-section {
    margin-top: 2rem;
    margin-bottom: 2rem;
  }

  .claim-cta-box {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    background: var(--bg-surface);
    border: 1px solid var(--accent);
    border-radius: 6px;
    padding: 1rem 1.25rem;
  }

  .claim-cta-text {
    flex: 1;
  }

  .claim-cta-text strong {
    font-size: 0.85rem;
    color: var(--text);
    display: block;
    margin-bottom: 0.2rem;
  }

  .claim-cta-text p {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.4;
  }

  .claim-cta-btn {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.4rem 0.85rem;
    border-radius: 4px;
    background: var(--accent);
    color: #000;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .claim-cta-btn:hover {
    opacity: 0.85;
    text-decoration: none;
  }

  @media (max-width: 480px) {
    .claim-cta-box {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  .claimed-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.75rem;
    color: var(--accent);
    margin-top: 0.25rem;
  }

  .claim-tagline {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin-top: 0.2rem;
    font-style: italic;
  }

  .deprecated-badge {
    font-size: 0.65rem;
    padding: 0.1rem 0.35rem;
    border-radius: 3px;
    background: #78350f;
    color: #fbbf24;
  }

  .summary {
    margin-bottom: 2rem;
  }

  .summary-text {
    font-size: 0.9rem;
    color: var(--text);
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }

  .context-sentences {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .context-line {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .ecosystem {
    margin-bottom: 2rem;
  }

  .eco-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .eco-pill {
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    border-radius: 3px;

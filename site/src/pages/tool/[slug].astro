      </div>
    </section>
  )}

  <BlogSubscribeCTA source="tool" />

  <script>
    document.querySelectorAll('.copy-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const text = btn.getAttribute('data-copy') || '';
        navigator.clipboard.writeText(text).then(() => {
          btn.textContent = 'Copied!';
          setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
        });
      });
    });
    document.querySelectorAll('.copy-link-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const text = btn.getAttribute('data-copy') || '';
        navigator.clipboard.writeText(text).then(() => {
          btn.textContent = 'Copied!';
          setTimeout(() => { btn.textContent = 'Copy link'; }, 2000);
        });
      });
    });

    // Embed widget tabs
    const embedTabs = document.querySelectorAll<HTMLButtonElement>('.embed-tab');
    const embedPanels = document.querySelectorAll<HTMLElement>('.embed-panel');
    embedTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.etab!;
        embedTabs.forEach(t => t.classList.toggle('active', t.dataset.etab === target));
        embedPanels.forEach(p => p.classList.toggle('hidden', p.id !== `epanel-${target}`));
      });
    });
  </script>

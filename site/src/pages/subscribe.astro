---
export const prerender = true;

import Base from '../layouts/Base.astro';
---

<Base
  title="Subscribe — AgentRank Weekly Digest"
  description="Get the weekly AgentRank digest. Top MCP tools, biggest movers, and ecosystem insights — for developers building with AI agents."
  canonicalUrl="https://agentrank-ai.com/subscribe/"
  keywords="AgentRank newsletter, MCP server digest, AI agent tools newsletter, weekly MCP rankings"
>
  <div class="subscribe-page">

    <div class="hero">
      <p class="eyebrow">AgentRank Newsletter</p>
      <h1>The weekly MCP ecosystem digest</h1>
      <p class="hero-sub">
        25,000+ tools ranked daily. We distill it down to what actually moved —
        top tools, biggest rank jumps, ecosystem signals — every week.
      </p>
    </div>

    <div class="form-card">
      <form id="subscribe-form" novalidate>
        <input type="text" name="_hp" class="hp-field" tabindex="-1" autocomplete="off" />
        <div class="form-row">
          <input
            type="email"
            id="subscribe-email"
            name="email"
            placeholder="you@example.com"
            autocomplete="email"
            required
          />
          <button type="submit" id="subscribe-btn">Get the digest</button>
        </div>
        <p class="form-note">Free. No noise. Unsubscribe any time.</p>
        <span id="subscribe-msg" class="subscribe-msg" aria-live="polite"></span>
      </form>
    </div>

    <div class="what-you-get">
      <h2>What you get every week</h2>
      <div class="features">
        <div class="feature">
          <span class="feature-icon">01</span>
          <div>
            <strong>Top 5 tools</strong>
            <p>Scores, stars, and what the ranking signals tell you that raw GitHub search doesn't.</p>
          </div>
        </div>
        <div class="feature">
          <span class="feature-icon">02</span>
          <div>
            <strong>Biggest movers</strong>
            <p>Tools that jumped or fell the most since last week, and why the data moved.</p>
          </div>
        </div>
        <div class="feature">
          <span class="feature-icon">03</span>
          <div>
            <strong>New entries</strong>
            <p>Recently added tools with strong early signals — before the rest of the ecosystem notices.</p>
          </div>
        </div>
        <div class="feature">
          <span class="feature-icon">04</span>
          <div>
            <strong>Ecosystem insight</strong>
            <p>One data-driven observation about what the rankings reveal about where MCP is heading.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="preview-section">
      <h2>From issue #1</h2>
      <p class="preview-note">March 17, 2026</p>

      <div class="preview-card">
        <div class="preview-header">
          <span class="preview-label">Top 5 this week</span>
        </div>
        <table class="preview-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Tool</th>
              <th>Score</th>
              <th>Stars</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="rank-cell">1</td>
              <td>CoplayDev/unity-mcp</td>
              <td class="score-cell">98.7</td>
              <td>7,003</td>
            </tr>
            <tr>
              <td class="rank-cell">2</td>
              <td>microsoft/azure-devops-mcp</td>
              <td class="score-cell">97.2</td>
              <td>1,406</td>
            </tr>
            <tr>
              <td class="rank-cell">3</td>
              <td>laravel/boost</td>
              <td class="score-cell">96.9</td>
              <td>3,333</td>
            </tr>
            <tr>
              <td class="rank-cell">4</td>
              <td>CoderGamester/mcp-unity</td>
              <td class="score-cell">96.4</td>
              <td>1,412</td>
            </tr>
            <tr>
              <td class="rank-cell">5</td>
              <td>mark3labs/mcp-go</td>
              <td class="score-cell">96.3</td>
              <td>8,353</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="preview-card">
        <div class="preview-header">
          <span class="preview-label">Biggest movers</span>
        </div>
        <table class="preview-table">
          <thead>
            <tr>
              <th>Tool</th>
              <th>Was</th>
              <th>Now</th>
              <th>Change</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>homeassistant-ai/ha-mcp</td>
              <td class="rank-was">#72</td>
              <td>#16</td>
              <td class="mover-up">+56</td>
            </tr>
            <tr>
              <td>jgravelle/jcodemunch-mcp</td>
              <td class="rank-was">#68</td>
              <td>#18</td>
              <td class="mover-up">+50</td>
            </tr>
            <tr>
              <td>samanhappy/mcphub</td>
              <td class="rank-was">#50</td>
              <td>#9</td>
              <td class="mover-up">+41</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="preview-insight">
        <strong>Ecosystem insight:</strong> Unity is dominating the top 5 — two of the top 4 tools are Unity MCP integrations.
        Game developers are adopting MCP faster than any other category, and their maintainers are keeping pace.
        The smart home community (homeassistant-ai/ha-mcp, +56 rank) appears to have just discovered it.
      </div>
    </div>

    <div class="bottom-cta">
      <p>Updated weekly from a live index of 25,000+ tools.</p>
      <a href="/" class="back-link">Browse the full rankings</a>
    </div>

  </div>
</Base>

<style>
  .subscribe-page {
    max-width: 680px;
    margin: 0 auto;
    padding: 3rem 1rem 4rem;
  }

  .hero {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.75rem;
  }

  h1 {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.75rem;
    line-height: 1.25;
  }

  .hero-sub {
    font-size: 0.92rem;
    color: var(--text-muted);
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .form-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.75rem 2rem;
    margin-bottom: 3rem;
  }

  .form-row {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .form-row input[type="email"] {
    flex: 1;
    min-width: 0;
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 0.6rem 0.875rem;
    border-radius: 4px;
    font-family: inherit;
    font-size: 0.9rem;
  }

  .form-row input[type="email"]:focus {
    outline: 1px solid var(--accent);
    border-color: var(--accent);
  }

  .form-row button {
    background: var(--accent);
    color: #000;
    border: none;
    border-radius: 4px;
    padding: 0.6rem 1.25rem;
    font-family: inherit;
    font-size: 0.9rem;
    font-weight: 700;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.15s;
  }

  .form-row button:hover {
    opacity: 0.85;
  }

  .form-row button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .form-note {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-top: 0.4rem;
  }

  .subscribe-msg {
    display: block;
    font-size: 0.82rem;
    min-height: 1.1em;
    margin-top: 0.4rem;
  }

  .subscribe-msg.success { color: var(--accent); }
  .subscribe-msg.error { color: #ef4444; }

  .hp-field {
    position: absolute;
    left: -9999px;
    opacity: 0;
    height: 0;
    width: 0;
    pointer-events: none;
  }

  /* What you get */
  .what-you-get {
    margin-bottom: 3rem;
  }

  h2 {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .features {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .feature {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .feature-icon {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--accent);
    min-width: 2rem;
    padding-top: 0.05rem;
    letter-spacing: 0.05em;
  }

  .feature strong {
    display: block;
    font-size: 0.88rem;
    color: var(--text);
    margin-bottom: 0.2rem;
  }

  .feature p {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.5;
  }

  /* Preview section */
  .preview-section {
    margin-bottom: 3rem;
  }

  .preview-note {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
    margin-top: -0.75rem;
  }

  .preview-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    margin-bottom: 1rem;
  }

  .preview-header {
    padding: 0.6rem 1rem;
    border-bottom: 1px solid var(--border);
    background: var(--bg-hover);
  }

  .preview-label {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .preview-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.82rem;
  }

  .preview-table th {
    text-align: left;
    padding: 0.45rem 1rem;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: var(--bg-surface);
    border-bottom: 1px solid var(--border);
  }

  .preview-table td {
    padding: 0.55rem 1rem;
    border-bottom: 1px solid var(--border);
    color: var(--text);
  }

  .preview-table tr:last-child td {
    border-bottom: none;
  }

  .rank-cell {
    font-weight: 700;
    color: var(--text-muted) !important;
    width: 2rem;
  }

  .score-cell {
    font-weight: 600;
    color: var(--accent) !important;
  }

  .rank-was {
    color: var(--text-muted) !important;
  }

  .mover-up {
    font-weight: 700;
    color: var(--accent) !important;
  }

  .preview-insight {
    background: var(--bg-surface);
    border-left: 2px solid var(--accent);
    border-radius: 0 4px 4px 0;
    padding: 0.85rem 1.25rem;
    font-size: 0.82rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .preview-insight strong {
    color: var(--text);
  }

  /* Bottom CTA */
  .bottom-cta {
    text-align: center;
    border-top: 1px solid var(--border);
    padding-top: 1.5rem;
  }

  .bottom-cta p {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .back-link {
    font-size: 0.85rem;
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  @media (max-width: 480px) {
    .subscribe-page {
      padding: 2rem 1rem 3rem;
    }
    h1 {
      font-size: 1.35rem;
    }
    .form-card {
      padding: 1.25rem;
    }
    .form-row {
      flex-direction: column;
    }
    .form-row button {
      width: 100%;
    }
  }
</style>

<script>
  const form = document.getElementById('subscribe-form') as HTMLFormElement;
  const input = document.getElementById('subscribe-email') as HTMLInputElement;
  const btn = document.getElementById('subscribe-btn') as HTMLButtonElement;
  const msg = document.getElementById('subscribe-msg') as HTMLSpanElement;

  // Extract UTM params from the URL to pass to the API
  function getUtmParams(): Record<string, string> {
    const params: Record<string, string> = {};
    const sp = new URLSearchParams(window.location.search);
    for (const key of ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term']) {
      const val = sp.get(key);
      if (val) params[key] = val;
    }
    return params;
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = input.value.trim();
    const hp = (form.querySelector<HTMLInputElement>('.hp-field')?.value ?? '');
    if (hp) return;

    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      msg.textContent = 'Please enter a valid email address.';
      msg.className = 'subscribe-msg error';
      return;
    }

    btn.disabled = true;
    msg.textContent = '';
    msg.className = 'subscribe-msg';

    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email,
          source: 'subscribe-page',
          _hp: '',
          utm_params: getUtmParams(),
        }),
      });
      const data = await res.json();
      if (data.success) {
        msg.textContent = data.already
          ? "You're already subscribed."
          : "You're in. First digest coming your way.";
        msg.className = 'subscribe-msg success';
        input.value = '';
      } else {
        msg.textContent = data.error || 'Something went wrong.';
        msg.className = 'subscribe-msg error';
        btn.disabled = false;
      }
    } catch {
      msg.textContent = 'Network error. Please try again.';
      msg.className = 'subscribe-msg error';
      btn.disabled = false;
    }
  });
</script>

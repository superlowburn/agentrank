---
export const prerender = true;

import Base from '../layouts/Base.astro';
import { getTopTools } from '../data/ranked';
import { toSlug } from '../data/tools';

const rawTools = getTopTools(300).map((t) => ({
  full_name: t.full_name,
  description: t.description,
  score: t.score,
  stars: t.stars,
  language: t.language,
  license: t.license,
  last_commit_at: t.last_commit_at,
  category: t.category,
  slug: toSlug(t.full_name),
}));

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'AgentRank',
      item: 'https://agentrank-ai.com',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'MCP Server Finder',
      item: 'https://agentrank-ai.com/finder/',
    },
  ],
};
---

<Base
  title="Find the Best MCP Server for Your Project — AgentRank"
  description="Answer 4 questions and get personalized MCP server recommendations ranked by real signals. Find the right tool for your AI chatbot, code assistant, data pipeline, or automation project."
  keywords="find MCP server, best MCP server for my project, MCP server recommendation, MCP server wizard, choose MCP server, model context protocol tools"
  canonicalUrl="https://agentrank-ai.com/finder/"
  jsonLd={breadcrumbJsonLd}
>
  <div class="finder-wrap">
    <div class="finder-header">
      <h1>MCP Server Finder</h1>
      <p class="subtitle">Answer 4 questions. Get personalized recommendations from 25,000+ ranked tools.</p>
    </div>

    <div class="progress-bar" id="progress-bar">
      <div class="progress-steps">
        <div class="progress-step active" data-step="1">1</div>
        <div class="progress-line"></div>
        <div class="progress-step" data-step="2">2</div>
        <div class="progress-line"></div>
        <div class="progress-step" data-step="3">3</div>
        <div class="progress-line"></div>
        <div class="progress-step" data-step="4">4</div>
      </div>
      <div class="progress-labels">
        <span>What are you building?</span>
        <span>Language</span>
        <span>Capabilities</span>
        <span>Preferences</span>
      </div>
    </div>

    <!-- Step 1: What are you building? -->
    <div class="step" id="step-1">
      <h2>What are you building?</h2>
      <div class="options">
        <label class="option">
          <input type="radio" name="building" value="chatbot" />
          <span class="option-box">
            <span class="option-icon">💬</span>
            <span class="option-label">AI chatbot / assistant</span>
            <span class="option-desc">Claude, GPT, or custom LLM-powered chat or agent</span>
          </span>
        </label>
        <label class="option">
          <input type="radio" name="building" value="code" />
          <span class="option-box">
            <span class="option-icon">💻</span>
            <span class="option-label">Code assistant</span>
            <span class="option-desc">Cursor, Copilot, or custom coding tool</span>
          </span>
        </label>
        <label class="option">
          <input type="radio" name="building" value="data" />
          <span class="option-box">
            <span class="option-icon">📊</span>
            <span class="option-label">Data pipeline</span>
            <span class="option-desc">ETL, analytics, or data processing workflow</span>
          </span>
        </label>
        <label class="option">
          <input type="radio" name="building" value="automation" />
          <span class="option-box">
            <span class="option-icon">⚙️</span>
            <span class="option-label">Automation / workflows</span>
            <span class="option-desc">API integrations, scheduled tasks, or bot automation</span>
          </span>
        </label>
        <label class="option">
          <input type="radio" name="building" value="other" />
          <span class="option-box">
            <span class="option-icon">🔧</span>
            <span class="option-label">Something else</span>
            <span class="option-desc">Research, experiments, or other use case</span>
          </span>
        </label>
      </div>
      <div class="step-nav">
        <span></span>
        <button class="btn-primary" id="next-1" disabled>Next &rarr;</button>
      </div>
    </div>

    <!-- Step 2: Language -->
    <div class="step hidden" id="step-2">
      <h2>What language or framework?</h2>
      <div class="options">
        <label class="option">
          <input type="radio" name="lang" value="typescript" />
          <span class="option-box">
            <span class="option-icon">🟦</span>
            <span class="option-label">TypeScript / JavaScript</span>
            <span class="option-desc">Node.js, Deno, Bun</span>
          </span>
        </label>
        <label class="option">
          <input type="radio" name="lang" value="python" />
          <span class="option-box">
            <span class="option-icon">🐍</span>
            <span class="option-label">Python</span>
            <span class="option-desc">FastAPI, Django, or plain Python</span>
          </span>
        </label>
        <label class="option">
          <input type="radio" name="lang" value="go" />
          <span class="option-box">
            <span class="option-icon">🐹</span>
            <span class="option-label">Go</span>
            <span class="option-desc">High-performance services</span>
          </span>
        </label>
        <label class="option">
          <input type="radio" name="lang" value="rust" />
          <span class="option-box">
            <span class="option-icon">🦀</span>
            <span class="option-label">Rust</span>
            <span class="option-desc">Systems-level performance</span>
          </span>
        </label>
        <label class="option">
          <input type="radio" name="lang" value="any" />
          <span class="option-box">
            <span class="option-icon">🌐</span>
            <span class="option-label">Any language</span>
            <span class="option-desc">Language doesn't matter</span>
          </span>
        </label>
      </div>
      <div class="step-nav">
        <button class="btn-secondary" id="back-2">&larr; Back</button>
        <button class="btn-primary" id="next-2" disabled>Next &rarr;</button>
      </div>
    </div>

    <!-- Step 3: Capabilities (multi-select) -->
    <div class="step hidden" id="step-3">
      <h2>What capabilities do you need?</h2>
      <p class="step-hint">Select all that apply</p>
      <div class="options options-multi">
        <label class="option">
          <input type="checkbox" name="caps" value="database" />
          <span class="option-box">
            <span class="option-icon">🗄️</span>
            <span class="option-label">Database / storage</span>
            <span class="option-desc">SQL, NoSQL, vector stores</span>
          </span>
        </label>
        <label class="option">
          <input type="checkbox" name="caps" value="filesystem" />
          <span class="option-box">
            <span class="option-icon">📁</span>
            <span class="option-label">File system</span>
            <span class="option-desc">Read, write, manage local files</span>
          </span>
        </label>
        <label class="option">
          <input type="checkbox" name="caps" value="api" />
          <span class="option-box">
            <span class="option-icon">🔌</span>
            <span class="option-label">API / web integration</span>
            <span class="option-desc">REST, GraphQL, webhooks</span>
          </span>
        </label>
        <label class="option">
          <input type="checkbox" name="caps" value="browser" />
          <span class="option-box">
            <span class="option-icon">🌐</span>
            <span class="option-label">Browser automation</span>
            <span class="option-desc">Playwright, Puppeteer, web scraping</span>
          </span>
        </label>
        <label class="option">
          <input type="checkbox" name="caps" value="communication" />
          <span class="option-box">
            <span class="option-icon">💬</span>
            <span class="option-label">Communication</span>
            <span class="option-desc">Slack, email, Discord, Telegram</span>
          </span>
        </label>
        <label class="option">
          <input type="checkbox" name="caps" value="search" />
          <span class="option-box">
            <span class="option-icon">🔍</span>
            <span class="option-label">Search / RAG</span>
            <span class="option-desc">Vector search, semantic retrieval</span>
          </span>
        </label>
        <label class="option">
          <input type="checkbox" name="caps" value="codegen" />
          <span class="option-box">
            <span class="option-icon">⚡</span>
            <span class="option-label">Code generation</span>
            <span class="option-desc">Generate, scaffold, or analyze code</span>
          </span>
        </label>
        <label class="option">
          <input type="checkbox" name="caps" value="any" id="caps-any" />
          <span class="option-box">
            <span class="option-icon">✨</span>
            <span class="option-label">Not sure / any</span>
            <span class="option-desc">Show me top-ranked tools overall</span>
          </span>
        </label>
      </div>
      <div class="step-nav">
        <button class="btn-secondary" id="back-3">&larr; Back</button>
        <button class="btn-primary" id="next-3">Next &rarr;</button>
      </div>
    </div>

    <!-- Step 4: Preferences (multi-select) -->
    <div class="step hidden" id="step-4">
      <h2>Any preferences?</h2>
      <p class="step-hint">Optional — select all that matter to you</p>
      <div class="options options-multi">
        <label class="option">
          <input type="checkbox" name="prefs" value="maintained" />
          <span class="option-box">
            <span class="option-icon">🔄</span>
            <span class="option-label">Actively maintained</span>
            <span class="option-desc">Last commit within 30 days</span>
          </span>
        </label>
        <label class="option">
          <input type="checkbox" name="prefs" value="open-source" />
          <span class="option-box">
            <span class="option-icon">📖</span>
            <span class="option-label">Open source</span>
            <span class="option-desc">Has an explicit open source license</span>
          </span>
        </label>
        <label class="option">
          <input type="checkbox" name="prefs" value="adoption" />
          <span class="option-box">
            <span class="option-icon">⭐</span>
            <span class="option-label">High community adoption</span>
            <span class="option-desc">500+ GitHub stars</span>
          </span>
        </label>
      </div>
      <div class="step-nav">
        <button class="btn-secondary" id="back-4">&larr; Back</button>
        <button class="btn-primary" id="show-results">Find Matches &rarr;</button>
      </div>
    </div>

    <!-- Results -->
    <div class="step hidden" id="results-panel">
      <div class="results-header">
        <h2>Your top matches</h2>
        <div class="results-meta">
          <span class="results-summary" id="results-summary"></span>
          <button class="btn-secondary btn-sm" id="share-btn">Copy shareable link</button>
          <button class="btn-secondary btn-sm" id="restart-btn">Start over</button>
        </div>
      </div>
      <div id="results-list"></div>
      <p class="results-footer">Scores computed from stars, freshness, issue health, contributors, and dependents. <a href="/methodology/">How scoring works &rarr;</a></p>
    </div>
  </div>
</Base>

<script define:vars={{ rawTools }}>
  const tools = rawTools;

  // --- Wizard state ---
  let currentStep = 1;
  const answers = { building: '', lang: '', caps: [], prefs: [] };

  // --- Step navigation ---
  function showStep(n) {
    document.querySelectorAll('.step').forEach((s) => s.classList.add('hidden'));
    document.getElementById(`step-${n}`) && document.getElementById(`step-${n}`).classList.remove('hidden');
    if (n === 'results') {
      document.getElementById('results-panel').classList.remove('hidden');
    }
    updateProgress(n);
  }

  function updateProgress(step) {
    const stepEls = document.querySelectorAll('.progress-step');
    stepEls.forEach((el) => {
      const s = parseInt(el.dataset.step);
      el.classList.toggle('active', s === step);
      el.classList.toggle('done', s < step);
    });
  }

  // Step 1
  document.querySelectorAll('input[name="building"]').forEach((input) => {
    input.addEventListener('change', () => {
      answers.building = input.value;
      document.getElementById('next-1').disabled = false;
      document.querySelectorAll('.option-box').forEach((b) => b.classList.remove('selected'));
      input.closest('.option-box').classList.add('selected');
    });
  });

  document.getElementById('next-1').addEventListener('click', () => {
    currentStep = 2;
    showStep(2);
  });

  // Step 2
  document.querySelectorAll('input[name="lang"]').forEach((input) => {
    input.addEventListener('change', () => {
      answers.lang = input.value;
      document.getElementById('next-2').disabled = false;
      const parent = input.closest('.options');
      parent.querySelectorAll('.option-box').forEach((b) => b.classList.remove('selected'));
      input.closest('.option-box').classList.add('selected');
    });
  });

  document.getElementById('next-2').addEventListener('click', () => {
    currentStep = 3;
    showStep(3);
  });

  document.getElementById('back-2').addEventListener('click', () => {
    currentStep = 1;
    showStep(1);
  });

  // Step 3 — multi-select checkboxes
  const capsAny = document.getElementById('caps-any');
  document.querySelectorAll('input[name="caps"]').forEach((input) => {
    input.addEventListener('change', () => {
      if (input.value === 'any' && input.checked) {
        document.querySelectorAll('input[name="caps"]').forEach((c) => {
          if (c.value !== 'any') c.checked = false;
        });
      } else if (input.value !== 'any' && input.checked) {
        capsAny.checked = false;
      }
      input.closest('.option-box').classList.toggle('selected', input.checked);
      answers.caps = Array.from(document.querySelectorAll('input[name="caps"]:checked')).map((c) => c.value);
    });
  });

  document.getElementById('next-3').addEventListener('click', () => {
    answers.caps = Array.from(document.querySelectorAll('input[name="caps"]:checked')).map((c) => c.value);
    currentStep = 4;
    showStep(4);
  });

  document.getElementById('back-3').addEventListener('click', () => {
    currentStep = 2;
    showStep(2);
  });

  // Step 4 — preferences
  document.querySelectorAll('input[name="prefs"]').forEach((input) => {
    input.addEventListener('change', () => {
      input.closest('.option-box').classList.toggle('selected', input.checked);
      answers.prefs = Array.from(document.querySelectorAll('input[name="prefs"]:checked')).map((c) => c.value);
    });
  });

  document.getElementById('back-4').addEventListener('click', () => {
    currentStep = 3;
    showStep(3);
  });

  document.getElementById('show-results').addEventListener('click', () => {
    answers.prefs = Array.from(document.querySelectorAll('input[name="prefs"]:checked')).map((c) => c.value);
    showResults();
  });

  // --- Scoring ---
  const buildingCategories = {
    chatbot: ['mcp-server', 'agent-framework', 'llm-client', 'ai-tool', 'ai-models'],
    code: ['code-generation', 'code-assistant', 'mcp-server'],
    data: ['data-processing', 'database', 'search'],
    automation: ['api-integration', 'deployment', 'agent-framework'],
    other: [],
  };

  const capCategories = {
    database: 'database',
    filesystem: 'filesystem',
    api: 'api-integration',
    browser: 'browser-automation',
    communication: 'communication',
    search: 'search',
    codegen: 'code-generation',
  };

  const langMap = {
    typescript: ['TypeScript', 'JavaScript'],
    python: ['Python'],
    go: ['Go'],
    rust: ['Rust'],
    any: null,
  };

  function scoreForWizard(tool) {
    let score = tool.score;
    const now = Date.now();

    // Language match
    const wantedLangs = langMap[answers.lang];
    if (wantedLangs) {
      if (wantedLangs.includes(tool.language)) {
        score += 25;
      } else {
        score -= 15;
      }
    }

    // Building type → category bonus
    const wantedBuildCats = buildingCategories[answers.building] || [];
    if (wantedBuildCats.length > 0 && wantedBuildCats.includes(tool.category)) {
      score += 20;
    }

    // Capabilities match
    const selectedCaps = answers.caps.filter((c) => c !== 'any');
    if (selectedCaps.length > 0) {
      const wantedCapCats = selectedCaps.map((c) => capCategories[c]).filter(Boolean);
      if (wantedCapCats.includes(tool.category)) {
        score += 35;
      } else {
        score -= 25;
      }
    }

    // Preferences
    if (answers.prefs.includes('maintained')) {
      const daysSince = (now - new Date(tool.last_commit_at).getTime()) / (1000 * 60 * 60 * 24);
      if (daysSince > 90) score -= 50;
      else if (daysSince > 30) score -= 20;
    }

    if (answers.prefs.includes('open-source')) {
      if (!tool.license) score -= 40;
    }

    if (answers.prefs.includes('adoption')) {
      if (tool.stars < 500) score -= 30;
      else if (tool.stars >= 1000) score += 10;
    }

    return score;
  }

  function formatStars(n) {
    if (n >= 1000) return (n / 1000).toFixed(n >= 10000 ? 0 : 1) + 'k';
    return n.toLocaleString('en-US');
  }

  function relativeTime(dateStr) {
    const diffDays = Math.floor((Date.now() - new Date(dateStr).getTime()) / (1000 * 60 * 60 * 24));
    if (diffDays < 1) return 'today';
    if (diffDays === 1) return '1d ago';
    if (diffDays < 30) return `${diffDays}d ago`;
    const months = Math.floor(diffDays / 30);
    if (months < 12) return `${months}mo ago`;
    return `${Math.floor(months / 12)}y ago`;
  }

  function scoreColor(score) {
    if (score > 70) return '#22c55e';
    if (score > 40) return '#eab308';
    return '#ef4444';
  }

  function buildingLabel(v) {
    const m = { chatbot: 'AI chatbot', code: 'Code assistant', data: 'Data pipeline', automation: 'Automation', other: 'Other' };
    return m[v] || v;
  }

  function showResults() {
    const scored = tools
      .map((t) => ({ ...t, matchScore: scoreForWizard(t) }))
      .sort((a, b) => b.matchScore - a.matchScore)
      .slice(0, 5);

    // Update URL
    const params = new URLSearchParams();
    params.set('building', answers.building);
    params.set('lang', answers.lang);
    if (answers.caps.length) params.set('caps', answers.caps.join(','));
    if (answers.prefs.length) params.set('prefs', answers.prefs.join(','));
    history.replaceState(null, '', `?${params.toString()}`);

    const summaryParts = [buildingLabel(answers.building)];
    if (answers.lang && answers.lang !== 'any') summaryParts.push(answers.lang);
    if (answers.caps.filter((c) => c !== 'any').length) summaryParts.push(...answers.caps.filter((c) => c !== 'any'));
    document.getElementById('results-summary').textContent = `Best matches for: ${summaryParts.join(' · ')}`;

    const list = document.getElementById('results-list');
    list.innerHTML = scored
      .map(
        (t, i) => `
      <div class="result-card">
        <div class="result-rank">#${i + 1}</div>
        <div class="result-body">
          <div class="result-title">
            <a href="/tool/${t.slug}/" class="result-name">${t.full_name}</a>
            ${t.category ? `<span class="result-cat">${t.category}</span>` : ''}
          </div>
          <p class="result-desc">${t.description || 'No description available.'}</p>
          <div class="result-meta">
            <span class="result-score" style="color: ${scoreColor(t.score)}">Score ${Math.round(t.score)}</span>
            <span>⭐ ${formatStars(t.stars)}</span>
            <span>🕐 ${relativeTime(t.last_commit_at)}</span>
            ${t.language ? `<span>${t.language}</span>` : ''}
            ${t.license ? `<span class="result-license">${t.license}</span>` : ''}
          </div>
        </div>
        <div class="result-actions">
          <a href="/tool/${t.slug}/" class="btn-primary btn-sm">Details &rarr;</a>
        </div>
      </div>
    `
      )
      .join('');

    showStep('results');
    updateProgress(5);
  }

  // Share button
  document.getElementById('share-btn').addEventListener('click', () => {
    navigator.clipboard.writeText(window.location.href).then(() => {
      const btn = document.getElementById('share-btn');
      btn.textContent = 'Copied!';
      setTimeout(() => (btn.textContent = 'Copy shareable link'), 2000);
    });
  });

  // Restart
  document.getElementById('restart-btn').addEventListener('click', () => {
    answers.building = '';
    answers.lang = '';
    answers.caps = [];
    answers.prefs = [];
    document.querySelectorAll('input[name="building"], input[name="lang"]').forEach((i) => (i.checked = false));
    document.querySelectorAll('input[name="caps"], input[name="prefs"]').forEach((i) => (i.checked = false));
    document.querySelectorAll('.option-box').forEach((b) => b.classList.remove('selected'));
    document.getElementById('next-1').disabled = true;
    document.getElementById('next-2').disabled = true;
    history.replaceState(null, '', window.location.pathname);
    currentStep = 1;
    showStep(1);
  });

  // --- Load from URL params on page load ---
  function loadFromUrl() {
    const p = new URLSearchParams(window.location.search);
    const building = p.get('building');
    const lang = p.get('lang');
    const caps = p.get('caps') ? p.get('caps').split(',') : [];
    const prefs = p.get('prefs') ? p.get('prefs').split(',') : [];

    if (!building || !lang) return;

    answers.building = building;
    answers.lang = lang;
    answers.caps = caps;
    answers.prefs = prefs;

    // Pre-check inputs
    const bInput = document.querySelector(`input[name="building"][value="${building}"]`);
    if (bInput) { bInput.checked = true; bInput.closest('.option-box').classList.add('selected'); }

    const lInput = document.querySelector(`input[name="lang"][value="${lang}"]`);
    if (lInput) { lInput.checked = true; lInput.closest('.option-box').classList.add('selected'); }

    caps.forEach((c) => {
      const el = document.querySelector(`input[name="caps"][value="${c}"]`);
      if (el) { el.checked = true; el.closest('.option-box').classList.add('selected'); }
    });

    prefs.forEach((c) => {
      const el = document.querySelector(`input[name="prefs"][value="${c}"]`);
      if (el) { el.checked = true; el.closest('.option-box').classList.add('selected'); }
    });

    showResults();
  }

  loadFromUrl();
</script>

<style>
  .finder-wrap {
    max-width: 680px;
    margin: 0 auto;
    padding: 1rem 0 3rem;
  }

  .finder-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .finder-header h1 {
    font-size: 1.8rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
  }

  .finder-header .subtitle {
    color: var(--text-muted);
    margin: 0;
    font-size: 0.95rem;
  }

  /* Progress bar */
  .progress-bar {
    margin-bottom: 2rem;
  }

  .progress-steps {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    margin-bottom: 0.5rem;
  }

  .progress-step {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    border: 2px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-muted);
    background: var(--bg-surface);
    flex-shrink: 0;
    transition: all 0.2s;
  }

  .progress-step.active {
    border-color: var(--accent);
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
  }

  .progress-step.done {
    border-color: var(--accent);
    background: var(--accent);
    color: #000;
  }

  .progress-line {
    flex: 1;
    height: 2px;
    background: var(--border);
    max-width: 80px;
    min-width: 20px;
  }

  .progress-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.7rem;
    color: var(--text-muted);
    padding: 0 0.5rem;
  }

  /* Steps */

---
import Base from '../../layouts/Base.astro';
import { scoreColor, formatInstalls, sourceLabel } from '../../data/skills';
import { relativeTime } from '../../data/tools';
import { getSkillAdvice } from '../../data/advice';
import { generateSkillSummary, generateContextSentences, generateSkillJsonLd } from '../../data/content-gen';

const { slug } = Astro.params;

// Convert URL slug back to DB slug:
// URL uses -- for / and - for : (via toSkillSlug)
const decoded = slug!.replace(/--/g, '/').replace(/^(skills\.sh|glama|clawhub)-/, '$1:');

const { env } = Astro.locals.runtime;

// Try decoded slug first, then raw slug as fallback
let row = await env.DB.prepare('SELECT * FROM skills WHERE slug = ?').bind(decoded).first();
if (!row) {
  row = await env.DB.prepare('SELECT * FROM skills WHERE slug = ?').bind(slug).first();
}

if (!row) {
  return Astro.redirect('/404');
}

const skill = {
  rank: row.rank as number,
  slug: row.slug as string,
  name: (row.name as string | null) || row.slug as string,
  description: row.description as string | null,
  score: row.score as number,
  installs: row.installs as number,
  platforms: JSON.parse(row.platforms as string || '[]') as string[],
  source: row.source as string,
  github_repo: row.github_repo as string | null,
  author: row.author as string | null,
};

// Look up linked GitHub repo data if available
let repoData: {
  stars: number;
  last_commit_at: string;
  open_issues: number;
  closed_issues: number;
  contributors: number;
} | null = null;

let readmeExcerpt: string | null = null;
if (skill.github_repo) {
  const repoRow = await env.DB.prepare('SELECT stars, last_commit_at, open_issues, closed_issues, contributors, readme_excerpt FROM tools WHERE full_name = ?')
    .bind(skill.github_repo)
    .first();
  if (repoRow) {
    repoData = {
      stars: repoRow.stars as number,
      last_commit_at: repoRow.last_commit_at as string,
      open_issues: repoRow.open_issues as number,
      closed_issues: repoRow.closed_issues as number,
      contributors: repoRow.contributors as number,
    };
    readmeExcerpt = repoRow.readme_excerpt as string | null;
  }
}

// Fallback: use skill-level GitHub data if tools table join failed
if (!repoData && row.gh_stars !== null) {
  repoData = {
    stars: row.gh_stars as number,
    last_commit_at: row.gh_last_commit_at as string,
    open_issues: row.gh_open_issues as number,
    closed_issues: row.gh_closed_issues as number,
    contributors: row.gh_contributors as number,
  };
}

// Compute signal bars
const installsBar = Math.min(100, Math.log(1 + skill.installs) / Math.log(1 + 200000) * 100);

const freshnessBar = repoData ? (() => {
  const days = Math.floor((Date.now() - new Date(repoData.last_commit_at).getTime()) / (1000 * 60 * 60 * 24));
  if (days <= 7) return 100;
  if (days <= 90) return 100 - ((days - 7) / 83) * 60;
  return Math.max(0, 40 * Math.exp(-(days - 90) / 180));
})() : null;

const issueHealth = repoData ? (() => {
  const total = repoData.open_issues + repoData.closed_issues;
  return total > 0 ? repoData.closed_issues / total : 0.5;
})() : null;

const starsBar = repoData ? Math.min(100, Math.log(1 + repoData.stars) / Math.log(1 + 200000) * 100) : null;

const platformBar = Math.min(100, skill.platforms.length / 21 * 100);

const contributorsBar = repoData ? Math.min(100, Math.log(1 + repoData.contributors) / Math.log(1 + 500) * 100) : null;

const descLen = skill.description?.length ?? 0;
const descQuality = !skill.description ? 0 : descLen < 50 ? 0.3 : descLen < 150 ? 0.7 : 1.0;

// Build registry link
const registryLink = skill.source === 'skills.sh'
  ? `https://skills.sh/${skill.slug}`
  : skill.source === 'glama'
    ? `https://glama.ai/mcp/servers/${skill.slug}`
    : null;

const githubLink = skill.github_repo
  ? (skill.github_repo.startsWith('http') ? skill.github_repo : `https://github.com/${skill.github_repo}`)
  : null;

const advice = skill.score <= 85 ? getSkillAdvice(skill, repoData) : [];
const SITE_URL = 'https://agentrank-ai.com';
const badgeUrl = `${SITE_URL}/api/badge/skill/${slug}`;
const pageUrl = `${SITE_URL}/skill/${slug}/`;
const mdSnippet = `[![AgentRank](${badgeUrl})](${pageUrl})`;
const htmlSnippet = `<a href="${pageUrl}"><img src="${badgeUrl}" alt="AgentRank"></a>`;

const totalSkills = (await env.DB.prepare('SELECT COUNT(*) as count FROM skills').first())?.count as number || 0;
const summary = generateSkillSummary({
  name: skill.name,
  description: skill.description,
  source: skill.source,
  author: skill.author,
  platforms: skill.platforms,
  ...(repoData ? {
    stars: repoData.stars,
    issueHealth: issueHealth ?? undefined,
  } : {}),
});
const contextSentences = generateContextSentences({
  rank: skill.rank,
  score: skill.score,
  ...(repoData ? {
    stars: repoData.stars,
    contributors: repoData.contributors,
    last_commit_at: repoData.last_commit_at,
  } : {}),
}, totalSkills);
const jsonLd = generateSkillJsonLd({
  name: skill.name,
  slug: skill.slug,
  description: skill.description,
  source: skill.source,
  author: skill.author,
  score: skill.score,
  platforms: skill.platforms,
}, pageUrl);
const keywordsStr = [skill.source, ...skill.platforms.slice(0, 5), 'AI skill', 'agent skill'].join(', ');

// Related skills
const relatedRows = await env.DB.prepare(
  'SELECT slug, name, score, rank FROM skills WHERE slug != ? AND score IS NOT NULL ORDER BY score DESC LIMIT 5'
).bind(skill.slug).all();
const relatedSkills = relatedRows.results || [];
---

<Base title={`${skill.name} — AgentRank`} description={summary} activeTab="skills" jsonLd={jsonLd} keywords={keywordsStr} canonicalUrl={pageUrl}>
  <nav class="breadcrumb" aria-label="breadcrumb">
    <a href="/">Home</a>
    <span class="breadcrumb-sep" aria-hidden="true">&rsaquo;</span>
    <a href="/">Skills</a>
    <span class="breadcrumb-sep" aria-hidden="true">&rsaquo;</span>
    <span class="breadcrumb-current" aria-current="page">{skill.name}</span>
  </nav>

  <div class="tool-header">
    <div class="tool-header-left">
      <h2>{skill.name}</h2>
      <div class="tool-meta">
        <span class="rank-pill">#{skill.rank} of {totalSkills}</span>
        {skill.author && <span class="author-badge">by {skill.author}</span>}
      </div>
    </div>
    <div class="score-ring" style={`border-color: ${scoreColor(skill.score)}`}>
      <span class="score-number" style={`color: ${scoreColor(skill.score)}`}>{Math.round(skill.score)}</span>
      <span class="score-label">score</span>
    </div>
  </div>

  {skill.description && <p class="description">{skill.description}</p>}

  {contextSentences.length > 0 && (
    <div class="context-sentences">
      {contextSentences.map((s) => (
        <span class="context-line">{s}</span>
      ))}
    </div>
  )}

  <section class="signals">
    <h3>Signal Breakdown</h3>
    <div class="signal-list">
      <div class="signal">
        <div class="signal-label">
          <span>Installs</span>
          <span class="signal-value">{formatInstalls(skill.installs)}</span>
        </div>
        <div class="signal-track">
          <div class="signal-fill" style={`width: ${installsBar}%; background: ${scoreColor(installsBar)}`}></div>
        </div>
      </div>

      {freshnessBar !== null && repoData ? (
        <div class="signal">
          <div class="signal-label">
            <span>Freshness</span>
            <span class="signal-value">{relativeTime(repoData.last_commit_at)}</span>
          </div>
          <div class="signal-track">
            <div class="signal-fill" style={`width: ${freshnessBar}%; background: ${scoreColor(freshnessBar)}`}></div>
          </div>
        </div>
      ) : (
        <div class="signal">
          <div class="signal-label">
            <span>Freshness</span>
            <span class="signal-value muted">GitHub not linked</span>
          </div>
        </div>
      )}

      {issueHealth !== null ? (
        <div class="signal">
          <div class="signal-label">
            <span>Issue Health</span>
            <span class="signal-value">{(issueHealth * 100).toFixed(0)}%</span>
          </div>
          <div class="signal-track">
            <div class="signal-fill" style={`width: ${issueHealth * 100}%; background: ${scoreColor(issueHealth * 100)}`}></div>
          </div>
        </div>
      ) : (
        <div class="signal">
          <div class="signal-label">
            <span>Issue Health</span>
            <span class="signal-value muted">GitHub not linked</span>
          </div>
        </div>
      )}

      {starsBar !== null && repoData ? (
        <div class="signal">
          <div class="signal-label">
            <span>Stars</span>
            <span class="signal-value">{repoData.stars.toLocaleString('en-US')}</span>
          </div>
          <div class="signal-track">
            <div class="signal-fill" style={`width: ${starsBar}%; background: ${scoreColor(starsBar)}`}></div>
          </div>
        </div>
      ) : (
        <div class="signal">
          <div class="signal-label">
            <span>Stars</span>
            <span class="signal-value muted">GitHub not linked</span>
          </div>
        </div>
      )}

      <div class="signal">
        <div class="signal-label">
          <span>Platform Breadth</span>
          <span class="signal-value">{skill.platforms.length} platform{skill.platforms.length !== 1 ? 's' : ''}</span>
        </div>
        <div class="signal-track">
          <div class="signal-fill" style={`width: ${platformBar}%; background: ${scoreColor(platformBar)}`}></div>
        </div>
      </div>

      {contributorsBar !== null && repoData ? (
        <div class="signal">
          <div class="signal-label">
            <span>Contributors</span>
            <span class="signal-value">{repoData.contributors}</span>
          </div>
          <div class="signal-track">
            <div class="signal-fill" style={`width: ${contributorsBar}%; background: ${scoreColor(contributorsBar)}`}></div>
          </div>
        </div>
      ) : (
        <div class="signal">
          <div class="signal-label">
            <span>Contributors</span>
            <span class="signal-value muted">GitHub not linked</span>
          </div>
        </div>
      )}

      <div class="signal">
        <div class="signal-label">
          <span>Description</span>
          <span class="signal-value">{descQuality === 0 ? 'None' : descQuality === 0.3 ? 'Brief' : descQuality === 0.7 ? 'Good' : 'Detailed'}</span>
        </div>
        <div class="signal-track">
          <div class="signal-fill" style={`width: ${descQuality * 100}%; background: ${scoreColor(descQuality * 100)}`}></div>
        </div>
      </div>
    </div>
  </section>

  {advice.length > 0 && (
    <section class="advice">
      <h3>How to Improve</h3>
      <div class="advice-list">
        {advice.map((a) => (
          <div class="advice-card">
            <div class="advice-header">
              <span class={`impact-dot impact-${a.impact}`}></span>
              <span class="advice-signal">{a.signal}</span>
              <span class={`impact-label impact-${a.impact}`}>{a.impact} impact</span>
            </div>
            <p class="advice-message">{a.message}</p>
          </div>
        ))}
      </div>
    </section>
  )}

  <section class="badge-embed">
    <h3>Badge</h3>
    <div class="badge-preview">
      <img src={`/api/badge/skill/${slug}`} alt={`AgentRank score for ${skill.name}`} />
    </div>
    <div class="snippet">
      <label>Markdown</label>
      <div class="snippet-row">
        <code class="snippet-code">{mdSnippet}</code>
        <button class="copy-btn" data-copy={mdSnippet}>Copy</button>
      </div>
    </div>
    <div class="snippet">
      <label>HTML</label>
      <div class="snippet-row">
        <code class="snippet-code">{htmlSnippet}</code>
        <button class="copy-btn" data-copy={htmlSnippet}>Copy</button>
      </div>
    </div>
  </section>

  {skill.platforms.length > 0 && (
    <section class="queries">
      <h3>Supported Platforms</h3>
      <div class="tags">
        {skill.platforms.map((p) => (
          <span class="tag">{p}</span>
        ))}
      </div>
    </section>
  )}

  {readmeExcerpt && (
    <section class="readme-excerpt">
      <h3>From the README</h3>
      <pre class="readme-text">{readmeExcerpt}</pre>
      {githubLink && (
        <a href={`${githubLink}#readme`} class="readme-link" target="_blank" rel="noopener noreferrer">Read full README on GitHub &rarr;</a>
      )}
    </section>
  )}

  {relatedSkills.length > 0 && (
    <section class="related">
      <h3>Top Ranked Skills</h3>
      <div class="related-list">
        {relatedSkills.map((r) => {
          const rSlug = (r.slug as string).replace(/\//g, '--').replace(/:/g, '-');
          return (
            <a href={`/skill/${rSlug}/`} class="related-item">
              <span class="related-name">{(r.name as string) || (r.slug as string)}</span>
              <span class="related-score" style={`color: ${scoreColor(r.score as number)}`}>
                {(r.score as number).toFixed(1)}
              </span>
            </a>
          );
        })}
      </div>
    </section>
  )}

  <div class="links">
    {githubLink && (
      <a href={githubLink} target="_blank" rel="noopener noreferrer">View on GitHub &rarr;</a>
    )}
    {registryLink && (
      <a href={registryLink} target="_blank" rel="noopener noreferrer">View on {sourceLabel(skill.source)} &rarr;</a>
    )}
  </div>

  <div class="share-section">
    <h3>Share</h3>
    <div class="share-buttons">
      <a
        href={`https://x.com/intent/tweet?text=${encodeURIComponent(`${skill.name} scored ${skill.score.toFixed(1)} on AgentRank`)}&url=${encodeURIComponent(pageUrl)}`}
        target="_blank"
        rel="noopener noreferrer"
        class="share-btn share-twitter"
      >Share on X</a>
      <button class="share-btn copy-link-btn" data-copy={pageUrl}>Copy link</button>
    </div>
  </div>

  <script>
    document.querySelectorAll('.copy-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const text = btn.getAttribute('data-copy') || '';
        navigator.clipboard.writeText(text).then(() => {
          btn.textContent = 'Copied!';
          setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
        });
      });
    });
    document.querySelectorAll('.copy-link-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const text = btn.getAttribute('data-copy') || '';
        navigator.clipboard.writeText(text).then(() => {
          btn.textContent = 'Copied!';
          setTimeout(() => { btn.textContent = 'Copy link'; }, 2000);
        });
      });
    });
  </script>
</Base>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    margin-bottom: 1.5rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: var(--text-muted);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .breadcrumb-sep {
    color: var(--border);
    font-size: 0.9rem;
  }

  .breadcrumb-current {
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 40ch;
  }

  .tool-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .tool-header-left {
    flex: 1;
    min-width: 0;
  }

  .tool-header-left h2 {
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
    line-height: 1.3;
  }

  .tool-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }

  .author-badge {
    color: var(--text-muted);
    font-size: 0.8rem;
  }

  .description {
    color: var(--text-muted);
    margin-top: 0;
    margin-bottom: 0.5rem;
    font-size: 0.85rem;
    line-height: 1.5;
  }

  .score-ring {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    border: 3px solid;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .score-number {
    font-size: 1.4rem;
    font-weight: 800;
    line-height: 1;
  }

  .score-label {
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-top: 2px;
  }

  .rank-pill {
    font-size: 0.7rem;
    color: var(--text-muted);
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 0.15rem 0.5rem;
    border-radius: 10px;
    white-space: nowrap;
  }

  .context-sentences {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1rem;
    margin-bottom: 2rem;
  }

  .context-line {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  section {
    margin-bottom: 2rem;
  }

  h3 {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  @media (max-width: 480px) {
    .tool-header {
      gap: 0.75rem;
    }
  }

  .signal-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .signal-label {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    margin-bottom: 0.25rem;
  }

  .signal-value {
    color: var(--text-muted);
  }

  .signal-value.muted {
    font-style: italic;
    opacity: 0.6;
  }

  .signal-track {
    height: 6px;
    background: var(--bg-surface);
    border-radius: 3px;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .signal-fill {
    height: 100%;
    border-radius: 3px;
    transition: width 0.3s;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    padding: 0.2rem 0.6rem;
    border-radius: 3px;
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .links {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .links a {
    font-weight: 600;
  }

  .advice-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .advice-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.75rem;
  }

  .advice-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.35rem;
  }

  .impact-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .impact-dot.impact-high { background: #22c55e; }
  .impact-dot.impact-medium { background: #eab308; }
  .impact-dot.impact-low { background: #6b7280; }

  .advice-signal {
    font-weight: 600;
    font-size: 0.8rem;
  }

  .impact-label {
    font-size: 0.7rem;
    margin-left: auto;
  }

  .impact-label.impact-high { color: #22c55e; }
  .impact-label.impact-medium { color: #eab308; }
  .impact-label.impact-low { color: #6b7280; }

  .advice-message {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.4;
  }

  .badge-embed {
    margin-bottom: 2rem;
  }

  .badge-preview {
    margin-bottom: 0.75rem;
  }

  .badge-preview img {
    height: 20px;
  }

  .snippet {
    margin-bottom: 0.5rem;
  }

  .snippet label {
    font-size: 0.7rem;
    color: var(--text-muted);
    display: block;
    margin-bottom: 0.25rem;
  }

  .snippet-row {
    display: flex;
    gap: 0.5rem;
    align-items: stretch;
  }

  .snippet-code {
    flex: 1;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    padding: 0.35rem 0.5rem;
    border-radius: 3px;
    font-size: 0.7rem;
    overflow-x: auto;
    white-space: nowrap;
  }

  .copy-btn {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 0.35rem 0.6rem;
    font-size: 0.7rem;
    cursor: pointer;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .copy-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }



  .readme-excerpt {
    margin-bottom: 2rem;
  }

  .readme-text {
    font-size: 0.8rem;
    color: var(--text);
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1rem;
    overflow-x: auto;
    white-space: pre-wrap;
    word-break: break-word;
    max-height: 400px;
    overflow-y: auto;
    line-height: 1.5;
    margin-bottom: 0.5rem;
  }

  .readme-link {
    font-size: 0.8rem;
  }

  .related-list {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .related-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.4rem 0.6rem;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 3px;
    text-decoration: none;
    font-size: 0.8rem;
  }

  .related-item:hover {
    border-color: var(--accent);
    text-decoration: none;
  }

  .related-name {
    color: var(--text);
  }

  .related-score {
    font-weight: 600;
    font-size: 0.75rem;
  }

  .share-section {
    margin-top: 2rem;
  }

  .share-buttons {
    display: flex;
    gap: 0.5rem;
  }

  .share-btn {
    font-size: 0.75rem;
    padding: 0.35rem 0.75rem;
    border-radius: 3px;
    border: 1px solid var(--border);

---
import Base from '../../layouts/Base.astro';
export const prerender = true;

const SITE_URL = 'https://agentrank-ai.com';
---

<Base
  title="Authentication — AgentRank API"
  description="AgentRank API authentication guide. Free tier requires no key. Pro tier uses Bearer token API keys."
  keywords="AgentRank API key, authentication, bearer token, API access"
  canonicalUrl={`${SITE_URL}/docs/authentication/`}
  activeTab="api"
>
  <div class="page-header">
    <div class="breadcrumb"><a href="/docs/">Docs</a> / Authentication</div>
    <h1>Authentication</h1>
    <p class="subtitle">Free access requires no key. Pro access uses an API key in the Authorization header.</p>
  </div>

  <nav class="docs-nav">
    <a href="/docs/">Overview</a>
    <a href="/docs/quickstart/">Quick Start</a>
    <a href="/docs/authentication/" class="active">Auth</a>
    <a href="/docs/rate-limits/">Rate Limits</a>
    <a href="/docs/api/">API Reference</a>
    <a href="/docs/sdk/">SDK</a>
    <a href="/docs/embed/">Embed</a>
  </nav>

  <div class="divider"></div>

  <section class="method" id="free">
    <h2>Free tier — no key required</h2>
    <p>All <code>/api/v1/*</code> endpoints are public. No account, no key, no headers needed:</p>
    <div class="code-block-wrap">
      <div class="code-label">curl</div>
      <pre class="code-block">curl "https://agentrank-ai.com/api/v1/search?q=database"</pre>
      <button class="copy-btn" data-copy={`curl "https://agentrank-ai.com/api/v1/search?q=database"`}>Copy</button>
    </div>
    <p>Rate limit: <strong>100 requests per minute per IP</strong>. No daily cap. See <a href="/docs/rate-limits/">Rate Limits</a> for headers and 429 handling.</p>
  </section>

  <div class="divider"></div>

  <section class="method" id="pro">
    <h2>Pro tier — API key</h2>
    <p>Pro keys unlock <code>/api/v2/*</code> endpoints with rank history, batch lookups, and higher daily limits.</p>

    <h3>Getting a key</h3>
    <p>Get a Pro API key from <a href="/pricing/">agentrank-ai.com/pricing/</a>. After purchase, your key is shown once — save it immediately.</p>

    <h3>Key format</h3>
    <div class="tier-table">
      <div class="tier-row header-row">
        <span>Tier</span>
        <span>Key prefix</span>
        <span>Daily limit</span>
      </div>
      <div class="tier-row">
        <span class="tier-name free">Free</span>
        <code>— (no key)</code>
        <span class="tier-limit">100 req/min per IP</span>
      </div>
      <div class="tier-row">
        <span class="tier-name pro">Pro</span>
        <code>ark_pro_...</code>
        <span class="tier-limit">10,000 req/day</span>
      </div>
      <div class="tier-row">
        <span class="tier-name enterprise">Enterprise</span>
        <code>ark_enterprise_...</code>
        <span class="tier-limit">Unlimited</span>
      </div>
    </div>

    <h3>Sending the key</h3>
    <p>Pass the key in the <code>Authorization</code> header using the <code>Bearer</code> scheme:</p>
    <div class="code-block-wrap">
      <div class="code-label">curl</div>
      <pre class="code-block">curl -H "Authorization: Bearer ark_pro_your_key_here" \</pre>
      <button class="copy-btn" data-copy={`curl -H "Authorization: Bearer ark_pro_your_key_here" \\\n  "https://agentrank-ai.com/api/v2/search?q=database"`}>Copy</button>
    </div>
    <div class="code-block-wrap" style="margin-top:0.25rem;">
      <div class="code-label"></div>
      <pre class="code-block">&nbsp;&nbsp;"https://agentrank-ai.com/api/v2/search?q=database"</pre>
    </div>

    <p style="margin-top:0.75rem;">Or with the SDK — pass the key at construction:</p>
    <div class="code-block-wrap">
      <div class="code-label">TS</div>
      <pre class="code-block">const ar = new AgentRank({ "{'apiKey: \'ark_pro_your_key_here\''}" });</pre>
    </div>
    <div class="code-block-wrap">
      <div class="code-label">TS</div>
      <pre class="code-block multiline">{`import { AgentRank } from '@agentrank/sdk';

const ar = new AgentRank({ apiKey: 'ark_pro_your_key_here' });
// All requests now use /api/v2/* automatically`}</pre>
      <button class="copy-btn" data-copy={`import { AgentRank } from '@agentrank/sdk';\n\nconst ar = new AgentRank({ apiKey: 'ark_pro_your_key_here' });\n// All requests now use /api/v2/* automatically`}>Copy</button>
    </div>
  </section>

  <div class="divider"></div>

  <section class="method" id="errors">
    <h2>Authentication errors</h2>
    <div class="error-table">
      <div class="error-row header-row">
        <span>Status</span>
        <span>Error</span>
        <span>Cause</span>
      </div>
      <div class="error-row">
        <span class="status-code">401</span>
        <code>Missing Authorization header</code>
        <span class="error-cause">Called a v2 endpoint without a key</span>
      </div>
      <div class="error-row">
        <span class="status-code">401</span>
        <code>Invalid API key</code>
        <span class="error-cause">Key not recognized</span>
      </div>
      <div class="error-row">
        <span class="status-code">401</span>
        <code>API key has been revoked</code>
        <span class="error-cause">Key was disabled</span>
      </div>
      <div class="error-row">
        <span class="status-code">403</span>
        <code>Batch endpoint requires Pro or Enterprise</code>
        <span class="error-cause">Free key used on Pro-only endpoint</span>
      </div>
      <div class="error-row">
        <span class="status-code">429</span>
        <code>Daily limit exceeded</code>
        <span class="error-cause">10,000 req/day Pro limit reached</span>
      </div>
    </div>
    <p style="margin-top:0.75rem;">Error responses are JSON with an <code>error</code> field:</p>
    <div class="response-block">
      <div class="code-label response-label">JSON</div>
      <pre class="response-code">{"{ \"error\": \"Invalid API key.\" }"}</pre>
    </div>
  </section>

  <div class="divider"></div>

  <section class="method" id="security">
    <h2>Security</h2>
    <ul class="info-list">
      <li>API keys are stored as hashed values. Only the key prefix (<code>ark_pro_a1b2c3d4e5f6</code>) is stored in plain text for identification.</li>
      <li>Never expose your API key in client-side code or public repositories.</li>
      <li>Use environment variables: <code>AGENTRANK_API_KEY=ark_pro_...</code></li>
      <li>If a key is compromised, contact support to revoke it immediately.</li>
    </ul>
  </section>

  <script>
    document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const text = btn.dataset.copy || btn.previousElementSibling?.textContent || '';
        if (!text) return;
        navigator.clipboard.writeText(text.trim()).then(() => {
          const orig = btn.textContent;
          btn.textContent = 'Copied!';
          setTimeout(() => { btn.textContent = orig; }, 2000);
        });
      });
    });
  </script>
</Base>

<style>
  .page-header { margin-bottom: 1.5rem; }

  .breadcrumb {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .breadcrumb a { color: var(--text-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--accent); }

  h1 { font-size: 1.5rem; font-weight: 700; margin-bottom: 0.5rem; }

  .subtitle { color: var(--text-muted); font-size: 0.88rem; }

  .docs-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .docs-nav a {
    font-size: 0.78rem;
    color: var(--text-muted);
    text-decoration: none;
    padding: 0.25rem 0.6rem;
    border: 1px solid var(--border);
    border-radius: 3px;
    background: var(--bg-surface);
    transition: color 0.15s, border-color 0.15s;
  }

  .docs-nav a:hover { color: var(--text); text-decoration: none; }
  .docs-nav a.active { color: var(--accent); border-color: var(--accent); font-weight: 600; }

  .divider { border-top: 1px solid var(--border); margin: 2rem 0; }

  .method { margin-bottom: 0.5rem; }

  h2 { font-size: 1rem; font-weight: 700; margin-bottom: 0.75rem; }
  h3 { font-size: 0.88rem; font-weight: 700; margin: 1rem 0 0.5rem; color: var(--text); }

  p {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 0.6rem;
    line-height: 1.5;
  }

  p code, h3 code {
    background: var(--bg-surface);
    padding: 0.1rem 0.3rem;
    border-radius: 2px;
    font-size: 0.7rem;
    color: var(--text);
  }

  strong { color: var(--text); }

  .code-block-wrap {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.6rem 0.75rem;
    margin-bottom: 0.5rem;
  }

  .code-label {
    font-size: 0.65rem;
    color: var(--text-muted);
    font-weight: 600;
    flex-shrink: 0;
    padding-top: 2px;
    width: 3rem;
  }

  .code-block {
    flex: 1;
    font-size: 0.72rem;
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', monospace;
    background: none;
    border: none;
    margin: 0;
    padding: 0;
  }

  .code-block.multiline {
    white-space: pre;
    overflow-x: auto;
    text-overflow: unset;
  }

  .copy-btn {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 0.2rem 0.45rem;
    font-size: 0.65rem;
    cursor: pointer;
    color: var(--text-muted);
    font-family: inherit;
    flex-shrink: 0;
    white-space: nowrap;
    align-self: flex-start;
  }

  .copy-btn:hover { border-color: var(--accent); color: var(--accent); }

  .tier-table {
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 1rem;
  }

  .tier-row {
    display: grid;
    grid-template-columns: 7rem 1fr 1fr;
    gap: 0.75rem;
    align-items: center;
    padding: 0.45rem 0.75rem;
    font-size: 0.78rem;
    border-bottom: 1px solid var(--border);
  }

  .tier-row:last-child { border-bottom: none; }

  .header-row {
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.4px;
    background: var(--bg-surface);
  }

  .tier-name {
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    display: inline-block;
  }

  .tier-name.free { background: rgba(34, 197, 94, 0.1); color: var(--accent); border: 1px solid rgba(34, 197, 94, 0.3); }
  .tier-name.pro { background: rgba(96, 165, 250, 0.1); color: #60a5fa; border: 1px solid rgba(96, 165, 250, 0.3); }
  .tier-name.enterprise { background: rgba(251, 191, 36, 0.1); color: #fbbf24; border: 1px solid rgba(251, 191, 36, 0.3); }

  .tier-row code {
    font-size: 0.7rem;
    color: var(--text);
    background: none;
    font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', monospace;
  }

  .tier-limit { color: var(--text-muted); }

  .error-table {
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 0.5rem;
  }

  .error-row {
    display: grid;
    grid-template-columns: 3.5rem 1fr 1fr;
    gap: 0.75rem;
    align-items: center;
    padding: 0.45rem 0.75rem;
    font-size: 0.78rem;
    border-bottom: 1px solid var(--border);
  }

  .error-row:last-child { border-bottom: none; }

  .status-code {
    font-size: 0.72rem;
    font-weight: 700;
    color: #ef4444;
    font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', monospace;
  }

  .error-row code {
    font-size: 0.7rem;
    color: var(--text);
    background: none;
    font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', monospace;
  }

  .error-cause { color: var(--text-muted); font-size: 0.75rem; }

  .response-block {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.6rem 0.75rem;
  }

  .response-label { color: var(--text-muted); }

  .response-code {
    flex: 1;
    font-size: 0.7rem;
    color: var(--text-muted);
    white-space: pre;
    font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', monospace;
    background: none;
    border: none;
    margin: 0;
    padding: 0;
  }

  .info-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .info-list li {
    font-size: 0.82rem;
    color: var(--text-muted);
    padding-left: 1rem;
    position: relative;
    line-height: 1.5;
  }

  .info-list li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  .info-list li code {
    background: var(--bg-surface);
    padding: 0.1rem 0.3rem;
    border-radius: 2px;
    font-size: 0.7rem;
    color: var(--text);
  }
</style>

---
import Base from '../../layouts/Base.astro';
export const prerender = true;

const SITE_URL = 'https://agentrank-ai.com';

const sections = [
  { href: '/docs/quickstart/', title: 'Quick Start', desc: 'First API call in 5 minutes. No key required to start.' },
  { href: '/docs/authentication/', title: 'Authentication', desc: 'How to get and use an API key. Free vs Pro access.' },
  { href: '/docs/rate-limits/', title: 'Rate Limits', desc: 'Free tier: 100 req/min per IP. Pro: 10,000 req/day.' },
  { href: '/docs/api/', title: 'API Reference', desc: 'All endpoints — search, lookup, movers, batch, and more.' },
  { href: '/docs/sdk/', title: 'SDK Reference', desc: 'TypeScript/JavaScript SDK — @agentrank/sdk.' },
  { href: '/docs/embed/', title: 'Embed & Badges', desc: 'Live score widgets for READMEs and websites.' },
];
---

<Base
  title="API Documentation — AgentRank"
  description="AgentRank API documentation. Ranked index of 25,000+ MCP servers and agent tools. Free public API, Pro authenticated API, TypeScript SDK."
  keywords="AgentRank API docs, MCP server API, agent tools API, TypeScript SDK"
  canonicalUrl={`${SITE_URL}/docs/`}
  activeTab="api"
>
  <div class="page-header">
    <h1>API Documentation</h1>
    <p class="subtitle">Everything you need to query the AgentRank index programmatically. The public API is free — no key required.</p>
  </div>

  <div class="quick-facts">
    <div class="fact">
      <span class="fact-label">Base URL</span>
      <code>https://agentrank-ai.com</code>
    </div>
    <div class="fact">
      <span class="fact-label">Free tier</span>
      <span>100 req/min per IP &mdash; no key needed</span>
    </div>
    <div class="fact">
      <span class="fact-label">Pro tier</span>
      <span>10,000 req/day &mdash; API key required</span>
    </div>
    <div class="fact">
      <span class="fact-label">Format</span>
      <span>JSON. All endpoints are GET unless noted.</span>
    </div>
  </div>

  <div class="divider"></div>

  <div class="section-grid">
    {sections.map(s => (
      <a href={s.href} class="section-card">
        <div class="section-title">{s.title}</div>
        <div class="section-desc">{s.desc}</div>
      </a>
    ))}
  </div>

  <div class="divider"></div>

  <section class="endpoint-overview">
    <h2>Endpoints at a glance</h2>
    <div class="endpoint-table">
      <div class="endpoint-row header-row">
        <span class="method">Method</span>
        <span class="path">Path</span>
        <span class="endpoint-desc">Description</span>
        <span class="auth">Auth</span>
      </div>
      <a href="/docs/api/#search" class="endpoint-row">
        <span class="method get">GET</span>
        <code class="path">/api/v1/search</code>
        <span class="endpoint-desc">Search tools, skills, and agents</span>
        <span class="auth-badge free">Free</span>
      </a>
      <a href="/docs/api/#tool" class="endpoint-row">
        <span class="method get">GET</span>
        <code class="path">/api/v1/tool/{'{id}'}</code>
        <span class="endpoint-desc">Get full detail for one tool</span>
        <span class="auth-badge free">Free</span>
      </a>
      <a href="/docs/api/#movers" class="endpoint-row">
        <span class="method get">GET</span>
        <code class="path">/api/v1/movers</code>
        <span class="endpoint-desc">Biggest rank changes this week</span>
        <span class="auth-badge free">Free</span>
      </a>
      <a href="/docs/api/#new-tools" class="endpoint-row">
        <span class="method get">GET</span>
        <code class="path">/api/v1/new-tools</code>
        <span class="endpoint-desc">Newly indexed tools</span>
        <span class="auth-badge free">Free</span>
      </a>
      <a href="/docs/api/#v2-search" class="endpoint-row">
        <span class="method get">GET</span>
        <code class="path">/api/v2/search</code>
        <span class="endpoint-desc">Search with rank history</span>
        <span class="auth-badge pro">Pro</span>
      </a>
      <a href="/docs/api/#v2-tool" class="endpoint-row">
        <span class="method get">GET</span>
        <code class="path">/api/v2/tool/{'{id}'}</code>
        <span class="endpoint-desc">Tool detail with full rank history</span>
        <span class="auth-badge pro">Pro</span>
      </a>
      <a href="/docs/api/#batch" class="endpoint-row">
        <span class="method post">POST</span>
        <code class="path">/api/v2/batch</code>
        <span class="endpoint-desc">Batch lookup up to 50 tools</span>
        <span class="auth-badge pro">Pro</span>
      </a>
      <a href="/docs/api/#stats" class="endpoint-row">
        <span class="method get">GET</span>
        <code class="path">/api/v1/stats</code>
        <span class="endpoint-desc">Index-wide counts and averages</span>
        <span class="auth-badge free">Free</span>
      </a>
    </div>
  </section>

  <div class="divider"></div>

  <section class="method">
    <h2>Get an API key</h2>
    <p>The free tier requires no key. For Pro access (10,000 req/day, rank history, batch endpoint), get a key from the <a href="/pricing/">pricing page</a>.</p>
    <p>Keys look like: <code>ark_pro_a1b2c3d4e5f6...</code></p>
    <p>Pass the key in the <code>Authorization</code> header:</p>
    <div class="code-block-wrap">
      <div class="code-label">HTTP</div>
      <pre class="code-block">Authorization: Bearer ark_pro_your_key_here</pre>
    </div>
  </section>
</Base>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  h1 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 0.88rem;
  }

  .quick-facts {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .fact {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.4rem 0.75rem;
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .fact-label {
    font-weight: 600;
    color: var(--text);
    font-size: 0.72rem;
  }

  .fact code {
    background: none;
    font-size: 0.72rem;
    color: var(--accent);
    font-family: inherit;
  }

  .divider {
    border-top: 1px solid var(--border);
    margin: 2rem 0;
  }

  .section-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.75rem;
  }

  .section-card {
    display: block;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.9rem 1rem;
    text-decoration: none;
    transition: border-color 0.15s;
  }

  .section-card:hover {
    border-color: var(--accent);
    text-decoration: none;
  }

  .section-title {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 0.3rem;
  }

  .section-desc {
    font-size: 0.78rem;
    color: var(--text-muted);
    line-height: 1.4;
  }

  h2 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .endpoint-overview {
    margin-bottom: 0.5rem;
  }

  .endpoint-table {
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
  }

  .endpoint-row {
    display: grid;
    grid-template-columns: 3rem 1fr 1fr 3.5rem;
    gap: 0.75rem;
    align-items: center;
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border);
    font-size: 0.78rem;
    text-decoration: none;
    color: var(--text);
    transition: background 0.1s;
  }

  .endpoint-row:last-child {
    border-bottom: none;
  }

  .endpoint-row:not(.header-row):hover {
    background: var(--bg-hover);
  }

  .header-row {
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.4px;
    background: var(--bg-surface);
  }

  .method {
    font-size: 0.65rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .method.get { color: var(--accent); }
  .method.post { color: #60a5fa; }

  .path {
    font-size: 0.72rem;
    color: var(--text);
    font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', monospace;
    background: none;
  }

  .endpoint-desc {
    color: var(--text-muted);
    font-size: 0.75rem;
  }

  .auth-badge {
    font-size: 0.62rem;
    font-weight: 600;
    padding: 0.1rem 0.35rem;
    border-radius: 3px;
    text-align: center;
  }

  .auth-badge.free {
    background: rgba(34, 197, 94, 0.1);
    color: var(--accent);
    border: 1px solid rgba(34, 197, 94, 0.3);
  }

  .auth-badge.pro {
    background: rgba(96, 165, 250, 0.1);
    color: #60a5fa;
    border: 1px solid rgba(96, 165, 250, 0.3);
  }

  .auth {
    color: var(--text-muted);
  }

  p {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 0.6rem;
    line-height: 1.5;
  }

  p code, .method .code-block code {
    background: var(--bg-surface);
    padding: 0.1rem 0.3rem;
    border-radius: 2px;
    font-size: 0.7rem;
    color: var(--text);
  }

  .code-block-wrap {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.6rem 0.75rem;
    margin-bottom: 0.5rem;
  }

  .code-label {
    font-size: 0.65rem;
    color: var(--text-muted);
    font-weight: 600;
    flex-shrink: 0;
    padding-top: 2px;
    width: 3rem;
  }

  .code-block {
    flex: 1;
    font-size: 0.72rem;
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', monospace;
    background: none;
    border: none;
    margin: 0;
    padding: 0;
  }

  .method {
    margin-bottom: 0.5rem;
  }

  @media (max-width: 600px) {
    .endpoint-row {
      grid-template-columns: 3rem 1fr 3.5rem;
    }
    .endpoint-desc {
      display: none;
    }
  }
</style>

  <script>
  // ─── Playground ───────────────────────────────────────────────────
  const BASE = 'https://agentrank-ai.com';

  const ENDPOINTS = {
    search: {
      method: 'GET',
      buildUrl: (p) => {
        const q = new URLSearchParams();
        if (p.q) q.set('q', p.q);
        if (p.category) q.set('category', p.category);
        if (p.limit) q.set('limit', p.limit);
        return `/api/v1/search?${q}`;
      },
      params: [
        { name: 'q', label: 'Query', default: 'database', type: 'text' },
        { name: 'category', label: 'Category', default: '', type: 'select', options: ['', 'tool', 'skill', 'agent'] },
        { name: 'limit', label: 'Limit', default: '5', type: 'number' },
      ],
    },
    tool: {
      method: 'GET',
      buildUrl: (p) => `/api/v1/tool/${encodeURIComponent(p.id || 'modelcontextprotocol--servers')}`,
      params: [
        { name: 'id', label: 'Tool ID (owner--repo)', default: 'modelcontextprotocol--servers', type: 'text' },
      ],
    },
    movers: {
      method: 'GET',
      buildUrl: (p) => {
        const q = new URLSearchParams();
        if (p.days) q.set('days', p.days);
        if (p.limit) q.set('limit', p.limit);
        return `/api/v1/movers?${q}`;
      },
      params: [
        { name: 'days', label: 'Days', default: '7', type: 'number' },
        { name: 'limit', label: 'Limit', default: '5', type: 'number' },
      ],
    },
    'new-tools': {
      method: 'GET',
      buildUrl: (p) => {
        const q = new URLSearchParams();
        if (p.days) q.set('days', p.days);
        if (p.limit) q.set('limit', p.limit);
        return `/api/v1/new-tools?${q}`;
      },
      params: [
        { name: 'days', label: 'Days', default: '7', type: 'number' },
        { name: 'limit', label: 'Limit', default: '5', type: 'number' },
      ],
    },
    stats: {
      method: 'GET',
      buildUrl: () => '/api/v1/stats',
      params: [],
    },
  };

  let currentEp = 'search';

  function getParams() {
    const ep = ENDPOINTS[currentEp];
    const result = {};
    ep.params.forEach(p => {
      const el = document.getElementById(`pg-param-${p.name}`);
      result[p.name] = el ? el.value : p.default;
    });
    return result;
  }

  function updateUrlPreview() {
    const ep = ENDPOINTS[currentEp];
    const path = ep.buildUrl(getParams());
    const el = document.getElementById('pg-url-preview');
    if (el) el.textContent = BASE + path;
  }

  function renderForm(epKey) {
    const ep = ENDPOINTS[epKey];
    const container = document.getElementById('pg-inputs');
    if (!container) return;
    if (ep.params.length === 0) {
      container.innerHTML = '<span class="pg-no-params">No parameters required.</span>';
      return;
    }
    container.innerHTML = ep.params.map(p => {
      if (p.type === 'select') {
        const opts = (p.options || []).map(o => `<option value="${o}" ${o === p.default ? 'selected' : ''}>${o || '(all)'}</option>`).join('');
        return `<label class="pg-label">${p.label}<select id="pg-param-${p.name}" class="pg-input">${opts}</select></label>`;
      }
      return `<label class="pg-label">${p.label}<input id="pg-param-${p.name}" class="pg-input" type="${p.type}" value="${p.default}" /></label>`;
    }).join('');
    // live preview on input change
    container.querySelectorAll('input, select').forEach(el => {
      el.addEventListener('input', updateUrlPreview);
    });
  }

  function init() {
    // Tab clicks
    document.querySelectorAll<HTMLButtonElement>('.pg-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.pg-tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        currentEp = tab.dataset.ep || 'search';
        renderForm(currentEp);
        updateUrlPreview();
        const wrap = document.getElementById('pg-response-wrap');
        if (wrap) wrap.style.display = 'none';
      });
    });

    // Run button
    const runBtn = document.getElementById('pg-run-btn');
    if (runBtn) {
      runBtn.addEventListener('click', async () => {
        const ep = ENDPOINTS[currentEp];
        const path = ep.buildUrl(getParams());
        const url = BASE + path;
        const jsonEl = document.getElementById('pg-json');
        const statusEl = document.getElementById('pg-status-badge');
        const timingEl = document.getElementById('pg-timing');
        const wrap = document.getElementById('pg-response-wrap');

        runBtn.textContent = 'Running...';
        runBtn.disabled = true;

        const t0 = performance.now();
        try {
          const res = await fetch(url);
          const ms = Math.round(performance.now() - t0);
          const data = await res.json();
          if (jsonEl) jsonEl.textContent = JSON.stringify(data, null, 2);
          if (statusEl) {
            statusEl.textContent = String(res.status);
            statusEl.className = 'pg-status-badge ' + (res.ok ? 'ok' : 'err');
          }
          if (timingEl) timingEl.textContent = `${ms}ms`;
        } catch (e) {
          if (jsonEl) jsonEl.textContent = `Error: ${e && e.message ? e.message : String(e)}`;
          if (statusEl) { statusEl.textContent = 'Error'; statusEl.className = 'pg-status-badge err'; }
        } finally {
          runBtn.textContent = 'Run';
          runBtn.disabled = false;
          if (wrap) wrap.style.display = 'block';
        }
      });
    }

    renderForm(currentEp);
    updateUrlPreview();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  </script>
</Base>


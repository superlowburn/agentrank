---
import Base from '../../../layouts/Base.astro';
export const prerender = true;

const SITE_URL = 'https://agentrank-ai.com';
---

<Base
  title="API Reference — AgentRank"
  description="Complete AgentRank API reference. All endpoints: search, tool lookup, movers, new tools, batch. Free v1 and Pro v2 APIs documented."
  keywords="AgentRank API reference, MCP server API endpoints, agent tools API"
  canonicalUrl={`${SITE_URL}/docs/api/`}
  activeTab="api"
>
  <div class="page-header">
    <div class="breadcrumb"><a href="/docs/">Docs</a> / API Reference</div>
    <h1>API Reference</h1>
    <p class="subtitle">Base URL: <code>https://agentrank-ai.com</code> &mdash; All responses are JSON &mdash; <a href="/docs/authentication/">Auth guide</a></p>
  </div>

  <nav class="docs-nav">
    <a href="/docs/">Overview</a>
    <a href="/docs/quickstart/">Quick Start</a>
    <a href="/docs/authentication/">Auth</a>
    <a href="/docs/rate-limits/">Rate Limits</a>
    <a href="/docs/api/" class="active">API Reference</a>
    <a href="/docs/sdk/">SDK</a>
    <a href="/docs/embed/">Embed</a>
  </nav>

  <div class="divider"></div>

  <nav class="section-nav">
    <span class="section-nav-label">On this page</span>
    <a href="#playground">Playground</a>
    <a href="#v1">Free (v1)</a>
    <a href="#search">Search</a>
    <a href="#tool">Tool Detail</a>
    <a href="#movers">Movers</a>
    <a href="#new-tools">New Tools</a>
    <a href="#stats">Stats</a>
    <a href="#v2">Pro (v2)</a>
    <a href="#v2-search">v2 Search</a>
    <a href="#v2-tool">v2 Tool</a>
    <a href="#batch">Batch</a>
  </nav>

  <div class="divider"></div>

  <!-- ─────────── PLAYGROUND ─────────── -->

  <section id="playground" class="playground-section">
    <h2>Try it now</h2>
    <p>Run live requests against the API. No key required for free-tier endpoints.</p>

    <div class="pg-endpoint-tabs" role="tablist">
      <button class="pg-tab active" data-ep="search" role="tab">Search</button>
      <button class="pg-tab" data-ep="tool" role="tab">Tool Detail</button>
      <button class="pg-tab" data-ep="movers" role="tab">Movers</button>
      <button class="pg-tab" data-ep="new-tools" role="tab">New Tools</button>
      <button class="pg-tab" data-ep="stats" role="tab">Stats</button>
    </div>

    <div class="pg-form-wrap">
      <div class="pg-inputs" id="pg-inputs">
        <!-- rendered by JS -->
      </div>
      <div class="pg-url-row">
        <span class="pg-url-label">GET</span>
        <code id="pg-url-preview" class="pg-url-code">https://agentrank-ai.com/api/v1/search?q=database&amp;limit=5</code>
      </div>
      <button id="pg-run-btn" class="pg-run-btn">Run</button>
    </div>

    <div id="pg-response-wrap" class="pg-response-wrap" style="display:none">
      <div class="pg-response-header">
        <span class="code-label">Response</span>
        <span id="pg-status-badge" class="pg-status-badge"></span>
        <span id="pg-timing" class="pg-timing"></span>
      </div>
      <pre id="pg-json" class="pg-json"></pre>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ─────────── FREE (v1) ─────────── -->

  <section id="v1">
    <div class="tier-header free">
      <span class="tier-badge free">Free (v1)</span>
      <span>No API key required &mdash; 100 req/min per IP</span>
    </div>
  </section>

  <!-- Search v1 -->
  <section class="endpoint" id="search">
    <div class="endpoint-sig">
      <span class="method-badge get">GET</span>
      <code class="endpoint-path">/api/v1/search</code>
    </div>
    <p>Search across tools, skills, and agents. Returns ranked results sorted by score.</p>

    <h3>Query Parameters</h3>
    <div class="param-table">
      <div class="param-row header-row">
        <span>Parameter</span>
        <span>Type</span>
        <span>Default</span>
        <span>Description</span>
      </div>
      <div class="param-row">
        <code class="param-name">q</code>
        <span class="param-type">string</span>
        <code>""</code>
        <span>Search query. Empty returns top-ranked results.</span>
      </div>
      <div class="param-row">
        <code class="param-name">category</code>
        <span class="param-type">string</span>
        <code>"all"</code>
        <span>Filter by type: <code>tool</code>, <code>skill</code>, <code>agent</code>, or omit for all.</span>
      </div>
      <div class="param-row">
        <code class="param-name">sort</code>
        <span class="param-type">string</span>
        <code>"score"</code>
        <span>Sort order: <code>score</code>, <code>rank</code>, <code>stars</code>, <code>freshness</code>.</span>
      </div>
      <div class="param-row">
        <code class="param-name">limit</code>
        <span class="param-type">integer</span>
        <code>20</code>
        <span>Results per page. Max 100.</span>
      </div>
      <div class="param-row">
        <code class="param-name">offset</code>
        <span class="param-type">integer</span>
        <code>0</code>
        <span>Pagination offset.</span>
      </div>
    </div>

    <h3>Example</h3>
    <div class="snippet-tabs" data-group="search-example">
      <button class="snip-tab active" data-lang="curl">curl</button>
      <button class="snip-tab" data-lang="python">Python</button>
      <button class="snip-tab" data-lang="typescript">TypeScript</button>
    </div>
    <div class="code-block-wrap snip-panel active" data-group="search-example" data-lang="curl">
      <div class="code-label">curl</div>
      <pre class="code-block">curl "https://agentrank-ai.com/api/v1/search?q=database&category=tool&limit=5"</pre>
      <button class="copy-btn" data-copy={`curl "https://agentrank-ai.com/api/v1/search?q=database&category=tool&limit=5"`}>Copy</button>
    </div>
    <div class="code-block-wrap snip-panel" data-group="search-example" data-lang="python" style="display:none">
      <div class="code-label">Python</div>
      <pre class="code-block multiline">{`import httpx

resp = httpx.get(
    "https://agentrank-ai.com/api/v1/search",
    params={"q": "database", "category": "tool", "limit": 5},
)
data = resp.json()
for item in data["results"]:
    print(item["name"], item["score"])`}</pre>
      <button class="copy-btn">Copy</button>
    </div>
    <div class="code-block-wrap snip-panel" data-group="search-example" data-lang="typescript" style="display:none">
      <div class="code-label">TypeScript</div>
      <pre class="code-block multiline">{`const params = new URLSearchParams({ q: "database", category: "tool", limit: "5" });
const res = await fetch("https://agentrank-ai.com/api/v1/search?" + params);
const data = await res.json();
for (const item of data.results) {
  console.log(item.name, item.score);
}`}</pre>
      <button class="copy-btn">Copy</button>
    </div>

    <h3>Response</h3>
    <div class="response-block">
      <div class="code-label">JSON</div>
      <pre class="response-code">{`{
  "query": "database",
  "category": "tool",
  "sort": "score",
  "results": [
    {
      "type": "tool",
      "id": "owner--repo",
      "name": "owner/repo",
      "description": "A database MCP server",
      "score": 82.5,
      "rank": 14,
      "url": "https://agentrank-ai.com/tool/owner--repo/",
      "raw": {
        "stars": 1240,
        "contributors": 8,
        "dependents": 23,
        "lastCommitAt": "2026-03-10T00:00:00Z",
        "language": "TypeScript",
        "license": "MIT",
        "isArchived": false,
        "topics": ["mcp", "database", "sqlite"]
      }
    }
  ],
  "meta": { "total": 87, "limit": 5, "offset": 0 }
}`}</pre>
    </div>
  </section>

  <div class="divider"></div>

  <!-- Tool v1 -->
  <section class="endpoint" id="tool">
    <div class="endpoint-sig">
      <span class="method-badge get">GET</span>
      <code class="endpoint-path">/api/v1/tool/{'{id}'}</code>
    </div>
    <p>Get full detail for a single tool, skill, or agent. Includes score, rank, and signal breakdown.</p>

    <h3>Path Parameters</h3>
    <div class="param-table">
      <div class="param-row header-row">
        <span>Parameter</span>
        <span>Type</span>
        <span>Description</span>
      </div>
      <div class="param-row three-col">
        <code class="param-name">id</code>
        <span class="param-type">string</span>
        <span>GitHub <code>owner--repo</code> (use <code>--</code> in place of <code>/</code>). Also accepts skill slugs.</span>
      </div>
    </div>

    <h3>Example</h3>
    <div class="snippet-tabs" data-group="tool-example">
      <button class="snip-tab active" data-lang="curl">curl</button>
      <button class="snip-tab" data-lang="python">Python</button>
      <button class="snip-tab" data-lang="typescript">TypeScript</button>
    </div>
    <div class="code-block-wrap snip-panel active" data-group="tool-example" data-lang="curl">
      <div class="code-label">curl</div>
      <pre class="code-block">curl "https://agentrank-ai.com/api/v1/tool/modelcontextprotocol--servers"</pre>
      <button class="copy-btn" data-copy={`curl "https://agentrank-ai.com/api/v1/tool/modelcontextprotocol--servers"`}>Copy</button>
    </div>
    <div class="code-block-wrap snip-panel" data-group="tool-example" data-lang="python" style="display:none">
      <div class="code-label">Python</div>
      <pre class="code-block multiline">{`import httpx

tool_id = "modelcontextprotocol--servers"  # owner--repo
resp = httpx.get(f"https://agentrank-ai.com/api/v1/tool/{tool_id}")
tool = resp.json()
print(tool["name"], "score:", tool["score"])`}</pre>
      <button class="copy-btn">Copy</button>
    </div>
    <div class="code-block-wrap snip-panel" data-group="tool-example" data-lang="typescript" style="display:none">
      <div class="code-label">TypeScript</div>
      <pre class="code-block multiline">{`const toolId = "modelcontextprotocol--servers"; // owner--repo
const res = await fetch("https://agentrank-ai.com/api/v1/tool/" + toolId);
const tool = await res.json();
console.log(tool.name, "score:", tool.score);`}</pre>
      <button class="copy-btn">Copy</button>
    </div>

    <h3>Response</h3>
    <div class="response-block">
      <div class="code-label">JSON</div>
      <pre class="response-code">{`{
  "type": "tool",
  "id": "modelcontextprotocol--servers",
  "name": "modelcontextprotocol/servers",
  "description": "Model Context Protocol servers",
  "score": 97.4,
  "rank": 1,
  "githubUrl": "https://github.com/modelcontextprotocol/servers",
  "signals": {
    "stars": 1.0,
    "freshness": 0.98,
    "issueHealth": 0.82,
    "contributors": 1.0,
    "dependents": 1.0,
    "descriptionQuality": 0.9,
    "licenseHealth": 1.0
  },
  "weights": {
    "stars": 0.15,
    "freshness": 0.25,
    "issueHealth": 0.20,
    "contributors": 0.10,
    "dependents": 0.25,
    "descriptionQuality": 0.03,
    "licenseHealth": 0.02
  },
  "raw": { ... }
}`}</pre>
    </div>

    <div class="field-note">Returns <code>404</code> if the tool is not in the index.</div>
  </section>

  <div class="divider"></div>

  <!-- Movers v1 -->
  <section class="endpoint" id="movers">
    <div class="endpoint-sig">
      <span class="method-badge get">GET</span>
      <code class="endpoint-path">/api/v1/movers</code>
    </div>
    <p>Returns tools with the largest rank changes over a lookback window. Useful for "biggest movers" content.</p>

    <h3>Query Parameters</h3>
    <div class="param-table">
      <div class="param-row header-row">
        <span>Parameter</span>
        <span>Type</span>
        <span>Default</span>
        <span>Description</span>
      </div>
      <div class="param-row">
        <code class="param-name">days</code>
        <span class="param-type">integer</span>
        <code>7</code>
        <span>Lookback window in days. Max 30.</span>
      </div>
      <div class="param-row">
        <code class="param-name">limit</code>
        <span class="param-type">integer</span>
        <code>10</code>
        <span>Number of results. Max 50.</span>
      </div>
      <div class="param-row">
        <code class="param-name">type</code>
        <span class="param-type">string</span>
        <code>"tool"</code>
        <span>Filter by type: <code>tool</code>, <code>skill</code>, or omit for all.</span>
      </div>
    </div>

    <h3>Example</h3>
    <div class="code-block-wrap">
      <div class="code-label">curl</div>
      <pre class="code-block">curl "https://agentrank-ai.com/api/v1/movers?days=7&limit=10"</pre>
      <button class="copy-btn" data-copy={`curl "https://agentrank-ai.com/api/v1/movers?days=7&limit=10"`}>Copy</button>
    </div>

    <h3>Response</h3>
    <div class="response-block">
      <div class="code-label">JSON</div>
      <pre class="response-code">{`{
  "movers": [
    {
      "full_name": "owner/repo",
      "tool_type": "tool",
      "current_rank": 12,
      "prev_rank": 31,
      "rank_delta": 19,
      "current_score": 78.3,
      "stars": 842,
      "url": "https://agentrank-ai.com/tool/owner--repo/"
    }
  ],
  "meta": {
    "today": "2026-03-18",
    "prev_date": "2026-03-11",
    "days": 7,
    "count": 10
  }
}`}</pre>
    </div>
  </section>

  <div class="divider"></div>

  <!-- New Tools v1 -->
  <section class="endpoint" id="new-tools">
    <div class="endpoint-sig">
      <span class="method-badge get">GET</span>
      <code class="endpoint-path">/api/v1/new-tools</code>
    </div>
    <p>Returns tools newly added to the index within the last N days.</p>

    <h3>Query Parameters</h3>
    <div class="param-table">
      <div class="param-row header-row">
        <span>Parameter</span>
        <span>Type</span>
        <span>Default</span>
        <span>Description</span>
      </div>
      <div class="param-row">
        <code class="param-name">days</code>
        <span class="param-type">integer</span>
        <code>7</code>
        <span>Lookback window in days. Max 30.</span>
      </div>
      <div class="param-row">
        <code class="param-name">limit</code>
        <span class="param-type">integer</span>
        <code>20</code>
        <span>Number of results. Max 100.</span>
      </div>
      <div class="param-row">
        <code class="param-name">type</code>
        <span class="param-type">string</span>
        <code>"tool"</code>
        <span>Filter by type: <code>tool</code>, <code>skill</code>, or omit for all.</span>
      </div>
    </div>

    <h3>Example</h3>
    <div class="code-block-wrap">
      <div class="code-label">curl</div>
      <pre class="code-block">curl "https://agentrank-ai.com/api/v1/new-tools?days=14&limit=20"</pre>
      <button class="copy-btn" data-copy={`curl "https://agentrank-ai.com/api/v1/new-tools?days=14&limit=20"`}>Copy</button>
    </div>

    <h3>Response</h3>
    <div class="response-block">
      <div class="code-label">JSON</div>
      <pre class="response-code">{`{
  "tools": [
    {
      "full_name": "owner/new-tool",
      "tool_type": "tool",
      "rank": 284,
      "score": 41.2,
      "stars": 87,
      "first_seen": "2026-03-15",
      "url": "https://agentrank-ai.com/tool/owner--new-tool/"
    }
  ],
  "meta": {
    "today": "2026-03-18",
    "cutoff": "2026-03-04",
    "days": 14,
    "count": 18
  }
}`}</pre>
    </div>
  </section>

  <div class="divider"></div>

  <!-- Stats v1 -->
  <section class="endpoint" id="stats">
    <div class="endpoint-sig">
      <span class="method-badge get">GET</span>
      <code class="endpoint-path">/api/v1/stats</code>
    </div>
    <p>Returns aggregate counts and averages for the entire index. Useful for dashboards, status pages, or displaying live stats. No parameters required. Response is cached for 1 hour.</p>

    <h3>Example</h3>
    <div class="code-block-wrap">
      <div class="code-label">curl</div>
      <pre class="code-block">curl "https://agentrank-ai.com/api/v1/stats"</pre>
      <button class="copy-btn" data-copy={`curl "https://agentrank-ai.com/api/v1/stats"`}>Copy</button>
    </div>

    <h3>Response</h3>
    <div class="response-block">
      <div class="code-label">JSON</div>
      <pre class="response-code">{`{
  "totalTools": 25843,
  "totalSkills": 1204,
  "toolsUpdatedWeek": 3741,
  "averageScore": 38.2,
  "totalCategories": 42,
  "generatedAt": "2026-03-19T08:00:00.000Z"
}`}</pre>
    </div>

    <div class="field-note">Cached for 1 hour (<code>Cache-Control: public, s-maxage=3600</code>). <code>generatedAt</code> reflects when the response was generated, not the cache hit time.</div>
  </section>

  <div class="divider"></div>

  <!-- ─────────── PRO (v2) ─────────── -->

  <section id="v2">
    <div class="tier-header pro">
      <span class="tier-badge pro">Pro (v2)</span>
      <span>Requires API key &mdash; 10,000 req/day &mdash; <a href="/developer/dashboard/">Get a key</a></span>
    </div>
    <p>All v2 endpoints require an API key in the Authorization header:</p>
    <div class="code-block-wrap" style="margin-bottom:0">
      <div class="code-label">HTTP</div>
      <pre class="code-block">Authorization: Bearer ark_pro_your_key_here</pre>
    </div>
  </section>

  <div class="divider"></div>

  <!-- Search v2 -->
  <section class="endpoint" id="v2-search">
    <div class="endpoint-sig">
      <span class="method-badge get">GET</span>
      <code class="endpoint-path">/api/v2/search</code>
      <span class="pro-badge">Pro</span>
    </div>
    <p>Same as v1 search, but with an additional <code>history</code> parameter and tier metadata in responses.</p>

    <h3>Additional Parameters</h3>
    <div class="param-table">
      <div class="param-row header-row">
        <span>Parameter</span>
        <span>Type</span>
        <span>Default</span>
        <span>Description</span>
      </div>
      <div class="param-row">
        <code class="param-name">history</code>
        <span class="param-type">string</span>
        <code>0</code>
        <span>Set to <code>1</code> to include 30-day rank history for each result.</span>
      </div>
    </div>
    <p>All v1 search parameters (<code>q</code>, <code>category</code>, <code>sort</code>, <code>limit</code>, <code>offset</code>) are also supported.</p>

    <h3>Example</h3>
    <div class="code-block-wrap">
      <div class="code-label">curl</div>
      <pre class="code-block multiline">{`curl -H "Authorization: Bearer ark_pro_your_key" \\
  "https://agentrank-ai.com/api/v2/search?q=filesystem&history=1"`}</pre>
      <button class="copy-btn" data-copy={`curl -H "Authorization: Bearer ark_pro_your_key" \\\n  "https://agentrank-ai.com/api/v2/search?q=filesystem&history=1"`}>Copy</button>
    </div>
  </section>

  <div class="divider"></div>

  <!-- Tool v2 -->
  <section class="endpoint" id="v2-tool">
    <div class="endpoint-sig">
      <span class="method-badge get">GET</span>
      <code class="endpoint-path">/api/v2/tool/{'{id}'}</code>
      <span class="pro-badge">Pro</span>
    </div>
    <p>Same as v1 tool detail, but includes <code>rankHistory</code> — a 30-day array of <code>{'{date, rank, score}'}</code> entries.</p>

    <h3>Example</h3>
    <div class="code-block-wrap">
      <div class="code-label">curl</div>
      <pre class="code-block multiline">{`curl -H "Authorization: Bearer ark_pro_your_key" \\
  "https://agentrank-ai.com/api/v2/tool/modelcontextprotocol--servers"`}</pre>
      <button class="copy-btn" data-copy={`curl -H "Authorization: Bearer ark_pro_your_key" \\\n  "https://agentrank-ai.com/api/v2/tool/modelcontextprotocol--servers"`}>Copy</button>
    </div>

    <h3>Additional Response Field</h3>
    <div class="response-block">
      <div class="code-label">JSON</div>
      <pre class="response-code">{`{
  // ... all v1 fields ...
  "rankHistory": [
    { "date": "2026-03-18", "rank": 1,  "score": 97.4 },
    { "date": "2026-03-17", "rank": 1,  "score": 97.2 },
    { "date": "2026-03-16", "rank": 2,  "score": 96.8 }
    // up to 30 entries
  ]
}`}</pre>
    </div>
  </section>

  <div class="divider"></div>

  <!-- Batch v2 -->
  <section class="endpoint" id="batch">
    <div class="endpoint-sig">
      <span class="method-badge post">POST</span>
      <code class="endpoint-path">/api/v2/batch</code>
      <span class="pro-badge">Pro</span>
    </div>
    <p>Resolve up to 50 tool IDs in a single request. Returns a map of <code>id &rarr; tool | null</code>. Null means the tool is not in the index.</p>

    <h3>Request Body</h3>
    <div class="param-table">
      <div class="param-row header-row">
        <span>Field</span>
        <span>Type</span>
        <span>Description</span>
      </div>
      <div class="param-row three-col">
        <code class="param-name">ids</code>
        <span class="param-type">string[]</span>
        <span>Array of tool IDs in <code>owner--repo</code> format. Max 50.</span>
      </div>
    </div>

    <h3>Example</h3>
    <div class="code-block-wrap">
      <div class="code-label">curl</div>
      <pre class="code-block multiline">{`curl -X POST \\
  -H "Authorization: Bearer ark_pro_your_key" \\
  -H "Content-Type: application/json" \\
  -d '{"ids": ["modelcontextprotocol--servers", "owner--repo2"]}' \\
  "https://agentrank-ai.com/api/v2/batch"`}</pre>
      <button class="copy-btn" data-copy={`curl -X POST \\\n  -H "Authorization: Bearer ark_pro_your_key" \\\n  -H "Content-Type: application/json" \\\n  -d '{"ids": ["modelcontextprotocol--servers", "owner--repo2"]}' \\\n  "https://agentrank-ai.com/api/v2/batch"`}>Copy</button>
    </div>

    <h3>Response</h3>
    <div class="response-block">
      <div class="code-label">JSON</div>
      <pre class="response-code">{`{
  "results": {
    "modelcontextprotocol--servers": {
      "type": "tool",
      "id": "modelcontextprotocol--servers",
      "score": 97.4,
      "rank": 1
      // ... full tool detail
    },
    "owner--repo2": null
  }
}`}</pre>
    </div>

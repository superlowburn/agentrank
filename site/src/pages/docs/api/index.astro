          document.querySelectorAll(`.snip-panel[data-group="${group}"]`).forEach(panel => {
            panel.style.display = panel.dataset.lang === lang ? '' : 'none';
            if (panel.dataset.lang === lang) panel.classList.add('active');
            else panel.classList.remove('active');
          });
        });
